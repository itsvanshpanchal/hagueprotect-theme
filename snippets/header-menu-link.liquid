{%- comment -%}
  Renders a Shop All menu link to an editable collection page.
  @param handle {String} collection handle
  @param template {String} optional collection template suffix (defaults to menu-category)
  @param label {String} link text
  @param class {String} optional CSS class
  @param style {String} optional inline style
{%- endcomment -%}
{%- capture menu_href -%}
  {%- render 'care-kit-collection-url', handle: handle, template: template -%}
{%- endcapture -%}
<a href="{{ menu_href | strip }}"{% if class != blank %} class="{{ class }}"{% endif %}{% if style != blank %} style="{{ style }}"{% endif %}>{{ label }}</a>

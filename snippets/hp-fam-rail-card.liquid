{%- comment -%}
  Product card for Horizontal Product Slider (desktop rail + mobile carousel)
  Accepts: product (required)
{%- endcomment -%}
{%- liquid
  assign card_desc = product.description | strip_html | strip | truncate: 90
  assign card_variant = product.selected_or_first_available_variant
  assign show_bestseller = false
  for tag in product.tags
    assign tag_down = tag | downcase
    if tag_down == 'bestseller'
      assign show_bestseller = true
      break
    endif
  endfor
-%}
<div class="rail-card" data-hp-fam-card onclick="window.location.href='{{ product.url }}'">
  <div class="rail-card-img">
    {%- if show_bestseller -%}
      <span class="rail-badge-bestseller">Bestseller</span>
    {%- endif -%}
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.title | escape }}"
        loading="lazy"
        width="600"
        height="600"
      >
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag }}
    {%- endif -%}
  </div>
  <div class="rail-card-info">
    <h3 class="rail-card-title">{{ product.title }}</h3>

    <div class="rail-rating-row">
      <span class="rail-rating-badge">★ {{ rating_value | default: '4.9' }}</span>
      <span class="rail-rating-count">({{ rating_count | default: '4.8' }})</span>
    </div>

    {%- if product.type != blank -%}
      <p class="rail-subtitle">{{ product.type }}</p>
    {%- elsif product.vendor != blank -%}
      <p class="rail-subtitle">{{ product.vendor }}</p>
    {%- endif -%}
    {%- if card_desc != blank -%}
      <p class="rail-elite-care">{{ card_desc }}</p>
    {%- endif -%}
    <div class="rail-price-row">
      {%- if product.compare_at_price > product.price -%}
        <span class="rail-price-compare">{{ product.compare_at_price | money_without_trailing_zeros }}</span>
      {%- endif -%}
      <span class="rail-price-current">{{ product.price | money_without_trailing_zeros }}</span>
    </div>
    {%- if card_variant.available -%}
      <form action="{{ routes.cart_add_url }}" method="post" onclick="event.stopPropagation();">
        <input type="hidden" name="id" value="{{ card_variant.id }}">
        <button type="submit" class="rail-card-atc">Add to Cart</button>
      </form>
    {%- else -%}
      <button type="button" class="rail-card-atc" onclick="event.stopPropagation(); window.location.href='{{ product.url }}'">View Product</button>
    {%- endif -%}
  </div>
</div>

{%- comment -%}
  Implied CSS font-weight.
  - Google shared-family variants (Inter Bold, etc.) need numeric weight.
  - Named file faces (Bahnschrift Bold, Inter 18pt Medium) stay at 400.
{%- endcomment -%}
{%- case font_key -%}
  {%- when 'inter_light', 'montserrat_light', 'oswald_light', 'darker_grotesque_light' -%}300
  {%- when 'inter_medium', 'montserrat_medium', 'oswald_medium', 'darker_grotesque_medium' -%}500
  {%- when 'inter_semibold', 'montserrat_semibold', 'oswald_semibold', 'darker_grotesque_semibold' -%}600
  {%- when 'inter_bold', 'montserrat_bold', 'oswald_bold', 'darker_grotesque_bold' -%}700
  {%- when 'inter_extrabold', 'darker_grotesque_extrabold' -%}800
  {%- when 'inter_black', 'darker_grotesque_black' -%}900
  {%- when 'bahnschrift_semibold', 'bahnschrift_bold',
    'calisto_mt_bold', 'calisto_mt_italic', 'calisto_mt_bold_italic',
    'inter_18pt_medium', 'inter_18pt_semibold', 'inter_18pt_bold',
    'freight_text_pro_book' -%}400
  {%- else -%}400
{%- endcase -%}

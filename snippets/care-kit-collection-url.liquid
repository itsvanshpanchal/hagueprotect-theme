{%- liquid
  assign kit_handle = handle | default: ''
  assign kit_search = search_query | default: kit_handle | replace: '-', ' '
  assign kit_collection = collections[kit_handle]

  if kit_collection != blank
    echo kit_collection.url
  else
    assign encoded_query = kit_search | url_encode
    echo routes.search_url | append: '?q=' | append: encoded_query | append: '&type=product'
  endif
-%}

{%- liquid
  assign kit_handle = handle | default: ''
  assign kit_collection = collections[kit_handle]
  assign kit_search = search_query | default: label | default: kit_handle | replace: '-', ' '
  assign care_kit_handles = 'leather-care-kit|suede-care-kit|nubuck-care-kit|fabric-care-kit|soles-care-kit' | split: '|'

  comment
    Direct product handles — these kits are known products, so link straight
    to their product pages instead of relying on collections or all_products.
  endcomment
  assign direct_product_handles = 'signature-kit|refresh-kit|indepth-kit|supreme-kit' | split: '|'

  if direct_product_handles contains kit_handle
    echo '/products/' | append: kit_handle
  elsif kit_collection != blank
    if template != blank
      assign template_suffix = template
    elsif care_kit_handles contains kit_handle
      assign template_suffix = kit_handle
    else
      assign template_suffix = 'menu-category'
    endif

    assign collection_url = kit_collection.url

    if template_suffix != blank
      if collection_url contains '?'
        assign collection_url = collection_url | append: '&view=' | append: template_suffix
      else
        assign collection_url = collection_url | append: '?view=' | append: template_suffix
      endif
    endif

    echo collection_url
  elsif all_products[kit_handle] != blank
    echo all_products[kit_handle].url
  else
    assign exact_search = '"' | append: kit_search | append: '"'
    assign encoded_query = exact_search | url_encode
    echo routes.search_url | append: '?q=' | append: encoded_query | append: '&type=product'
  endif
-%}

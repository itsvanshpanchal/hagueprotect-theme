{%- comment -%}
  Vanrosector Shop All mega-menu (desktop + mobile).
  @param variant {String} 'desktop' (default) or 'mobile'
{%- endcomment -%}
{%- liquid
  assign variant = variant | default: 'desktop'
  assign vr_template = 'vanrosector'
-%}


{%- comment -%}
  Per-section typography CSS variables.
  Always uses THIS section's font settings so Theme Editor changes apply only here.
{%- endcomment -%}
{%- liquid
  assign h1_family = section.settings.h1_font_family | default: settings.font_h1_family | default: 'bebas_neue'
  assign h2_family = section.settings.h2_font_family | default: settings.font_h2_family | default: 'bebas_neue'
  assign paragraph_family = section.settings.paragraph_font_family | default: settings.font_paragraph_family | default: 'inter'
  assign eyebrow_family = section.settings.eyebrow_font_family | default: settings.font_eyebrow_family | default: 'inter'

  assign h1_weight = section.settings.h1_font_weight | default: settings.font_h1_weight | default: '400'
  assign h2_weight = section.settings.h2_font_weight | default: settings.font_h2_weight | default: '400'
  assign paragraph_weight = section.settings.paragraph_font_weight | default: settings.font_paragraph_weight | default: '400'
  assign eyebrow_weight = section.settings.eyebrow_font_weight | default: settings.font_eyebrow_weight | default: '700'

  assign h1_style = section.settings.h1_font_style | default: settings.font_h1_style | default: 'normal'
  assign h2_style = section.settings.h2_font_style | default: settings.font_h2_style | default: 'normal'
  assign paragraph_style = section.settings.paragraph_font_style | default: settings.font_paragraph_style | default: 'normal'
  assign eyebrow_style = section.settings.eyebrow_font_style | default: settings.font_eyebrow_style | default: 'normal'
-%}
{%- capture h1_implied_weight -%}{% render 'hp-font-weight', font_key: h1_family %}{%- endcapture -%}
{%- capture h2_implied_weight -%}{% render 'hp-font-weight', font_key: h2_family %}{%- endcapture -%}
{%- capture paragraph_implied_weight -%}{% render 'hp-font-weight', font_key: paragraph_family %}{%- endcapture -%}
{%- capture eyebrow_implied_weight -%}{% render 'hp-font-weight', font_key: eyebrow_family %}{%- endcapture -%}
{%- capture h1_named -%}{% render 'hp-font-is-named-face', font_key: h1_family %}{%- endcapture -%}
{%- capture h2_named -%}{% render 'hp-font-is-named-face', font_key: h2_family %}{%- endcapture -%}
{%- capture paragraph_named -%}{% render 'hp-font-is-named-face', font_key: paragraph_family %}{%- endcapture -%}
{%- capture eyebrow_named -%}{% render 'hp-font-is-named-face', font_key: eyebrow_family %}{%- endcapture -%}
{%- liquid
  assign h1_implied_weight = h1_implied_weight | strip
  assign h2_implied_weight = h2_implied_weight | strip
  assign paragraph_implied_weight = paragraph_implied_weight | strip
  assign eyebrow_implied_weight = eyebrow_implied_weight | strip
  assign h1_named = h1_named | strip
  assign h2_named = h2_named | strip
  assign paragraph_named = paragraph_named | strip
  assign eyebrow_named = eyebrow_named | strip

  if h1_named != blank
    assign h1_weight = '400'
    assign h1_style = 'normal'
  elsif h1_implied_weight != '400'
    assign h1_weight = h1_implied_weight
  endif
  if h2_named != blank
    assign h2_weight = '400'
    assign h2_style = 'normal'
  elsif h2_implied_weight != '400'
    assign h2_weight = h2_implied_weight
  endif
  if paragraph_named != blank
    assign paragraph_weight = '400'
    assign paragraph_style = 'normal'
  elsif paragraph_implied_weight != '400'
    assign paragraph_weight = paragraph_implied_weight
  endif
  if eyebrow_named != blank
    assign eyebrow_weight = '400'
    assign eyebrow_style = 'normal'
  elsif eyebrow_implied_weight != '400'
    assign eyebrow_weight = eyebrow_implied_weight
  endif

  assign hero_h1_desktop = settings.font_hero_h1_size_desktop | default: 72
  assign hero_h1_mobile = settings.font_hero_h1_size_mobile | default: 44
  assign h1_desktop = section.settings.h1_font_size_desktop | default: settings.font_h1_size_desktop | default: 64
  assign h1_mobile = section.settings.h1_font_size_mobile | default: settings.font_h1_size_mobile | default: 40
  assign h2_desktop = section.settings.h2_font_size_desktop | default: settings.font_h2_size_desktop | default: 52
  assign h2_mobile = section.settings.h2_font_size_mobile | default: settings.font_h2_size_mobile | default: 34
  assign paragraph_desktop = section.settings.paragraph_font_size_desktop | default: settings.font_paragraph_size_desktop | default: 16
  assign paragraph_mobile = section.settings.paragraph_font_size_mobile | default: settings.font_paragraph_size_mobile | default: 15
  assign eyebrow_desktop = section.settings.eyebrow_font_size_desktop | default: settings.font_eyebrow_size_desktop | default: 12
  assign eyebrow_mobile = section.settings.eyebrow_font_size_mobile | default: settings.font_eyebrow_size_mobile | default: 12

  case section.type
    when 'hero', 'corporate-gifting-hero', 'business-hero', 'premium-scrolling-hero'
      assign hero_h1_desktop = h1_desktop
      assign hero_h1_mobile = h1_mobile
    when 'header', 'footer', 'announcement-bar', 'cart-drawer'
      # Compact chrome UI — remap leftover homepage display sizes (e.g. 52/64)
      assign h1_desktop = section.settings.h1_font_size_desktop | default: 21
      assign h1_mobile = section.settings.h1_font_size_mobile | default: 14
      assign h2_desktop = section.settings.h2_font_size_desktop | default: 14
      assign h2_mobile = section.settings.h2_font_size_mobile | default: 13
      assign paragraph_desktop = section.settings.paragraph_font_size_desktop | default: 15
      assign paragraph_mobile = section.settings.paragraph_font_size_mobile | default: 14
      assign eyebrow_desktop = section.settings.eyebrow_font_size_desktop | default: 12
      assign eyebrow_mobile = section.settings.eyebrow_font_size_mobile | default: 12
      if h1_desktop > 40
        assign h1_desktop = 21
      endif
      if h1_mobile > 28
        assign h1_mobile = 14
      endif
      if h2_desktop > 24
        assign h2_desktop = 14
      endif
      if h2_mobile > 20
        assign h2_mobile = 13
      endif
      if paragraph_desktop > 24
        assign paragraph_desktop = 15
      endif
      if paragraph_mobile > 20
        assign paragraph_mobile = 14
      endif
      if section.type == 'header'
        if eyebrow_desktop < 14 or eyebrow_desktop > 48
          assign eyebrow_desktop = 28
        endif
        if eyebrow_mobile < 14 or eyebrow_mobile > 36
          assign eyebrow_mobile = 22
        endif
      else
        if eyebrow_desktop > 20
          assign eyebrow_desktop = 12
        endif
        if eyebrow_mobile > 18
          assign eyebrow_mobile = 12
        endif
      endif
  endcase

  assign title_desc_spacing_desktop = section.settings.heading_subheading_spacing_desktop | default: settings.heading_subheading_spacing_desktop | default: 12
  assign title_desc_spacing_mobile = section.settings.heading_subheading_spacing_mobile | default: settings.heading_subheading_spacing_mobile | default: 10
  assign eyebrow_title_spacing_desktop = section.settings.eyebrow_title_spacing_desktop | default: settings.eyebrow_title_spacing_desktop | default: 12
  assign eyebrow_title_spacing_mobile = section.settings.eyebrow_title_spacing_mobile | default: settings.eyebrow_title_spacing_mobile | default: 10
-%}
#shopify-section-{{ section.id }} {
  --font-family-heading: {% render 'hp-font-stack', font_key: h1_family %};
  --font-family-h2: {% render 'hp-font-stack', font_key: h2_family %};
  --font-family-subheading: {% render 'hp-font-stack', font_key: h2_family %};
  --font-family-sans: {% render 'hp-font-stack', font_key: paragraph_family %};
  --font-family-eyebrow: {% render 'hp-font-stack', font_key: eyebrow_family %};
  --font-weight-heading: {{ h1_weight }};
  --heading-weight: {{ h1_weight }};
  --subheading-weight: {{ h2_weight }};
  --font-weight-h2: {{ h2_weight }};
  --font-weight-sans: {{ paragraph_weight }};
  --font-weight-eyebrow: {{ eyebrow_weight }};
  --font-style-heading: {{ h1_style }};
  --font-style-h2: {{ h2_style }};
  --font-style-sans: {{ paragraph_style }};
  --font-style-eyebrow: {{ eyebrow_style }};
  --heading-size-hero: clamp({{ hero_h1_desktop }}px, {{ hero_h1_desktop | divided_by: 16.0 }}vw, {{ hero_h1_desktop | times: 1.5 | round }}px);
  --heading-size-xl: clamp({{ h1_desktop }}px, {{ h1_desktop | divided_by: 16.0 }}vw, {{ h1_desktop | times: 1.5 | round }}px);
  --section-heading-size: {{ h2_desktop }}px;
  --section-heading-size-mobile: {{ h2_mobile }}px;
  --section-subheading-size: {{ paragraph_desktop }}px;
  --section-label-size: {{ eyebrow_desktop }}px;
  --body-font-size: {{ paragraph_desktop }}px;
  --section-subheading-spacing-top: {{ title_desc_spacing_desktop }}px;
  --section-label-to-title-gap: {{ eyebrow_title_spacing_desktop }}px;
  --section-label-margin-bottom: {{ eyebrow_title_spacing_desktop }}px;
}
@media screen and (max-width: 989px) {
  #shopify-section-{{ section.id }} {
    --heading-size-hero: {{ hero_h1_mobile }}px;
    --heading-size-xl: {{ h1_mobile }}px;
    --section-heading-size: {{ h2_mobile }}px;
    --section-subheading-size: {{ paragraph_mobile }}px;
    --section-label-size: {{ eyebrow_mobile }}px;
    --body-font-size: {{ paragraph_mobile }}px;
    --section-subheading-spacing-top: {{ title_desc_spacing_mobile }}px;
    --section-label-to-title-gap: {{ eyebrow_title_spacing_mobile }}px;
    --section-label-margin-bottom: {{ eyebrow_title_spacing_mobile }}px;
  }
}

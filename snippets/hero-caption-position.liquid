{%- liquid
  assign pos_x = x | default: 0 | plus: 0
  assign pos_y = y | default: 75 | plus: 0
  assign pos_align = align | default: 'left'

  if pos_align == 'center' and pos_x <= 15
    assign pos_x = 50
  elsif pos_align == 'right' and pos_x <= 20
    assign pos_x = 90
  endif
-%}
left: {{ pos_x }}%; top: {{ pos_y }}%; right: auto; bottom: auto; width: max-content; max-width: calc(100% - 24px);

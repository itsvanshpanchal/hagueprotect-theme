{%- liquid
  assign pos_x = x | default: 0
  assign pos_y = y | default: 75
  assign pos_align = align | default: 'left'

  case pos_align
    when 'center'
      assign pos_tx = '-50%'
    when 'right'
      assign pos_tx = '-100%'
    else
      assign pos_tx = '0'
  endcase
-%}
left: {{ pos_x }}%; top: {{ pos_y }}%; transform: translate({{ pos_tx }}, 0); text-align: {{ pos_align }}; right: auto; bottom: auto; width: max-content; max-width: calc(100% - 24px);

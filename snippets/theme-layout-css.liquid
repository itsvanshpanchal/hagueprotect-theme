{%- liquid
  assign site_max_width = settings.site_max_width | default: 1440
  assign homepage_label_color = settings.homepage_label_color | default: '#2563eb'
  assign section_heading_align = settings.section_heading_align | default: 'left'
  assign heading_line2_color = settings.heading_line2_color | default: '#6b6b6b'
  assign eyebrow_title_spacing_desktop = settings.eyebrow_title_spacing_desktop | default: 12
  assign eyebrow_title_spacing_mobile = settings.eyebrow_title_spacing_mobile | default: 10
  assign heading_subheading_spacing_desktop = settings.heading_subheading_spacing_desktop | default: 12
  assign heading_subheading_spacing_mobile = settings.heading_subheading_spacing_mobile | default: 10

  if section_heading_align == 'center'
    assign section_heading_items = 'center'
    assign section_heading_margin_left = 'auto'
    assign section_heading_margin_right = 'auto'
  else
    assign section_heading_items = 'flex-start'
    assign section_heading_margin_left = '0'
    assign section_heading_margin_right = 'auto'
  endif
-%}
<style>
  :root {
    --site-max-width: {{ site_max_width }}px;
    --section-heading-align: {{ section_heading_align }};
    --section-heading-items: {{ section_heading_items }};
    --section-heading-margin-left: {{ section_heading_margin_left }};
    --section-heading-margin-right: {{ section_heading_margin_right }};
    --section-heading-line2-color: {{ heading_line2_color }};
    --section-label-to-title-gap: {{ eyebrow_title_spacing_desktop }}px;
    --section-label-margin-bottom: {{ eyebrow_title_spacing_desktop }}px;
    --section-subheading-spacing-top: {{ heading_subheading_spacing_desktop }}px;
  }

  @media screen and (max-width: 989px) {
    :root {
      --section-label-to-title-gap: {{ eyebrow_title_spacing_mobile }}px;
      --section-label-margin-bottom: {{ eyebrow_title_spacing_mobile }}px;
      --section-subheading-spacing-top: {{ heading_subheading_spacing_mobile }}px;
    }
  }

  .template-index {
    --section-label-color: {{ homepage_label_color }};
  }

  /*
    Homepage: ONE content column for every section heading + subheading.
    Same max-width, same gutter, same left edge on every section.
  */
  body.template-index {
    --homepage-section-gutter: 40px;
    --homepage-text-inset: max(
      var(--homepage-section-gutter),
      calc((100vw - var(--site-max-width)) / 2 + var(--homepage-section-gutter))
    );
  }

  @media screen and (max-width: 767px) {
    body.template-index {
      --homepage-section-gutter: max(16px, var(--site-padding, 20px));
    }
  }

  /* Shared outer column — headings AND cards sit inside this same box */
  body.template-index .bs-coverflow__container,
  body.template-index .trending-social-section .container,
  body.template-index .fc-container,
  body.template-index .feature-grid__container,
  body.template-index .promo-banner__container,
  body.template-index .hp-fam-sec__container,
  body.template-index .hp-dna__container,
  body.template-index .comm-container,
  body.template-index .mat-container,
  body.template-index .fb__header,
  body.template-index .fb__grid,
  body.template-index .brandsel__inner {
    max-width: var(--site-max-width) !important;
    width: 100% !important;
    margin-left: auto !important;
    margin-right: auto !important;
    padding-left: var(--homepage-section-gutter) !important;
    padding-right: var(--homepage-section-gutter) !important;
    box-sizing: border-box !important;
  }

  /* Featured brands section padding was doubling the gutter */
  body.template-index [class*="featured-brands-"] {
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  /* Headers inside the shared column: no extra inset / centering */
  body.template-index .bs-coverflow__header,
  body.template-index .trending-social-header,
  body.template-index .fc-header,
  body.template-index .mat-left,
  body.template-index .feature-grid__header,
  body.template-index .promo-banner__content,
  body.template-index .hp-dna__heading,
  body.template-index .hp-fam-sec__heading,
  body.template-index .comm-top,
  body.template-index .brandsel__head,
  body.template-index .fb__header .section-heading-stack,
  body.template-index .section-heading-stack {
    max-width: none !important;
    width: 100% !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    text-align: left !important;
    align-items: flex-start !important;
  }

  /* fb__header is itself a column box — keep its gutter, zero nested stack */
  body.template-index .fb__header {
    text-align: left !important;
  }

  body.template-index .fb__header.section-heading-stack {
    max-width: var(--site-max-width) !important;
    margin-left: auto !important;
    margin-right: auto !important;
    padding-left: var(--homepage-section-gutter) !important;
    padding-right: var(--homepage-section-gutter) !important;
  }

  /* Heading + subheading text: flush left, same edge */
  body.template-index .bs-coverflow__heading,
  body.template-index .bs-coverflow__eyebrow,
  body.template-index .fb__title,
  body.template-index .fb__eyebrow,
  body.template-index .fb__subtitle,
  body.template-index .trending-social__heading,
  body.template-index .trending-social__eyebrow,
  body.template-index .mat-headline,
  body.template-index .mat-eyebrow,
  body.template-index .mat-desc,
  body.template-index .fc-heading,
  body.template-index .fc-subtitle,
  body.template-index .feature-grid__heading,
  body.template-index .feature-grid__eyebrow,
  body.template-index .promo-banner__heading,
  body.template-index .promo-banner__eyebrow,
  body.template-index .hp-fam-sec__heading,
  body.template-index .hp-dna__heading,
  body.template-index .comm-headline,
  body.template-index .comm-eyebrow,
  body.template-index .comm-desc,
  body.template-index .brandsel__heading,
  body.template-index .brandsel__eyebrow,
  body.template-index .brandsel__sub,
  body.template-index .story-banner__heading,
  body.template-index .story-banner__subheading,
  body.template-index .story-banner__eyebrow,
  body.template-index .story-banner__paragraph,
  body.template-index [class*="ai-story-banner-heading-"],
  body.template-index [class*="ai-story-banner-subheading-"],
  body.template-index .hero-fullscreen__heading,
  body.template-index .hero-fullscreen__subheading,
  body.template-index .hero-fullscreen__eyebrow,
  body.template-index .hp-heading-line,
  body.template-index .hero-heading-line {
    text-align: left !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  body.template-index .hp-heading-line,
  body.template-index .hero-heading-line {
    display: block !important;
    width: 100% !important;
  }

  body.template-index .fc-header .fc-subtitle {
    margin-left: 0 !important;
    margin-right: 0 !important;
  }

  /* Hero pinned to the same inset as section headings */
  body.template-index .hero-fullscreen__content {
    left: var(--homepage-text-inset) !important;
    right: auto !important;
    transform: none !important;
    width: min(
      calc(var(--site-max-width) - (var(--homepage-section-gutter) * 2)),
      calc(100vw - (var(--homepage-text-inset) * 2))
    ) !important;
    max-width: none !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    text-align: left !important;
    align-items: flex-start !important;
  }

  @media screen and (max-width: 989px) {
    body.template-index .hero-fullscreen__content {
      left: var(--homepage-section-gutter) !important;
      width: calc(100% - (var(--homepage-section-gutter) * 2)) !important;
    }
  }

  /* Story / AI banners: text starts on the shared inset */
  body.template-index .story-banner__content {
    left: 0 !important;
    right: 0 !important;
    padding-left: var(--homepage-text-inset) !important;
    padding-right: var(--homepage-section-gutter) !important;
    align-items: flex-start !important;
    text-align: left !important;
    box-sizing: border-box !important;
  }

  body.template-index [class*="ai-story-banner-content-"] {
    left: var(--homepage-text-inset) !important;
    margin-left: 0 !important;
    padding-left: 0 !important;
    text-align: left !important;
    box-sizing: border-box !important;
  }

  /* Kill forced center stacks on homepage */
  body.template-index .section-heading-stack--center,
  body.template-index .section-heading-stack--center > * {
    text-align: left !important;
    align-items: flex-start !important;
  }

  @media screen and (max-width: 767px) {
    body.template-index .fc-heading,
    body.template-index .fc-subtitle {
      padding-left: 0 !important;
      padding-right: 0 !important;
    }
  }

  .template-index .hero-fullscreen__eyebrow,
  .template-index .fb__eyebrow,
  .template-index .bs-coverflow__eyebrow,
  .template-index .trending-social__eyebrow,
  .template-index .mat-eyebrow,
  .template-index .fc-subtitle,
  .template-index .comm-eyebrow,
  .template-index .story-banner__eyebrow,
  .template-index .feature-grid__eyebrow,
  .template-index .section-heading-stack__label,
  .template-index [class*="ai-story-banner-subheading-"] {
    color: {{ homepage_label_color }} !important;
  }
</style>

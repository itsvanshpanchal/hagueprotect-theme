{%- liquid
  assign site_max_width = settings.site_max_width | default: 1440
  assign homepage_label_color = settings.homepage_label_color | default: '#2563eb'
  assign section_heading_align = settings.section_heading_align | default: 'left'
  assign heading_line2_color = settings.heading_line2_color | default: '#6b6b6b'
  assign eyebrow_title_spacing_desktop = settings.eyebrow_title_spacing_desktop | default: 12
  assign eyebrow_title_spacing_mobile = settings.eyebrow_title_spacing_mobile | default: 10
  assign heading_subheading_spacing_desktop = settings.heading_subheading_spacing_desktop | default: 12
  assign heading_subheading_spacing_mobile = settings.heading_subheading_spacing_mobile | default: 10

  if section_heading_align == 'center'
    assign section_heading_items = 'center'
    assign section_heading_margin_left = 'auto'
    assign section_heading_margin_right = 'auto'
  else
    assign section_heading_items = 'flex-start'
    assign section_heading_margin_left = '0'
    assign section_heading_margin_right = 'auto'
  endif
-%}
<style>
  :root {
    --site-max-width: {{ site_max_width }}px;
    --section-heading-align: {{ section_heading_align }};
    --section-heading-items: {{ section_heading_items }};
    --section-heading-margin-left: {{ section_heading_margin_left }};
    --section-heading-margin-right: {{ section_heading_margin_right }};
    --section-heading-line2-color: {{ heading_line2_color }};
    --section-label-to-title-gap: {{ eyebrow_title_spacing_desktop }}px;
    --section-label-margin-bottom: {{ eyebrow_title_spacing_desktop }}px;
    --section-subheading-spacing-top: {{ heading_subheading_spacing_desktop }}px;
  }

  @media screen and (max-width: 989px) {
    :root {
      --section-label-to-title-gap: {{ eyebrow_title_spacing_mobile }}px;
      --section-label-margin-bottom: {{ eyebrow_title_spacing_mobile }}px;
      --section-subheading-spacing-top: {{ heading_subheading_spacing_mobile }}px;
    }
  }

  .template-index {
    --section-label-color: {{ homepage_label_color }};
  }

  /* Same alignment on every screen size for section top headings + matching subcopy.
     !important beats per-section #shopify-section-{id} / hardcoded center rules. */
  .bs-coverflow__header,
  .bs-coverflow__heading,
  .bs-coverflow__eyebrow,
  .fb__header,
  .fb__title,
  .fb__eyebrow,
  .fb__subtitle,
  .trending-social-header,
  .trending-social__heading-group,
  .trending-social__heading,
  .trending-social__eyebrow,
  .mat-left,
  .mat-headline,
  .mat-eyebrow,
  .mat-desc,
  .fc-header,
  .fc-heading,
  .fc-subtitle,
  .hp-dna__heading,
  .hp-fam-sec__heading,
  .product-family-header,
  .feature-grid__header,
  .feature-grid__heading,
  .feature-grid__eyebrow,
  .promo-banner__header,
  .promo-banner__heading,
  .promo-banner__eyebrow,
  .brand-banner,
  .brand-banner__title,
  .brand-banner__subtitle,
  .brandsel__heading,
  .brandsel__eyebrow,
  .brandsel__sub,
  .comm-headline,
  .comm-eyebrow,
  .comm-desc,
  .comm-badge-desc,
  .story-banner__heading,
  .story-banner__subheading,
  .story-banner__eyebrow,
  .story-banner__paragraph,
  [class*="ai-story-banner-heading-"],
  [class*="ai-story-banner-subheading-"],
  .trust-statement__heading,
  .reviews-sec__heading,
  .product-rec__heading,
  .social-slider__heading,
  .faq-custom__heading,
  .bundle-title,
  .corp-features__heading,
  .corp-features__sub,
  .how-to-videos__heading,
  .biz-solutions__heading,
  .biz-solutions__sub,
  .biz-advantages__heading,
  .hero-fullscreen__heading,
  .hero-fullscreen__subheading,
  .hero-fullscreen__eyebrow,
  .section-heading-stack:not(.section-heading-stack--center) {
    text-align: var(--section-heading-align, left) !important;
  }

  /* Keep every heading line + subheading on one shared left edge */
  .hero-fullscreen__heading .hero-heading-line,
  .hp-heading-line,
  .bs-coverflow__heading,
  .bs-coverflow__eyebrow,
  .fb__title,
  .fb__eyebrow,
  .fb__subtitle,
  .trending-social__heading,
  .trending-social__eyebrow,
  .mat-headline,
  .mat-eyebrow,
  .mat-desc,
  .fc-heading,
  .fc-subtitle,
  .feature-grid__heading,
  .feature-grid__eyebrow,
  .brand-banner__title,
  .brand-banner__subtitle,
  .brandsel__heading,
  .brandsel__eyebrow,
  .brandsel__sub,
  .story-banner__heading,
  .story-banner__subheading,
  .story-banner__eyebrow,
  .story-banner__paragraph,
  .hero-fullscreen__heading,
  .hero-fullscreen__subheading,
  .hero-fullscreen__eyebrow,
  .section-heading-stack > * {
    margin-left: 0 !important;
    padding-left: 0 !important;
    margin-right: 0 !important;
  }

  .hero-fullscreen__heading .hero-heading-line,
  .hp-heading-line {
    display: block !important;
    width: 100% !important;
    text-align: inherit !important;
  }

  .bs-coverflow__header,
  .fb__header,
  .trending-social-header,
  .trending-social__heading-group,
  .fc-header,
  .mat-left,
  .product-family-header,
  .feature-grid__header,
  .promo-banner__header,
  .hero-fullscreen__content,
  .section-heading-stack:not(.section-heading-stack--center) {
    align-items: var(--section-heading-items, flex-start) !important;
  }

  .comm-headline {
    justify-content: var(--section-heading-items, flex-start) !important;
  }

  .fb__subtitle,
  .mat-desc,
  .brand-banner__subtitle,
  .brandsel__sub,
  .comm-desc,
  .comm-badge-desc,
  .story-banner__paragraph,
  .corp-features__sub,
  .biz-solutions__sub,
  .hero-fullscreen__subheading {
    margin-left: var(--section-heading-margin-left, 0) !important;
    margin-right: var(--section-heading-margin-right, auto) !important;
  }

  /* Homepage: one shared horizontal gutter so headings line up down the page */
  body.template-index {
    --homepage-section-gutter: 40px;
  }

  @media screen and (max-width: 767px) {
    body.template-index {
      --homepage-section-gutter: max(16px, var(--site-padding, 20px));
    }
  }

  body.template-index .bs-coverflow__container,
  body.template-index .trending-social-section .container,
  body.template-index .fc-container,
  body.template-index .feature-grid__container,
  body.template-index .promo-banner__container,
  body.template-index .hp-fam-sec__container,
  body.template-index .hp-dna__container,
  body.template-index [class*="featured-brands-"] {
    padding-left: var(--homepage-section-gutter) !important;
    padding-right: var(--homepage-section-gutter) !important;
  }

  body.template-index .fb__header {
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  /* Hero heading + subheading share one left edge inside the content box */
  body.template-index .hero-fullscreen__heading,
  body.template-index .hero-fullscreen__subheading,
  body.template-index .hero-fullscreen__eyebrow,
  body.template-index .hero-fullscreen__heading .hero-heading-line {
    text-align: left !important;
    margin-left: 0 !important;
    padding-left: 0 !important;
    width: 100% !important;
  }

  body.template-index .hero-fullscreen__content {
    align-items: flex-start !important;
  }

  /* Explicitly centered stacks always win (opt-in only) */
  .section-heading-stack--center,
  .section-heading-stack--center > * {
    text-align: center !important;
  }

  .section-heading-stack--center {
    align-items: center !important;
  }

  .template-index .hero-fullscreen__eyebrow,
  .template-index .fb__eyebrow,
  .template-index .bs-coverflow__eyebrow,
  .template-index .trending-social__eyebrow,
  .template-index .mat-eyebrow,
  .template-index .fc-subtitle,
  .template-index .comm-eyebrow,
  .template-index .story-banner__eyebrow,
  .template-index .feature-grid__eyebrow,
  .template-index .section-heading-stack__label,
  .template-index [class*="ai-story-banner-subheading-"] {
    color: {{ homepage_label_color }} !important;
  }
</style>

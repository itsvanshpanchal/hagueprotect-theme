{%- liquid
  assign site_max_width = settings.site_max_width | default: 1440
  assign homepage_label_color = settings.homepage_label_color | default: '#2563eb'
  assign heading_subheading_spacing_desktop = settings.heading_subheading_spacing_desktop | default: 12
  assign heading_subheading_spacing_mobile = settings.heading_subheading_spacing_mobile | default: 10
-%}
<style>
  :root {
    --site-max-width: {{ site_max_width }}px;
    --section-subheading-spacing-top: {{ heading_subheading_spacing_desktop }}px;
  }

  @media screen and (max-width: 989px) {
    :root {
      --section-subheading-spacing-top: {{ heading_subheading_spacing_mobile }}px;
    }
  }

  .template-index {
    --section-label-color: {{ homepage_label_color }};
  }

  .template-index .hero-fullscreen__eyebrow,
  .template-index .fb__eyebrow,
  .template-index .bs-coverflow__eyebrow,
  .template-index .trending-social__eyebrow,
  .template-index .mat-eyebrow,
  .template-index .fc-subtitle,
  .template-index .comm-eyebrow,
  .template-index .story-banner__eyebrow,
  .template-index .feature-grid__eyebrow,
  .template-index .section-heading-stack__label,
  .template-index [class*="ai-story-banner-subheading-"] {
    color: {{ homepage_label_color }} !important;
  }
</style>

{%- liquid
  assign h1_family = settings.font_h1_family | default: 'bebas_neue'
  assign h2_family = settings.font_h2_family | default: 'bebas_neue'
  assign paragraph_family = settings.font_paragraph_family | default: 'inter'
  assign eyebrow_family = settings.font_eyebrow_family | default: 'inter'

  assign h1_weight = settings.font_h1_weight | default: '400'
  assign h2_weight = settings.font_h2_weight | default: '400'
  assign paragraph_weight = settings.font_paragraph_weight | default: '400'
  assign eyebrow_weight = settings.font_eyebrow_weight | default: '700'

  assign h1_style = settings.font_h1_style | default: 'normal'
  assign h2_style = settings.font_h2_style | default: 'normal'
  assign paragraph_style = settings.font_paragraph_style | default: 'normal'
  assign eyebrow_style = settings.font_eyebrow_style | default: 'normal'
-%}
{%- capture h1_implied_weight -%}{% render 'hp-font-weight', font_key: h1_family %}{%- endcapture -%}
{%- capture h2_implied_weight -%}{% render 'hp-font-weight', font_key: h2_family %}{%- endcapture -%}
{%- capture paragraph_implied_weight -%}{% render 'hp-font-weight', font_key: paragraph_family %}{%- endcapture -%}
{%- capture eyebrow_implied_weight -%}{% render 'hp-font-weight', font_key: eyebrow_family %}{%- endcapture -%}
{%- capture h1_named -%}{% render 'hp-font-is-named-face', font_key: h1_family %}{%- endcapture -%}
{%- capture h2_named -%}{% render 'hp-font-is-named-face', font_key: h2_family %}{%- endcapture -%}
{%- capture paragraph_named -%}{% render 'hp-font-is-named-face', font_key: paragraph_family %}{%- endcapture -%}
{%- capture eyebrow_named -%}{% render 'hp-font-is-named-face', font_key: eyebrow_family %}{%- endcapture -%}
{%- liquid
  assign h1_implied_weight = h1_implied_weight | strip
  assign h2_implied_weight = h2_implied_weight | strip
  assign paragraph_implied_weight = paragraph_implied_weight | strip
  assign eyebrow_implied_weight = eyebrow_implied_weight | strip
  assign h1_named = h1_named | strip
  assign h2_named = h2_named | strip
  assign paragraph_named = paragraph_named | strip
  assign eyebrow_named = eyebrow_named | strip

  if h1_named != blank
    assign h1_weight = '400'
    assign h1_style = 'normal'
  elsif h1_implied_weight != '400'
    assign h1_weight = h1_implied_weight
  endif
  if h2_named != blank
    assign h2_weight = '400'
    assign h2_style = 'normal'
  elsif h2_implied_weight != '400'
    assign h2_weight = h2_implied_weight
  endif
  if paragraph_named != blank
    assign paragraph_weight = '400'
    assign paragraph_style = 'normal'
  elsif paragraph_implied_weight != '400'
    assign paragraph_weight = paragraph_implied_weight
  endif
  if eyebrow_named != blank
    assign eyebrow_weight = '400'
    assign eyebrow_style = 'normal'
  elsif eyebrow_implied_weight != '400'
    assign eyebrow_weight = eyebrow_implied_weight
  endif

  assign hero_h1_desktop = settings.font_hero_h1_size_desktop | default: 72
  assign hero_h1_mobile = settings.font_hero_h1_size_mobile | default: 44
  assign h1_desktop = settings.font_h1_size_desktop | default: 64
  assign h1_mobile = settings.font_h1_size_mobile | default: 40
  assign h2_desktop = settings.font_h2_size_desktop | default: 52
  assign h2_mobile = settings.font_h2_size_mobile | default: 34
  assign paragraph_desktop = settings.font_paragraph_size_desktop | default: 16
  assign paragraph_mobile = settings.font_paragraph_size_mobile | default: 15
  assign eyebrow_desktop = settings.font_eyebrow_size_desktop | default: 12
  assign eyebrow_mobile = settings.font_eyebrow_size_mobile | default: 12
-%}
<style>
  :root {
    --font-family-heading: {% render 'hp-font-stack', font_key: h1_family %};
    --font-family-h2: {% render 'hp-font-stack', font_key: h2_family %};
    --font-family-subheading: {% render 'hp-font-stack', font_key: h2_family %};
    --font-family-sans: {% render 'hp-font-stack', font_key: paragraph_family %};
    --font-family-eyebrow: {% render 'hp-font-stack', font_key: eyebrow_family %};
    --font-weight-heading: {{ h1_weight }};
    --font-weight-h2: {{ h2_weight }};
    --font-weight-sans: {{ paragraph_weight }};
    --font-weight-eyebrow: {{ eyebrow_weight }};
    --font-style-heading: {{ h1_style }};
    --font-style-h2: {{ h2_style }};
    --font-style-sans: {{ paragraph_style }};
    --font-style-eyebrow: {{ eyebrow_style }};
    --heading-size-hero: clamp({{ hero_h1_mobile }}px, 8vw, {{ hero_h1_desktop }}px);
    --heading-size-xl: clamp({{ h1_mobile }}px, 5.5vw, {{ h1_desktop }}px);
    --section-heading-size: clamp({{ h2_mobile }}px, 5.5vw, {{ h2_desktop }}px);
    --section-heading-size-mobile: clamp({{ h2_mobile }}px, 8vw, {{ h2_mobile | plus: 6 }}px);
    --section-subheading-size: {{ paragraph_desktop }}px;
    --section-label-size: {{ eyebrow_desktop }}px;
    --body-font-size: {{ paragraph_desktop }}px;
  }
  @media screen and (max-width: 767px) {
    :root {
      --section-subheading-size: {{ paragraph_mobile }}px;
      --section-label-size: {{ eyebrow_mobile }}px;
      --body-font-size: {{ paragraph_mobile }}px;
    }
  }
</style>

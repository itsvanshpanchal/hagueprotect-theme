{%- comment -%}
  Vanrosector brand home page markup (reusable).
  Structure: banner (hero) -> bestseller products.
  Rendered by templates/page.vanrosector.liquid (if a real Page exists)
  and by templates/404.liquid (so /pages/vanrosector works without an
  Admin page). Logo: logo-vanrosector.svg in Shopify Assets.
{%- endcomment -%}

{%- comment -%} Vanrosector's own collection — keeps its products isolated from the other brands. {%- endcomment -%}
{%- assign brand_handle = 'vanrosector' -%}
{%- assign accent = '#8a6a3b' -%}

<div class="brandpage brandpage--vanrosector" style="font-family: var(--font-family-sans);">

  <!-- Banner -->
  <section style="background:linear-gradient(165deg,#fbf8f2 0%,#efe2cd 100%); padding:96px 20px; text-align:center;">
    <div style="max-width:760px; margin:0 auto; display:flex; flex-direction:column; align-items:center; gap:22px;">
      <span style="display:inline-flex; align-items:center; justify-content:center; background:#ffffff; border-radius:20px; box-shadow:0 12px 32px rgba(138,106,59,0.16); padding:26px 40px;">
        <img src="{{ 'logo-vanrosector.svg' | asset_url }}" alt="Vanrosector" width="320" height="117" style="display:block; width:auto; height:auto; max-height:96px; max-width:320px; object-fit:contain;" loading="eager" decoding="async">
      </span>
      <h1 style="font-size:clamp(30px,5vw,52px); font-weight:800; letter-spacing:-0.03em; color:#2c2113; margin:8px 0 0; line-height:1.08;">Journey Through Nature's Finest Essence</h1>
      <p style="font-size:17px; color:#6a5b43; line-height:1.65; margin:0; max-width:600px;">Vanrosector is a celebration of nature's purest ingredients — thoughtfully sourced, expertly crafted, and made to elevate your everyday ritual.</p>
      <a href="/collections/{{ brand_handle }}" style="display:inline-flex; align-items:center; gap:9px; background:{{ accent }}; color:#fff; font-size:13px; font-weight:800; letter-spacing:0.08em; text-transform:uppercase; padding:15px 34px; border-radius:100px; text-decoration:none; margin-top:8px;">
        Discover the Collection
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M1 5h11M8 1l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </section>

  <!-- Bestseller products -->
  {%- render 'brand-bestsellers', accent: accent, heading: 'Vanrosector bestsellers', collection: brand_handle -%}

  <!-- Page content (editable in admin, only when a real Page exists) -->
  {%- if page.content != blank -%}
    <section style="background:#ffffff; padding:0 20px 80px;">
      <div class="rte" style="max-width:820px; margin:0 auto; font-size:16px; color:#444; line-height:1.7;">
        {{ page.content }}
      </div>
    </section>
  {%- endif -%}

  <!-- Back to family -->
  <section style="background:linear-gradient(165deg,#2c2113 0%,#4a3a22 100%); padding:64px 20px; text-align:center;">
    <p style="color:#e8dcc6; font-size:15px; margin:0 0 18px; letter-spacing:0.02em;">Part of the family alongside Hague Protect &amp; Science of Raw.</p>
    <a href="/" style="display:inline-flex; align-items:center; gap:8px; color:#fff; font-size:13px; font-weight:800; letter-spacing:0.08em; text-transform:uppercase; text-decoration:none; border:1px solid rgba(255,255,255,0.4); padding:13px 28px; border-radius:100px;">Back to Hague Protect</a>
  </section>

</div>

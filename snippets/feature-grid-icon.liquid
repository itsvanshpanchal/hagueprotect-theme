{%- comment -%}
  Premium feature grid icon — dual-tone outline system
  Accepts: preset, primary_color, accent_color
{%- endcomment -%}
{%- liquid
  assign stroke_w = '1.85'
  assign primary = primary_color | default: '#111111'
  assign accent = accent_color | default: '#FF2B2B'
-%}

<svg
  class="feature-grid__icon-svg"
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 48 48"
  fill="none"
  aria-hidden="true"
  focusable="false"
>
  {%- case preset -%}
    {%- when 'lasting' -%}
      <g class="feature-grid__icon-primary">
        <path d="M24 6.5l11.5 4.2v11.8c0 7.8-5.2 14.8-11.5 17.5-6.3-2.7-11.5-9.7-11.5-17.5V10.7L24 6.5z" stroke="{{ primary }}" stroke-width="{{ stroke_w }}" stroke-linejoin="round"/>
        <circle cx="24" cy="22.5" r="7.5" stroke="{{ primary }}" stroke-width="{{ stroke_w }}"/>
        <path d="M24 19v4.2l2.8 1.6" stroke="{{ primary }}" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </g>
      <g class="feature-grid__icon-accent">
        <path d="M17.5 35.5l3 6.8h7l3-6.8" stroke="{{ accent }}" stroke-width="{{ stroke_w }}" stroke-linejoin="round"/>
        <path d="M20 42.2h8" stroke="{{ accent }}" stroke-width="{{ stroke_w }}" stroke-linecap="round"/>
        <circle cx="33.5" cy="14.5" r="2.2" fill="{{ accent }}"/>
        <path d="M33.5 11.8v5.4M31.2 14.5h4.6" stroke="{{ accent }}" stroke-width="1.2" stroke-linecap="round"/>
      </g>

    {%- when 'color' -%}
      <g class="feature-grid__icon-primary">
        <path d="M11 28.5c0-9.5 5.5-17 13-17s13 7.5 13 17" stroke="{{ primary }}" stroke-width="{{ stroke_w }}" stroke-linecap="round"/>
        <path d="M9.5 28.5h29" stroke="{{ primary }}" stroke-width="{{ stroke_w }}" stroke-linecap="round"/>
        <circle cx="16.5" cy="26" r="2.2" stroke="{{ primary }}" stroke-width="1.4"/>
        <circle cx="24" cy="23.5" r="2.2" stroke="{{ primary }}" stroke-width="1.4"/>
        <circle cx="31.5" cy="26" r="2.2" stroke="{{ primary }}" stroke-width="1.4"/>
      </g>
      <g class="feature-grid__icon-accent">
        <path d="M33.5 12.5l4.5 2-8.5 8.5-3-1.2 7-9.3z" stroke="{{ accent }}" stroke-width="1.7" stroke-linejoin="round"/>
        <path d="M30.5 21.5l3 3" stroke="{{ accent }}" stroke-width="1.6" stroke-linecap="round"/>
        <path d="M14.5 16.5c2-3 5.5-4.5 9-3.5" stroke="{{ accent }}" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="16" cy="26" r="1.2" fill="{{ accent }}"/>
        <circle cx="24" cy="23.5" r="1.2" fill="{{ accent }}"/>
        <circle cx="31.5" cy="26" r="1.2" fill="{{ accent }}"/>
      </g>

    {%- when 'protection' -%}
      <g class="feature-grid__icon-primary">
        <path d="M24 5.5l13 4.8v12.2c0 8.5-5.8 16-13 19-7.2-3-13-10.5-13-19V10.3l13-4.8z" stroke="{{ primary }}" stroke-width="{{ stroke_w }}" stroke-linejoin="round"/>
        <path d="M18.5 24.5l3.8 3.8 7.2-7.5" stroke="{{ primary }}" stroke-width="{{ stroke_w }}" stroke-linecap="round" stroke-linejoin="round"/>
      </g>
      <g class="feature-grid__icon-accent">
        <path d="M8.5 16.5c1.2-2.2 3.2-3.5 5-2.5 1.2-2.5 4.2-3.2 6.2-1.2" stroke="{{ accent }}" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M38.5 20c-1.5 2-3.8 2.8-5.8 1.8-1.5 2.2-4.5 2.5-6.2.5" stroke="{{ accent }}" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="36" cy="12" r="2" fill="{{ accent }}"/>
        <path d="M36 9.5v5M33.5 12h5" stroke="#ffffff" stroke-width="1" stroke-linecap="round"/>
      </g>

    {%- when 'deep_clean' -%}
      <g class="feature-grid__icon-primary">
        <path d="M14 34.5c0-8 4.5-14.5 10-14.5s10 6.5 10 14.5" stroke="{{ primary }}" stroke-width="{{ stroke_w }}" stroke-linecap="round"/>
        <path d="M11 34.5h26" stroke="{{ primary }}" stroke-width="{{ stroke_w }}" stroke-linecap="round"/>
        <ellipse cx="24" cy="20" rx="10" ry="4.5" stroke="{{ primary }}" stroke-width="{{ stroke_w }}"/>
      </g>
      <g class="feature-grid__icon-accent">
        <path d="M20 14.5c2.5-3.5 7.5-3.5 10 0" stroke="{{ accent }}" stroke-width="{{ stroke_w }}" stroke-linecap="round"/>
        <path d="M18.5 11.5c4-5.5 11-5.5 15 0" stroke="{{ accent }}" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
        <circle cx="24" cy="28" r="2.2" fill="{{ accent }}"/>
      </g>

    {%- when 'safe' -%}
      <g class="feature-grid__icon-primary">
        <rect x="10" y="14" width="28" height="22" rx="4" stroke="{{ primary }}" stroke-width="{{ stroke_w }}"/>
        <path d="M16 22h16M16 27h11" stroke="{{ primary }}" stroke-width="1.6" stroke-linecap="round"/>
        <path d="M18 10.5h12l2 3.5H16l2-3.5z" stroke="{{ primary }}" stroke-width="{{ stroke_w }}" stroke-linejoin="round"/>
      </g>
      <g class="feature-grid__icon-accent">
        <circle cx="33" cy="33" r="7" stroke="{{ accent }}" stroke-width="{{ stroke_w }}"/>
        <path d="M30.5 33l1.8 1.8 3.5-3.8" stroke="{{ accent }}" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round"/>
      </g>

    {%- when 'shield' -%}
      <g class="feature-grid__icon-primary">
        <path d="M24 7l10.5 3.8v10.5c0 6.8-4.5 12.8-10.5 15.2-6-2.4-10.5-8.4-10.5-15.2V10.8L24 7z" stroke="{{ primary }}" stroke-width="{{ stroke_w }}" stroke-linejoin="round"/>
        <path d="M17.5 23.5h13M17.5 27.5h9" stroke="{{ primary }}" stroke-width="1.5" stroke-linecap="round"/>
      </g>
      <g class="feature-grid__icon-accent">
        <path d="M24 14.5v5.5" stroke="{{ accent }}" stroke-width="{{ stroke_w }}" stroke-linecap="round"/>
        <circle cx="24" cy="24.5" r="1.8" fill="{{ accent }}"/>
        <path d="M31 12.5l2-1.5M17 12.5l-2-1.5" stroke="{{ accent }}" stroke-width="1.4" stroke-linecap="round"/>
      </g>

    {%- else -%}
      <g class="feature-grid__icon-primary">
        <circle cx="24" cy="24" r="12" stroke="{{ primary }}" stroke-width="{{ stroke_w }}"/>
        <path d="M24 16v16M16 24h16" stroke="{{ primary }}" stroke-width="{{ stroke_w }}" stroke-linecap="round"/>
      </g>
      <g class="feature-grid__icon-accent">
        <circle cx="34" cy="14" r="3" stroke="{{ accent }}" stroke-width="1.5"/>
      </g>
  {%- endcase -%}
</svg>

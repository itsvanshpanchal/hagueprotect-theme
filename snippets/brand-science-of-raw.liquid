{%- comment -%}
  Science of Raw brand home page markup (reusable).
  Rendered by templates/page.science-of-raw.liquid (if a real Page exists)
  and by templates/404.liquid (so /pages/science-of-raw works without an
  Admin page). Logo: logo-science-of-raw.svg in Shopify Assets.
{%- endcomment -%}

{%- assign accent = '#27355f' -%}

<div class="brandpage brandpage--science-of-raw" style="font-family:'Inter',sans-serif;">

  <!-- Hero -->
  <section style="background:linear-gradient(165deg,#f6f8fc 0%,#dde5f3 100%); padding:96px 20px; text-align:center;">
    <div style="max-width:760px; margin:0 auto; display:flex; flex-direction:column; align-items:center; gap:22px;">
      <span style="display:inline-flex; align-items:center; justify-content:center; background:#ffffff; border-radius:20px; box-shadow:0 12px 32px rgba(39,53,95,0.16); padding:26px 40px;">
        <img src="{{ 'logo-science-of-raw.svg' | asset_url }}" alt="Science of Raw" width="300" height="150" style="display:block; width:auto; height:auto; max-height:104px; max-width:300px; object-fit:contain;" loading="eager" decoding="async">
      </span>
      <h1 style="font-size:clamp(30px,5vw,52px); font-weight:800; letter-spacing:-0.03em; color:#1a2440; margin:8px 0 0; line-height:1.08;">Pure, Raw, and Precisely Refined</h1>
      <p style="font-size:17px; color:#4f5a78; line-height:1.65; margin:0; max-width:600px;">Science of Raw blends nature and precision — formulations built on clean, honest ingredients and backed by a relentless pursuit of quality.</p>
      <a href="/collections/all" style="display:inline-flex; align-items:center; gap:9px; background:{{ accent }}; color:#fff; font-size:13px; font-weight:800; letter-spacing:0.08em; text-transform:uppercase; padding:15px 34px; border-radius:100px; text-decoration:none; margin-top:8px;">
        Discover the Collection
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M1 5h11M8 1l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </section>

  <!-- Pillars -->
  <section style="background:#ffffff; padding:80px 20px;">
    <div style="max-width:1120px; margin:0 auto;">
      <div style="text-align:center; max-width:560px; margin:0 auto 48px;">
        <span style="color:{{ accent }}; font-size:12px; font-weight:800; letter-spacing:0.2em; text-transform:uppercase;">The Science of Raw Standard</span>
        <h2 style="font-size:clamp(24px,3.5vw,34px); font-weight:800; color:#111; margin:12px 0 0; letter-spacing:-0.02em;">Where nature meets precision</h2>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:24px;">
        <div style="background:#f5f8fd; border:1px solid #dde5f3; border-radius:18px; padding:34px 30px;">
          <div style="width:46px; height:46px; border-radius:12px; background:{{ accent }}1f; margin-bottom:18px;"></div>
          <h3 style="font-size:19px; font-weight:700; color:#1a2440; margin:0 0 8px;">Clean Ingredients</h3>
          <p style="font-size:14.5px; color:#4f5a78; line-height:1.6; margin:0;">Honest, raw inputs with nothing to hide — transparency at the core of every formula.</p>
        </div>
        <div style="background:#f5f8fd; border:1px solid #dde5f3; border-radius:18px; padding:34px 30px;">
          <div style="width:46px; height:46px; border-radius:12px; background:{{ accent }}1f; margin-bottom:18px;"></div>
          <h3 style="font-size:19px; font-weight:700; color:#1a2440; margin:0 0 8px;">Backed by Science</h3>
          <p style="font-size:14.5px; color:#4f5a78; line-height:1.6; margin:0;">Precision formulation and rigorous testing behind every product we make.</p>
        </div>
        <div style="background:#f5f8fd; border:1px solid #dde5f3; border-radius:18px; padding:34px 30px;">
          <div style="width:46px; height:46px; border-radius:12px; background:{{ accent }}1f; margin-bottom:18px;"></div>
          <h3 style="font-size:19px; font-weight:700; color:#1a2440; margin:0 0 8px;">Uncompromising Quality</h3>
          <p style="font-size:14.5px; color:#4f5a78; line-height:1.6; margin:0;">No shortcuts — just results you can see, feel, and trust, every single time.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Page content (editable in admin, only when a real Page exists) -->
  {%- if page.content != blank -%}
    <section style="background:#ffffff; padding:0 20px 80px;">
      <div class="rte" style="max-width:820px; margin:0 auto; font-size:16px; color:#444; line-height:1.7;">
        {{ page.content }}
      </div>
    </section>
  {%- endif -%}

  <!-- Back to family -->
  <section style="background:linear-gradient(165deg,#1a2440 0%,#2c3c66 100%); padding:64px 20px; text-align:center;">
    <p style="color:#cdd7ec; font-size:15px; margin:0 0 18px; letter-spacing:0.02em;">Part of the family alongside Hague Protect &amp; Vanrosector.</p>
    <a href="/" style="display:inline-flex; align-items:center; gap:8px; color:#fff; font-size:13px; font-weight:800; letter-spacing:0.08em; text-transform:uppercase; text-decoration:none; border:1px solid rgba(255,255,255,0.4); padding:13px 28px; border-radius:100px;">Back to Hague Protect</a>
  </section>

</div>

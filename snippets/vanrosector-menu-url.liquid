{%- comment -%}
  Builds a Vanrosector-scoped URL.
  @param handle {String}
  @param search_query {String}
  @param label {String}
  @param link_type {String} 'collection' | 'product' (default: auto)
{%- endcomment -%}
{%- liquid
  assign vr_handle = handle | default: '' | strip
  assign vr_search = search_query | default: label | default: vr_handle | replace: '-', ' ' | strip
  assign vr_type = link_type | default: 'auto' | strip

  if vr_type == 'collection'
    assign vr_collection = collections[vr_handle]
    if vr_collection != blank
      assign vr_url = vr_collection.url
      if vr_url contains '?'
        echo vr_url | append: '&view=vanrosector&brand=vanrosector'
      else
        echo vr_url | append: '?view=vanrosector&brand=vanrosector'
      endif
    elsif vr_handle != blank
      echo '/collections/' | append: vr_handle | append: '?view=vanrosector&brand=vanrosector'
    else
      echo '/collections/vanrosector?view=vanrosector&brand=vanrosector'
    endif

  elsif vr_type == 'product'
    if vr_handle != blank and all_products[vr_handle] != blank
      assign vr_url = all_products[vr_handle].url
      if vr_url contains '?'
        echo vr_url | append: '&view=vanrosector&brand=vanrosector'
      else
        echo vr_url | append: '?view=vanrosector&brand=vanrosector'
      endif
    elsif vr_handle != blank
      echo '/products/' | append: vr_handle | append: '?view=vanrosector&brand=vanrosector'
    else
      assign exact_search = '"' | append: vr_search | append: '"'
      assign encoded_query = exact_search | url_encode
      echo '/collections/all?view=vanrosector&brand=vanrosector&q=' | append: encoded_query
    endif

  else
    comment
      Legacy auto mode: collection → product → brand catalog
    endcomment
    assign vr_collection = collections[vr_handle]
    if vr_collection != blank
      assign vr_url = vr_collection.url
      if vr_url contains '?'
        echo vr_url | append: '&view=vanrosector&brand=vanrosector'
      else
        echo vr_url | append: '?view=vanrosector&brand=vanrosector'
      endif
    elsif vr_handle != blank and all_products[vr_handle] != blank
      assign vr_url = all_products[vr_handle].url
      if vr_url contains '?'
        echo vr_url | append: '&view=vanrosector&brand=vanrosector'
      else
        echo vr_url | append: '?view=vanrosector&brand=vanrosector'
      endif
    else
      assign exact_search = '"' | append: vr_search | append: '"'
      assign encoded_query = exact_search | url_encode
      echo '/collections/all?view=vanrosector&brand=vanrosector&q=' | append: encoded_query
    endif
  endif
-%}

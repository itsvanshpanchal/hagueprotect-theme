{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .product-rec {
    font-family: var(--font-family-sans);
    background-color: #ffffff;
    padding: 80px 0;
  }

  .product-rec__container {
    max-width: var(--site-max-width);
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .product-rec__heading {
    font-size: 28px;
    font-weight: 700;
    color: #000;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .product-rec__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  @media screen and (max-width: 1024px) {
    .product-rec__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }

  @media screen and (max-width: 768px) {
    .product-rec__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }

  @media screen and (max-width: 480px) {
    .product-rec__grid {
      grid-template-columns: 1fr;
    }
  }

  .product-rec__card {
    background-color: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
  }

  .product-rec__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.04);
  }

  .product-rec__image-container {
    background-color: #f6f6f6;
    border-radius: 12px;
    aspect-ratio: 1;
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-rec__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .product-rec__card:hover .product-rec__image {
    transform: scale(1.04);
  }

  .product-rec__info {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-grow: 1;
  }

  .product-rec__title {
    font-size: 16px;
    font-weight: 700;
    color: #000;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .product-rec__title-main {
    display: block;
    color: #000;
  }

  .product-rec__title-sub {
    display: block;
    color: #9AA0A6;
    font-weight: 400;
    font-size: 13px;
    margin-top: 2px;
  }

  .product-rec__price {
    font-size: 15px;
    font-weight: 600;
    color: #FF2B2B;
  }

  .product-rec__btn {
    margin-top: auto;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 12px 24px;
    border-radius: 30px;
    border: none;
    background-color: #000000;
    color: #ffffff;
    cursor: pointer;
    text-align: center;
    transition: background-color 0.2s, transform 0.2s;
  }

  .product-rec__btn:hover {
    background-color: #FF2B2B;
    transform: translateY(-2px);
  }
{%- endstyle -%}

<div class="product-rec">
  <div class="product-rec__container">
    <h2 class="product-rec__heading">{{ section.settings.heading | default: 'You may also like' }}</h2>

    <div class="product-rec__grid">
      {%- assign collection = collections[section.settings.collection] -%}
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for prod in collection.products limit: 4 -%}
          <div class="product-rec__card">
            <div class="product-rec__image-container">
              <a href="{{ prod.url }}" style="width:100%; height:100%;">
                {%- if prod.featured_image != blank -%}
                  <img src="{{ prod.featured_image | image_url: width: 600 }}" alt="{{ prod.title | escape }}" class="product-rec__image" loading="lazy">
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'product-rec__image' }}
                {%- endif -%}
              </a>
            </div>

            <div class="product-rec__info">
              <a href="{{ prod.url }}">
                <h3 class="product-rec__title">
                  {%- if prod.title contains '|' -%}
                    {%- assign parts = prod.title | split: '|' -%}
                    <span class="product-rec__title-main">{{ parts[0] | strip }}</span>
                    <span class="product-rec__title-sub">{{ parts[1] | strip }}</span>
                  {%- else -%}
                    <span class="product-rec__title-main">{{ prod.title }}</span>
                  {%- endif -%}
                </h3>
              </a>
              <span class="product-rec__price">{{ prod.price | money }}</span>

              <form action="/cart/add" method="post">
                <input type="hidden" name="id" value="{{ prod.variants.first.id }}">
                <button type="submit" class="product-rec__btn" style="width: 100%;">Add to Cart</button>
              </form>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <!-- Static Fallback Products -->
        {%- for i in (1..4) -%}
          <div class="product-rec__card">
            <div class="product-rec__image-container">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 300" class="product-rec__image">
                <rect width="300" height="300" fill="#fcfcfc"/>
                <circle cx="150" cy="150" r="100" fill="#ffffff" filter="drop-shadow(0 12px 32px rgba(0,0,0,0.02))"/>
                <rect x="120" y="80" width="60" height="130" rx="12" fill="#ffffff" stroke="#eeeeee" stroke-width="2"/>
                <rect x="135" y="60" width="30" height="20" fill="#111111" rx="4"/>
                <text x="150" y="240" font-family="Inter, sans-serif" font-size="10" font-weight="700" fill="#111111" opacity="0.3" text-anchor="middle" letter-spacing="1">HAGUEPROTECT</text>
              </svg>
            </div>

            <div class="product-rec__info">
              <h3 class="product-rec__title">
                <span class="product-rec__title-main">
                  {%- if i == 1 -%}Elite Cleaner{%- elsif i == 2 -%}Shield Guard{%- elsif i == 3 -%}Premium Brush{%- else -%}Luxury Cloth{%- endif -%}
                </span>
                <span class="product-rec__title-sub">PREMIUM CARE</span>
              </h3>
              <span class="product-rec__price">
                {%- if i == 1 -%}$45.00{%- elsif i == 2 -%}$30.00{%- elsif i == 3 -%}$22.00{%- else -%}$15.00{%- endif -%}
              </span>

              <button type="button" class="product-rec__btn" style="width: 100%;">Add to Cart</button>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</div>


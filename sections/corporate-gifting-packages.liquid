{%- style -%}
  .corp-packages {
    padding: clamp(80px, 10vw, 120px) 0;
    background: #0a0a0a;
    color: #ffffff;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    overflow: hidden;
  }

  .corp-packages__container {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 max(20px, var(--site-padding, 24px));
  }

  .corp-packages__header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto clamp(48px, 6vw, 64px);
  }

  .corp-packages__eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #ff2b2b;
    margin: 0 0 12px;
  }

  .corp-packages__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(40px, 5.5vw, 64px);
    font-weight: 400;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 0 0 16px;
    line-height: 1;
    color: #ffffff !important;
  }

  .corp-packages__desc {
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  .corp-packages__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: stretch;
  }

  .corp-packages__card {
    position: relative;
    border-radius: 20px;
    padding: 36px 28px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    transition: transform 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease;
    opacity: 1;
    transform: none;
  }

  .corp-packages__card:hover {
    transform: translateY(-8px);
    border-color: rgba(255, 43, 43, 0.4);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4);
  }

  .corp-packages__card--featured {
    background: linear-gradient(160deg, rgba(255, 43, 43, 0.15) 0%, rgba(255, 255, 255, 0.06) 100%);
    border-color: rgba(255, 43, 43, 0.35);
  }

  .corp-packages__card-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 20px;
    background: rgba(255, 255, 255, 0.06);
  }

  .corp-packages__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .corp-packages__badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: #ff2b2b;
    color: #ffffff;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: 999px;
    white-space: nowrap;
  }

  .corp-packages__tier {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 8px;
  }

  .corp-packages__name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 8px;
    line-height: 1;
    color: #ffffff !important;
  }

  .corp-packages__qty {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 24px;
  }

  .corp-packages__list {
    list-style: none;
    margin: 0 0 32px;
    padding: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .corp-packages__list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.75);
  }

  .corp-packages__list li::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #ff2b2b;
    flex-shrink: 0;
    margin-top: 6px;
  }

  .corp-packages__cta {
    display: block;
    text-align: center;
    padding: 14px 24px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #ffffff;
    transition: background 0.25s ease, border-color 0.25s ease;
  }

  .corp-packages__cta:hover {
    background: #ffffff;
    color: #111111;
    border-color: #ffffff;
  }

  .corp-packages__card--featured .corp-packages__cta {
    background: #ff2b2b;
    border-color: #ff2b2b;
    color: #ffffff !important;
  }

  .corp-packages__card--featured .corp-packages__cta:hover {
    background: #ffffff;
    color: #111111 !important;
  }

  @media screen and (max-width: 900px) {
    .corp-packages__grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin: 0 auto;
    }
  }
{%- endstyle -%}

<section class="corp-packages" data-no-typewriter>
  <div class="corp-packages__container">
    <div class="corp-packages__header">
      <p class="corp-packages__eyebrow">{{ section.settings.eyebrow | default: 'Gift Tiers' }}</p>
      <h2 class="corp-packages__title">{{ section.settings.heading | default: 'Pick Your Perfect Kit' }}</h2>
      <p class="corp-packages__desc">{{ section.settings.description | default: 'Flexible packages for every occasion — from startup swag to enterprise executive gifts.' }}</p>
    </div>

    <div class="corp-packages__grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="corp-packages__card{% if block.settings.featured %} corp-packages__card--featured{% endif %}" data-corp-card {{ block.shopify_attributes }}>
            {%- if block.settings.featured -%}
              <span class="corp-packages__badge">{{ section.settings.featured_badge | default: 'Most Popular' }}</span>
            {%- endif -%}
            {%- if block.settings.image != blank -%}
              <div class="corp-packages__card-image">
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.title | escape }}"
                  width="400"
                  height="250"
                  loading="lazy"
                >
              </div>
            {%- endif -%}
            <p class="corp-packages__tier">{{ block.settings.tier_label | default: 'Tier' }}</p>
            <h3 class="corp-packages__name">{{ block.settings.title }}</h3>
            <p class="corp-packages__qty">{{ block.settings.quantity_hint }}</p>
            <ul class="corp-packages__list">
              {%- assign perks = block.settings.perks | newline_to_br | split: '<br />' -%}
              {%- for perk in perks -%}
                {%- if perk != blank -%}<li>{{ perk | strip }}</li>{%- endif -%}
              {%- endfor -%}
            </ul>
            <a href="{{ block.settings.cta_link | default: '#corp-inquiry' }}" class="corp-packages__cta">{{ block.settings.cta_label | default: 'Get Quote' }}</a>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="corp-packages__card" data-corp-card>
          <p class="corp-packages__tier">Starter</p>
          <h3 class="corp-packages__name">Essential Kit</h3>
          <p class="corp-packages__qty">25 – 100 units</p>
          <ul class="corp-packages__list">
            <li>Quick-clean solution + microfiber cloth</li>
            <li>Standard branded sleeve</li>
            <li>Volume pricing from 25 units</li>
            <li>7-day production lead time</li>
          </ul>
          <a href="#corp-inquiry" class="corp-packages__cta">Get Quote</a>
        </div>
        <div class="corp-packages__card corp-packages__card--featured" data-corp-card>
          <span class="corp-packages__badge">{{ section.settings.featured_badge | default: 'Most Popular' }}</span>
          <p class="corp-packages__tier">Executive</p>
          <h3 class="corp-packages__name">Signature Box</h3>
          <p class="corp-packages__qty">50 – 500 units</p>
          <ul class="corp-packages__list">
            <li>Full cleaning kit with premium brushes</li>
            <li>Co-branded rigid gift box</li>
            <li>Custom thank-you card insert</li>
            <li>Dedicated account manager</li>
          </ul>
          <a href="#corp-inquiry" class="corp-packages__cta">Get Quote</a>
        </div>
        <div class="corp-packages__card" data-corp-card>
          <p class="corp-packages__tier">Enterprise</p>
          <h3 class="corp-packages__name">Bespoke Program</h3>
          <p class="corp-packages__qty">500+ units</p>
          <ul class="corp-packages__list">
            <li>Fully custom kit curation</li>
            <li>Logo embossing & premium packaging</li>
            <li>Multi-location delivery</li>
            <li>Priority production & white-glove support</li>
          </ul>
          <a href="#corp-inquiry" class="corp-packages__cta">Get Quote</a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Corporate Packages",
  "enabled_on": {
    "templates": ["search.corporate-gifting", "page.corporate"]
  },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Gift Tiers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pick Your Perfect Kit" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Flexible packages for every occasion — from startup swag to enterprise executive gifts." },
    { "type": "text", "id": "featured_badge", "label": "Featured badge text", "default": "Most Popular" }
  ],
  "blocks": [
    {
      "type": "package",
      "name": "Package",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Package image" },
        { "type": "text", "id": "tier_label", "label": "Tier label", "default": "Starter" },
        { "type": "text", "id": "title", "label": "Package name", "default": "Essential Kit" },
        { "type": "text", "id": "quantity_hint", "label": "Quantity hint", "default": "25 – 100 units" },
        { "type": "textarea", "id": "perks", "label": "Perks (one per line)", "default": "Quick-clean solution\nStandard branded sleeve\nVolume pricing" },
        { "type": "text", "id": "cta_label", "label": "Button label", "default": "Get Quote" },
        { "type": "url", "id": "cta_link", "label": "Button link" },
        { "type": "checkbox", "id": "featured", "label": "Featured (most popular)", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Corporate Packages",
      "blocks": [
        { "type": "package", "settings": { "tier_label": "Starter", "title": "Essential Kit", "quantity_hint": "25 – 100 units", "perks": "Quick-clean solution + microfiber cloth\nStandard branded sleeve\nVolume pricing from 25 units\n7-day production lead time" } },
        { "type": "package", "settings": { "tier_label": "Executive", "title": "Signature Box", "quantity_hint": "50 – 500 units", "featured": true, "perks": "Full cleaning kit with premium brushes\nCo-branded rigid gift box\nCustom thank-you card insert\nDedicated account manager" } },
        { "type": "package", "settings": { "tier_label": "Enterprise", "title": "Bespoke Program", "quantity_hint": "500+ units", "perks": "Fully custom kit curation\nLogo embossing & premium packaging\nMulti-location delivery\nPriority production & white-glove support" } }
      ]
    }
  ]
}
{% endschema %}

{%- style -%}
  .lpt-section {
    background-color: #fcfcfc;
    padding: 60px 0;
    font-family: 'Inter', system-ui, -apple-system, sans-serif !important;
  }

  .lpt-container {
    max-width: 100%;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: flex-start;
    box-sizing: border-box;
  }

  .lpt-card {
    width: 100%;
    background-color: #ffffff;
    border-radius: 0;
    display: flex;
    flex-direction: column;
    position: relative;
    box-shadow: none;
    overflow: hidden;
    box-sizing: border-box;
    transition: none;
  }

  /* Badge */
  .lpt-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background-color: #E74C3C;
    color: #ffffff;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    padding: 6px 12px;
    border-radius: 20px;
    z-index: 10;
    letter-spacing: 0.05em;
  }

  /* Image Area */
  .lpt-image-wrapper {
    width: 100%;
    min-height: 320px;
    background-color: #F0F0F0;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    border-radius: 12px 12px 0 0;
    overflow: hidden;
    box-sizing: border-box;
    padding: 24px;
  }

  @media screen and (max-width: 768px) {
    .lpt-image-wrapper {
      min-height: 240px;
    }
  }

  .lpt-image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    transition: transform 300ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .lpt-card:hover .lpt-image {
    transform: scale(1.05);
  }

  /* Remote Icon overlay */
  .lpt-remote-icon {
    position: absolute;
    bottom: 16px;
    right: 16px;
    width: 50px;
    height: 50px;
    background-color: #ffffff;
    border: 2px solid #E74C3C;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.9;
    z-index: 3;
  }

  /* LOWER CONTENT SECTION */
  .lpt-content {
    padding: 20px;
    background-color: #ffffff;
    display: flex;
    flex-direction: column;
    gap: 12px;
    box-sizing: border-box;
  }

  @media screen and (max-width: 1200px) {
    .lpt-content {
      padding: 16px;
    }
  }

  /* Rating Row */
  .lpt-rating-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .lpt-rating-badge {
    background-color: #2ECC71;
    color: #1A1A1A;
    font-size: 13px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: 3px;
  }

  .lpt-reviews {
    font-size: 13px;
    color: #888888;
    font-weight: 400;
  }

  /* Title */
  .lpt-title {
    font-size: 20px;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 6px 0;
    line-height: 1.3;
  }

  /* Subtitle */
  .lpt-subtitle {
    font-size: 14px;
    font-weight: 400;
    color: #888888;
    margin: 0 0 8px 0;
    line-height: 1.4;
  }

  /* Description */
  .lpt-desc {
    font-size: 15px;
    font-weight: 600;
    color: #1A1A1A;
    margin: 0 0 12px 0;
  }

  /* Swatches */
  .lpt-swatches {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 12px;
  }

  .lpt-swatch {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    cursor: pointer;
    border: 2px solid transparent;
    transition: all 300ms ease;
    box-sizing: border-box;
  }

  .lpt-swatch:hover {
    transform: scale(1.1);
  }

  .lpt-swatch.is-black {
    background-color: #000000;
  }

  .lpt-swatch.is-white {
    background-color: #ffffff;
    border: 1px solid #e0e0e0;
  }

  .lpt-swatch.active {
    border-color: #E74C3C;
    box-shadow: 0 0 6px rgba(231, 76, 60, 0.4);
  }

  /* Price */
  .lpt-price-box {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 8px;
    text-align: left;
  }

  .lpt-price-old {
    font-size: 12px;
    color: #CCCCCC;
    text-decoration: line-through;
    line-height: 1.1;
  }

  .lpt-price-new {
    font-size: 24px;
    font-weight: 700;
    color: #1A1A1A;
    line-height: 1.1;
  }

  /* Button */
  .lpt-btn {
    background-color: #000000;
    color: #ffffff;
    font-size: 15px;
    font-weight: 700;
    padding: 12px 24px;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    text-align: center;
    transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
    width: 100%;
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    height: 44px;
  }

  .lpt-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
{%- endstyle -%}

<section class="lpt-section" aria-label="Large Featured Product">
  <div class="lpt-container">
    <div class="lpt-card">
      
      <!-- Top Right Badge -->
      <span class="lpt-badge">BESTSELLER</span>

      <!-- Top Image Wrapper Area -->
      <div class="lpt-image-wrapper">
        {%- if product.featured_image != blank -%}
          <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" class="lpt-image" loading="lazy">
        {%- else -%}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 600" class="lpt-image">
            <rect width="600" height="600" fill="#f4f4f4"/>
            <circle cx="300" cy="270" r="160" fill="#ffffff" stroke="#e0e0e0" stroke-width="2"/>
            <!-- graphic -->
            <path d="M300 270 L300 120 M300 270 L430 190 M300 270 L380 380 M300 270 L220 380 M300 270 L170 190" stroke="#E74C3C" stroke-width="8" stroke-linecap="round"/>
            <circle cx="300" cy="270" r="30" fill="#111111"/>
            <text x="300" y="470" font-family="'Inter', sans-serif" font-size="16" font-weight="700" fill="#1A1A1A" letter-spacing="2" text-anchor="middle">HĀLO v2 | PREMIUM FAN</text>
          </svg>
        {%- endif -%}

        <!-- Remote icon -->
        <div class="lpt-remote-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="7" y="2" width="10" height="20" rx="3" stroke="#E74C3C" stroke-width="2"/>
            <circle cx="12" cy="7" r="1.5" fill="#E74C3C"/>
            <circle cx="12" cy="11.5" r="1" fill="#E74C3C"/>
            <circle cx="12" cy="15" r="1" fill="#E74C3C"/>
          </svg>
        </div>
      </div>

      <!-- Bottom Minimal Padding Content Area -->
      <div class="lpt-content">
        <!-- Rating row -->
        <div class="lpt-rating-row">
          <span class="lpt-rating-badge">★ 4.9</span>
          <span class="lpt-reviews">(260)</span>
        </div>

        <h3 class="lpt-title">{{ section.settings.title | default: 'HĀLO v2' }}</h3>
        <p class="lpt-subtitle">{{ section.settings.subtitle | default: 'HĀLO v2 | 3D Air Circulation Fan with Mood Lamp' }}</p>

        <p class="lpt-desc">{{ section.settings.desc | default: "India's most silent air circulator" }}</p>

        <!-- Color variants -->
        <div class="lpt-swatches">
          <div class="lpt-swatch is-black active" title="Black"></div>
          <div class="lpt-swatch is-white" title="White"></div>
        </div>

        <!-- Pricing -->
        <div class="lpt-price-box">
          <span class="lpt-price-old">{{ section.settings.old_price | default: 'Rs. 15,999' }}</span>
          <span class="lpt-price-new">{{ section.settings.new_price | default: 'Rs. 10,999' }}</span>
        </div>

        <!-- Button -->
        {%- assign current_variant = product.selected_or_first_available_variant -%}
        {%- form 'product', product, id: 'AddToCartForm-lpt' -%}
          <input type="hidden" name="id" value="{{ current_variant.id | default: 12345678 }}">
          <button type="submit" name="add" class="lpt-btn">Add to Cart</button>
        {%- endform -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Large Product Tile",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Product Title",
      "default": "HĀLO v2"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "HĀLO v2 | 3D Air Circulation Fan with Mood Lamp"
    },
    {
      "type": "text",
      "id": "desc",
      "label": "Description",
      "default": "India's most silent air circulator"
    },
    {
      "type": "text",
      "id": "old_price",
      "label": "Old Price",
      "default": "Rs. 15,999"
    },
    {
      "type": "text",
      "id": "new_price",
      "label": "New Price",
      "default": "Rs. 10,999"
    }
  ],
  "presets": [
    {
      "name": "Large Product Tile"
    }
  ]
}
{% endschema %}

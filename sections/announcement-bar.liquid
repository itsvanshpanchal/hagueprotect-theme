{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .announcement-bar-marquee {
    background-color: {{ section.settings.bg_color | default: '#FF1A2D' }};
    color: {{ section.settings.text_color | default: '#FFFFFF' }};
    height: 42px;
    display: flex;
    align-items: center;
    overflow: hidden;
    white-space: nowrap;
    position: relative;
    user-select: none;
    font-family: 'Inter', sans-serif !important;
    border: none;
  }

  .announcement-bar__track {
    display: flex;
    width: max-content;
    animation: marquee-scroll-dtc 20s linear infinite;
  }

  .announcement-bar-marquee:hover .announcement-bar__track {
    animation-play-state: paused;
  }

  .announcement-bar__item {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 0 16px;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  @keyframes marquee-scroll-dtc {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 768px) {
    .announcement-bar-marquee {
      height: 36px;
    }
    .announcement-bar__item {
      font-size: 11px;
      padding: 0 12px;
      letter-spacing: 0.03em;
    }
    .announcement-bar__track {
      animation-duration: 28s;
    }
  }
{%- endstyle -%}

{%- if section.settings.show_announcement -%}
  <div class="announcement-bar-marquee">
    <div class="announcement-bar__track">
      <div class="announcement-bar__item">
        {{ section.settings.text }} &nbsp;&bull;&nbsp; {{ section.settings.text }} &nbsp;&bull;&nbsp; {{ section.settings.text }} &nbsp;&bull;&nbsp; {{ section.settings.text }}
      </div>
      <div class="announcement-bar__item">
        {{ section.settings.text }} &nbsp;&bull;&nbsp; {{ section.settings.text }} &nbsp;&bull;&nbsp; {{ section.settings.text }} &nbsp;&bull;&nbsp; {{ section.settings.text }}
      </div>
    </div>
  </div>
{%- endif -%}


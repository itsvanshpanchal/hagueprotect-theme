{%- style -%}
  {% render 'section-typography-vars', section: section %}

{%- endstyle -%}

{%- comment -%}
  ============================================================
  BRAND PAGE Ã¢â‚¬â€ editable brand landing (banner + bestsellers)
  Used by the alternate collection templates:
    collection.vanrosector.json   -> /collections/all?view=vanrosector
    collection.science-of-raw.json-> /collections/all?view=science-of-raw
  Every field below is editable in the Shopify theme editor, and the
  values are stored per-template, so changes here NEVER affect the main
  store or the other brand page.
  ============================================================
{%- endcomment -%}

{%- liquid
  assign accent = section.settings.accent | default: '#111111'
  assign bs_collection = section.settings.bestseller_collection
  if bs_collection == blank or bs_collection.products.size == 0
    assign bs_collection = collections['all']
  endif
  assign products_count = section.settings.products_count | default: 4
-%}

<div class="brandpage" style="font-family:'Inter',sans-serif;">

  <!-- Banner -->
  <section style="background:linear-gradient(165deg,{{ section.settings.banner_bg_from | default: '#f6f6f6' }} 0%,{{ section.settings.banner_bg_to | default: '#e9e9e9' }} 100%); padding:{{ section.settings.banner_padding | default: 96 }}px 20px; text-align:center;">
    <div style="max-width:760px; margin:0 auto; display:flex; flex-direction:column; align-items:center; gap:22px;">
      {%- if section.settings.logo != blank -%}
        <span style="display:inline-flex; align-items:center; justify-content:center; background:#ffffff; border-radius:20px; box-shadow:0 12px 32px rgba(0,0,0,0.12); padding:26px 40px;">
          <img src="{{ section.settings.logo | image_url: width: 640 }}" alt="{{ section.settings.heading | escape }}" width="320" height="120" style="display:block; width:auto; height:auto; max-height:100px; max-width:320px; object-fit:contain;" loading="eager" decoding="async">
        </span>
      {%- elsif section.settings.logo_asset != blank -%}
        <span style="display:inline-flex; align-items:center; justify-content:center; background:#ffffff; border-radius:20px; box-shadow:0 12px 32px rgba(0,0,0,0.12); padding:26px 40px;">
          <img src="{{ section.settings.logo_asset | asset_url }}" alt="{{ section.settings.heading | escape }}" width="320" height="120" style="display:block; width:auto; height:auto; max-height:100px; max-width:320px; object-fit:contain;" loading="eager" decoding="async">
        </span>
      {%- endif -%}

      {%- if section.settings.eyebrow != blank -%}
        <p style="font-size:12px; font-weight:800; letter-spacing:0.2em; text-transform:uppercase; color:{{ accent }}; margin:0;">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 style="font-size:clamp(30px,5vw,52px); font-weight:800; letter-spacing:-0.03em; color:#1c1c1c; margin:0; line-height:1.08;">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p style="font-size:17px; color:#555; line-height:1.65; margin:0; max-width:600px;">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '/collections/all' }}" style="display:inline-flex; align-items:center; gap:9px; background:{{ accent }}; color:#fff; font-size:13px; font-weight:800; letter-spacing:0.08em; text-transform:uppercase; padding:15px 34px; border-radius:100px; text-decoration:none; margin-top:8px;">
          {{ section.settings.button_label }}
          <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M1 5h11M8 1l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      {%- endif -%}
    </div>
  </section>

  <!-- Bestseller products -->
  {%- if section.settings.show_bestsellers -%}
    <section style="background:{{ section.settings.bs_bg | default: '#ffffff' }}; padding:72px 20px;">
      <div style="max-width:1180px; margin:0 auto;">
        <div style="text-align:center; max-width:560px; margin:0 auto 44px;">
          {%- if section.settings.bs_eyebrow != blank -%}
            <span style="color:{{ accent }}; font-size:12px; font-weight:800; letter-spacing:0.2em; text-transform:uppercase;">{{ section.settings.bs_eyebrow }}</span>
          {%- endif -%}
          {%- if section.settings.bs_heading != blank -%}
            <h2 style="font-size:clamp(24px,3.5vw,34px); font-weight:800; color:#111; margin:12px 0 0; letter-spacing:-0.02em;">{{ section.settings.bs_heading }}</h2>
          {%- endif -%}
        </div>

        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:24px;">
          {%- for product in bs_collection.products limit: products_count -%}
            <a href="{{ product.url }}" style="display:flex; flex-direction:column; text-decoration:none; background:#fafafa; border:1px solid rgba(0,0,0,0.06); border-radius:18px; overflow:hidden;">
              <span style="display:block; aspect-ratio:1/1; background:#f1f1f1;">
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape | default: product.title }}" width="600" height="600" loading="lazy" decoding="async" style="width:100%; height:100%; object-fit:cover; display:block;">
                {%- endif -%}
              </span>
              <span style="display:flex; flex-direction:column; gap:6px; padding:18px 18px 22px;">
                <span style="font-size:15px; font-weight:700; color:#111; line-height:1.3;">{{ product.title }}</span>
                <span style="font-size:14px; font-weight:600; color:{{ accent }};">
                  {%- if product.compare_at_price > product.price -%}
                    <span style="color:#FF2B2B;">{{ product.price | money }}</span>
                    <s style="color:#9a9a9a; font-weight:500; margin-left:6px;">{{ product.compare_at_price | money }}</s>
                  {%- else -%}
                    {{ product.price | money }}
                  {%- endif -%}
                </span>
              </span>
            </a>
          {%- else -%}
            <p style="grid-column:1/-1; text-align:center; color:#888; margin:0;">Products coming soon.</p>
          {%- endfor -%}
        </div>

        {%- if section.settings.bs_button_label != blank and bs_collection.url != blank -%}
          <div style="text-align:center; margin-top:44px;">
            <a href="{{ bs_collection.url }}" style="display:inline-flex; align-items:center; gap:9px; background:{{ accent }}; color:#fff; font-size:13px; font-weight:800; letter-spacing:0.08em; text-transform:uppercase; padding:14px 32px; border-radius:100px; text-decoration:none;">
              {{ section.settings.bs_button_label }}
              <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M1 5h11M8 1l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        {%- endif -%}
      </div>
    </section>
  {%- endif -%}

  <!-- Back band -->
  {%- if section.settings.show_back_band and section.settings.back_text != blank -%}
    <section style="background:{{ section.settings.back_bg | default: '#1c1c1c' }}; padding:64px 20px; text-align:center;">
      <p style="color:rgba(255,255,255,0.82); font-size:15px; margin:0 0 18px; letter-spacing:0.02em;">{{ section.settings.back_text }}</p>
      <a href="{{ section.settings.back_link | default: '/' }}" style="display:inline-flex; align-items:center; gap:8px; color:#fff; font-size:13px; font-weight:800; letter-spacing:0.08em; text-transform:uppercase; text-decoration:none; border:1px solid rgba(255,255,255,0.4); padding:13px 28px; border-radius:100px;">{{ section.settings.back_label | default: 'Back to Hague Protect' }}</a>
    </section>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "Brand Page",
  "settings": [
    { "type": "header", "content": "Banner" },
    { "type": "image_picker", "id": "logo", "label": "Logo image", "info": "Overrides the fallback below when set." },
    { "type": "text", "id": "logo_asset", "label": "Logo fallback (asset filename)", "info": "e.g. logo-vanrosector.svg Ã¢â‚¬â€ used if no logo image is chosen." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Brand heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Discover the Collection" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "color", "id": "accent", "label": "Accent color", "default": "#111111" },
    { "type": "color", "id": "banner_bg_from", "label": "Banner background (top)", "default": "#f6f6f6" },
    { "type": "color", "id": "banner_bg_to", "label": "Banner background (bottom)", "default": "#e9e9e9" },
    { "type": "range", "id": "banner_padding", "min": 40, "max": 160, "step": 4, "unit": "px", "label": "Banner padding", "default": 96 },

    { "type": "header", "content": "Bestsellers" },
    { "type": "checkbox", "id": "show_bestsellers", "label": "Show bestsellers", "default": true },
    { "type": "collection", "id": "bestseller_collection", "label": "Collection" },
    { "type": "text", "id": "bs_eyebrow", "label": "Eyebrow", "default": "Bestsellers" },
    { "type": "text", "id": "bs_heading", "label": "Heading", "default": "Most loved right now" },
    { "type": "range", "id": "products_count", "min": 2, "max": 8, "step": 1, "label": "Products to show", "default": 4 },
    { "type": "text", "id": "bs_button_label", "label": "Shop-all button label", "default": "Shop all" },
    { "type": "color", "id": "bs_bg", "label": "Background", "default": "#ffffff" },

    { "type": "header", "content": "Back band" },
    { "type": "checkbox", "id": "show_back_band", "label": "Show back band", "default": true },
    { "type": "text", "id": "back_text", "label": "Back band text" },
    { "type": "text", "id": "back_label", "label": "Back button label", "default": "Back to Hague Protect" },
    { "type": "url", "id": "back_link", "label": "Back button link" },
    { "type": "color", "id": "back_bg", "label": "Back band background", "default": "#1c1c1c" }
,
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "paragraph",
      "content": "Font and size for this section. Global defaults: Theme settings > Typography."
    },
    {
      "type": "checkbox",
      "id": "typography_override",
      "label": "Override theme typography for this section",
      "default": false
    },
    {
      "type": "select",
      "id": "h1_font_family",
      "label": "H1 font family",
      "options": [
        { "value": "bebas_neue", "label": "Bebas Neue" },
        { "value": "anton", "label": "Anton" },
        { "value": "oswald", "label": "Oswald" },
        { "value": "inter", "label": "Inter" },
        { "value": "montserrat", "label": "Montserrat" }
      ],
      "default": "bebas_neue"
    },
    {
      "type": "range",
      "id": "h1_font_size_desktop",
      "label": "H1 size (desktop)",
      "min": 24,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "h1_font_size_mobile",
      "label": "H1 size (mobile)",
      "min": 18,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "select",
      "id": "h2_font_family",
      "label": "H2 font family",
      "options": [
        { "value": "bebas_neue", "label": "Bebas Neue" },
        { "value": "anton", "label": "Anton" },
        { "value": "oswald", "label": "Oswald" },
        { "value": "inter", "label": "Inter" },
        { "value": "montserrat", "label": "Montserrat" }
      ],
      "default": "bebas_neue"
    },
    {
      "type": "range",
      "id": "h2_font_size_desktop",
      "label": "H2 size (desktop)",
      "min": 20,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "h2_font_size_mobile",
      "label": "H2 size (mobile)",
      "min": 16,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 34
    },
    {
      "type": "select",
      "id": "paragraph_font_family",
      "label": "Paragraph font family",
      "options": [
        { "value": "inter", "label": "Inter" },
        { "value": "montserrat", "label": "Montserrat" },
        { "value": "bebas_neue", "label": "Bebas Neue" },
        { "value": "oswald", "label": "Oswald" }
      ],
      "default": "inter"
    },
    {
      "type": "range",
      "id": "paragraph_font_size_desktop",
      "label": "Paragraph size (desktop)",
      "min": 11,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "paragraph_font_size_mobile",
      "label": "Paragraph size (mobile)",
      "min": 11,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "select",
      "id": "eyebrow_font_family",
      "label": "Eyebrow / label font family",
      "options": [
        { "value": "inter", "label": "Inter" },
        { "value": "montserrat", "label": "Montserrat" },
        { "value": "bebas_neue", "label": "Bebas Neue" },
        { "value": "oswald", "label": "Oswald" }
      ],
      "default": "inter"
    },
    {
      "type": "range",
      "id": "eyebrow_font_size_desktop",
      "label": "Eyebrow size (desktop)",
      "min": 9,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "eyebrow_font_size_mobile",
      "label": "Eyebrow size (mobile)",
      "min": 9,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    }

  ],
  "presets": [
    { "name": "Brand Page" }
  ]
}
{% endschema %}

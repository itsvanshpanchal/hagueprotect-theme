{%- style -%}
  :root {
    --fc-bg: #F4F5F7;
    --fc-card-bg: #FAFAFB;
    --fc-border: #E6E7E8;
    --fc-border-hover: #D1D2D4;
    --fc-text: #111111;
    --fc-muted: #666668;
    --fc-primary: #111111;
  }

  /* Dark mode variable updates if applicable */
  @media (prefers-color-scheme: dark) {
    :root {
      --fc-bg: #1A1B1D;
      --fc-card-bg: #222426;
      --fc-border: #333639;
      --fc-border-hover: #4A4D51;
      --fc-text: #F4F5F7;
      --fc-muted: #8E9196;
    }
  }

  .fc-section {
    padding: 60px 0;
    background-color: transparent;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif !important;
    overflow: hidden;
  }

  .fc-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    box-sizing: border-box;
  }

  .fc-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .fc-heading {
    font-size: 20px;
    font-weight: 700;
    color: var(--fc-text);
    margin: 0 0 6px 0;
    letter-spacing: -0.02em;
  }

  .fc-subtitle {
    font-size: 13px;
    font-weight: 400;
    color: var(--fc-muted);
    margin: 0;
  }

  .fc-slider-wrapper {
    position: relative;
    width: 100%;
    box-sizing: border-box;
  }

  .fc-slider-container {
    overflow: hidden;
    width: 100%;
    box-sizing: border-box;
    position: relative;
    padding-bottom: 8px;
  }

  .fc-slider-track {
    display: flex;
    gap: 20px;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    box-sizing: border-box;
  }

  .fc-slide {
    flex: 0 0 calc(25% - 15px);
    box-sizing: border-box;
    min-width: calc(25% - 15px);
    height: 140px;
    background-color: var(--fc-card-bg);
    border: 1px solid var(--fc-border);
    border-radius: 12px;
    padding: 20px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    transition: background-color 0.2s ease, border-color 0.2s ease;
    cursor: pointer;
    text-decoration: none;
  }

  .fc-slide:hover {
    background-color: var(--fc-bg);
    border-color: var(--fc-border-hover);
  }

  .fc-category-name {
    font-size: 15px;
    font-weight: 700;
    color: var(--fc-text);
    margin: 0 0 4px 0;
    line-height: 1.3;
    max-width: calc(100% - 70px);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .fc-product-count {
    font-size: 12px;
    font-weight: 500;
    color: var(--fc-muted);
    margin: 0;
  }

  .fc-illustration {
    position: absolute;
    bottom: -15px;
    right: -10px;
    width: 90px;
    height: 110px;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    pointer-events: none;
    transition: transform 0.3s ease;
    z-index: 2;
    color: var(--fc-text);
  }

  .fc-slide:hover .fc-illustration {
    transform: scale(1.04) rotate(-1deg);
  }

  /* Navigation arrows */
  .fc-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: absolute;
    top: 50%;
    left: -20px;
    right: -20px;
    transform: translateY(-50%);
    pointer-events: none;
    z-index: 10;
  }

  .fc-arrow {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: #FFFFFF;
    border: 1px solid var(--fc-border);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    pointer-events: auto;
    transition: all 0.2s ease;
    color: #111111;
  }

  .fc-arrow:hover {
    border-color: var(--fc-border-hover);
    background-color: #FAFAFB;
    transform: scale(1.05);
  }

  .fc-arrow:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    transform: none;
  }

  .fc-arrow svg {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.5;
  }

  /* Progress bar */
  .fc-progress-container {
    width: 140px;
    height: 3px;
    background-color: var(--fc-border);
    margin: 30px auto 0 auto;
    border-radius: 1.5px;
    position: relative;
    overflow: hidden;
  }

  .fc-progress-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 33.333%;
    background-color: var(--fc-primary);
    border-radius: 1.5px;
    transition: transform 0.35s cubic-bezier(0.25, 1, 0.5, 1);
  }

  @media (max-width: 991px) {
    .fc-slide {
      flex: 0 0 calc(33.333% - 14px);
      min-width: calc(33.333% - 14px);
    }
    .fc-progress-container {
      width: 100px;
    }
  }

  @media (max-width: 767px) {
    .fc-slide {
      flex: 0 0 calc(50% - 10px);
      min-width: calc(50% - 10px);
    }
    .fc-nav {
      left: -8px;
      right: -8px;
    }
    .fc-arrow {
      width: 28px;
      height: 28px;
    }
  }

  @media (max-width: 480px) {
    .fc-slide {
      flex: 0 0 100%;
      min-width: 100%;
    }
  }
{%- endstyle -%}

<section class="fc-section" aria-label="Shop by Function and Category">
  <div class="fc-container">
    <div class="fc-header animate-fade-in">
      <h2 class="fc-heading">{{ section.settings.heading | default: 'Shop by Function and Category' }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="fc-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="fc-slider-wrapper">
      <div class="fc-slider-container" id="fc-slider-{{ section.id }}">
        <div class="fc-slider-track" id="fc-track-{{ section.id }}">
          {%- for block in section.blocks -%}
            {%- assign link = block.settings.link | default: '#' -%}
            <a href="{{ link }}" class="fc-slide" {{ block.shopify_attributes }}>
              <div class="fc-category-info">
                <h3 class="fc-category-name">{{ block.settings.title }}</h3>
                <p class="fc-product-count">{{ block.settings.product_count | default: '0 products' }}</p>
              </div>
              <div class="fc-illustration">
                {%- if block.settings.svg_code != blank -%}
                  {{ block.settings.svg_code }}
                {%- else -%}
                  <!-- fallback graphic icon -->
                  <svg viewBox="0 0 120 120" width="80" height="80" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="25" y="25" width="70" height="70" rx="12" stroke="currentColor" stroke-width="2"/>
                    <circle cx="60" cy="60" r="15" stroke="currentColor" stroke-width="2"/>
                  </svg>
                {%- endif -%}
              </div>
            </a>
          {%- endfor -%}
        </div>
      </div>

      <div class="fc-nav">
        <button class="fc-arrow fc-arrow--prev" id="fc-prev-{{ section.id }}" aria-label="Previous categories" disabled>
          <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="fc-arrow fc-arrow--next" id="fc-next-{{ section.id }}" aria-label="Next categories">
          <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>

    <div class="fc-progress-container">
      <div class="fc-progress-fill" id="fc-fill-{{ section.id }}"></div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    initFunctionCategorySlider();
  });

  document.addEventListener('shopify:section:load', function(e) {
    if (e.target.id.includes('function-category') || e.target.querySelector('.fc-section')) {
      initFunctionCategorySlider();
    }
  });

  function initFunctionCategorySlider() {
    const track = document.getElementById('fc-track-{{ section.id }}');
    const prevBtn = document.getElementById('fc-prev-{{ section.id }}');
    const nextBtn = document.getElementById('fc-next-{{ section.id }}');
    const fill = document.getElementById('fc-fill-{{ section.id }}');
    if (!track || !prevBtn || !nextBtn || !fill) return;

    let currentIndex = 0;

    function getVisibleCardsCount() {
      if (window.innerWidth <= 480) return 1;
      if (window.innerWidth <= 767) return 2;
      if (window.innerWidth <= 991) return 3;
      return 4;
    }

    function updateSlider() {
      const slides = track.querySelectorAll('.fc-slide');
      if (slides.length === 0) return;

      const visible = getVisibleCardsCount();
      const maxSteps = Math.max(0, slides.length - visible);
      if (currentIndex > maxSteps) currentIndex = maxSteps;
      if (currentIndex < 0) currentIndex = 0;

      // Update arrow states
      prevBtn.disabled = (currentIndex === 0);
      nextBtn.disabled = (currentIndex === maxSteps);

      // Get individual slide width + gap dynamically
      const slideWidth = slides[0].offsetWidth;
      const gap = 20; // Exact defined track gap
      const offset = currentIndex * (slideWidth + gap);

      track.style.transform = `translateX(-${offset}px)`;

      // Update progress fill width and transform
      const totalSteps = maxSteps + 1;
      const fillWidth = 100 / totalSteps;
      fill.style.width = `${fillWidth}%`;
      fill.style.transform = `translateX(${currentIndex * 100}%)`;
    }

    prevBtn.addEventListener('click', () => {
      currentIndex--;
      updateSlider();
    });

    nextBtn.addEventListener('click', () => {
      currentIndex++;
      updateSlider();
    });

    window.addEventListener('resize', updateSlider);
    updateSlider();
  }
</script>


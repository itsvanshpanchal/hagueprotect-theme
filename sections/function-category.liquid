{%- style -%}
  {% render 'section-typography-vars', section: section %}


  :root {
    --fc-bg: #fdfeff;
    --fc-card-bg: #fdfeff;
    --fc-border: #D1D2D4;
    --fc-border-hover: #B8B9BB;
    --fc-text: #111111;
    --fc-muted: #666668;
    --fc-primary: #c6c2c2ff;
  }

  /* Dark mode variable updates if applicable */
  @media (prefers-color-scheme: dark) {
    :root {
      --fc-bg: #fdfeff;
      --fc-card-bg: #fdfeff;
      --fc-border: #D1D2D4;
      --fc-border-hover: #B8B9BB;
      --fc-text: #111111;
      --fc-muted: #666668;
    }
  }

  .fc-section {
    padding: 60px 0;
    background-color: transparent;
    font-family: var(--font-family-sans, 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif);
    overflow: hidden;
  }

  .fc-container {
    max-width: var(--site-max-width);
    margin: 0 auto;
    padding: 0 35px;
    position: relative;
    box-sizing: border-box;
  }

  .fc-header {
    text-align: center;
  }

  .fc-heading {
    color: var(--fc-text);
    margin: 0;
  }

  .fc-subtitle {
    margin: 0;
  }

  .fc-slider-wrapper {
    position: relative;
    width: 100%;
    box-sizing: border-box;
  }

  .fc-slider-container {
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    width: 100%;
    box-sizing: border-box;
    position: relative;
    padding-bottom: 8px;
    /* Hide scrollbar */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .fc-slider-container::-webkit-scrollbar {
    display: none;
  }

  .fc-slider-track {
    display: flex;
    gap: 20px;
    box-sizing: border-box;
    /* Width set by JS so scroll works correctly */
  }

  .fc-slide {
    flex: 0 0 calc(25% - 15px);
    box-sizing: border-box;
    min-width: calc(25% - 15px);
    aspect-ratio: 1 / 1;
    background-color: #fdfeff !important;
    border: 1px solid var(--fc-border);
    border-radius: var(--homepage-corner, 20px);
    padding: 20px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    transition: background-color 0.2s ease, border-color 0.2s ease, transform 0.35s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.35s ease;
    cursor: pointer;
    text-decoration: none;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  @media (min-width: 768px) {
    .fc-slider-track {
      padding: 28px 0;
    }

    .fc-slide {
      overflow: visible;
      perspective: 1200px;
      transform-style: preserve-3d;
    }

    .fc-slide.fc-slide--hover {
      z-index: 8;
      transform: translateY(-8px);
      box-shadow: 0 28px 52px rgba(17, 17, 17, 0.14);
      border-color: var(--fc-border-hover);
    }
  }

  .fc-slide:hover {
    background-color: #fdfeff !important;
    border-color: var(--fc-border-hover);
  }

  .fc-category-name {
    font-size: 15px !important;
    font-weight: 700 !important;
    font-family: var(--font-family-sans, 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif) !important;
    text-transform: uppercase !important;
    letter-spacing: 0.02em !important;
    line-height: 1.3 !important;
    color: #111111;
    margin: 0 0 4px 0;
    max-width: calc(100% - 70px);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .fc-product-count {
    font-size: 12px;
    font-weight: 700;
    color: #111111;
    margin: 0;
  }

  .fc-category-info {
    position: relative;
    z-index: 3;
    max-width: 55%;
    pointer-events: auto;
  }

  .fc-illustration {
    position: absolute;
    top: 15px;
    bottom: 0;
    right: 0;
    width: 68%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    pointer-events: none;
    transition: filter 0.45s ease;
    transform-style: preserve-3d;
    will-change: transform;
    z-index: 2;
    color: var(--fc-text);
  }

  @media (min-width: 768px) {
    .fc-illustration {
      transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1), filter 0.45s ease;
    }

    .fc-slide.fc-slide--hover .fc-illustration {
      transition: transform 0.1s ease-out, filter 0.45s ease;
    }
  }

  .fc-illustration img,
  .fc-illustration svg {
    width: auto !important;
    height: 100% !important;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    transition: filter 0.45s ease;
    transform: translateZ(0);
  }

  @media (min-width: 768px) {
    .fc-slide.fc-slide--hover .fc-illustration img,
    .fc-slide.fc-slide--hover .fc-illustration svg {
      filter: drop-shadow(0 22px 28px rgba(17, 17, 17, 0.28));
    }
  }

  /* Navigation arrows */
  .fc-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: absolute;
    top: 50%;
    left: -20px;
    right: -20px;
    transform: translateY(-50%);
    pointer-events: none;
    z-index: 10;
  }

  .fc-arrow {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: #FFFFFF;
    border: 1px solid var(--fc-border);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    pointer-events: auto;
    transition: all 0.2s ease;
    color: #111111;
  }

  .fc-arrow:hover {
    border-color: var(--fc-border-hover);
    background-color: #FAFAFB;
    transform: scale(1.05);
  }

  .fc-arrow:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    transform: none;
  }

  .fc-arrow svg {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.5;
  }

  /* Progress bar */
  .fc-progress-container {
    width: 140px;
    height: 3px;
    background-color: var(--fc-border);
    margin: 30px auto 0 auto;
    border-radius: 1.5px;
    position: relative;
    overflow: hidden;
  }

  .fc-progress-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 33.333%;
    background-color: var(--fc-primary);
    border-radius: 1.5px;
    transition: transform 0.35s cubic-bezier(0.25, 1, 0.5, 1);
  }

  @media (max-width: 991px) {
    .fc-slide {
      flex: 0 0 calc(33.333% - 14px);
      min-width: calc(33.333% - 14px);
    }
    .fc-progress-container {
      width: 100px;
    }
  }

  @media (max-width: 767px) {
    .fc-section {
      padding: 44px 0 52px;
      margin-bottom: 8px;
      background-color: #ffffff;
    }

    .fc-container {
      padding: 0 max(16px, var(--site-padding, 20px));
    }

    .fc-heading {
      line-height: 1.05;
      padding: 0 8px;
      text-align: left;
    }

    .fc-slider-wrapper {
      overflow: hidden;
    }

    .fc-slider-container {
      overflow: hidden;
      scroll-snap-type: none;
      padding-bottom: 0;
    }

    .fc-slider-track {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 14px;
      row-gap: 16px;
      width: 100% !important;
    }

    .fc-slide {
      flex: none;
      min-width: 0;
      width: 100%;
      aspect-ratio: unset;
      min-height: 196px;
      background: #f2f2f4 !important;
      border: none;
      border-radius: var(--homepage-corner, 20px);
      padding: 14px 12px 10px;
      overflow: hidden;
      box-shadow: none;
      scroll-snap-align: unset;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      gap: 8px;
    }

    .fc-slide:hover {
      background: #f2f2f4 !important;
      border-color: transparent;
    }

    .fc-slide:hover .fc-illustration {
      transform: none;
    }

    .fc-category-info {
      max-width: 100%;
      flex: 0 0 auto;
    }

    .fc-category-name {
      font-size: 14px;
      font-weight: 700;
      line-height: 1.25;
      max-width: 100%;
      -webkit-line-clamp: 2;
    }

    .fc-product-count {
      font-size: 12px;
      font-weight: 500;
      color: #666666;
    }

    .fc-illustration {
      position: relative;
      inset: auto;
      top: auto;
      right: auto;
      bottom: auto;
      flex: 1 1 auto;
      width: 100%;
      height: 108px;
      max-height: 108px;
      min-height: 108px;
      margin-top: auto;
      align-items: flex-end;
      justify-content: flex-end;
      overflow: hidden;
    }

    .fc-illustration img,
    .fc-illustration svg {
      width: auto !important;
      height: auto !important;
      max-width: 88%;
      max-height: 100%;
      object-fit: contain;
      object-position: bottom right;
    }

    .fc-nav,
    .fc-progress-container {
      display: none !important;
    }
  }

  @media (max-width: 380px) {
    .fc-slider-track {
      column-gap: 12px;
      row-gap: 14px;
    }

    .fc-slide {
      min-height: 184px;
      padding: 12px 10px 8px;
    }

    .fc-category-name {
      font-size: 13px;
    }

    .fc-illustration {
      height: 96px;
      max-height: 96px;
      min-height: 96px;
    }

    .fc-illustration img,
    .fc-illustration svg {
      max-width: 84%;
    }
  }
{%- endstyle -%}

<section class="fc-section" aria-label="Shop by Function and Category">
  <div class="fc-container">
    <div class="fc-header animate-fade-in section-heading-stack section-heading-stack--center">
      {%- if section.settings.subtitle != blank -%}
        <p class="fc-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
      <h2 class="fc-heading">{{ section.settings.heading | default: 'Shop by Function and Category' }}</h2>
    </div>

    <div class="fc-slider-wrapper">
      <div class="fc-slider-container" id="fc-slider-{{ section.id }}">
        <div class="fc-slider-track" id="fc-track-{{ section.id }}">
          {%- for block in section.blocks -%}
            {%- assign link = block.settings.link | default: '#' -%}
            <a href="{{ link }}" class="fc-slide" {{ block.shopify_attributes }}>
              <div class="fc-category-info">
                <h3 class="fc-category-name">{{ block.settings.title }}</h3>
                <p class="fc-product-count">{{ block.settings.product_count | default: '0 products' }}</p>
              </div>
              <div class="fc-illustration">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title }}" loading="lazy">
                {%- elsif block.settings.svg_code != blank -%}
                  {{ block.settings.svg_code }}
                {%- else -%}
                  <!-- fallback graphic icon -->
                  <svg viewBox="0 0 120 120" width="80" height="80" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="25" y="25" width="70" height="70" rx="12" stroke="currentColor" stroke-width="2"/>
                    <circle cx="60" cy="60" r="15" stroke="currentColor" stroke-width="2"/>
                  </svg>
                {%- endif -%}
              </div>
            </a>
          {%- endfor -%}
        </div>
      </div>

      <div class="fc-nav">
        <button class="fc-arrow fc-arrow--prev" id="fc-prev-{{ section.id }}" aria-label="Previous categories" disabled>
          <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="fc-arrow fc-arrow--next" id="fc-next-{{ section.id }}" aria-label="Next categories">
          <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>

    <div class="fc-progress-container">
      <div class="fc-progress-fill" id="fc-fill-{{ section.id }}"></div>
    </div>
  </div>
</section>

<script>
  (function() {
    function initFc3DTilt(trackEl) {
      if (!trackEl || window.innerWidth <= 767 || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      const slides = trackEl.querySelectorAll('.fc-slide');
      const maxTilt = 14;
      const maxLift = 56;
      const maxScale = 1.22;

      slides.forEach(function(slide) {
        const illustration = slide.querySelector('.fc-illustration');
        if (!illustration || slide.dataset.fcTiltInit === 'true') return;
        slide.dataset.fcTiltInit = 'true';

        function resetIllustration() {
          illustration.style.transform = '';
          slide.classList.remove('fc-slide--hover');
        }

        slide.addEventListener('mouseenter', function() {
          slide.classList.add('fc-slide--hover');
        });

        slide.addEventListener('mousemove', function(e) {
          const rect = slide.getBoundingClientRect();
          const x = (e.clientX - rect.left) / rect.width - 0.5;
          const y = (e.clientY - rect.top) / rect.height - 0.5;
          const rotateY = x * maxTilt * 2;
          const rotateX = -y * maxTilt * 2;

          illustration.style.transform =
            'perspective(900px) rotateX(' + rotateX + 'deg) rotateY(' + rotateY + 'deg) scale(' + maxScale + ') translateZ(' + maxLift + 'px)';
        });

        slide.addEventListener('mouseleave', resetIllustration);
      });
    }

    function initFunctionCategorySlider() {
      const slider = document.getElementById('fc-slider-{{ section.id }}');
      const track = document.getElementById('fc-track-{{ section.id }}');
      const prevBtn = document.getElementById('fc-prev-{{ section.id }}');
      const nextBtn = document.getElementById('fc-next-{{ section.id }}');
      const fill = document.getElementById('fc-fill-{{ section.id }}');
      
      if (!slider || !track || !prevBtn || !nextBtn || !fill) return;

      function isMobileGrid() {
        return window.innerWidth <= 767;
      }

      if (isMobileGrid()) {
        track.style.width = '';
        return;
      }

      let currentIndex = 0;
      let autoplayInterval = null;

      function getVisibleCardsCount() {
        if (window.innerWidth <= 767) return 2;
        if (window.innerWidth <= 991) return 3;
        return 4;
      }

      function getSlideWidth() {
        const slides = track.querySelectorAll('.fc-slide');
        if (slides.length === 0) return 0;
        return slides[0].offsetWidth + 20; // width + gap
      }

      function updateSlider() {
        const slides = track.querySelectorAll('.fc-slide');
        const visible = getVisibleCardsCount();
        const maxSteps = Math.max(0, slides.length - visible);
        
        if (currentIndex < 0) currentIndex = 0;
        if (currentIndex > maxSteps) currentIndex = maxSteps;

        const offset = currentIndex * getSlideWidth();
        slider.scrollTo({ left: offset, behavior: 'smooth' });
      }

      function syncUI() {
        const slides = track.querySelectorAll('.fc-slide');
        if (slides.length === 0) return;
        
        const visible = getVisibleCardsCount();
        const maxSteps = Math.max(0, slides.length - visible);
        const slideWidth = getSlideWidth();
        
        // Calculate current index from scroll position
        const scrollIndex = Math.round(slider.scrollLeft / slideWidth);
        currentIndex = scrollIndex;

        // Update arrow states
        prevBtn.disabled = (currentIndex === 0);
        nextBtn.disabled = (currentIndex >= maxSteps);

        // Update progress bar
        const totalSteps = maxSteps + 1;
        const fillWidth = 100 / totalSteps;
        fill.style.width = `${fillWidth}%`;
        fill.style.transform = `translateX(${currentIndex * 100}%)`;
      }

      function startAutoplay() {
        if (autoplayInterval) clearInterval(autoplayInterval);
        autoplayInterval = setInterval(() => {
          const slides = track.querySelectorAll('.fc-slide');
          const visible = getVisibleCardsCount();
          const maxSteps = Math.max(0, slides.length - visible);
          if (currentIndex >= maxSteps) {
            currentIndex = 0;
          } else {
            currentIndex++;
          }
          updateSlider();
        }, 5000);
      }

      function stopAutoplay() {
        if (autoplayInterval) clearInterval(autoplayInterval);
      }

      slider.addEventListener('mouseenter', stopAutoplay);
      slider.addEventListener('mouseleave', startAutoplay);
      slider.addEventListener('touchstart', stopAutoplay, { passive: true });

      prevBtn.addEventListener('click', () => {
        currentIndex--;
        updateSlider();
        startAutoplay();
      });

      nextBtn.addEventListener('click', () => {
        currentIndex++;
        updateSlider();
        startAutoplay();
      });

      // Sync UI on scroll (for native swipes)
      let scrollTimeout;
      slider.addEventListener('scroll', () => {
        clearTimeout(scrollTimeout);
        scrollTimeout = setTimeout(syncUI, 50);
      }, { passive: true });

      window.addEventListener('resize', function() {
        if (isMobileGrid()) {
          stopAutoplay();
          track.style.width = '';
          track.querySelectorAll('.fc-slide').forEach(function(slide) {
            slide.classList.remove('fc-slide--hover');
            const illustration = slide.querySelector('.fc-illustration');
            if (illustration) illustration.style.transform = '';
          });
          return;
        }
        updateSlider();
        syncUI();
        initFc3DTilt(track);
      });

      // Initial sync
      setTimeout(function() {
        syncUI();
        startAutoplay();
        initFc3DTilt(track);
      }, 100);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFunctionCategorySlider);
    } else {
      initFunctionCategorySlider();
    }
    document.addEventListener('shopify:section:load', initFunctionCategorySlider);
  })();
</script>


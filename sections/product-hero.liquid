{%- style -%}
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap');

:root {
  --d2c-primary: #000000;
  --d2c-secondary: #666666;
  --d2c-bg: #FFFFFF;
  --d2c-light-grey: #F5F5F5;
  --d2c-border: #DDDDDD;
  --d2c-accent: #E53935;
  --d2c-stock-green: #2E7D32;
  --d2c-font: 'Inter', sans-serif;
  --d2c-heading-font: 'Poppins', sans-serif;
  --d2c-radius-sm: 8px;
  --d2c-radius-md: 10px;
  --d2c-radius-lg: 12px;
  --d2c-radius-xl: 16px;
}

.d2c-pdp-section {
  background: var(--d2c-bg);
  padding: 24px 0 64px 0;
  box-sizing: border-box;
}

.d2c-pdp-grid {
  display: grid;
  grid-template-columns: calc(60% - 16px) calc(40% - 16px);
  gap: 32px;
  max-width: 1200px;
  margin: 0 auto;
  padding: 24px;
  font-family: var(--d2c-font);
  box-sizing: border-box;
}

@media screen and (max-width: 991px) {
  .d2c-pdp-grid {
    grid-template-columns: 1fr;
    gap: 32px;
    padding: 16px;
  }
}

/* LEFT COLUMN: MEDIA GALLERY */
.d2c-media-gallery {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.d2c-media-main {
  position: relative;
  background-color: #F7F7F7;
  border-radius: var(--d2c-radius-xl);
  overflow: hidden;
  padding: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  aspect-ratio: 1 / 1;
  border: 1px solid rgba(0, 0, 0, 0.04);
}

.d2c-media-main-img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  border-radius: calc(var(--d2c-radius-xl) - 4px);
  transition: transform 0.3s ease, transform-origin 0.1s ease;
}

@media (min-width: 768px) {
  .d2c-media-main:hover .d2c-media-main-img {
    transform: scale(1.6);
    cursor: zoom-in;
  }
}

.d2c-gallery-nav-btn {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 40px;
  height: 40px;
  background: #FFFFFF;
  border: 1px solid var(--d2c-border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--d2c-primary);
  cursor: pointer;
  z-index: 10;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  transition: all 0.2s ease;
  opacity: 0;
}

.d2c-media-main:hover .d2c-gallery-nav-btn {
  opacity: 1;
}

.d2c-gallery-nav-btn:hover {
  background: var(--d2c-primary);
  color: #FFFFFF;
  border-color: var(--d2c-primary);
}

.d2c-gallery-prev {
  left: 16px;
}

.d2c-gallery-next {
  right: 16px;
}

.d2c-gallery-nav-btn svg {
  width: 20px;
  height: 20px;
}

.d2c-badge-overlay {
  position: absolute;
  top: 16px;
  left: 16px;
  background: var(--d2c-accent);
  color: #FFFFFF;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  padding: 4px 8px;
  border-radius: 6px;
  z-index: 5;
}

.d2c-thumbs-wrapper {
  overflow: hidden;
}

.d2c-thumbs-scroll {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding-bottom: 6px;
  scrollbar-width: thin;
}

.d2c-thumbs-scroll::-webkit-scrollbar {
  height: 4px;
}

.d2c-thumbs-scroll::-webkit-scrollbar-thumb {
  background-color: #DDD;
  border-radius: 4px;
}

.d2c-thumb-item {
  width: 64px;
  height: 64px;
  flex: 0 0 auto;
  border-radius: var(--d2c-radius-sm);
  background-color: #F7F7F7;
  border: 1px solid transparent;
  cursor: pointer;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: border 0.2s ease, transform 0.2s ease;
  padding: 4px;
}

.d2c-thumb-item:hover {
  transform: scale(1.03);
}

.d2c-thumb-item.active {
  border: 2px solid #000000;
}

.d2c-thumb-item img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  border-radius: calc(var(--d2c-radius-sm) - 2px);
}

/* RIGHT COLUMN: PRODUCT INFO */
.d2c-product-info {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.d2c-brand-award-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: -4px;
}

.d2c-brand-text {
  font-family: var(--d2c-heading-font);
  font-size: 32px;
  font-weight: 800;
  color: {{ section.settings.brand_color | default: '#000000' }};
  letter-spacing: -0.5px;
  line-height: 1;
}

.d2c-award-badge {
  background-color: {{ section.settings.award_bg | default: '#FF1E43' }};
  color: {{ section.settings.award_color | default: '#FFFFFF' }};
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  padding: 5px 10px;
  border-radius: 6px;
  letter-spacing: 0.5px;
  display: inline-flex;
  align-items: center;
}

.d2c-product-title {
  font-size: 42px;
  font-weight: 700;
  font-family: var(--d2c-heading-font);
  color: #000000;
  line-height: 1.15;
  margin: 0;
  letter-spacing: -0.5px;
}

@media screen and (max-width: 767px) {
  .d2c-product-title {
    font-size: 32px;
  }
  .d2c-brand-text {
    font-size: 26px;
  }
}

.d2c-rating-badge-row {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  margin-top: -4px;
  margin-bottom: -4px;
}

.d2c-rating-pill {
  background-color: {{ section.settings.rating_pill_bg | default: '#2ECC71' }};
  color: #111111;
  font-weight: 700;
  font-size: 13px;
  padding: 5px 10px;
  border-radius: 6px;
  display: inline-flex;
  align-items: center;
}

.d2c-rating-reviews {
  color: #000000;
  font-weight: 500;
  font-size: 14px;
}

.d2c-subtitle-text {
  font-size: 17px;
  color: #1A1A1A;
  line-height: 1.45;
  font-weight: 500;
  margin-top: 4px;
  margin-bottom: 4px;
}

.d2c-pdp-badge-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin-top: 12px;
  margin-bottom: 12px;
}

.d2c-pdp-badge-item {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #F1F3F5;
  color: #1A1A1A;
  font-size: 13px;
  font-weight: 500;
  padding: 6px 12px;
  border-radius: 8px;
  border: 1px solid transparent;
  transition: all 0.2s ease;
}

.d2c-pdp-badge-item:hover {
  background: #E9ECEF;
  transform: translateY(-1px);
}

.d2c-pdp-badge-emoji {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 16px;
  height: 16px;
}

.d2c-pdp-badge-text {
  line-height: 1.2;
}

/* KEY FEATURES LIST */
.d2c-features-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.d2c-feature-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 14px;
  color: #333333;
  line-height: 1.6;
}

.d2c-feature-icon {
  width: 18px;
  height: 18px;
  color: #000000;
  flex-shrink: 0;
  margin-top: 2px;
}

/* PRICING SECTION */
.d2c-price-wrapper {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.d2c-price-current {
  font-size: 22px;
  font-weight: 700;
  color: var(--d2c-primary);
}

.d2c-price-compare {
  font-size: 14px;
  color: #999999;
  text-decoration: line-through;
  font-weight: 400;
}

.d2c-discount-badge {
  background: var(--d2c-accent);
  color: #FFFFFF;
  font-size: 11px;
  font-weight: 600;
  padding: 4px 8px;
  border-radius: 6px;
  text-transform: uppercase;
}

/* STOCK / URGENCY MESSAGE */
.d2c-stock-message {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: var(--d2c-stock-green);
  font-weight: 500;
}

.d2c-stock-message svg {
  color: var(--d2c-stock-green);
}

/* VARIANT SELECTOR CARDS */
.d2c-variant-picker {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.d2c-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--d2c-primary);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.d2c-variant-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
  gap: 8px;
}

@media screen and (max-width: 480px) {
  .d2c-variant-cards {
    display: flex;
    overflow-x: auto;
    gap: 8px;
    padding-bottom: 4px;
  }
  .d2c-variant-card {
    flex: 0 0 120px;
  }
}

.d2c-variant-card {
  border: 1px solid var(--d2c-border);
  padding: 8px;
  border-radius: var(--d2c-radius-md);
  background: var(--d2c-bg);
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 10px;
  transition: all 0.2s ease;
  user-select: none;
}

.d2c-variant-card:hover {
  background: var(--d2c-light-grey);
  border-color: #AAAAAA;
}

.d2c-variant-card.active {
  border: 2px solid #000000;
}

.d2c-variant-img {
  width: 42px;
  height: 42px;
  border-radius: 6px;
  object-fit: contain;
  background-color: #F7F7F7;
  flex-shrink: 0;
}

.d2c-variant-fallback-img {
  width: 42px;
  height: 42px;
  border-radius: 6px;
  background-color: var(--d2c-light-grey);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #777;
  flex-shrink: 0;
}

.d2c-variant-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--d2c-primary);
  line-height: 1.2;
}

/* PERSONALIZATION BLOCK */
.d2c-personalization {
  background: var(--d2c-light-grey);
  padding: 12px;
  border-radius: var(--d2c-radius-lg);
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.d2c-personalization-toggle {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
}

.d2c-input {
  width: 100%;
  padding: 10px;
  border: 1px solid var(--d2c-border);
  border-radius: var(--d2c-radius-sm);
  font-family: var(--d2c-font);
  font-size: 13px;
  outline: none;
  background: #FFFFFF;
  box-sizing: border-box;
}

.d2c-input:focus {
  border-color: #000000;
}

/* QUANTITY & ADD TO CART */
.d2c-quantity-wrapper {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.d2c-qty-selector {
  display: flex;
  align-items: center;
  width: 120px;
  height: 42px;
  border: 1px solid var(--d2c-border);
  border-radius: var(--d2c-radius-sm);
  overflow: hidden;
  background: var(--d2c-bg);
}

.d2c-qty-btn {
  width: 40px;
  height: 100%;
  background: none;
  border: none;
  font-size: 16px;
  color: var(--d2c-primary);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  user-select: none;
  transition: background 0.15s;
}

.d2c-qty-btn:hover {
  background: var(--d2c-light-grey);
}

.d2c-qty-number {
  flex: 1;
  text-align: center;
  font-size: 14px;
  font-weight: 600;
  color: var(--d2c-primary);
}

.d2c-atc-btn {
  width: 100%;
  height: 50px;
  background: var(--d2c-primary);
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 600;
  border: none;
  border-radius: var(--d2c-radius-md);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s ease, transform 0.2s ease;
  user-select: none;
}

.d2c-atc-btn:hover {
  opacity: 0.9;
  transform: translateY(-1px);
}

/* TRUST BADGES ROW */
.d2c-trust-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  border-top: 1px solid #EEEEEE;
  border-bottom: 1px solid #EEEEEE;
  padding: 16px 0;
}

@media screen and (max-width: 600px) {
  .d2c-trust-row {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px 8px;
  }
}

.d2c-trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 10px;
}

.d2c-trust-icon {
  width: 32px;
  height: 32px;
  color: #E02020;
}

.d2c-trust-text {
  font-size: 15px;
  color: #E02020;
  font-weight: 700;
  line-height: 1.3;
}

/* ACCORDIONS SECTION */
.d2c-accordions {
  display: flex;
  flex-direction: column;
}

.d2c-accordion-item {
  border-bottom: 1px solid #EEEEEE;
}

.d2c-accordion-toggle {
  width: 100%;
  height: 50px;
  background: none;
  border: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-align: left;
  font-size: 14px;
  font-weight: 600;
  color: var(--d2c-primary);
  cursor: pointer;
  padding: 0;
  transition: color 0.15s ease;
}

.d2c-accordion-toggle:hover {
  color: var(--d2c-secondary);
}

.d2c-accordion-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s cubic-bezier(0, 1, 0, 1);
  font-size: 14px;
  color: var(--d2c-secondary);
  line-height: 1.6;
}

.d2c-accordion-content-inner {
  padding-bottom: 16px;
}

/* FLOATING STICKY Add to Cart Bar */
.d2c-floating-sticky-atc {
  position: fixed;
  bottom: 24px;
  right: 24px;
  left: auto;
  transform: translateY(150px);
  width: calc(100% - 48px);
  max-width: 600px;
  background: #ffffff;
  border-radius: 20px;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
  border: 1px solid rgba(0, 0, 0, 0.05);
  z-index: 999;
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  opacity: 0;
  box-sizing: border-box;
}

.d2c-floating-sticky-atc.visible {
  transform: translateY(0);
  opacity: 1;
}

.d2c-floating-sticky-atc__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 24px;
  gap: 16px;
}

.d2c-floating-sticky-atc__left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 2px;
}

.d2c-floating-compare-price {
  font-size: 15px;
  color: #a1a1a1;
  text-decoration: line-through;
  font-weight: 600;
  letter-spacing: -0.01em;
  text-transform: uppercase;
}

.d2c-floating-price-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.d2c-floating-price {
  font-size: 24px;
  font-weight: 800;
  color: #000000;
  letter-spacing: -0.02em;
  line-height: 1.1;
  text-transform: uppercase;
}

.d2c-floating-discount {
  background-color: #00E676;
  color: #000000;
  font-size: 13px;
  font-weight: 700;
  padding: 4px 8px;
  border-radius: 6px;
  letter-spacing: -0.01em;
  text-transform: uppercase;
}

.d2c-floating-variant-select {
  padding: 8px 12px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
  background-color: #fafafa;
  color: #111;
  outline: none;
  cursor: pointer;
  max-width: 180px;
}

.d2c-floating-atc-btn {
  background-color: #000000;
  color: #ffffff;
  border: none;
  border-radius: 12px;
  padding: 12px 28px;
  font-size: 16px;
  font-weight: 700;
  cursor: pointer;
  transition: opacity 0.2s, background-color 0.2s;
  white-space: nowrap;
}

.d2c-floating-atc-btn:hover {
  background-color: #222222;
}

.d2c-floating-atc-btn:disabled {
  background-color: #ccc;
  cursor: not-allowed;
}

@media screen and (max-width: 600px) {
  .d2c-floating-sticky-atc {
    bottom: 12px;
    width: calc(100% - 24px);
    border-radius: 16px;
  }
  .d2c-floating-sticky-atc__inner {
    padding: 10px 14px;
    gap: 8px;
  }
  .d2c-floating-price {
    font-size: 18px;
  }
  .d2c-floating-atc-btn {
    padding: 10px 16px;
    font-size: 14px;
    border-radius: 8px;
  }
  .d2c-floating-variant-select {
    display: none;
  }
}
{%- endstyle -%}

{%- assign main_product = section.settings.product | default: product -%}
{%- assign product = main_product -%}

<div class="d2c-pdp-section" aria-label="Modern Product Layout Section">
  <div class="d2c-pdp-grid">
    <!-- LEFT COLUMN: Product media gallery -->
    <div class="d2c-media-gallery">
      <div class="d2c-media-main">
        {%- if product.images.size > 1 -%}
          <button type="button" class="d2c-gallery-nav-btn d2c-gallery-prev" id="PrevGalleryBtn" aria-label="Previous image">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
        {%- endif -%}

        {%- if product.featured_image != blank -%}
          <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }}" id="MainProductImage" class="d2c-media-main-img" loading="eager">
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'd2c-media-main-img' }}
        {%- endif -%}

        {%- if product.images.size > 1 -%}
          <button type="button" class="d2c-gallery-nav-btn d2c-gallery-next" id="NextGalleryBtn" aria-label="Next image">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>
        {%- endif -%}

        {%- if product.compare_at_price > product.price -%}
          <span class="d2c-badge-overlay">SALE</span>
        {%- endif -%}
      </div>

      <!-- Thumbnail Slider -->
      {%- if product.images.size > 1 -%}
        <div class="d2c-thumbs-wrapper">
          <div class="d2c-thumbs-scroll">
            {%- for image in product.images -%}
              <div class="d2c-thumb-item{% if forloop.first %} active{% endif %}" data-src="{{ image | image_url: width: 1200 }}">
                <img src="{{ image | image_url: width: 120 }}" alt="{{ product.title | escape }}" loading="lazy">
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>

    <!-- RIGHT COLUMN: Product information -->
    <div class="d2c-product-info">
      <!-- Tag / Category Label -->
      <div class="d2c-brand-award-row">
        {%- if section.settings.award_text != blank -%}
          <span class="d2c-award-badge">{{ section.settings.award_text }}</span>
        {%- endif -%}
      </div>

      <!-- Title -->
      {%- if product.title contains "Cleaning Kit" -%}
        {%- assign parts = product.title | split: "Cleaning Kit" -%}
        <h1 class="d2c-product-title">
          <span style="color: #000000; font-weight: 700;">{{ parts[0] }}</span><span style="color: #888888; font-weight: 400;">Cleaning Kit</span>{%- if parts[1] != blank -%}<span style="color: #000000; font-weight: 700;">{{ parts[1] }}</span>{%- endif -%}
        </h1>
      {%- elsif product.title contains "cleaning kit" -%}
        {%- assign parts = product.title | split: "cleaning kit" -%}
        <h1 class="d2c-product-title">
          <span style="color: #000000; font-weight: 700;">{{ parts[0] }}</span><span style="color: #888888; font-weight: 400;">cleaning kit</span>{%- if parts[1] != blank -%}<span style="color: #000000; font-weight: 700;">{{ parts[1] }}</span>{%- endif -%}
        </h1>
      {%- else -%}
        <h1 class="d2c-product-title" style="color: #000000; font-weight: 700;">{{ product.title }}</h1>
      {%- endif -%}

      <!-- Rating / Review Pill Row -->
      <div class="d2c-rating-badge-row">
        <span class="d2c-rating-pill">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" style="margin-right: 4px; margin-top: -2px;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          {{ section.settings.rating_value | default: "4.9" }}
        </span>
        <span class="d2c-rating-reviews">({{ section.settings.rating_reviews | default: "201" }})</span>
      </div>

      <!-- Short Description / Subtitle -->
      {%- if section.settings.subtitle_text != blank -%}
        <div class="d2c-subtitle-text">{{ section.settings.subtitle_text }}</div>
      {%- elsif product.description != blank -%}
        <div class="d2c-subtitle-text">{{ product.description | strip_html | truncatewords: 25 }}</div>
      {%- endif -%}

      <!-- Feature Highlight Badges -->
      <div class="d2c-pdp-badge-list">
        {%- if section.settings.pill_1_text != blank -%}
          <div class="d2c-pdp-badge-item">
            <span class="d2c-pdp-badge-emoji">
              {%- if section.settings.pill_1_icon != blank -%}
                <img src="{{ section.settings.pill_1_icon | image_url: width: 32, height: 32 }}" alt="{{ section.settings.pill_1_text | escape }}" style="width: 16px; height: 16px; object-fit: contain;">
              {%- else -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              {%- endif -%}
            </span>
            <span class="d2c-pdp-badge-text">{{ section.settings.pill_1_text }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.pill_2_text != blank -%}
          <div class="d2c-pdp-badge-item">
            <span class="d2c-pdp-badge-emoji">
              {%- if section.settings.pill_2_icon != blank -%}
                <img src="{{ section.settings.pill_2_icon | image_url: width: 32, height: 32 }}" alt="{{ section.settings.pill_2_text | escape }}" style="width: 16px; height: 16px; object-fit: contain;">
              {%- else -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3 1.912 3.874 4.276.622-3.094 3.016.73 4.258L12 14.75l-3.824 2.02.73-4.258-3.094-3.016 4.276-.622z"></path></svg>
              {%- endif -%}
            </span>
            <span class="d2c-pdp-badge-text">{{ section.settings.pill_2_text }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.pill_3_text != blank -%}
          <div class="d2c-pdp-badge-item">
            <span class="d2c-pdp-badge-emoji">
              {%- if section.settings.pill_3_icon != blank -%}
                <img src="{{ section.settings.pill_3_icon | image_url: width: 32, height: 32 }}" alt="{{ section.settings.pill_3_text | escape }}" style="width: 16px; height: 16px; object-fit: contain;">
              {%- else -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
              {%- endif -%}
            </span>
            <span class="d2c-pdp-badge-text">{{ section.settings.pill_3_text }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.pill_4_text != blank -%}
          <div class="d2c-pdp-badge-item">
            <span class="d2c-pdp-badge-emoji">
              {%- if section.settings.pill_4_icon != blank -%}
                <img src="{{ section.settings.pill_4_icon | image_url: width: 32, height: 32 }}" alt="{{ section.settings.pill_4_text | escape }}" style="width: 16px; height: 16px; object-fit: contain;">
              {%- else -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.5 21 3c-1.5 4-2 5.5-3.1 11.2A7 7 0 0 1 11 20z"></path><path d="M11 20v-5"></path></svg>
              {%- endif -%}
            </span>
            <span class="d2c-pdp-badge-text">{{ section.settings.pill_4_text }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.pill_5_text != blank -%}
          <div class="d2c-pdp-badge-item">
            <span class="d2c-pdp-badge-emoji">
              {%- if section.settings.pill_5_icon != blank -%}
                <img src="{{ section.settings.pill_5_icon | image_url: width: 32, height: 32 }}" alt="{{ section.settings.pill_5_text | escape }}" style="width: 16px; height: 16px; object-fit: contain;">
              {%- else -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
              {%- endif -%}
            </span>
            <span class="d2c-pdp-badge-text">{{ section.settings.pill_5_text }}</span>
          </div>
        {%- endif -%}
      </div>

      <!-- Pricing & Quantity Wrapper -->
      <div class="d2c-pricing-qty-wrapper" style="display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: flex-start; margin-top: 16px; margin-bottom: 16px;">
        <!-- Left: Price Info -->
        <div class="d2c-price-box">
          <div style="display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap;">
            <span class="d2c-price-current" id="D2CPriceCurrent" style="font-size: 32px; font-weight: 800; color: #000000; font-family: var(--d2c-heading-font);">{{ product.price | money }}</span>
            {%- if product.compare_at_price > product.price -%}
              <span class="d2c-price-compare" id="D2CPriceCompare" style="font-size: 18px; color: #B8B8B8; text-decoration: line-through; font-weight: 400; font-family: var(--d2c-heading-font);">{{ product.compare_at_price | money }}</span>
            {%- else -%}
              <span class="d2c-price-compare" id="D2CPriceCompare" style="display: none;"></span>
            {%- endif -%}
            <span id="D2CDiscountBadge" style="display: none;"></span>
          </div>
          <div style="font-size: 14px; color: #999999; margin-top: 6px; font-weight: 500;">MRP incl. of all taxes</div>
        </div>

        <!-- Right: Quantity selector -->
        <div class="d2c-quantity-box" style="display: flex; flex-direction: column; align-items: flex-end;">
          <label class="d2c-label" style="font-size: 14px; font-weight: 700; color: #000000; margin-bottom: 6px; text-transform: none; letter-spacing: 0;">Quantity</label>
          <div class="d2c-qty-selector" style="width: 140px; height: 44px; border: 1.5px solid #000000; border-radius: 12px; display: flex; align-items: center; overflow: hidden; background: #FFFFFF;">
            <button type="button" class="d2c-qty-btn" id="Qty-Decrement" style="width: 44px; height: 100%; border: none; background: none; font-size: 18px; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; user-select: none;">−</button>
            <div class="d2c-qty-number" id="Qty-Number" style="flex: 1; text-align: center; font-size: 16px; font-weight: 700; color: #000000;">1</div>
            <button type="button" class="d2c-qty-btn" id="Qty-Increment" style="width: 44px; height: 100%; border: none; background: none; font-size: 18px; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; user-select: none;">+</button>
          </div>
        </div>
      </div>

      <!-- Below: Snapmint / Nuuk EMI Banner -->
      <div class="d2c-emi-banner" style="background-color: #F1F1F1; border-radius: 8px; padding: 14px 16px; display: flex; align-items: center; justify-content: space-between; position: relative; margin-top: 12px; margin-bottom: 20px; border: 1px solid #E5E5E5;">
        <!-- Green New Tag -->
        <span style="background-color: #2D9652; color: #FFFFFF; font-size: 9px; font-weight: 700; padding: 3px 8px; border-radius: 3px; position: absolute; top: -11px; left: 16px; text-transform: uppercase; letter-spacing: 0.5px;">NEW</span>
        
        <!-- EMI Details Left -->
        <div style="display: flex; flex-direction: column; gap: 4px;">
          <div style="font-size: 16px; color: #111111; font-weight: 500; display: flex; align-items: center; gap: 6px; flex-wrap: wrap;">
            <span>or</span>
            <span style="background-color: #2D9652; color: #FFFFFF; font-weight: 700; padding: 2px 8px; border-radius: 4px; font-family: var(--d2c-font);">
              {%- assign emi_val = product.price | divided_by: 3 -%}
              {{ emi_val | money }}
            </span>
            <span>/month (3 months)</span>
          </div>
          <div style="font-size: 13px; color: #444444; margin-top: 2px;">
            <span style="font-weight: 700;">0% EMI</span> on <span style="font-style: italic;">UPI</span> via <span style="color: #E53935; font-weight: 800;">HAGUEPROTECT</span> PAYLATER
          </div>
        </div>

        <!-- Buy on EMI Button Right -->
        <button type="button" style="background: #E53935; background: linear-gradient(135deg, #FF3D3D 0%, #E53935 100%); color: #FFFFFF; border: none; border-radius: 8px; padding: 10px 18px; font-weight: 700; font-size: 11px; text-transform: uppercase; cursor: pointer; text-align: center; line-height: 1.3; box-shadow: 0 3px 8px rgba(229, 57, 53, 0.3); transition: all 0.2s ease;">
          BUY ON EMI<br><span style="font-size: 8px; font-weight: normal; text-transform: none; opacity: 0.9;">By snapmint</span>
        </button>
      </div>

      <!-- Stock / Urgency Message -->
      <div class="d2c-stock-message">
        {%- if product.available -%}
          <svg width="8" height="8" viewBox="0 0 8 8" fill="none"><circle cx="4" cy="4" r="4" fill="currentColor"></circle></svg>
          <span>In stock and ready to ship</span>
        {%- else -%}
          <svg width="8" height="8" viewBox="0 0 8 8" fill="none"><circle cx="4" cy="4" r="4" fill="#D32F2F"></circle></svg>
          <span style="color: #D32F2F;">Out of Stock</span>
        {%- endif -%}
      </div>

      <!-- Form for Quantity & ATC -->
      {%- form 'product', product, id: 'AddToCartForm-modern-pdp' -%}
        <input type="hidden" name="id" id="VariantSelector-Input" value="{{ product.selected_or_first_available_variant.id }}">
        <input type="hidden" name="quantity" id="QuantitySelector-Input" value="1">

        <div style="display: flex; flex-direction: column; gap: 20px;">

          <!-- Optional Personalization Block -->
          <div class="d2c-personalization">
            <label class="d2c-personalization-toggle">
              <input type="checkbox" id="TogglePersonalization" onchange="togglePersonalizationInput()">
              <span>Add custom note or personalization</span>
            </label>
            <div class="d2c-personalization-input-wrapper" id="PersonalizationWrapper" style="display: none;">
              <input type="text" id="CustomPersonalizationInput" name="properties[Personalization]" placeholder="Enter your text here..." class="d2c-input">
            </div>
          </div>



          <!-- Add to Cart Button -->
          <button type="submit" name="add" id="AddToCartBtn-Submit" class="d2c-atc-btn" {% unless product.available %}disabled{% endunless %}>
            {%- if product.available -%}
              Add to Cart
            {%- else -%}
              Sold Out
            {%- endif -%}
          </button>
        </div>
      {%- endform -%}

      <!-- Trust Badges Row -->
      <div class="d2c-trust-row">
        <div class="d2c-trust-item">
          <svg class="d2c-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 14 4-4M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Z"/></svg>
          <span class="d2c-trust-text">Eco Friendly</span>
        </div>
        <div class="d2c-trust-item">
          <svg class="d2c-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span class="d2c-trust-text">Certified Care</span>
        </div>
        <div class="d2c-trust-item">
          <svg class="d2c-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          <span class="d2c-trust-text">Material Safe</span>
        </div>
        <div class="d2c-trust-item">
          <svg class="d2c-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22v-6m0-4V2m-7.5 5.5v11a2.5 2.5 0 0 0 2.5 2.5h10a2.5 2.5 0 0 0 2.5-2.5v-11"/></svg>
          <span class="d2c-trust-text">Tested Efficacy</span>
        </div>
      </div>

      <!-- Accordions -->
      <div class="d2c-accordions">
        <div class="d2c-accordion-item">
          <button type="button" class="d2c-accordion-toggle">
            <span>Product Details</span>
            <span class="d2c-accordion-icon">+</span>
          </button>
          <div class="d2c-accordion-content">
            <div class="d2c-accordion-content-inner">
              <p>{{ product.description | default: "Premium performance product designed and developed for discerning enthusiasts looking to keep their personal items at their absolute best." }}</p>
            </div>
          </div>
        </div>

        <div class="d2c-accordion-item">
          <button type="button" class="d2c-accordion-toggle">
            <span>Technical Specifications</span>
            <span class="d2c-accordion-icon">+</span>
          </button>
          <div class="d2c-accordion-content">
            <div class="d2c-accordion-content-inner">
              <p>Specifically engineered with precise viscosity for effortless coverage and long-lasting efficacy. Completely non-toxic and ph-neutral formula.</p>
            </div>
          </div>
        </div>

        <div class="d2c-accordion-item">
          <button type="button" class="d2c-accordion-toggle">
            <span>Materials & Care</span>
            <span class="d2c-accordion-icon">+</span>
          </button>
          <div class="d2c-accordion-content">
            <div class="d2c-accordion-content-inner">
              <p>Safe for use on all premium materials including soft leathers, woven knits, suedes, canvases, and rubber surfaces. Store safely in a dry place.</p>
            </div>
          </div>
        </div>

        <div class="d2c-accordion-item">
          <button type="button" class="d2c-accordion-toggle">
            <span>In the Box</span>
            <span class="d2c-accordion-icon">+</span>
          </button>
          <div class="d2c-accordion-content">
            <div class="d2c-accordion-content-inner">
              <p>1x Concentrated formula solution, 1x Ergonomic cleaning applicator, 1x Premium microfiber towel, 1x Care instruction guide.</p>
            </div>
          </div>
        </div>

        <div class="d2c-accordion-item">
          <button type="button" class="d2c-accordion-toggle">
            <span>Additional Details</span>
            <span class="d2c-accordion-icon">+</span>
          </button>
          <div class="d2c-accordion-content">
            <div class="d2c-accordion-content-inner">
              <p>Fast processing on every order. Hassle-free dynamic returns and full satisfaction guarantee.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Floating Sticky ATC Bar -->
<div class="d2c-floating-sticky-atc" id="FloatingStickyAtc">
  <div class="d2c-floating-sticky-atc__inner">
    <div class="d2c-floating-sticky-atc__left">
      {%- if product.compare_at_price > product.price -%}
        <div class="d2c-floating-compare-price">{{ product.compare_at_price | money }}</div>
      {%- endif -%}
      <div class="d2c-floating-price-row">
        <div class="d2c-floating-price">{{ product.price | money }}</div>
        {%- if product.compare_at_price > product.price -%}
          {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
          <div class="d2c-floating-discount">{{ discount }}% OFF</div>
        {%- endif -%}
      </div>
    </div>

    {%- if product.has_only_default_variant == false -%}
      <div class="d2c-floating-sticky-atc__center">
        <select id="FloatingStickyAtcVariantSelector" class="d2c-floating-variant-select">
          {%- for variant in product.variants -%}
            <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>
              {{ variant.title | escape }}
            </option>
          {%- endfor -%}
        </select>
      </div>
    {%- endif -%}

    <div class="d2c-floating-sticky-atc__right">
      <button type="button" class="d2c-floating-atc-btn" id="FloatingStickyAtcSubmit" {% unless product.available %}disabled{% endunless %}>
        {%- if product.available -%}
          Add to Cart
        {%- else -%}
          Sold Out
        {%- endif -%}
      </button>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Main Image Mouse Zoom
  const mainImgContainer = document.querySelector('.d2c-media-main');
  const mainImg = document.querySelector('#MainProductImage');
  if (mainImgContainer && mainImg) {
    mainImgContainer.addEventListener('mousemove', function(e) {
      if (window.innerWidth >= 768) {
        const rect = this.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        mainImg.style.transformOrigin = `${x}% ${y}%`;
      }
    });
    mainImgContainer.addEventListener('mouseleave', function() {
      mainImg.style.transformOrigin = 'center center';
    });
  }

  // Thumbnail Clicking
  const thumbs = document.querySelectorAll('.d2c-thumb-item');
  const prevBtn = document.querySelector('#PrevGalleryBtn');
  const nextBtn = document.querySelector('#NextGalleryBtn');

  thumbs.forEach((thumb, idx) => {
    thumb.addEventListener('click', function() {
      thumbs.forEach(t => t.classList.remove('active'));
      this.classList.add('active');
      if (mainImg) {
        mainImg.src = this.getAttribute('data-src');
      }
    });
  });

  // Next and Previous Gallery Buttons
  if (thumbs.length > 1 && prevBtn && nextBtn) {
    let activeIndex = 0;

    thumbs.forEach((thumb, idx) => {
      thumb.addEventListener('click', function() {
        activeIndex = idx;
      });
    });

    prevBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      activeIndex = (activeIndex - 1 + thumbs.length) % thumbs.length;
      thumbs[activeIndex].click();
      thumbs[activeIndex].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    });

    nextBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      activeIndex = (activeIndex + 1) % thumbs.length;
      thumbs[activeIndex].click();
      thumbs[activeIndex].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    });
  }

  // Quantity Stepper UI
  let quantity = 1;
  const qtyNumber = document.querySelector('#Qty-Number');
  const qtyInput = document.querySelector('#QuantitySelector-Input');
  const qtyIncrement = document.querySelector('#Qty-Increment');
  const qtyDecrement = document.querySelector('#Qty-Decrement');

  if (qtyIncrement && qtyDecrement && qtyNumber && qtyInput) {
    qtyIncrement.addEventListener('click', function() {
      quantity++;
      qtyNumber.innerText = quantity;
      qtyInput.value = quantity;
    });

    qtyDecrement.addEventListener('click', function() {
      if (quantity > 1) {
        quantity--;
        qtyNumber.innerText = quantity;
        qtyInput.value = quantity;
      }
    });
  }

  // Variant Switcher
  const variantInput = document.querySelector('#VariantSelector-Input');
  const priceCurrent = document.querySelector('#D2CPriceCurrent');
  const priceCompare = document.querySelector('#D2CPriceCompare');
  const discountBadge = document.querySelector('#D2CDiscountBadge');
  const stickyPrice = document.querySelector('#D2CStickyPriceCurrent');
  const submitBtn = document.querySelector('#AddToCartBtn-Submit');
  const stickyBtn = document.querySelector('#MobileStickyAtcBtn');

  document.querySelectorAll('.d2c-variant-card').forEach(card => {
    card.addEventListener('click', function() {
      document.querySelectorAll('.d2c-variant-card').forEach(c => c.classList.remove('active'));
      this.classList.add('active');

      const variantId = this.getAttribute('data-variant-id');
      const variantPrice = this.getAttribute('data-price');
      const variantCompare = this.getAttribute('data-compare-price');
      const available = this.getAttribute('data-available') === 'true';

      if (variantInput) variantInput.value = variantId;
      if (priceCurrent) priceCurrent.innerText = variantPrice;
      if (stickyPrice) stickyPrice.innerText = variantPrice;

      if (variantCompare && priceCompare && discountBadge) {
        priceCompare.innerText = variantCompare;
        priceCompare.style.display = 'inline';
        discountBadge.style.display = 'inline';
      } else if (priceCompare && discountBadge) {
        priceCompare.style.display = 'none';
        discountBadge.style.display = 'none';
      }

      if (available) {
        if (submitBtn) {
          submitBtn.removeAttribute('disabled');
          submitBtn.innerText = 'Add to Cart';
        }
        if (stickyBtn) {
          stickyBtn.removeAttribute('disabled');
          stickyBtn.innerText = 'Add to Cart';
        }
      } else {
        if (submitBtn) {
          submitBtn.setAttribute('disabled', 'disabled');
          submitBtn.innerText = 'Sold Out';
        }
        if (stickyBtn) {
          stickyBtn.setAttribute('disabled', 'disabled');
          stickyBtn.innerText = 'Sold Out';
        }
      }
    });
  });

  // Accordions Toggle
  document.querySelectorAll('.d2c-accordion-toggle').forEach(btn => {
    btn.addEventListener('click', function() {
      const parent = this.parentElement;
      const content = parent.querySelector('.d2c-accordion-content');
      const icon = this.querySelector('.d2c-accordion-icon');
      const isActive = parent.classList.contains('active');

      document.querySelectorAll('.d2c-accordion-item').forEach(item => {
        item.classList.remove('active');
        item.querySelector('.d2c-accordion-content').style.maxHeight = null;
        item.querySelector('.d2c-accordion-icon').innerText = '+';
      });

      if (!isActive) {
        parent.classList.add('active');
        content.style.maxHeight = content.scrollHeight + 'px';
        icon.innerText = '−';
      } else {
        parent.classList.remove('active');
        content.style.maxHeight = null;
        icon.innerText = '+';
      }
    });
  });

  // Floating Sticky ATC Click & Visibility
  const floatingStickyAtc = document.getElementById('FloatingStickyAtc');
  if (floatingStickyAtc) {
    window.addEventListener('scroll', function() {
      if (window.scrollY > 400) {
        floatingStickyAtc.classList.add('visible');
      } else {
        floatingStickyAtc.classList.remove('visible');
      }
    });

    const atcSubmitBtn = document.getElementById('FloatingStickyAtcSubmit');
    if (atcSubmitBtn && submitBtn) {
      atcSubmitBtn.addEventListener('click', function() {
        const stickyVariantSelect = document.getElementById('FloatingStickyAtcVariantSelector');
        if (stickyVariantSelect) {
          const mainFormVariantInput = document.querySelector('input[name="id"]');
          if (mainFormVariantInput) {
            mainFormVariantInput.value = stickyVariantSelect.value;
          }
        }
        submitBtn.click();
      });
    }
  }
});

function togglePersonalizationInput() {
  const checkbox = document.getElementById('TogglePersonalization');
  const wrapper = document.getElementById('PersonalizationWrapper');
  const input = document.getElementById('CustomPersonalizationInput');
  if (checkbox.checked) {
    wrapper.style.display = 'block';
    input.focus();
  } else {
    wrapper.style.display = 'none';
    input.value = '';
  }
}
</script>


{%- style -%}
  {% render 'section-typography-vars', section: section %}



:root {
  --d2c-primary: #000000;
  --d2c-secondary: #666666;
  --d2c-bg: #FFFFFF;
  --d2c-light-grey: #F5F5F5;
  --d2c-border: #DDDDDD;
  --d2c-accent: #E53935;
  --d2c-stock-green: #2E7D32;
  --d2c-font: 'Inter', sans-serif;
  --d2c-heading-font: 'Inter', sans-serif;
  --d2c-radius-sm: 8px;
  --d2c-radius-md: 10px;
  --d2c-radius-lg: 12px;
  --d2c-radius-xl: 16px;
}

.d2c-pdp-section {
  background: var(--d2c-bg);
  padding: 24px 0 64px 0;
  box-sizing: border-box;
}

.d2c-pdp-grid {
  display: grid;
  grid-template-columns: calc(60% - 16px) calc(40% - 16px);
  gap: 32px;
  max-width: var(--site-max-width);
  margin: 0 auto;
  padding: 24px;
  font-family: var(--d2c-font);
  box-sizing: border-box;
  width: 100%;
}

.d2c-product-info {
  min-width: 0;
}

@media screen and (max-width: 991px) {
  .d2c-pdp-grid {
    grid-template-columns: 1fr;
    gap: 24px;
    padding: 16px;
  }
}

@media screen and (max-width: 767px) {
  .d2c-pdp-section {
    padding: 12px 0 100px 0;
    overflow-x: hidden;
    width: 100%;
    max-width: 100vw;
  }

  .d2c-pdp-grid,
  .d2c-media-gallery,
  .d2c-product-info {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
  }

  .d2c-pdp-grid {
    padding: 12px 16px;
    gap: 20px;
  }

  .d2c-media-main {
    width: 100%;
    max-width: 100%;
    padding: 12px;
  }

  .d2c-media-main-img {
    width: 100%;
    max-width: 100%;
    height: auto;
  }

  .d2c-thumbs-wrapper {
    width: 100%;
    max-width: 100%;
  }

  .d2c-brand-award-row {
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 4px !important;
    width: 100%;
  }

  .d2c-handwriting-label {
    font-size: clamp(22px, 6vw, 28px) !important;
    line-height: 1.2 !important;
    max-width: 100%;
    word-break: break-word;
  }

  .d2c-award-badge {
    flex-shrink: 0;
  }

  .d2c-product-title {
    font-size: clamp(20px, 5.5vw, 28px) !important;
    font-family: 'Bebas Neue', 'Impact', 'Arial Narrow', sans-serif !important;
    font-weight: 900 !important;
    line-height: 1.3 !important;
    padding: 4px 0 !important;
    max-width: 100%;
    overflow-wrap: break-word;
    word-wrap: break-word;
    letter-spacing: -0.03em !important;
    -webkit-font-smoothing: antialiased;
  }

  .d2c-product-title span {
    display: inline;
    font-family: inherit !important;
    font-weight: inherit !important;
  }

  .d2c-subtitle-text {
    max-width: 100%;
    overflow-wrap: break-word;
  }

  .d2c-pdp-badge-list {
    grid-template-columns: 1fr;
    gap: 8px;
    width: 100%;
  }

  .d2c-pdp-badge-item {
    min-width: 0;
    width: 100%;
    box-sizing: border-box;
  }

  .d2c-pdp-badge-text {
    overflow-wrap: break-word;
    word-break: break-word;
    flex: 1;
    min-width: 0;
  }

  .d2c-pricing-qty-wrapper {
    display: flex !important;
    flex-direction: column !important;
    gap: 16px !important;
    width: 100% !important;
    margin-top: 12px !important;
    margin-bottom: 12px !important;
  }

  .d2c-price-box,
  .d2c-quantity-box {
    width: 100% !important;
    max-width: 100% !important;
  }

  .d2c-quantity-box {
    align-items: flex-start !important;
  }

  .d2c-qty-selector {
    width: 100% !important;
    max-width: 200px;
  }

  .d2c-price-current {
    font-size: clamp(22px, 6vw, 28px) !important;
  }

  .d2c-personalization,
  .d2c-personalization-toggle {
    max-width: 100%;
    overflow-wrap: break-word;
  }

  .d2c-atc-btn,
  .d2c-buy-now-wrapper,
  .d2c-buy-now-wrapper .shopify-payment-button,
  .d2c-buy-now-wrapper .shopify-payment-button__button {
    width: 100% !important;
    max-width: 100% !important;
    box-sizing: border-box !important;
  }

  .d2c-trust-row {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px 8px;
    width: 100%;
  }

  .d2c-trust-text {
    font-size: 12px;
    word-break: break-word;
  }

  .d2c-accordion-toggle {
    padding-right: 4px;
    font-size: 13px;
  }

  .d2c-variant-cards {
    display: flex !important;
    overflow-x: auto !important;
    scroll-snap-type: x mandatory !important;
    gap: 10px !important;
    scrollbar-width: none !important;
    padding-bottom: 8px !important;
    width: 100%;
    max-width: 100%;
  }

  .d2c-variant-cards::-webkit-scrollbar {
    display: none;
  }

  .d2c-variant-card {
    flex: 0 0 130px !important;
    scroll-snap-align: start !important;
  }

  .d2c-floating-sticky-atc {
    left: 12px;
    right: 12px;
    width: auto;
    max-width: none;
    bottom: 12px;
  }

  .d2c-floating-sticky-atc__inner {
    flex-wrap: wrap;
    padding: 10px 12px;
    gap: 10px;
  }

  .d2c-floating-sticky-atc__left {
    flex: 1 1 auto;
    min-width: 0;
  }

  .d2c-floating-price {
    font-size: clamp(16px, 4.5vw, 20px);
    word-break: break-word;
  }

  .d2c-floating-atc-btn {
    flex: 1 1 100%;
    width: 100%;
    max-width: 100%;
    text-align: center;
    white-space: normal;
    padding: 12px 16px;
  }
}

/* LEFT COLUMN: MEDIA GALLERY */
.d2c-media-gallery {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.d2c-media-main {
  position: relative;
  background-color: #F7F7F7;
  border-radius: var(--d2c-radius-xl);
  overflow: hidden;
  padding: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  aspect-ratio: 1 / 1;
  border: 1px solid rgba(0, 0, 0, 0.04);
}

.d2c-media-main-img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  border-radius: calc(var(--d2c-radius-xl) - 4px);
  transition: transform 0.3s ease, transform-origin 0.1s ease;
}

@media (min-width: 768px) {
  .d2c-media-main:hover .d2c-media-main-img {
    transform: scale(1.6);
    cursor: zoom-in;
  }
}

.d2c-gallery-nav-btn {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 40px;
  height: 40px;
  background: #FFFFFF;
  border: 1px solid var(--d2c-border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--d2c-primary);
  cursor: pointer;
  z-index: 10;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  transition: all 0.2s ease;
  opacity: 0;
}

.d2c-media-main:hover .d2c-gallery-nav-btn {
  opacity: 1;
}

.d2c-gallery-nav-btn:hover {
  background: var(--d2c-primary);
  color: #FFFFFF;
  border-color: var(--d2c-primary);
}

.d2c-gallery-prev {
  left: 16px;
}

.d2c-gallery-next {
  right: 16px;
}

.d2c-gallery-nav-btn svg {
  width: 20px;
  height: 20px;
}

.d2c-badge-overlay {
  position: absolute;
  top: 16px;
  left: 16px;
  background: var(--d2c-accent);
  color: #FFFFFF;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  padding: 4px 8px;
  border-radius: 6px;
  z-index: 5;
}

.d2c-thumbs-wrapper {
  overflow: hidden;
}

.d2c-thumbs-scroll {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding-bottom: 6px;
  scrollbar-width: thin;
}

.d2c-thumbs-scroll::-webkit-scrollbar {
  height: 4px;
}

.d2c-thumbs-scroll::-webkit-scrollbar-thumb {
  background-color: #DDD;
  border-radius: 4px;
}

.d2c-thumb-item {
  width: 64px;
  height: 64px;
  flex: 0 0 auto;
  border-radius: var(--d2c-radius-sm);
  background-color: #F7F7F7;
  border: 1px solid transparent;
  cursor: pointer;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: border 0.2s ease, transform 0.2s ease;
  padding: 4px;
}

.d2c-thumb-item:hover {
  transform: scale(1.03);
}

.d2c-thumb-item.active {
  border: 2px solid #000000;
}

.d2c-thumb-item img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  border-radius: calc(var(--d2c-radius-sm) - 2px);
}

/* RIGHT COLUMN: PRODUCT INFO */
.d2c-product-info {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.d2c-brand-award-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: -4px;
}

.d2c-brand-text {
  font-family: var(--d2c-heading-font);
  font-size: 32px;
  font-weight: 800;
  color: {{ section.settings.brand_color | default: '#000000' }};
  letter-spacing: -0.5px;
  line-height: 1;
}

.d2c-award-badge {
  background-color: {{ section.settings.award_bg | default: '#FF1E43' }};
  color: {{ section.settings.award_color | default: '#FFFFFF' }};
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  padding: 5px 10px;
  border-radius: 6px;
  letter-spacing: 0.5px;
  display: inline-flex;
  align-items: center;
}

.d2c-product-title {
  font-size: 42px;
  font-weight: 900;
  font-family: 'Bebas Neue', 'Impact', 'Arial Narrow', sans-serif;
  color: #000000;
  line-height: 1.15;
  margin: 0;
  letter-spacing: -0.03em;
  -webkit-font-smoothing: antialiased;
}

.d2c-product-title span {
  font-family: inherit;
  font-weight: inherit;
  letter-spacing: inherit;
}


.d2c-rating-badge-row {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  margin-top: -4px;
  margin-bottom: -4px;
}

.d2c-rating-pill {
  background-color: {{ section.settings.rating_pill_bg | default: '#2ECC71' }};
  color: #111111;
  font-weight: 700;
  font-size: 13px;
  padding: 5px 10px;
  border-radius: 6px;
  display: inline-flex;
  align-items: center;
}

.d2c-rating-reviews {
  color: #000000;
  font-weight: 500;
  font-size: 14px;
}

.d2c-subtitle-text {
  margin-top: 4px;
  margin-bottom: 4px;
}

.d2c-pdp-badge-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin-top: 12px;
  margin-bottom: 12px;
}

.d2c-pdp-badge-item {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #F1F3F5;
  color: #1A1A1A;
  font-size: 13px;
  font-weight: 500;
  padding: 6px 12px;
  border-radius: 8px;
  border: 1px solid transparent;
  transition: all 0.2s ease;
}

.d2c-pdp-badge-item:hover {
  background: #E9ECEF;
  transform: translateY(-1px);
}

.d2c-pdp-badge-emoji {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 16px;
  height: 16px;
}

.d2c-pdp-badge-text {
  line-height: 1.2;
}

/* KEY FEATURES LIST */
.d2c-features-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.d2c-feature-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 14px;
  color: #333333;
  line-height: 1.6;
}

.d2c-feature-icon {
  width: 18px;
  height: 18px;
  color: #000000;
  flex-shrink: 0;
  margin-top: 2px;
}

/* PRICING SECTION */
.d2c-price-wrapper {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.d2c-price-current {
  font-size: 22px;
  font-weight: 700;
  color: var(--d2c-primary);
}

.d2c-price-compare {
  font-size: 14px;
  color: #999999;
  text-decoration: line-through;
  font-weight: 400;
}

.d2c-discount-badge {
  background: var(--d2c-accent);
  color: #FFFFFF;
  font-size: 11px;
  font-weight: 600;
  padding: 4px 8px;
  border-radius: 6px;
  text-transform: uppercase;
}

/* STOCK / URGENCY MESSAGE */
.d2c-stock-message {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: var(--d2c-stock-green);
  font-weight: 500;
}

.d2c-stock-message svg {
  color: var(--d2c-stock-green);
}

/* VARIANT SELECTOR CARDS */
.d2c-variant-picker {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.d2c-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--d2c-primary);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.d2c-variant-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
  gap: 8px;
}

@media screen and (max-width: 480px) {
  .d2c-variant-cards {
    display: flex;
    overflow-x: auto;
    gap: 8px;
    padding-bottom: 4px;
  }
  .d2c-variant-card {
    flex: 0 0 120px;
  }
}

.d2c-variant-card {
  border: 1px solid var(--d2c-border);
  padding: 8px;
  border-radius: var(--d2c-radius-md);
  background: var(--d2c-bg);
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 10px;
  transition: all 0.2s ease;
  user-select: none;
}

.d2c-variant-card:hover {
  background: var(--d2c-light-grey);
  border-color: #AAAAAA;
}

.d2c-variant-card.active {
  border: 2px solid #000000;
}

.d2c-variant-img {
  width: 42px;
  height: 42px;
  border-radius: 6px;
  object-fit: contain;
  background-color: #F7F7F7;
  flex-shrink: 0;
}

.d2c-variant-fallback-img {
  width: 42px;
  height: 42px;
  border-radius: 6px;
  background-color: var(--d2c-light-grey);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #777;
  flex-shrink: 0;
}

.d2c-variant-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--d2c-primary);
  line-height: 1.2;
}

/* PERSONALIZATION BLOCK */
.d2c-personalization {
  background: var(--d2c-light-grey);
  padding: 12px;
  border-radius: var(--d2c-radius-lg);
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.d2c-personalization-toggle {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
}

.d2c-input {
  width: 100%;
  padding: 10px;
  border: 1px solid var(--d2c-border);
  border-radius: var(--d2c-radius-sm);
  font-family: var(--d2c-font);
  font-size: 13px;
  outline: none;
  background: #FFFFFF;
  box-sizing: border-box;
}

.d2c-input:focus {
  border-color: #000000;
}

/* QUANTITY & ADD TO CART */
.d2c-quantity-wrapper {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.d2c-qty-selector {
  display: flex;
  align-items: center;
  width: 120px;
  height: 42px;
  border: 1px solid var(--d2c-border);
  border-radius: var(--d2c-radius-sm);
  overflow: hidden;
  background: var(--d2c-bg);
}

.d2c-qty-btn {
  width: 40px;
  height: 100%;
  background: none;
  border: none;
  font-size: 16px;
  color: var(--d2c-primary);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  user-select: none;
  transition: background 0.15s;
}

.d2c-qty-btn:hover {
  background: var(--d2c-light-grey);
}

.d2c-qty-number {
  flex: 1;
  text-align: center;
  font-size: 14px;
  font-weight: 600;
  color: var(--d2c-primary);
}

.d2c-atc-btn {
  width: 100%;
  height: 50px;
  background: var(--d2c-primary);
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 600;
  border: none;
  border-radius: var(--d2c-radius-md);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s ease, transform 0.2s ease;
  user-select: none;
}

.d2c-atc-btn:hover {
  opacity: 0.9;
  transform: translateY(-1px);
}

/* TRUST BADGES ROW */
.d2c-trust-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  border-top: 1px solid #EEEEEE;
  border-bottom: 1px solid #EEEEEE;
  padding: 16px 0;
}

@media screen and (max-width: 600px) {
  .d2c-trust-row {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px 8px;
  }
}

.d2c-trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 10px;
}

.d2c-trust-icon {
  width: 32px;
  height: 32px;
  color: #E02020;
}

.d2c-trust-text {
  font-size: 15px;
  color: #E02020;
  font-weight: 700;
  line-height: 1.3;
}

/* ACCORDIONS SECTION */
.d2c-accordions {
  display: flex;
  flex-direction: column;
}

.d2c-accordion-item {
  border-bottom: 1px solid #EEEEEE;
}

.d2c-accordion-toggle {
  width: 100%;
  height: 50px;
  background: none;
  border: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-align: left;
  font-size: 14px;
  font-weight: 600;
  color: var(--d2c-primary);
  cursor: pointer;
  padding: 0;
  transition: color 0.15s ease;
}

.d2c-accordion-toggle:hover {
  color: var(--d2c-secondary);
}

.d2c-accordion-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s cubic-bezier(0, 1, 0, 1);
  font-size: 14px;
  color: var(--d2c-secondary);
  line-height: 1.6;
}

.d2c-accordion-content-inner {
  padding-bottom: 16px;
}

/* FLOATING STICKY Add to Cart Bar */
.d2c-floating-sticky-atc {
  position: fixed;
  bottom: 24px;
  right: 24px;
  left: auto;
  transform: translateY(150px);
  width: calc(100% - 48px);
  max-width: 600px;
  background: #ffffff;
  border-radius: 20px;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
  border: 1px solid rgba(0, 0, 0, 0.05);
  z-index: 999;
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  opacity: 0;
  box-sizing: border-box;
}

.d2c-floating-sticky-atc.visible {
  transform: translateY(0);
  opacity: 1;
}

.d2c-floating-sticky-atc__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 24px;
  gap: 16px;
}

.d2c-floating-sticky-atc__left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 2px;
}

.d2c-floating-compare-price {
  font-size: 15px;
  color: #a1a1a1;
  text-decoration: line-through;
  font-weight: 600;
  letter-spacing: -0.01em;
  text-transform: uppercase;
}

.d2c-floating-price-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.d2c-floating-price {
  font-size: 24px;
  font-weight: 800;
  color: #000000;
  letter-spacing: -0.02em;
  line-height: 1.1;
  text-transform: uppercase;
}

.d2c-floating-discount {
  background-color: #00E676;
  color: #000000;
  font-size: 13px;
  font-weight: 700;
  padding: 4px 8px;
  border-radius: 6px;
  letter-spacing: -0.01em;
  text-transform: uppercase;
}

.d2c-floating-variant-select {
  padding: 8px 12px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
  background-color: #fafafa;
  color: #111;
  outline: none;
  cursor: pointer;
  max-width: 180px;
}

.d2c-floating-atc-btn {
  background-color: #000000;
  color: #ffffff;
  border: none;
  border-radius: 12px;
  padding: 12px 28px;
  font-size: 16px;
  font-weight: 700;
  cursor: pointer;

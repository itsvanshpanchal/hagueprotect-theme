{%- style -%}
  .dtc-pdp-hero {
    width: 100%;
    min-height: 90vh;
    display: grid;
    grid-template-columns: 3fr 2fr;
    background-color: #ffffff;
    font-family: 'Inter', sans-serif !important;
    overflow: hidden;
  }

  @media screen and (max-width: 991px) {
    .dtc-pdp-hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
  }

  /* Left column: media and overlay */
  .dtc-pdp-hero__left {
    position: relative;
    background-color: #f7f7f7;
    display: flex;
    align-items: center;
    padding: 60px;
    box-sizing: border-box;
    min-height: 80vh;
  }

  @media screen and (max-width: 768px) {
    .dtc-pdp-hero__left {
      padding: 30px 20px;
      min-height: 400px;
    }
  }

  .dtc-pdp-hero__bg-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .dtc-pdp-hero__overlay-content {
    position: relative;
    z-index: 2;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-align: left;
  }

  .dtc-pdp-hero__left-badge {
    position: absolute;
    top: 30px;
    right: 30px;
    z-index: 2;
    background-color: #FF2D2D;
    color: #ffffff;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 30px;
    letter-spacing: 0.05em;
  }

  .dtc-pdp-hero__left-heading {
    color: #000000;
    font-size: clamp(32px, 4.5vw, 44px);
    font-weight: 800;
    line-height: 1.15;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .dtc-pdp-hero__left-subtext {
    color: #666666;
    font-size: clamp(14px, 1.8vw, 16px);
    margin: 0;
    line-height: 1.4;
  }

  /* Right column: details */
  .dtc-pdp-hero__right {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px;
    box-sizing: border-box;
    gap: 28px;
    text-align: left;
  }

  @media screen and (max-width: 768px) {
    .dtc-pdp-hero__right {
      padding: 40px 20px;
    }
  }

  .dtc-pdp-hero__rating-badge {
    background-color: #2ECC71;
    color: #ffffff;
    font-size: 13px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 6px;
    width: max-content;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    letter-spacing: 0.02em;
  }

  .dtc-pdp-hero__title {
    font-size: clamp(28px, 3.5vw, 34px);
    font-weight: 800;
    color: #000000;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .dtc-pdp-hero__subtitle {
    font-size: 16px;
    font-weight: 500;
    color: #888888;
    margin: -16px 0 0 0;
  }

  .dtc-pdp-hero__desc {
    font-size: 18px;
    font-weight: 500;
    color: #000000;
    margin: 0;
    line-height: 1.4;
  }

  /* Swatches */
  .dtc-pdp-hero__swatches {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .dtc-pdp-hero__swatch-label {
    font-size: 13px;
    font-weight: 700;
    color: #888888;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .dtc-pdp-hero__swatch-row {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .dtc-pdp-hero__swatch-box {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    border: 1px solid #e5e5e5;
    cursor: pointer;
    transition: all 0.2s;
  }

  .dtc-pdp-hero__swatch-box:hover {
    transform: scale(1.1);
  }

  .dtc-pdp-hero__swatch-box.is-pink { background-color: #FFC0CB; }
  .dtc-pdp-hero__swatch-box.is-green { background-color: #2ECC71; }
  .dtc-pdp-hero__swatch-box.is-grey { background-color: #888888; }
  
  .dtc-pdp-hero__swatch-plus {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    border: 1px solid #e5e5e5;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    color: #888888;
    cursor: pointer;
    background-color: #f7f7f7;
  }

  /* Pricing */
  .dtc-pdp-hero__price-box {
    display: flex;
    align-items: baseline;
    gap: 14px;
  }

  .dtc-pdp-hero__price-old {
    font-size: 16px;
    text-decoration: line-through;
    color: #888888;
  }

  .dtc-pdp-hero__price-new {
    font-size: 24px;
    font-weight: 800;
    color: #000000;
  }

  /* ATC Button */
  .dtc-pdp-hero__atc-btn {
    background-color: #000000;
    color: #ffffff;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 16px 36px;
    border-radius: 40px;
    border: none;
    cursor: pointer;
    width: 100%;
    text-align: center;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    display: inline-block;
    text-decoration: none;
    box-sizing: border-box;
  }

  .dtc-pdp-hero__atc-btn:hover {
    background-color: #FF2D2D;
    transform: translateY(-2px);
  }
{%- endstyle -%}

<div class="dtc-pdp-hero" aria-label="Premium Product Detail Hero">
  <!-- Left Side Media + Overlay Content -->
  <div class="dtc-pdp-hero__left">
    {%- if product.featured_image != blank -%}
      <img src="{{ product.featured_image | image_url: width: 1400 }}" alt="{{ product.title | escape }}" class="dtc-pdp-hero__bg-img" loading="eager">
    {%- else -%}
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 1000" class="dtc-pdp-hero__bg-img">
        <rect width="1000" height="1000" fill="#f7f7f7"/>
        <circle cx="500" cy="450" r="280" fill="#ffffff" stroke="#eeeeee" stroke-width="2"/>
        <!-- Clean minimalist fan graphic for BFF -->
        <path d="M500 450 L500 230 M500 450 L690 340 M500 450 L610 610 M500 450 L390 610 M500 450 L310 340" stroke="#FF2D2D" stroke-width="12" stroke-linecap="round"/>
        <circle cx="500" cy="450" r="40" fill="#000000"/>
        <rect x="475" y="490" width="50" height="180" rx="16" fill="#ffffff" stroke="#e5e5e5" stroke-width="4"/>
        <circle cx="500" cy="530" r="8" fill="#FF2D2D"/>
        <text x="500" y="740" font-family="'Inter', sans-serif" font-size="16" font-weight="800" fill="#000000" letter-spacing="2" text-anchor="middle">BFF | ICETOUCH™</text>
      </svg>
    {%- endif -%}

    <span class="dtc-pdp-hero__left-badge">AWARD WINNER</span>

    <div class="dtc-pdp-hero__overlay-content">
      <h2 class="dtc-pdp-hero__left-heading">Make it yours.<br>Personalize your BFF</h2>
      <p class="dtc-pdp-hero__left-subtext">Lyrics, affirmations, memes, whatever screams you</p>
    </div>
  </div>

  <!-- Right Side Product Details Content -->
  <div class="dtc-pdp-hero__right">
    <div class="dtc-pdp-hero__rating-badge">★ 4.9 (201)</div>
    
    <h1 class="dtc-pdp-hero__title">BFF</h1>
    <p class="dtc-pdp-hero__subtitle">BFF | Personal Hand Fan with IceTouch™</p>

    <p class="dtc-pdp-hero__desc">Instant cooling. Pocket-sized. Always with you.</p>

    <!-- Color swatches -->
    <div class="dtc-pdp-hero__swatches">
      <span class="dtc-pdp-hero__swatch-label">Color</span>
      <div class="dtc-pdp-hero__swatch-row">
        <div class="dtc-pdp-hero__swatch-box is-pink" title="Pink"></div>
        <div class="dtc-pdp-hero__swatch-box is-green" title="Green"></div>
        <div class="dtc-pdp-hero__swatch-box is-grey" title="Grey"></div>
        <div class="dtc-pdp-hero__swatch-plus" title="More Colors">+</div>
      </div>
    </div>

    <!-- Pricing -->
    <div class="dtc-pdp-hero__price-box">
      <span class="dtc-pdp-hero__price-old">Rs. 2700</span>
      <span class="dtc-pdp-hero__price-new">Rs. 2,299</span>
    </div>

    <!-- ATC -->
    {%- form 'product', product, id: 'AddToCartForm-pdp-hero' -%}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id | default: 12345678 }}">
      <button type="submit" name="add" class="dtc-pdp-hero__atc-btn">Add to Cart</button>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Product Hero",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Product Hero"
    }
  ]
}
{% endschema %}

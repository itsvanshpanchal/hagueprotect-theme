{%- style -%}
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap');

:root {
  --d2c-primary: #000000;
  --d2c-secondary: #666666;
  --d2c-bg: #FFFFFF;
  --d2c-light-grey: #F5F5F5;
  --d2c-border: #DDDDDD;
  --d2c-accent: #E53935;
  --d2c-stock-green: #2E7D32;
  --d2c-font: 'Inter', sans-serif;
  --d2c-heading-font: 'Poppins', sans-serif;
  --d2c-radius-sm: 8px;
  --d2c-radius-md: 10px;
  --d2c-radius-lg: 12px;
  --d2c-radius-xl: 16px;
}

.d2c-pdp-section {
  background: var(--d2c-bg);
  padding: 24px 0 64px 0;
  box-sizing: border-box;
}

.d2c-pdp-grid {
  display: grid;
  grid-template-columns: calc(60% - 16px) calc(40% - 16px);
  gap: 32px;
  max-width: 1200px;
  margin: 0 auto;
  padding: 24px;
  font-family: var(--d2c-font);
  box-sizing: border-box;
}

@media screen and (max-width: 991px) {
  .d2c-pdp-grid {
    grid-template-columns: 1fr;
    gap: 32px;
    padding: 16px;
  }
}

/* LEFT COLUMN: MEDIA GALLERY */
.d2c-media-gallery {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.d2c-media-main {
  position: relative;
  background-color: #F7F7F7;
  border-radius: var(--d2c-radius-xl);
  overflow: hidden;
  padding: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  aspect-ratio: 1 / 1;
  border: 1px solid rgba(0, 0, 0, 0.04);
}

.d2c-media-main-img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  border-radius: calc(var(--d2c-radius-xl) - 4px);
  transition: transform 0.3s ease, transform-origin 0.1s ease;
}

@media (min-width: 768px) {
  .d2c-media-main:hover .d2c-media-main-img {
    transform: scale(1.6);
    cursor: zoom-in;
  }
}

.d2c-badge-overlay {
  position: absolute;
  top: 16px;
  left: 16px;
  background: var(--d2c-accent);
  color: #FFFFFF;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  padding: 4px 8px;
  border-radius: 6px;
  z-index: 5;
}

.d2c-thumbs-wrapper {
  overflow: hidden;
}

.d2c-thumbs-scroll {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding-bottom: 6px;
  scrollbar-width: thin;
}

.d2c-thumbs-scroll::-webkit-scrollbar {
  height: 4px;
}

.d2c-thumbs-scroll::-webkit-scrollbar-thumb {
  background-color: #DDD;
  border-radius: 4px;
}

.d2c-thumb-item {
  width: 64px;
  height: 64px;
  flex: 0 0 auto;
  border-radius: var(--d2c-radius-sm);
  background-color: #F7F7F7;
  border: 1px solid transparent;
  cursor: pointer;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: border 0.2s ease, transform 0.2s ease;
  padding: 4px;
}

.d2c-thumb-item:hover {
  transform: scale(1.03);
}

.d2c-thumb-item.active {
  border: 2px solid #000000;
}

.d2c-thumb-item img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  border-radius: calc(var(--d2c-radius-sm) - 2px);
}

/* RIGHT COLUMN: PRODUCT INFO */
.d2c-product-info {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.d2c-tag-label {
  font-size: 12px;
  color: var(--d2c-secondary);
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 600;
}

.d2c-product-title {
  font-size: 26px;
  font-weight: 700;
  font-family: var(--d2c-heading-font);
  color: var(--d2c-primary);
  line-height: 1.2;
  margin: 0;
}

@media screen and (max-width: 767px) {
  .d2c-product-title {
    font-size: 22px;
  }
}

.d2c-rating-row {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: #666666;
}

.d2c-stars {
  color: #FFB400;
  font-size: 15px;
}

.d2c-trust-msg {
  font-weight: 400;
}

/* KEY FEATURES LIST */
.d2c-features-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.d2c-feature-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 14px;
  color: #333333;
  line-height: 1.6;
}

.d2c-feature-icon {
  width: 18px;
  height: 18px;
  color: #000000;
  flex-shrink: 0;
  margin-top: 2px;
}

/* PRICING SECTION */
.d2c-price-wrapper {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.d2c-price-current {
  font-size: 22px;
  font-weight: 700;
  color: var(--d2c-primary);
}

.d2c-price-compare {
  font-size: 14px;
  color: #999999;
  text-decoration: line-through;
  font-weight: 400;
}

.d2c-discount-badge {
  background: var(--d2c-accent);
  color: #FFFFFF;
  font-size: 11px;
  font-weight: 600;
  padding: 4px 8px;
  border-radius: 6px;
  text-transform: uppercase;
}

/* STOCK / URGENCY MESSAGE */
.d2c-stock-message {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: var(--d2c-stock-green);
  font-weight: 500;
}

.d2c-stock-message svg {
  color: var(--d2c-stock-green);
}

/* VARIANT SELECTOR CARDS */
.d2c-variant-picker {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.d2c-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--d2c-primary);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.d2c-variant-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
  gap: 8px;
}

@media screen and (max-width: 480px) {
  .d2c-variant-cards {
    display: flex;
    overflow-x: auto;
    gap: 8px;
    padding-bottom: 4px;
  }
  .d2c-variant-card {
    flex: 0 0 120px;
  }
}

.d2c-variant-card {
  border: 1px solid var(--d2c-border);
  padding: 8px;
  border-radius: var(--d2c-radius-md);
  background: var(--d2c-bg);
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 10px;
  transition: all 0.2s ease;
  user-select: none;
}

.d2c-variant-card:hover {
  background: var(--d2c-light-grey);
  border-color: #AAAAAA;
}

.d2c-variant-card.active {
  border: 2px solid #000000;
}

.d2c-variant-img {
  width: 42px;
  height: 42px;
  border-radius: 6px;
  object-fit: contain;
  background-color: #F7F7F7;
  flex-shrink: 0;
}

.d2c-variant-fallback-img {
  width: 42px;
  height: 42px;
  border-radius: 6px;
  background-color: var(--d2c-light-grey);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #777;
  flex-shrink: 0;
}

.d2c-variant-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--d2c-primary);
  line-height: 1.2;
}

/* PERSONALIZATION BLOCK */
.d2c-personalization {
  background: var(--d2c-light-grey);
  padding: 12px;
  border-radius: var(--d2c-radius-lg);
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.d2c-personalization-toggle {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
}

.d2c-input {
  width: 100%;
  padding: 10px;
  border: 1px solid var(--d2c-border);
  border-radius: var(--d2c-radius-sm);
  font-family: var(--d2c-font);
  font-size: 13px;
  outline: none;
  background: #FFFFFF;
  box-sizing: border-box;
}

.d2c-input:focus {
  border-color: #000000;
}

/* QUANTITY & ADD TO CART */
.d2c-quantity-wrapper {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.d2c-qty-selector {
  display: flex;
  align-items: center;
  width: 120px;
  height: 42px;
  border: 1px solid var(--d2c-border);
  border-radius: var(--d2c-radius-sm);
  overflow: hidden;
  background: var(--d2c-bg);
}

.d2c-qty-btn {
  width: 40px;
  height: 100%;
  background: none;
  border: none;
  font-size: 16px;
  color: var(--d2c-primary);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  user-select: none;
  transition: background 0.15s;
}

.d2c-qty-btn:hover {
  background: var(--d2c-light-grey);
}

.d2c-qty-number {
  flex: 1;
  text-align: center;
  font-size: 14px;
  font-weight: 600;
  color: var(--d2c-primary);
}

.d2c-atc-btn {
  width: 100%;
  height: 50px;
  background: var(--d2c-primary);
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 600;
  border: none;
  border-radius: var(--d2c-radius-md);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s ease, transform 0.2s ease;
  user-select: none;
}

.d2c-atc-btn:hover {
  opacity: 0.9;
  transform: translateY(-1px);
}

/* TRUST BADGES ROW */
.d2c-trust-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  border-top: 1px solid #EEEEEE;
  border-bottom: 1px solid #EEEEEE;
  padding: 16px 0;
}

@media screen and (max-width: 600px) {
  .d2c-trust-row {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px 8px;
  }
}

.d2c-trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 6px;
}

.d2c-trust-icon {
  width: 20px;
  height: 20px;
  color: var(--d2c-secondary);
}

.d2c-trust-text {
  font-size: 12px;
  color: var(--d2c-secondary);
  font-weight: 400;
  line-height: 1.3;
}

/* ACCORDIONS SECTION */
.d2c-accordions {
  display: flex;
  flex-direction: column;
}

.d2c-accordion-item {
  border-bottom: 1px solid #EEEEEE;
}

.d2c-accordion-toggle {
  width: 100%;
  height: 50px;
  background: none;
  border: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-align: left;
  font-size: 14px;
  font-weight: 600;
  color: var(--d2c-primary);
  cursor: pointer;
  padding: 0;
  transition: color 0.15s ease;
}

.d2c-accordion-toggle:hover {
  color: var(--d2c-secondary);
}

.d2c-accordion-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s cubic-bezier(0, 1, 0, 1);
  font-size: 14px;
  color: var(--d2c-secondary);
  line-height: 1.6;
}

.d2c-accordion-content-inner {
  padding-bottom: 16px;
}

/* MOBILE STICKY Add to Cart */
.d2c-mobile-sticky-atc {
  display: none;
}

@media screen and (max-width: 767px) {
  .d2c-mobile-sticky-atc {
    display: flex;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: #FFFFFF;
    padding: 12px 16px;
    box-shadow: 0 -4px 15px rgba(0,0,0,0.06);
    z-index: 1000;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border-top: 1px solid #EEEEEE;
  }

  .d2c-sticky-info {
    display: flex;
    flex-direction: column;
  }

  .d2c-sticky-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--d2c-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 150px;
  }

  .d2c-sticky-price {
    font-size: 14px;
    font-weight: 700;
    color: var(--d2c-primary);
  }

  .d2c-sticky-atc-btn {
    flex: 1;
    height: 44px;
    background: var(--d2c-primary);
    color: #FFFFFF;
    font-size: 14px;
    font-weight: 600;
    border: none;
    border-radius: var(--d2c-radius-sm);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
}
{%- endstyle -%}

{%- assign main_product = section.settings.product | default: product -%}
{%- assign product = main_product -%}

<div class="d2c-pdp-section" aria-label="Modern Product Layout Section">
  <div class="d2c-pdp-grid">
    <!-- LEFT COLUMN: Product media gallery -->
    <div class="d2c-media-gallery">
      <div class="d2c-media-main">
        {%- if product.featured_image != blank -%}
          <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }}" id="MainProductImage" class="d2c-media-main-img" loading="eager">
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'd2c-media-main-img' }}
        {%- endif -%}

        {%- if product.compare_at_price > product.price -%}
          <span class="d2c-badge-overlay">SALE</span>
        {%- endif -%}
      </div>

      <!-- Thumbnail Slider -->
      {%- if product.images.size > 1 -%}
        <div class="d2c-thumbs-wrapper">
          <div class="d2c-thumbs-scroll">
            {%- for image in product.images -%}
              <div class="d2c-thumb-item{% if forloop.first %} active{% endif %}" data-src="{{ image | image_url: width: 1200 }}">
                <img src="{{ image | image_url: width: 120 }}" alt="{{ product.title | escape }}" loading="lazy">
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>

    <!-- RIGHT COLUMN: Product information -->
    <div class="d2c-product-info">
      <!-- Tag / Category Label -->
      <div class="d2c-tag-label">
        {%- if product.tags.size > 0 -%}
          {{ product.tags | first }}
        {%- else -%}
          PREMIUM ITEM
        {%- endif -%}
      </div>

      <!-- Title -->
      <h1 class="d2c-product-title">{{ product.title }}</h1>

      <!-- Rating / Trust Row -->
      <div class="d2c-rating-row">
        <span class="d2c-stars">★★★★★</span>
        <span class="d2c-trust-msg">Highly rated dynamic choice</span>
      </div>

      <!-- Pricing -->
      <div class="d2c-price-wrapper">
        <span class="d2c-price-current" id="D2CPriceCurrent">{{ product.price | money }}</span>
        {%- if product.compare_at_price > product.price -%}
          <span class="d2c-price-compare" id="D2CPriceCompare">{{ product.compare_at_price | money }}</span>
          <span class="d2c-discount-badge" id="D2CDiscountBadge">
            {%- assign diff = product.compare_at_price | minus: product.price -%}
            {%- assign pct = diff | times: 100 | divided_by: product.compare_at_price -%}
            Save {{ pct }}%
          </span>
        {%- else -%}
          <span class="d2c-price-compare" id="D2CPriceCompare" style="display: none;"></span>
          <span class="d2c-discount-badge" id="D2CDiscountBadge" style="display: none;"></span>
        {%- endif -%}
      </div>

      <!-- Key Features List -->
      <div class="d2c-features-list">
        {%- if product.metafields.custom.highlights.value != blank -%}
          {%- for highlight in product.metafields.custom.highlights.value -%}
            <div class="d2c-feature-item">
              <svg class="d2c-feature-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span class="d2c-feature-text">{{ highlight }}</span>
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="d2c-feature-item">
            <svg class="d2c-feature-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span class="d2c-feature-text">Superior material care formula</span>
          </div>
          <div class="d2c-feature-item">
            <svg class="d2c-feature-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span class="d2c-feature-text">Engineered for ultimate sneaker maintenance</span>
          </div>
          <div class="d2c-feature-item">
            <svg class="d2c-feature-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span class="d2c-feature-text">Certified & trusted by shoe lovers worldwide</span>
          </div>
        {%- endif -%}
      </div>

      <!-- Stock / Urgency Message -->
      <div class="d2c-stock-message">
        {%- if product.available -%}
          <svg width="8" height="8" viewBox="0 0 8 8" fill="none"><circle cx="4" cy="4" r="4" fill="currentColor"></circle></svg>
          <span>In stock and ready to ship</span>
        {%- else -%}
          <svg width="8" height="8" viewBox="0 0 8 8" fill="none"><circle cx="4" cy="4" r="4" fill="#D32F2F"></circle></svg>
          <span style="color: #D32F2F;">Out of Stock</span>
        {%- endif -%}
      </div>

      <!-- Form for Quantity & ATC -->
      {%- form 'product', product, id: 'AddToCartForm-modern-pdp' -%}
        <input type="hidden" name="id" id="VariantSelector-Input" value="{{ product.selected_or_first_available_variant.id }}">
        <input type="hidden" name="quantity" id="QuantitySelector-Input" value="1">

        <div style="display: flex; flex-direction: column; gap: 20px;">
          <!-- Variant Cards -->
          {%- if product.variants.size > 1 -%}
            <div class="d2c-variant-picker">
              <label class="d2c-label">Select Option</label>
              <div class="d2c-variant-cards">
                {%- for variant in product.variants -%}
                  <div class="d2c-variant-card{% if variant == product.selected_or_first_available_variant %} active{% endif %}" 
                       data-variant-id="{{ variant.id }}" 
                       data-price="{{ variant.price | money }}"
                       data-compare-price="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money }}{% endif %}"
                       data-available="{{ variant.available }}">
                    {%- if variant.featured_image != blank -%}
                      <img src="{{ variant.featured_image | image_url: width: 60, height: 60, crop: 'center' }}" alt="{{ variant.title | escape }}" class="d2c-variant-img" loading="lazy">
                    {%- else -%}
                      <div class="d2c-variant-fallback-img">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
                           <rect width="18" height="18" x="3" y="3" rx="4"></rect>
                           <circle cx="9" cy="9" r="2"></circle>
                           <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
                        </svg>
                      </div>
                    {%- endif -%}
                    <div class="d2c-variant-name">{{ variant.title }}</div>
                  </div>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}

          <!-- Optional Personalization Block -->
          <div class="d2c-personalization">
            <label class="d2c-personalization-toggle">
              <input type="checkbox" id="TogglePersonalization" onchange="togglePersonalizationInput()">
              <span>Add custom note or personalization</span>
            </label>
            <div class="d2c-personalization-input-wrapper" id="PersonalizationWrapper" style="display: none;">
              <input type="text" id="CustomPersonalizationInput" name="properties[Personalization]" placeholder="Enter your text here..." class="d2c-input">
            </div>
          </div>

          <!-- Quantity Selector -->
          <div class="d2c-quantity-wrapper">
            <label class="d2c-label">Quantity</label>
            <div class="d2c-qty-selector">
              <button type="button" class="d2c-qty-btn" id="Qty-Decrement">−</button>
              <div class="d2c-qty-number" id="Qty-Number">1</div>
              <button type="button" class="d2c-qty-btn" id="Qty-Increment">+</button>
            </div>
          </div>

          <!-- Add to Cart Button -->
          <button type="submit" name="add" id="AddToCartBtn-Submit" class="d2c-atc-btn" {% unless product.available %}disabled{% endunless %}>
            {%- if product.available -%}
              Add to Cart
            {%- else -%}
              Sold Out
            {%- endif -%}
          </button>
        </div>
      {%- endform -%}

      <!-- Trust Badges Row -->
      <div class="d2c-trust-row">
        <div class="d2c-trust-item">
          <svg class="d2c-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 14 4-4M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Z"/></svg>
          <span class="d2c-trust-text">Eco Friendly</span>
        </div>
        <div class="d2c-trust-item">
          <svg class="d2c-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span class="d2c-trust-text">Certified Care</span>
        </div>
        <div class="d2c-trust-item">
          <svg class="d2c-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          <span class="d2c-trust-text">Material Safe</span>
        </div>
        <div class="d2c-trust-item">
          <svg class="d2c-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22v-6m0-4V2m-7.5 5.5v11a2.5 2.5 0 0 0 2.5 2.5h10a2.5 2.5 0 0 0 2.5-2.5v-11"/></svg>
          <span class="d2c-trust-text">Tested Efficacy</span>
        </div>
      </div>

      <!-- Accordions -->
      <div class="d2c-accordions">
        <div class="d2c-accordion-item">
          <button type="button" class="d2c-accordion-toggle">
            <span>Product Details</span>
            <span class="d2c-accordion-icon">+</span>
          </button>
          <div class="d2c-accordion-content">
            <div class="d2c-accordion-content-inner">
              <p>{{ product.description | default: "Premium performance product designed and developed for discerning enthusiasts looking to keep their personal items at their absolute best." }}</p>
            </div>
          </div>
        </div>

        <div class="d2c-accordion-item">
          <button type="button" class="d2c-accordion-toggle">
            <span>Technical Specifications</span>
            <span class="d2c-accordion-icon">+</span>
          </button>
          <div class="d2c-accordion-content">
            <div class="d2c-accordion-content-inner">
              <p>Specifically engineered with precise viscosity for effortless coverage and long-lasting efficacy. Completely non-toxic and ph-neutral formula.</p>
            </div>
          </div>
        </div>

        <div class="d2c-accordion-item">
          <button type="button" class="d2c-accordion-toggle">
            <span>Materials & Care</span>
            <span class="d2c-accordion-icon">+</span>
          </button>
          <div class="d2c-accordion-content">
            <div class="d2c-accordion-content-inner">
              <p>Safe for use on all premium materials including soft leathers, woven knits, suedes, canvases, and rubber surfaces. Store safely in a dry place.</p>
            </div>
          </div>
        </div>

        <div class="d2c-accordion-item">
          <button type="button" class="d2c-accordion-toggle">
            <span>In the Box</span>
            <span class="d2c-accordion-icon">+</span>
          </button>
          <div class="d2c-accordion-content">
            <div class="d2c-accordion-content-inner">
              <p>1x Concentrated formula solution, 1x Ergonomic cleaning applicator, 1x Premium microfiber towel, 1x Care instruction guide.</p>
            </div>
          </div>
        </div>

        <div class="d2c-accordion-item">
          <button type="button" class="d2c-accordion-toggle">
            <span>Additional Details</span>
            <span class="d2c-accordion-icon">+</span>
          </button>
          <div class="d2c-accordion-content">
            <div class="d2c-accordion-content-inner">
              <p>Fast processing on every order. Hassle-free dynamic returns and full satisfaction guarantee.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Mobile Sticky ATC -->
<div class="d2c-mobile-sticky-atc">
  <div class="d2c-sticky-info">
    <div class="d2c-sticky-title">{{ product.title | escape }}</div>
    <div class="d2c-sticky-price" id="D2CStickyPriceCurrent">{{ product.price | money }}</div>
  </div>
  <button type="button" class="d2c-sticky-atc-btn" id="MobileStickyAtcBtn" {% unless product.available %}disabled{% endunless %}>
    {%- if product.available -%}
      Add to Cart
    {%- else -%}
      Sold Out
    {%- endif -%}
  </button>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Main Image Mouse Zoom
  const mainImgContainer = document.querySelector('.d2c-media-main');
  const mainImg = document.querySelector('#MainProductImage');
  if (mainImgContainer && mainImg) {
    mainImgContainer.addEventListener('mousemove', function(e) {
      if (window.innerWidth >= 768) {
        const rect = this.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        mainImg.style.transformOrigin = `${x}% ${y}%`;
      }
    });
    mainImgContainer.addEventListener('mouseleave', function() {
      mainImg.style.transformOrigin = 'center center';
    });
  }

  // Thumbnail Clicking
  document.querySelectorAll('.d2c-thumb-item').forEach(thumb => {
    thumb.addEventListener('click', function() {
      document.querySelectorAll('.d2c-thumb-item').forEach(t => t.classList.remove('active'));
      this.classList.add('active');
      if (mainImg) {
        mainImg.src = this.getAttribute('data-src');
      }
    });
  });

  // Quantity Stepper UI
  let quantity = 1;
  const qtyNumber = document.querySelector('#Qty-Number');
  const qtyInput = document.querySelector('#QuantitySelector-Input');
  const qtyIncrement = document.querySelector('#Qty-Increment');
  const qtyDecrement = document.querySelector('#Qty-Decrement');

  if (qtyIncrement && qtyDecrement && qtyNumber && qtyInput) {
    qtyIncrement.addEventListener('click', function() {
      quantity++;
      qtyNumber.innerText = quantity;
      qtyInput.value = quantity;
    });

    qtyDecrement.addEventListener('click', function() {
      if (quantity > 1) {
        quantity--;
        qtyNumber.innerText = quantity;
        qtyInput.value = quantity;
      }
    });
  }

  // Variant Switcher
  const variantInput = document.querySelector('#VariantSelector-Input');
  const priceCurrent = document.querySelector('#D2CPriceCurrent');
  const priceCompare = document.querySelector('#D2CPriceCompare');
  const discountBadge = document.querySelector('#D2CDiscountBadge');
  const stickyPrice = document.querySelector('#D2CStickyPriceCurrent');
  const submitBtn = document.querySelector('#AddToCartBtn-Submit');
  const stickyBtn = document.querySelector('#MobileStickyAtcBtn');

  document.querySelectorAll('.d2c-variant-card').forEach(card => {
    card.addEventListener('click', function() {
      document.querySelectorAll('.d2c-variant-card').forEach(c => c.classList.remove('active'));
      this.classList.add('active');

      const variantId = this.getAttribute('data-variant-id');
      const variantPrice = this.getAttribute('data-price');
      const variantCompare = this.getAttribute('data-compare-price');
      const available = this.getAttribute('data-available') === 'true';

      if (variantInput) variantInput.value = variantId;
      if (priceCurrent) priceCurrent.innerText = variantPrice;
      if (stickyPrice) stickyPrice.innerText = variantPrice;

      if (variantCompare && priceCompare && discountBadge) {
        priceCompare.innerText = variantCompare;
        priceCompare.style.display = 'inline';
        discountBadge.style.display = 'inline';
      } else if (priceCompare && discountBadge) {
        priceCompare.style.display = 'none';
        discountBadge.style.display = 'none';
      }

      if (available) {
        if (submitBtn) {
          submitBtn.removeAttribute('disabled');
          submitBtn.innerText = 'Add to Cart';
        }
        if (stickyBtn) {
          stickyBtn.removeAttribute('disabled');
          stickyBtn.innerText = 'Add to Cart';
        }
      } else {
        if (submitBtn) {
          submitBtn.setAttribute('disabled', 'disabled');
          submitBtn.innerText = 'Sold Out';
        }
        if (stickyBtn) {
          stickyBtn.setAttribute('disabled', 'disabled');
          stickyBtn.innerText = 'Sold Out';
        }
      }
    });
  });

  // Accordions Toggle
  document.querySelectorAll('.d2c-accordion-toggle').forEach(btn => {
    btn.addEventListener('click', function() {
      const parent = this.parentElement;
      const content = parent.querySelector('.d2c-accordion-content');
      const icon = this.querySelector('.d2c-accordion-icon');
      const isActive = parent.classList.contains('active');

      document.querySelectorAll('.d2c-accordion-item').forEach(item => {
        item.classList.remove('active');
        item.querySelector('.d2c-accordion-content').style.maxHeight = null;
        item.querySelector('.d2c-accordion-icon').innerText = '+';
      });

      if (!isActive) {
        parent.classList.add('active');
        content.style.maxHeight = content.scrollHeight + 'px';
        icon.innerText = '−';
      } else {
        parent.classList.remove('active');
        content.style.maxHeight = null;
        icon.innerText = '+';
      }
    });
  });

  // Mobile Sticky ATC Click
  if (stickyBtn) {
    stickyBtn.addEventListener('click', function() {
      if (submitBtn) submitBtn.click();
    });
  }
});

function togglePersonalizationInput() {
  const checkbox = document.getElementById('TogglePersonalization');
  const wrapper = document.getElementById('PersonalizationWrapper');
  const input = document.getElementById('CustomPersonalizationInput');
  if (checkbox.checked) {
    wrapper.style.display = 'block';
    input.focus();
  } else {
    wrapper.style.display = 'none';
    input.value = '';
  }
}
</script>


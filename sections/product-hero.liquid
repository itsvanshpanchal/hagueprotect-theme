<script>
document.addEventListener('DOMContentLoaded', function() {
  // Main Image Mouse Zoom
  const mainImgContainer = document.querySelector('.d2c-media-main');
  const mainImg = document.querySelector('#MainProductImage');
  if (mainImgContainer && mainImg) {
    mainImgContainer.addEventListener('mousemove', function(e) {
      if (window.innerWidth >= 768) {
        const rect = this.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        mainImg.style.transformOrigin = `${x}% ${y}%`;
      }
    });
    mainImgContainer.addEventListener('mouseleave', function() {
      mainImg.style.transformOrigin = 'center center';
    });
  }

  // Thumbnail Clicking
  const thumbs = document.querySelectorAll('.d2c-thumb-item');
  const prevBtn = document.querySelector('#PrevGalleryBtn');
  const nextBtn = document.querySelector('#NextGalleryBtn');

  thumbs.forEach((thumb, idx) => {
    thumb.addEventListener('click', function() {
      thumbs.forEach(t => t.classList.remove('active'));
      this.classList.add('active');
      if (mainImg) {
        mainImg.src = this.getAttribute('data-src');
      }
    });
  });

  // Next and Previous Gallery Buttons
  if (thumbs.length > 1 && prevBtn && nextBtn) {
    let activeIndex = 0;

    thumbs.forEach((thumb, idx) => {
      thumb.addEventListener('click', function() {
        activeIndex = idx;
      });
    });

    prevBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      activeIndex = (activeIndex - 1 + thumbs.length) % thumbs.length;
      thumbs[activeIndex].click();
      thumbs[activeIndex].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    });

    nextBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      activeIndex = (activeIndex + 1) % thumbs.length;
      thumbs[activeIndex].click();
      thumbs[activeIndex].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    });

    // Touch Swipe Support for Mobile
    let touchstartX = 0;
    let touchendX = 0;

    mainImgContainer.addEventListener('touchstart', function(e) {
      touchstartX = e.changedTouches[0].screenX;
    }, { passive: true });

    mainImgContainer.addEventListener('touchend', function(e) {
      touchendX = e.changedTouches[0].screenX;
      if (window.innerWidth < 768) {
        if (touchendX < touchstartX - 50) nextBtn.click();
        if (touchendX > touchstartX + 50) prevBtn.click();
      }
    }, { passive: true });
  }

  // Quantity Stepper UI
  let quantity = 1;
  const qtyNumber = document.querySelector('#Qty-Number');
  const qtyInput = document.querySelector('#QuantitySelector-Input');
  const qtyIncrement = document.querySelector('#Qty-Increment');
  const qtyDecrement = document.querySelector('#Qty-Decrement');

  if (qtyIncrement && qtyDecrement && qtyNumber && qtyInput) {
    qtyIncrement.addEventListener('click', function() {
      quantity++;
      qtyNumber.textContent = quantity;
      qtyInput.value = quantity;
    });

    qtyDecrement.addEventListener('click', function() {
      if (quantity > 1) {
        quantity--;
        qtyNumber.textContent = quantity;
        qtyInput.value = quantity;
      }
    });
  }

  // Variant Switcher
  const variantInput = document.querySelector('#VariantSelector-Input');
  const priceCurrent = document.querySelector('#D2CPriceCurrent');
  const priceCompare = document.querySelector('#D2CPriceCompare');
  const discountBadge = document.querySelector('#D2CDiscountBadge');
  const stickyPrice = document.querySelector('#D2CStickyPriceCurrent');
  const submitBtn = document.querySelector('#AddToCartBtn-Submit');
  const stickyBtn = document.querySelector('#MobileStickyAtcBtn');

  document.querySelectorAll('.d2c-variant-card').forEach(card => {
    card.addEventListener('click', function() {
      document.querySelectorAll('.d2c-variant-card').forEach(c => c.classList.remove('active'));
      this.classList.add('active');

      const variantId = this.getAttribute('data-variant-id');
      const variantPrice = this.getAttribute('data-price');
      const variantCompare = this.getAttribute('data-compare-price');
      const available = this.getAttribute('data-available') === 'true';

      if (variantInput) variantInput.value = variantId;
      if (priceCurrent) priceCurrent.textContent = variantPrice;
      if (stickyPrice) stickyPrice.textContent = variantPrice;

      if (variantCompare && priceCompare && discountBadge) {
        priceCompare.textContent = variantCompare;
        priceCompare.style.display = 'inline';
        discountBadge.style.display = 'inline';
      } else if (priceCompare && discountBadge) {
        priceCompare.style.display = 'none';
        discountBadge.style.display = 'none';
      }

      if (available) {
        if (submitBtn) {
          submitBtn.removeAttribute('disabled');
          submitBtn.textContent = 'Add to Cart';
        }
        if (stickyBtn) {
          stickyBtn.removeAttribute('disabled');
          stickyBtn.textContent = 'Add to Cart';
        }
      } else {
        if (submitBtn) {
          submitBtn.setAttribute('disabled', 'disabled');
          submitBtn.textContent = 'Sold Out';
        }
        if (stickyBtn) {
          stickyBtn.setAttribute('disabled', 'disabled');
          stickyBtn.textContent = 'Sold Out';
        }
      }
    });
  });

  // Accordions Toggle
  document.querySelectorAll('.d2c-accordion-toggle').forEach(btn => {
    btn.addEventListener('click', function() {
      const parent = this.parentElement;
      const content = parent.querySelector('.d2c-accordion-content');
      const icon = this.querySelector('.d2c-accordion-icon');
      const isActive = parent.classList.contains('active');

      document.querySelectorAll('.d2c-accordion-item').forEach(item => {
        item.classList.remove('active');
        item.querySelector('.d2c-accordion-content').style.maxHeight = null;
        item.querySelector('.d2c-accordion-icon').textContent = '+';
      });

      if (!isActive) {
        parent.classList.add('active');
        content.style.maxHeight = content.scrollHeight + 'px';
        icon.textContent = 'Ã¢Ë†â€™';
      } else {
        parent.classList.remove('active');
        content.style.maxHeight = null;
        icon.textContent = '+';
      }
    });
  });

  // Floating Sticky ATC Click & Visibility
  const floatingStickyAtc = document.getElementById('FloatingStickyAtc');
  if (floatingStickyAtc) {
    window.addEventListener('scroll', function() {
      if (window.scrollY > 400) {
        floatingStickyAtc.classList.add('visible');
      } else {
        floatingStickyAtc.classList.remove('visible');
      }
    });

    const atcSubmitBtn = document.getElementById('FloatingStickyAtcSubmit');
    if (atcSubmitBtn && submitBtn) {
      atcSubmitBtn.addEventListener('click', function() {
        const stickyVariantSelect = document.getElementById('FloatingStickyAtcVariantSelector');
        if (stickyVariantSelect) {
          const mainFormVariantInput = document.querySelector('input[name="id"]');
          if (mainFormVariantInput) {
            mainFormVariantInput.value = stickyVariantSelect.value;
          }
        }
        submitBtn.click();
      });
    }
  }
});

function togglePersonalizationInput() {
  const checkbox = document.getElementById('TogglePersonalization');
  const wrapper = document.getElementById('PersonalizationWrapper');
  const input = document.getElementById('CustomPersonalizationInput');
  if (checkbox.checked) {
    wrapper.style.display = 'block';
    input.focus();
  } else {
    wrapper.style.display = 'none';
    input.value = '';
  }
}
</script>


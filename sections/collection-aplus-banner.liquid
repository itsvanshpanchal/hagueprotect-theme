{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .caplus-banner-{{ section.id }} {
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    overflow: hidden;
    background-color: {{ section.settings.bg_color | default: '#f6f6f6' }};
    padding-top: {{ section.settings.padding_top | default: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px;
    box-sizing: border-box;
  }

  .caplus-banner-{{ section.id }}__frame {
    width: 100%;
    margin: 0;
    position: relative;
    aspect-ratio: 2 / 1;
    overflow: hidden;
    background-color: #f0f0f0;
  }

  .caplus-banner-{{ section.id }}__link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  .caplus-banner-{{ section.id }}__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  @media screen and (max-width: 749px) {
    .caplus-banner-{{ section.id }}__frame {
      aspect-ratio: 4 / 5;
      min-height: 280px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign desktop_img = section.settings.image | default: collection.image
  assign mobile_img = section.settings.image_mobile | default: section.settings.image | default: collection.image
  assign banner_alt = section.settings.alt_text | default: desktop_img.alt | default: collection.title | default: 'Collection banner'
-%}

<section class="caplus-banner-{{ section.id }}" aria-label="{{ section.settings.label | default: 'A+ banner' | escape }}">
  <div class="caplus-banner-{{ section.id }}__frame">
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}" class="caplus-banner-{{ section.id }}__link">
    {%- endif -%}

    {%- if desktop_img != blank -%}
      <picture>
        {%- if mobile_img != blank -%}
          <source media="(max-width: 749px)" srcset="{{ mobile_img | image_url: width: 1080 }}">
        {%- endif -%}
        <img
          src="{{ desktop_img | image_url: width: 2800 }}"
          srcset="{{ desktop_img | image_url: width: 1400 }} 1400w, {{ desktop_img | image_url: width: 2000 }} 2000w, {{ desktop_img | image_url: width: 2800 }} 2800w"
          sizes="100vw"
          alt="{{ banner_alt | escape }}"
          class="caplus-banner-{{ section.id }}__image"
          loading="{% if section.settings.padding_top == 0 %}eager{% else %}lazy{% endif %}"
          {% if section.settings.padding_top == 0 %}fetchpriority="high"{% endif %}
          width="{{ desktop_img.width }}"
          height="{{ desktop_img.height }}"
        >
      </picture>
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'caplus-banner__image' }}
    {%- endif -%}

    {%- if section.settings.link != blank -%}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection A+ Banner",
  "tag": "section",
  "class": "section-collection-aplus-banner",
  "enabled_on": {
    "templates": [
      "collection",
      "page"
    ]
  },
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label (accessibility)",
      "default": "A+ banner"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop banner image",
      "info": "Recommended: 2800 x 1400 px (2:1). If empty, uses the collection image from Shopify Admin."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile banner image",
      "info": "Recommended: 1080 x 1350 px (4:5). Falls back to desktop if empty."
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Image alt text"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Banner link (optional)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f6f6f6"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Collection A+ Banner"
    }
  ]
}
{% endschema %}

{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .corp-hero {
    --corp-accent: #ff2b2b;
    --corp-dark: #0a0a0a;
    position: relative;
    min-height: min(100vh, 900px);
    min-height: min(100svh, 900px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow-x: clip;
    overflow-y: visible;
    background: var(--corp-dark);
    color: #ffffff;
    font-family: var(--font-family-sans);
  }

  .corp-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .corp-hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.28;
  }

  .corp-hero__mesh {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(ellipse 70% 55% at 78% 42%, rgba(255, 43, 43, 0.32) 0%, transparent 58%),
      radial-gradient(ellipse 45% 35% at 12% 18%, rgba(255, 43, 43, 0.14) 0%, transparent 50%),
      linear-gradient(160deg, #080808 0%, #101010 50%, #140808 100%);
  }

  .corp-hero__grain {
    position: absolute;
    inset: 0;
    z-index: 2;
    opacity: 0.035;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .corp-hero__container {
    position: relative;
    z-index: 5;
    max-width: var(--site-max-width);
    margin: 0 auto;
    width: 100%;
    padding: clamp(110px, 14vh, 150px) max(20px, var(--site-padding, 24px)) clamp(48px, 6vh, 72px);
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: clamp(40px, 6vw, 72px);
    align-items: center;
  }

  .corp-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--corp-accent);
    margin-bottom: 18px;
  }

  .corp-hero__eyebrow::before {
    content: '';
    width: 24px;
    height: 2px;
    background: var(--corp-accent);
  }

  .corp-hero__title {
    font-family: var(--font-family-heading);
    font-size: clamp(56px, 8vw, 104px);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: 0.02em;
    margin: 0 0 22px;
    text-transform: uppercase;
    color: #ffffff !important;
  }

  .corp-hero__title em {
    font-style: normal;
    color: var(--corp-accent);
    display: block;
  }

  .corp-hero__sub {
    font-size: clamp(15px, 1.7vw, 18px);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.75);
    margin: 0 0 32px;
    max-width: 500px;
  }

  .corp-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 40px;
  }

  .corp-hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 30px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
  }

  .corp-hero__btn--primary {
    background: var(--corp-accent);
    color: #ffffff !important;
    box-shadow: 0 10px 36px rgba(255, 43, 43, 0.45);
  }

  .corp-hero__btn--primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 44px rgba(255, 43, 43, 0.55);
  }

  .corp-hero__btn--ghost {
    background: transparent;
    color: #ffffff !important;
    border: 1px solid rgba(255, 255, 255, 0.28);
  }

  .corp-hero__btn--ghost:hover {
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-3px);
  }

  .corp-hero__stats {
    display: flex;
    gap: 0;
    flex-wrap: wrap;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 28px;
  }

  .corp-hero__stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-right: clamp(24px, 4vw, 40px);
    margin-right: clamp(24px, 4vw, 40px);
    border-right: 1px solid rgba(255, 255, 255, 0.1);
  }

  .corp-hero__stat:last-child {
    border-right: none;
    margin-right: 0;
    padding-right: 0;
  }

  .corp-hero__stat-num {
    font-family: var(--font-family-heading);
    font-size: clamp(38px, 4.5vw, 52px);
    line-height: 1;
    color: #ffffff !important;
  }

  .corp-hero__stat-num span {
    color: var(--corp-accent);
  }

  .corp-hero__stat-num__value {
    color: #ffffff !important;
  }

  .corp-hero__stat-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
  }

  /* Showcase Ã¢â‚¬â€ Trishul layout (center + left/right wings behind) */
  .corp-hero__showcase {
    position: relative;
    height: clamp(460px, 62vh, 640px);
    max-width: 680px;
    min-height: 420px;
    margin-left: auto;
    width: 100%;
    overflow: visible;
  }

  .corp-hero__showcase--single {
    height: clamp(380px, 50vh, 520px);
    overflow: hidden;
  }

  .corp-hero__showcase--single .corp-hero__frame {
    position: relative;
    inset: auto;
    width: 100%;
    height: 100%;
    transform: none !important;
    animation: none !important;
    opacity: 1;
  }

  .corp-hero__frame {
    position: absolute;
    border-radius: 18px;
    overflow: hidden;
    background: #1a1a1a;
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow: 0 28px 70px rgba(0, 0, 0, 0.5);
    transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.4s ease;
    will-change: transform;
  }

  .corp-hero__frame:hover {
    box-shadow: 0 36px 80px rgba(0, 0, 0, 0.55);
    z-index: 10 !important;
  }

  /* Center prong Ã¢â‚¬â€ main image */
  .corp-hero__frame--main {
    width: 64%;
    bottom: 6%;
    left: 50%;
    top: auto;
    z-index: 4;
    transform: translateX(-50%) rotate(-1deg);
    animation: corpFrameMain 6s ease-in-out infinite;
  }

  /* Left wing Ã¢â‚¬â€ behind center, popping up-left */
  .corp-hero__frame--back {
    width: 52%;
    bottom: 10%;
    left: -2%;
    top: auto;
    z-index: 1;
    transform: rotate(-16deg) translate(-6%, -18%);
    transform-origin: 85% 88%;
    opacity: 0.92;
    animation: corpFrameLeft 7s ease-in-out infinite;
  }

  /* Right wing Ã¢â‚¬â€ behind center, popping up-right */
  .corp-hero__frame--front {
    width: 52%;
    bottom: 10%;
    right: -2%;
    left: auto;
    top: auto;
    z-index: 2;
    transform: rotate(16deg) translate(6%, -18%);
    transform-origin: 15% 88%;
    opacity: 0.92;
    animation: corpFrameRight 6.5s ease-in-out infinite;
  }

  @keyframes corpFrameMain {
    0%, 100% { transform: translateX(-50%) rotate(-1deg) translateY(0); }
    50% { transform: translateX(-50%) rotate(-1deg) translateY(-10px); }
  }

  @keyframes corpFrameLeft {
    0%, 100% { transform: rotate(-16deg) translate(-6%, -18%); }
    50% { transform: rotate(-14deg) translate(-8%, -24%); }
  }

  @keyframes corpFrameRight {
    0%, 100% { transform: rotate(16deg) translate(6%, -18%); }
    50% { transform: rotate(14deg) translate(8%, -24%); }
  }

  .corp-hero__frame-media {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    background: linear-gradient(145deg, #2a2a2a, #111111);
    overflow: hidden;
  }

  .corp-hero__showcase--single .corp-hero__frame-media {
    aspect-ratio: auto;
    height: 100%;
    min-height: 380px;
  }

  .corp-hero__frame-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .corp-hero__frame:hover .corp-hero__frame-media img {
    transform: scale(1.05);
  }

  .corp-hero__frame-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 8px;
    color: rgba(255, 255, 255, 0.25);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: center;
    padding: 20px;
  }

  .corp-hero__frame-placeholder svg {
    opacity: 0.35;
    margin-bottom: 4px;
  }

  .corp-hero__frame-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.78) 0%, rgba(0, 0, 0, 0.08) 50%, transparent 100%);
    pointer-events: none;
  }

  .corp-hero__frame-caption {
    position: absolute;
    z-index: 2;
    padding: 18px 18px 16px;
    box-sizing: border-box;
  }

  .corp-hero__frame-caption--align-left {
    transform: translate(0, 0);
    text-align: left;
  }

  .corp-hero__frame-caption--align-center {
    transform: translate(-50%, 0);
    text-align: center;
  }

  .corp-hero__frame-caption--align-right {
    transform: translate(-100%, 0);
    text-align: right;
  }

  .corp-hero__frame-tag {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--corp-accent);
    margin: 0 0 4px;
  }

  .corp-hero__frame-title {
    font-size: 14px;
    font-weight: 700;
    color: #ffffff !important;
    margin: 0;
    line-height: 1.3;
  }

  .corp-hero__scroll-hint {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 6;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: rgba(255, 255, 255, 0.35);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    animation: corpScrollBounce 2s ease-in-out infinite;
  }

  @keyframes corpScrollBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(5px); }
  }

  @media screen and (max-width: 1024px) {
    .corp-hero__container {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .corp-hero__sub {
      margin-left: auto;
      margin-right: auto;
    }

    .corp-hero__actions,
    .corp-hero__eyebrow {
      justify-content: center;
    }

    .corp-hero__stats {
      justify-content: center;
    }

    .corp-hero__showcase {
      margin: 0 auto;
      height: 380px;
      max-width: 100%;
    }

    .corp-hero__frame--main {
      width: 68%;
    }

    .corp-hero__frame--back,
    .corp-hero__frame--front {
      width: 48%;
    }
  }

  @media screen and (max-width: 600px) {
    .corp-hero__showcase {
      height: 300px;
    }

    .corp-hero__frame--main {
      width: 72%;
      bottom: 4%;
    }

    .corp-hero__frame--back {
      left: -6%;
      transform: rotate(-14deg) translate(-4%, -14%);
    }

    .corp-hero__frame--front {
      right: -6%;
      transform: rotate(14deg) translate(4%, -14%);
    }

    .corp-hero__scroll-hint {
      display: none;
    }

    .corp-hero__stat {
      padding-right: 20px;
      margin-right: 20px;
    }
  }
{%- endstyle -%}

<section class="corp-hero" id="corp-hero" data-no-typewriter>
  <div class="corp-hero__bg" aria-hidden="true">
    {%- if section.settings.background_image != blank -%}
      <img
        src="{{ section.settings.background_image | image_url: width: 2400 }}"
        class="corp-hero__bg-img"
        alt=""
        loading="eager"
        fetchpriority="high"
        decoding="async"
      >
    {%- endif -%}
  </div>
  <div class="corp-hero__mesh"></div>
  <div class="corp-hero__grain"></div>

  <div class="corp-hero__container">
    <div class="corp-hero__copy">
      <p class="corp-hero__eyebrow">{{ section.settings.eyebrow | default: 'B2B Gifting Studio' }}</p>
      <h1 class="corp-hero__title">
        {{ section.settings.heading_line1 | default: 'Corporate' }}
        <em>{{ section.settings.heading_line2 | default: 'Gifting' }}</em>
      </h1>
      <p class="corp-hero__sub">{{ section.settings.subheading | default: 'Premium sneaker care kits, co-branded for your team, clients, and partners. From onboarding boxes to executive gifts Ã¢â‚¬â€ crafted to impress.' }}</p>

      <div class="corp-hero__actions">
        <a href="{{ section.settings.btn_link | default: '#corp-inquiry' }}" class="corp-hero__btn corp-hero__btn--primary">
          {{ section.settings.btn_label | default: 'Start Your Order' }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        {%- if section.settings.btn2_link != blank -%}
          <a href="{{ section.settings.btn2_link }}" class="corp-hero__btn corp-hero__btn--ghost">{{ section.settings.btn2_label | default: 'Download Catalog' }}</a>
        {%- endif -%}
      </div>

      {%- liquid
        assign stat1_num = section.settings.stat1_num | strip
        assign stat2_num = section.settings.stat2_num | strip
        assign stat3_num = section.settings.stat3_num | strip
        if stat1_num == blank
          assign stat1_num = '500'
        endif
        if stat2_num == blank
          assign stat2_num = '50'
        endif
        if stat3_num == blank
          assign stat3_num = '98'
        endif
      -%}
      <div class="corp-hero__stats">
        <div class="corp-hero__stat">
          <span class="corp-hero__stat-num" data-corp-hero-counter data-corp-hero-counter-value="{{ stat1_num | escape }}">
            <span class="corp-hero__stat-num__value" data-corp-hero-counter-number>{{ stat1_num }}</span><span class="corp-hero__stat-num__suffix" data-corp-hero-counter-suffix>+</span>
          </span>
          <span class="corp-hero__stat-label">{{ section.settings.stat1_label | default: 'Brands Gifted' }}</span>
        </div>
        <div class="corp-hero__stat">
          <span class="corp-hero__stat-num" data-corp-hero-counter data-corp-hero-counter-value="{{ stat2_num | escape }}">
            <span class="corp-hero__stat-num__value" data-corp-hero-counter-number>{{ stat2_num }}</span><span class="corp-hero__stat-num__suffix" data-corp-hero-counter-suffix>K+</span>
          </span>
          <span class="corp-hero__stat-label">{{ section.settings.stat2_label | default: 'Kits Delivered' }}</span>
        </div>
        <div class="corp-hero__stat">
          <span class="corp-hero__stat-num" data-corp-hero-counter data-corp-hero-counter-value="{{ stat3_num | escape }}">
            <span class="corp-hero__stat-num__value" data-corp-hero-counter-number>{{ stat3_num }}</span><span class="corp-hero__stat-num__suffix" data-corp-hero-counter-suffix>%</span>
          </span>
          <span class="corp-hero__stat-label">{{ section.settings.stat3_label | default: 'Satisfaction' }}</span>
        </div>
      </div>
    </div>

    <div class="corp-hero__showcase{% if section.settings.showcase_mode == 'single' %} corp-hero__showcase--single{% endif %}">
      {%- if section.settings.showcase_mode == 'single' and section.settings.single_showcase_image != blank -%}
        <div class="corp-hero__frame corp-hero__frame--main">
          <div class="corp-hero__frame-media">
            <img
              src="{{ section.settings.single_showcase_image | image_url: width: 1000 }}"
              alt="{{ section.settings.single_showcase_caption | escape }}"
              loading="eager"
            >
            <div class="corp-hero__frame-overlay"></div>
            {%- if section.settings.single_showcase_caption != blank -%}
              <div
                class="corp-hero__frame-caption corp-hero__frame-caption--align-{{ section.settings.single_caption_align | default: 'left' }}"
                style="{% render 'hero-caption-position', x: section.settings.single_caption_x, y: section.settings.single_caption_y, align: section.settings.single_caption_align %}"
              >
                {%- if section.settings.single_showcase_tag != blank -%}
                  <p class="corp-hero__frame-tag">{{ section.settings.single_showcase_tag }}</p>
                {%- endif -%}
                <p class="corp-hero__frame-title">{{ section.settings.single_showcase_caption }}</p>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- elsif section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'showcase_image' -%}
            <div
              class="corp-hero__frame corp-hero__frame--{{ block.settings.position | default: 'main' }}"
              {{ block.shopify_attributes }}
            >
              <div class="corp-hero__frame-media">
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 900 }}"
                    alt="{{ block.settings.caption | default: block.settings.tag | escape }}"
                    loading="{% if block.settings.position == 'main' %}eager{% else %}lazy{% endif %}"
                  >
                {%- else -%}
                  <div class="corp-hero__frame-placeholder">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><circle cx="8.5" cy="10" r="1.5" fill="currentColor"/><path d="M3 16l5-5 4 4 3-3 6 6" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                    Add image in theme editor
                  </div>
                {%- endif -%}
                <div class="corp-hero__frame-overlay"></div>
                {%- if block.settings.tag != blank or block.settings.caption != blank -%}
                  <div
                    class="corp-hero__frame-caption corp-hero__frame-caption--align-{{ block.settings.caption_align | default: 'left' }}"
                    style="{% render 'hero-caption-position', x: block.settings.caption_x, y: block.settings.caption_y, align: block.settings.caption_align %}"
                  >
                    {%- if block.settings.tag != blank -%}
                      <p class="corp-hero__frame-tag">{{ block.settings.tag }}</p>
                    {%- endif -%}
                    {%- if block.settings.caption != blank -%}
                      <p class="corp-hero__frame-title">{{ block.settings.caption }}</p>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Legacy settings fallback {%- endcomment -%}
        <div class="corp-hero__frame corp-hero__frame--back">
          <div class="corp-hero__frame-media">
            {%- if section.settings.card_image_2 != blank -%}
              <img src="{{ section.settings.card_image_2 | image_url: width: 700 }}" alt="Co-Branded">
            {%- else -%}
              <div class="corp-hero__frame-placeholder"><svg width="32" height="32" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/></svg>Add back image</div>
            {%- endif -%}
            <div class="corp-hero__frame-overlay"></div>
            <div class="corp-hero__frame-caption corp-hero__frame-caption--align-left" style="{% render 'hero-caption-position', x: 0, y: 75, align: 'left' %}">
              <p class="corp-hero__frame-tag">Co-Branded</p>
              <p class="corp-hero__frame-title">Your Logo. Our Quality.</p>
            </div>
          </div>
        </div>
        <div class="corp-hero__frame corp-hero__frame--main">
          <div class="corp-hero__frame-media">
            {%- if section.settings.card_image_1 != blank -%}
              <img src="{{ section.settings.card_image_1 | image_url: width: 900 }}" alt="Premium Kit">
            {%- else -%}
              <div class="corp-hero__frame-placeholder" style="background:linear-gradient(145deg,#ff2b2b,#8b0000);"><svg width="32" height="32" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/></svg>Add main image</div>
            {%- endif -%}
            <div class="corp-hero__frame-overlay"></div>
            <div class="corp-hero__frame-caption corp-hero__frame-caption--align-left" style="{% render 'hero-caption-position', x: 0, y: 75, align: 'left' %}">
              <p class="corp-hero__frame-tag">Premium Kit</p>
              <p class="corp-hero__frame-title">Executive Gift Box</p>
            </div>
          </div>
        </div>
        <div class="corp-hero__frame corp-hero__frame--front">
          <div class="corp-hero__frame-media">
            {%- if section.settings.card_image_3 != blank -%}
              <img src="{{ section.settings.card_image_3 | image_url: width: 600 }}" alt="Bulk">
            {%- else -%}
              <div class="corp-hero__frame-placeholder"><svg width="32" height="32" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/></svg>Add front image</div>
            {%- endif -%}
            <div class="corp-hero__frame-overlay"></div>
            <div class="corp-hero__frame-caption corp-hero__frame-caption--align-left" style="{% render 'hero-caption-position', x: 0, y: 75, align: 'left' %}">
              <p class="corp-hero__frame-tag">Bulk</p>
              <p class="corp-hero__frame-title">Team Onboarding</p>
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>

  <div class="corp-hero__scroll-hint" aria-hidden="true">
    <span>{{ section.settings.scroll_hint | default: 'Explore' }}</span>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12l7 7 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </div>
</section>

<script>
  (function () {
    function parseCounterValue(raw) {
      const match = String(raw || '').trim().match(/^(\d+)/);
      return match ? parseInt(match[1], 10) : NaN;
    }

    function animateHeroCounter(counterEl) {
      if (!counterEl || counterEl.dataset.corpHeroCounterReady === 'true') return;

      const numberEl = counterEl.querySelector('[data-corp-hero-counter-number]');
      const rawValue = counterEl.getAttribute('data-corp-hero-counter-value') || (numberEl ? numberEl.textContent : '');
      const target = parseCounterValue(rawValue);

      if (!numberEl || isNaN(target)) return;

      counterEl.dataset.corpHeroCounterReady = 'true';

      const showTarget = function () {
        numberEl.textContent = String(target);
      };

      if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        showTarget();
        return;
      }

      if (target <= 1) {
        showTarget();
        return;
      }

      const duration = 1800;
      const start = performance.now();
      numberEl.textContent = '1';

      function tick(now) {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.max(1, Math.round(1 + (target - 1) * eased));
        numberEl.textContent = String(current);

        if (progress < 1) {
          requestAnimationFrame(tick);
        } else {
          showTarget();
        }
      }

      requestAnimationFrame(tick);
    }

    function initHeroCounters(root) {
      const scope = root && root.querySelectorAll ? root : document;
      scope.querySelectorAll('[data-corp-hero-counter]').forEach(animateHeroCounter);

      scope.querySelectorAll('.corp-hero [data-corp-count]').forEach(function (el) {
        if (el.dataset.counted === 'true') return;

        const target = parseCounterValue(el.getAttribute('data-corp-count') || el.textContent);
        if (isNaN(target)) return;

        const suffix = el.querySelector('span');
        const suffixHTML = suffix ? suffix.outerHTML : '';
        el.dataset.counted = 'true';

        const showTarget = function () {
          el.innerHTML = String(target) + suffixHTML;
        };

        if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          showTarget();
          return;
        }

        if (target <= 1) {
          showTarget();
          return;
        }

        const duration = 1800;
        const start = performance.now();
        el.innerHTML = '1' + suffixHTML;

        function tick(now) {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = Math.max(1, Math.round(1 + (target - 1) * eased));
          el.innerHTML = String(current) + suffixHTML;

          if (progress < 1) {
            requestAnimationFrame(tick);
          } else {
            showTarget();
          }
        }

        requestAnimationFrame(tick);
      });
    }

    initHeroCounters();
    document.addEventListener('DOMContentLoaded', function () {
      initHeroCounters();
    });
    document.addEventListener('shopify:section:load', function (event) {
      if (event.target) initHeroCounters(event.target);
    });
  })();
</script>


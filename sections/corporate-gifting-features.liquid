{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .corp-features {
    padding: clamp(80px, 10vw, 120px) 0;
    background: #ffffff;
    font-family: var(--font-family-sans);
  }

  .corp-features__container {
    max-width: var(--site-max-width);
    margin: 0 auto;
    padding: 0 max(20px, var(--site-padding, 24px));
  }

  .corp-features__header {
    text-align: center;
    margin: 0 auto clamp(40px, 6vw, 64px);
    max-width: 640px;
  }

  .corp-features__eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #e74c3c;
    margin: 0 0 12px;
  }

  .corp-features__heading {
    font-family: var(--font-family-heading);
    font-size: clamp(40px, 5.5vw, 64px);
    font-weight: 400;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #111111 !important;
    margin: 0 0 16px;
    line-height: 1;
  }

  .corp-features__sub {
    font-size: 16px;
    line-height: 1.65;
    color: #565656;
    margin: 0;
  }

  /* Bento grid Ã¢â‚¬â€ fixed 3-row layout */
  .corp-bento {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-template-rows: repeat(3, minmax(200px, auto));
    gap: 20px;
  }

  .corp-bento__item {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: #f5f5f5;
    border: 1px solid #e8e8e8;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 200px;
    opacity: 1 !important;
    visibility: visible !important;
    transform: none !important;
    transition: box-shadow 0.3s ease;
  }

  .corp-bento__item:hover {
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.1);
  }

  /* Explicit grid placement */
  .corp-bento__item--pos-1 { grid-column: 1 / 7; grid-row: 1 / 3; min-height: 420px; }
  .corp-bento__item--pos-2 { grid-column: 7 / 13; grid-row: 1 / 2; min-height: 200px; }
  .corp-bento__item--pos-3 { grid-column: 7 / 13; grid-row: 2 / 3; min-height: 200px; }
  .corp-bento__item--pos-4 { grid-column: 1 / 5; grid-row: 3 / 4; min-height: 200px; }
  .corp-bento__item--pos-5 { grid-column: 5 / 13; grid-row: 3 / 4; min-height: 200px; }

  /* Card themes */
  .corp-bento__item--dark {
    background: #111111;
    border-color: #111111;
    justify-content: flex-start;
    padding: 32px;
  }

  .corp-bento__item--light {
    background: #f0eeeb;
    border-color: #e0ddd8;
    justify-content: flex-start;
    padding: 32px;
  }

  .corp-bento__item--red {
    background: linear-gradient(145deg, #ff2b2b 0%, #a00000 100%);
    border-color: #ff2b2b;
  }

  .corp-bento__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .corp-bento__media,
  .corp-bento__media > div {
    width: 100%;
    height: 100%;
  }

  .corp-bento__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .corp-bento__item:hover .corp-bento__media img {
    transform: scale(1.04);
  }

  .corp-bento__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.82) 0%, rgba(0, 0, 0, 0.25) 55%, rgba(0, 0, 0, 0.05) 100%);
    z-index: 1;
  }

  .corp-bento__item--red .corp-bento__media::after {
    background: linear-gradient(to top, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.1) 60%, transparent 100%);
  }

  .corp-bento__content {
    position: relative;
    z-index: 2;
    padding: 28px;
  }

  .corp-bento__item--dark .corp-bento__content,
  .corp-bento__item--light .corp-bento__content {
    padding: 0;
  }

  .corp-bento__icon {
    width: 44px;
    height: 44px;
    margin-bottom: 20px;
    color: #ff2b2b;
    flex-shrink: 0;
  }

  .corp-bento__item--dark .corp-bento__icon {
    color: #ff2b2b;
  }

  .corp-bento__num {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    color: #ff2b2b;
    margin: 0 0 10px;
  }

  .corp-bento__title {
    font-family: var(--font-family-heading) !important;
    font-size: clamp(22px, 2.8vw, 32px) !important;
    font-weight: 400 !important;
    letter-spacing: 0.04em !important;
    text-transform: uppercase !important;
    margin: 0 0 8px !important;
    line-height: 1.05 !important;
    color: #111111 !important;
  }

  .corp-bento__text {
    font-size: 14px;
    line-height: 1.6;
    color: #666666 !important;
    margin: 0;
    max-width: 420px;
  }

  /* White text on dark / image / red cards */
  .corp-bento__item--dark .corp-bento__title,
  .corp-bento__item--dark h3,
  .corp-bento__item--media .corp-bento__title,
  .corp-bento__item--media h3,
  .corp-bento__item--red .corp-bento__title,
  .corp-bento__item--red h3 {
    color: #ffffff !important;
  }

  .corp-bento__item--dark .corp-bento__text,
  .corp-bento__item--media .corp-bento__text,
  .corp-bento__item--red .corp-bento__text {
    color: rgba(255, 255, 255, 0.72);
  }

  .corp-bento__item--dark .corp-bento__num,
  .corp-bento__item--media .corp-bento__num,
  .corp-bento__item--red .corp-bento__num {
    color: #ff2b2b;
  }

  .corp-bento__item--light .corp-bento__title,
  .corp-bento__item--light h3 {
    color: #111111 !important;
  }

  .corp-bento__item--light .corp-bento__text {
    color: #555555;
  }

  @media screen and (max-width: 1024px) {
    .corp-bento {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }

    .corp-bento__item--pos-1,
    .corp-bento__item--pos-2,
    .corp-bento__item--pos-3,
    .corp-bento__item--pos-4,
    .corp-bento__item--pos-5 {
      grid-column: 1 / -1;
      grid-row: auto;
      min-height: 260px;
    }

    .corp-bento__item--pos-1 {
      min-height: 320px;
    }
  }
{%- endstyle -%}

<section class="corp-features" data-no-typewriter>
  <div class="corp-features__container">
    <div class="corp-features__header">
      <p class="corp-features__eyebrow">{{ section.settings.eyebrow | default: "What's Possible" }}</p>
      <h2 class="corp-features__heading">{{ section.settings.heading | default: 'Built for Brands That Care' }}</h2>
      <p class="corp-features__sub">{{ section.settings.subheading | default: 'Every detail Ã¢â‚¬â€ from co-branded packaging to bulk logistics Ã¢â‚¬â€ designed to make your gift unforgettable.' }}</p>
    </div>

    <div class="corp-bento">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- liquid
            assign pos = 'pos-1'
            case forloop.index
              when 2
                assign pos = 'pos-2'
              when 3
                assign pos = 'pos-3'
              when 4
                assign pos = 'pos-4'
              when 5
                assign pos = 'pos-5'
            endcase

            assign theme = 'media'
            if block.settings.dark_card
              assign theme = 'dark'
            elsif block.settings.red_card
              assign theme = 'red'
            elsif block.settings.light_card
              assign theme = 'light'
            endif
          -%}
          <div
            class="corp-bento__item corp-bento__item--{{ pos }} corp-bento__item--{{ theme }}{% if block.settings.image != blank %} corp-bento__item--has-img{% endif %}"
            data-corp-bento
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank -%}
              <div class="corp-bento__media">
                <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
              </div>
            {%- elsif theme == 'media' -%}
              <div class="corp-bento__media" aria-hidden="true">
                <div style="width:100%;height:100%;background:linear-gradient(135deg,#2a2a2a,#111);"></div>
              </div>
            {%- endif -%}
            <div class="corp-bento__content">
              {%- if theme == 'dark' or theme == 'light' -%}
                {%- if block.settings.show_icon != false -%}
                  <svg class="corp-bento__icon" viewBox="0 0 48 48" fill="none" aria-hidden="true"><rect x="8" y="14" width="32" height="24" rx="4" stroke="currentColor" stroke-width="2"/><path d="M8 20h32" stroke="currentColor" stroke-width="2"/></svg>
                {%- endif -%}
              {%- endif -%}
              <p class="corp-bento__num">{% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}</p>
              <h3 class="corp-bento__title">{{ block.settings.title }}</h3>
              <p class="corp-bento__text">{{ block.settings.text }}</p>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="corp-bento__item corp-bento__item--pos-1 corp-bento__item--media" data-corp-bento>
          <div class="corp-bento__media" aria-hidden="true">
            <div style="width:100%;height:100%;background:linear-gradient(135deg,#2a2a2a,#111);"></div>
          </div>
          <div class="corp-bento__content">
            <p class="corp-bento__num">01</p>
            <h3 class="corp-bento__title">Co-Branding</h3>
            <p class="corp-bento__text">Make our products your own. Partner with Hague Protect for co-branded kits that reflect your brand identity.</p>
          </div>
        </div>
        <div class="corp-bento__item corp-bento__item--pos-2 corp-bento__item--dark" data-corp-bento>
          <div class="corp-bento__content">
            <svg class="corp-bento__icon" viewBox="0 0 48 48" fill="none" aria-hidden="true"><rect x="8" y="14" width="32" height="24" rx="4" stroke="currentColor" stroke-width="2"/><path d="M8 20h32M16 14V10a4 4 0 018 0v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            <p class="corp-bento__num">02</p>
            <h3 class="corp-bento__title">Premium Packaging</h3>
            <p class="corp-bento__text">Exquisite presentation for corporate gifting that leaves a lasting impression on clients and partners.</p>
          </div>
        </div>
        <div class="corp-bento__item corp-bento__item--pos-3 corp-bento__item--red" data-corp-bento>
          <div class="corp-bento__media" aria-hidden="true"></div>
          <div class="corp-bento__content">
            <p class="corp-bento__num">03</p>
            <h3 class="corp-bento__title">Bulk Discounts</h3>
            <p class="corp-bento__text">Special pricing and dedicated support for large volume orders.</p>
          </div>
        </div>
        <div class="corp-bento__item corp-bento__item--pos-4 corp-bento__item--light" data-corp-bento>
          <div class="corp-bento__content">
            <svg class="corp-bento__icon" viewBox="0 0 48 48" fill="none" aria-hidden="true"><circle cx="24" cy="24" r="16" stroke="currentColor" stroke-width="2"/><path d="M24 16v8l6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            <p class="corp-bento__num">04</p>
            <h3 class="corp-bento__title">Fast Turnaround</h3>
            <p class="corp-bento__text">From brief to delivery in as little as 7 business days for standard orders.</p>
          </div>
        </div>
        <div class="corp-bento__item corp-bento__item--pos-5 corp-bento__item--media" data-corp-bento>
          <div class="corp-bento__media" aria-hidden="true">
            <div style="width:100%;height:100%;background:linear-gradient(135deg,#1a1a1a,#333);"></div>
          </div>
          <div class="corp-bento__content">
            <p class="corp-bento__num">05</p>
            <h3 class="corp-bento__title">Pan-India Delivery</h3>
            <p class="corp-bento__text">Ship to multiple locations with tracking, GST invoicing, and consolidated billing.</p>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>


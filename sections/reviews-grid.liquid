{%- style -%}
  .reviews-sec {
    background-color: #fafafc;
    padding: clamp(40px, 6vw, 80px) 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .reviews-sec__container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .reviews-sec__header {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .reviews-sec__heading {
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 800;
    color: #111;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .reviews-sec__summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .reviews-sec__summary-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .reviews-sec__stars-group {
    display: flex;
    gap: 3px;
    color: #FFB300;
  }

  .reviews-sec__stars-group svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  .reviews-sec__summary-text {
    font-size: 15px;
    font-weight: 600;
    color: #333333;
    display: flex;
    align-items: center;
    gap: 4px;
    cursor: pointer;
  }

  .reviews-sec__summary-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .reviews-sec__btn-write {
    background: transparent;
    color: #111;
    border: 1px solid #d9d9d9;
    border-radius: 8px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .reviews-sec__btn-write:hover {
    background: #f0f0f0;
  }

  .reviews-sec__btn-filter {
    background: transparent;
    color: #111;
    border: 1px solid #d9d9d9;
    border-radius: 8px;
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .reviews-sec__btn-filter:hover {
    background: #f0f0f0;
  }

  /* Masonry columns */
  .reviews-sec__masonry {
    column-count: 4;
    column-gap: 20px;
    width: 100%;
  }

  @media screen and (max-width: 1200px) {
    .reviews-sec__masonry {
      column-count: 3;
    }
  }

  @media screen and (max-width: 800px) {
    .reviews-sec__masonry {
      column-count: 2;
      column-gap: 12px;
    }
  }

  .reviews-sec__card {
    background: #ffffff;
    border: 1px solid #e9e9eb;
    border-radius: 12px;
    overflow: hidden;
    break-inside: avoid;
    margin-bottom: 20px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.02);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  @media screen and (max-width: 800px) {
    .reviews-sec__card {
      margin-bottom: 12px;
    }
  }

  .reviews-sec__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
  }

  .reviews-sec__media {
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .reviews-sec__image {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }

  .reviews-sec__play-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 48px;
    height: 48px;
    background: rgba(0, 0, 0, 0.4);
    border-radius: 50%;
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    border: 1.5px solid #ffffff;
  }

  .reviews-sec__play-icon svg {
    width: 16px;
    height: 16px;
    fill: #ffffff;
    margin-left: 3px;
  }

  .reviews-sec__info {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .reviews-sec__author-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px;
  }

  .reviews-sec__author-name {
    font-size: 14px;
    font-weight: 700;
    color: #111;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .reviews-sec__verified-badge {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 11px;
    font-weight: 600;
    color: #388E3C;
    background: #E8F5E9;
    padding: 2px 6px;
    border-radius: 4px;
  }

  .reviews-sec__date {
    font-size: 12px;
    color: #888888;
  }

  .reviews-sec__review-stars {
    display: flex;
    gap: 2px;
    color: #FFB300;
  }

  .reviews-sec__review-stars svg {
    width: 14px;
    height: 14px;
    fill: currentColor;
  }

  .reviews-sec__review-title {
    font-size: 14px;
    font-weight: 700;
    color: #111;
    margin: 0;
    line-height: 1.3;
  }

  .reviews-sec__review-body {
    font-size: 13px;
    color: #444444;
    line-height: 1.5;
    margin: 0;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .reviews-sec__item-type {
    font-size: 11px;
    color: #888888;
    margin-top: 4px;
  }

  .reviews-sec__item-type strong {
    color: #555555;
  }
{%- endstyle -%}

<div class="reviews-sec">
  <div class="reviews-sec__container">
    <div class="reviews-sec__header">
      <h2 class="reviews-sec__heading">{{ section.settings.heading | default: 'People Love Hague Protect' }}</h2>
      
      <div class="reviews-sec__summary-row">
        <div class="reviews-sec__summary-left">
          <div class="reviews-sec__stars-group">
            {%- for i in (1..5) -%}
              <svg viewBox="0 0 24 24"><path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.399 8.165-7.333-3.856-7.333 3.856 1.399-8.165-5.934-5.784 8.2-1.192zm0 0"/></svg>
            {%- endfor -%}
          </div>
          <span class="reviews-sec__summary-text">
            {{ section.settings.total_reviews | default: '201 Reviews' }}
            <svg style="width:10px; height:6px; fill:#333;" viewBox="0 0 10 6"><path d="M5 6L0 1.154 1.192 0 5 3.692 8.808 0 10 1.154z"/></svg>
          </span>
        </div>

        <div class="reviews-sec__summary-right">
          <a href="#" class="reviews-sec__btn-write">Write a review</a>
          <button type="button" class="reviews-sec__btn-filter">
            <svg style="width:16px; height:16px; fill:#111;" viewBox="0 0 16 16"><path d="M0 3h16v2H0V3zm0 4h16v2H0V7zm0 4h16v2H0v-2z"/></svg>
          </button>
        </div>
      </div>
    </div>

    <div class="reviews-sec__masonry">
      {%- for block in section.blocks -%}
        <div class="reviews-sec__card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="reviews-sec__media">
              <img src="{{ block.settings.image | image_url: width: 600 }}" alt="Review Image" class="reviews-sec__image" loading="lazy">
              {%- if block.settings.has_video -%}
                <div class="reviews-sec__play-icon">
                  <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}

          <div class="reviews-sec__info">
            <div class="reviews-sec__author-row">
              <div class="reviews-sec__author-name">
                {{ block.settings.author | default: 'Arpan A.' }}
                {%- if block.settings.is_verified -%}
                  <span class="reviews-sec__verified-badge">
                    <svg style="width:10px; height:10px; fill:#388E3C;" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                    Verified
                  </span>
                {%- endif -%}
              </div>
              <div class="reviews-sec__date">{{ block.settings.date | default: '4/24/2026' }}</div>
            </div>

            <div class="reviews-sec__review-stars">
              {%- assign stars = block.settings.rating | default: 5 -%}
              {%- for i in (1..stars) -%}
                <svg viewBox="0 0 24 24"><path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.399 8.165-7.333-3.856-7.333 3.856 1.399-8.165-5.934-5.784 8.2-1.192zm0 0"/></svg>
              {%- endfor -%}
            </div>

            {%- if block.settings.title != blank -%}
              <h3 class="reviews-sec__review-title">{{ block.settings.title }}</h3>
            {%- endif -%}

            <p class="reviews-sec__review-body">{{ block.settings.text | default: 'This sneaker cleaning solution is the absolute best. Safe on delicate suede and it leaves no residue at all.' }}</p>

            {%- if block.settings.item_type != blank -%}
              <div class="reviews-sec__item-type">Item type: <strong>{{ block.settings.item_type }}</strong></div>
            {%- endif -%}
          </div>
        </div>
      {%- else -%}
        <!-- Fallback cards for the editor -->
        {%- assign sample_names = "Arpan A.|Shahbaz M.|Rukshana A.|Anjali Singh" | split: "|" -%}
        {%- assign sample_dates = "4/24/2026|3/21/2026|2/20/2026|12/11/2025" | split: "|" -%}
        {%- assign sample_texts = "Incredible result. Safe on all premium sneakers, exactly as advertised.|Cleaned my old worn kicks in minutes without stiffening the material.|Our new go-to shoe cleaner. No bad chemical smells and works like a charm.|Instantly restores the original vibrance without fading any colors at all." | split: "|" -%}
        {%- assign sample_types = "Tokyo Totti Candy|Lemonade Yellow|Ivory Metal Grey|Classic Shield" | split: "|" -%}
        
        {%- for i in (0..3) -%}
          <div class="reviews-sec__card">
            <div class="reviews-sec__info">
              <div class="reviews-sec__author-row">
                <div class="reviews-sec__author-name">
                  {{ sample_names[i] }}
                  <span class="reviews-sec__verified-badge">
                    <svg style="width:10px; height:10px; fill:#388E3C;" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                    Verified
                  </span>
                </div>
                <div class="reviews-sec__date">{{ sample_dates[i] }}</div>
              </div>

              <div class="reviews-sec__review-stars">
                {%- for j in (1..5) -%}
                  <svg viewBox="0 0 24 24"><path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.399 8.165-7.333-3.856-7.333 3.856 1.399-8.165-5.934-5.784 8.2-1.192zm0 0"/></svg>
                {%- endfor -%}
              </div>

              <p class="reviews-sec__review-body">{{ sample_texts[i] }}</p>

              <div class="reviews-sec__item-type">Item type: <strong>{{ sample_types[i] }}</strong></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Social Proof Masonry Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "People Love Hague Protect"
    },
    {
      "type": "text",
      "id": "total_reviews",
      "label": "Summary Text",
      "default": "201 Reviews"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Customer Review Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Review Image/Thumbnail"
        },
        {
          "type": "checkbox",
          "id": "has_video",
          "label": "Has Video (Shows Play Icon on Image)",
          "default": false
        },
        {
          "type": "text",
          "id": "author",
          "label": "Customer Name",
          "default": "Julian A."
        },
        {
          "type": "checkbox",
          "id": "is_verified",
          "label": "Verified Buyer",
          "default": true
        },
        {
          "type": "text",
          "id": "date",
          "label": "Review Date",
          "default": "4/24/2026"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Stars Rating",
          "default": 5
        },
        {
          "type": "text",
          "id": "title",
          "label": "Review Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review Body Text",
          "default": "This sneaker cleaning solution is the absolute best. Safe on delicate suede and it leaves no residue at all."
        },
        {
          "type": "text",
          "id": "item_type",
          "label": "Variant/Item Type"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social Proof Masonry Grid",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "author": "Julian A.",
            "date": "4/24/2026",
            "rating": 5,
            "text": "This sneaker cleaning solution is the absolute best. Safe on delicate suede and it leaves no residue at all."
          }
        }
      ]
    }
  ]
}
{% endschema %}

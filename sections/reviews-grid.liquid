{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .reviews-sec {
    background-color: #fafafc;
    padding: clamp(40px, 6vw, 80px) 0;
    font-family: var(--font-family-sans);
  }

  .reviews-sec__container {
    max-width: var(--site-max-width);
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .reviews-sec__header {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .reviews-sec__heading {
    font-family: var(--font-family-h2, var(--font-family-heading));
    font-size: var(--section-heading-size);
    font-weight: var(--font-weight-h2, 800);
    font-style: var(--font-style-h2, normal);
    color: #111;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .reviews-sec__summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .reviews-sec__summary-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .reviews-sec__stars-group {
    display: flex;
    gap: 3px;
    color: #FFB300;
  }

  .reviews-sec__stars-group svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  .reviews-sec__summary-text {
    font-size: 15px;
    font-weight: 600;
    color: #333333;
    display: flex;
    align-items: center;
    gap: 4px;
    cursor: pointer;
  }

  .reviews-sec__summary-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .reviews-sec__btn-write {
    background: transparent;
    color: #111;
    border: 1px solid #d9d9d9;
    border-radius: 8px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .reviews-sec__btn-write:hover {
    background: #f0f0f0;
  }

  .reviews-sec__btn-filter {
    background: transparent;
    color: #111;
    border: 1px solid #d9d9d9;
    border-radius: 8px;
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .reviews-sec__btn-filter:hover {
    background: #f0f0f0;
  }

  /* Masonry columns */
  .reviews-sec__masonry {
    column-count: 4;
    column-gap: 20px;
    width: 100%;
  }

  @media screen and (max-width: 1200px) {
    .reviews-sec__masonry {
      column-count: 3;
    }
  }

  @media screen and (max-width: 800px) {
    .reviews-sec__masonry {
      column-count: 2;
      column-gap: 12px;
    }
  }

  .reviews-sec__card {
    background: #ffffff;
    border: 1px solid #e9e9eb;
    border-radius: 12px;
    overflow: hidden;
    break-inside: avoid;
    margin-bottom: 20px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.02);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  @media screen and (max-width: 800px) {
    .reviews-sec__card {
      margin-bottom: 12px;
    }
  }

  .reviews-sec__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
  }

  .reviews-sec__media {
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .reviews-sec__image {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }

  .reviews-sec__play-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 48px;
    height: 48px;
    background: rgba(0, 0, 0, 0.4);
    border-radius: 50%;
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    border: 1.5px solid #ffffff;
  }

  .reviews-sec__play-icon svg {
    width: 16px;
    height: 16px;
    fill: #ffffff;
    margin-left: 3px;
  }

  .reviews-sec__info {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .reviews-sec__author-name {
    font-size: 14px;
    font-weight: 700;
    color: #111;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .reviews-sec__verified-badge {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 11px;
    font-weight: 600;
    color: #616161;
  }

  .reviews-sec__date {
    font-size: 11px;
    color: #888888;
    margin-top: 2px;
  }

  .reviews-sec__review-stars {
    display: flex;
    gap: 2px;
    color: #FFB300;
    margin-top: 2px;
  }

  .reviews-sec__review-stars svg {
    width: 13px;
    height: 13px;
    fill: currentColor;
  }

  .reviews-sec__review-title {
    font-size: 13px;
    font-weight: 700;
    color: #111;
    margin: 4px 0 0;
    line-height: 1.3;
  }

  .reviews-sec__review-body {
    font-size: 13px;
    color: #444444;
    line-height: 1.5;
    margin: 4px 0 0;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .reviews-sec__item-type {
    font-size: 11px;
    color: #888888;
    margin-top: 8px;
  }

  .reviews-sec__item-type strong {
    color: #555555;
  }
{%- endstyle -%}

<div class="reviews-sec">
  <div class="reviews-sec__container">
    <div class="reviews-sec__header">
      <h2 class="reviews-sec__heading">{{ section.settings.heading | default: 'People Love BFF' }}</h2>
      
      <div class="reviews-sec__summary-row">
        <div class="reviews-sec__summary-left">
          <div class="reviews-sec__stars-group">
            {%- for i in (1..5) -%}
              <svg viewBox="0 0 24 24"><path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.399 8.165-7.333-3.856-7.333 3.856 1.399-8.165-5.934-5.784 8.2-1.192zm0 0"/></svg>
            {%- endfor -%}
          </div>
          <span class="reviews-sec__summary-text">
            {{ section.settings.total_reviews | default: '201 Reviews' }}
            <svg style="width:10px; height:6px; fill:#333;" viewBox="0 0 10 6"><path d="M5 6L0 1.154 1.192 0 5 3.692 8.808 0 10 1.154z"/></svg>
          </span>
        </div>

        <div class="reviews-sec__summary-right">
          <a href="#" class="reviews-sec__btn-write">Write a review</a>
          <button type="button" class="reviews-sec__btn-filter">
            <svg style="width:16px; height:16px; fill:#111;" viewBox="0 0 16 16"><path d="M0 3h16v2H0V3zm0 4h16v2H0V7zm0 4h16v2H0v-2z"/></svg>
          </button>
        </div>
      </div>
    </div>

    <div class="reviews-sec__masonry">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            <div class="reviews-sec__app-block" {{ block.shopify_attributes }} style="break-inside: avoid; margin-bottom: 20px;">
              {% render block %}
            </div>
          {%- when 'review' -%}
            <div class="reviews-sec__card" {{ block.shopify_attributes }}>
              {%- if block.settings.video != blank or block.settings.video_url != blank or block.settings.image != blank -%}
                <div class="reviews-sec__media">
                  {%- if block.settings.video != blank -%}
                    {{ block.settings.video | video_tag: autoplay: false, loop: true, muted: true, playsinline: true, controls: true, class: "reviews-sec__image" }}
                  {%- elsif block.settings.video_url != blank -%}
                    {%- if block.settings.video_url.type == 'youtube' -%}
                      <iframe src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen class="reviews-sec__image" style="aspect-ratio:16/9; border:0;"></iframe>
                    {%- elsif block.settings.video_url.type == 'vimeo' -%}
                      <iframe src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen class="reviews-sec__image" style="aspect-ratio:16/9; border:0;"></iframe>
                    {%- endif -%}
                  {%- elsif block.settings.image != blank -%}
                    <img src="{{ block.settings.image | image_url: width: 600 }}" alt="Review Image" class="reviews-sec__image" loading="lazy">
                    {%- if block.settings.has_video -%}
                      <div class="reviews-sec__play-icon">
                        <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                      </div>
                    {%- endif -%}
                  {%- endif -%}
                </div>
              {%- endif -%}

              <div class="reviews-sec__info">
                <div class="reviews-sec__author-name">
                  {{ block.settings.author | default: 'Arpan A.' }}
                  {%- if block.settings.is_verified -%}
                    <span class="reviews-sec__verified-badge">
                      <svg style="width:12px; height:12px; fill:#616161;" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                      Verified
                    </span>
                  {%- endif -%}
                </div>
                
                <div class="reviews-sec__date">{{ block.settings.date | default: '4/24/2026' }}</div>

                <div class="reviews-sec__review-stars">
                  {%- assign stars = block.settings.rating | default: 5 -%}
                  {%- for i in (1..stars) -%}
                    <svg viewBox="0 0 24 24"><path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.399 8.165-7.333-3.856-7.333 3.856 1.399-8.165-5.934-5.784 8.2-1.192zm0 0"/></svg>
                  {%- endfor -%}
                </div>

                {%- if block.settings.title != blank -%}
                  <h3 class="reviews-sec__review-title">{{ block.settings.title }}</h3>
                {%- endif -%}

                <p class="reviews-sec__review-body">{{ block.settings.text | default: 'nice product' }}</p>

                {%- if block.settings.item_type != blank -%}
                  <div class="reviews-sec__item-type">Item type: <strong>{{ block.settings.item_type }}</strong></div>
                {%- endif -%}
              </div>
            </div>
        {%- endcase -%}
      {%- else -%}
        <!-- Dynamic Fallbacks -->
        {%- assign sample_names = "Arpan A.|Shahbaz M.|Rukshana A.|Anjali Singh|Debadutta D.|Akshith G.|Anjana J.|Hansel|Ramakrishna R.|Er Gurminder D.|Natasha R.|Ridham P.|Gagan Y.|Apin F." | split: "|" -%}
        {%- assign sample_dates = "4/24/2026|3/21/2026|2/20/2026|12/11/2025|10/8/2025|8/24/2025|10/2/2025|12/12/2025|7/24/2025|7/28/2025|7/23/2025|7/18/2025|7/2/2025|6/14/2025" | split: "|" -%}
        {%- assign sample_texts = "nice product|build quality 5/5. overall product is great|Our new go-to cleaner. Truly remarkable formula|The best part of the product is its efficiency. Must buy.|one of a kind product. I love this. Will buy again.|absolutely thrilled. Compact, lightweight, surprisingly powerful.|Love the formula. Hand and shoes are safe. Super premium.|I love everything about it. It works smoothly, looks great, and exceeded my expectations.|Very handy. Elite cleaner. The BLDC motor is a marvel.|It's a very compact travel kit. Its unique feature is safe on suede.|I wasn't sure about spending this muchÃ¢â‚¬â€but OMG I'm so glad I did! The quality is top notch.|excellent|I spent a lot of time thinking if I should spend that much money but it was worth the quality.|It was awesome. My wife loved it." | split: "|" -%}
        {%- assign sample_types = "Classic Kit|Ivory Metal Grey|Tokyo Totti Candy|Classic Shield|Maluku Green|Ivory Metal Grey|Lemonade Yellow|Blackpink Grey|Maluku Green|Blackpink Grey|Ivory Metal Grey|Classic Shield|Maluku Green|Lemonade Yellow" | split: "|" -%}
        
        {%- for i in (0..13) -%}
          <div class="reviews-sec__card">
            <div class="reviews-sec__media">
              <div class="reviews-sec__image reviews-sec__fallback-media" style="background: #f1f1f1; aspect-ratio: 4/5; width: 100%; display: flex; align-items: center; justify-content: center; position: relative;">
                <svg style="width: 32px; height: 32px; fill: #9e9e9e;" viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-5.04-6.71l-2.75 3.54-1.96-2.36L6.5 17h11l-3.54-4.71z"/></svg>
                <div class="reviews-sec__play-icon" style="background: rgba(0,0,0,0.45); border: 1px solid #fff; border-radius: 50%; width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; position: absolute;">
                  <svg style="width: 14px; height: 14px; fill: #ffffff; margin-left: 2px;" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
            </div>
            <div class="reviews-sec__info">
              <div class="reviews-sec__author-name">
                {{ sample_names[i] }}
                <span class="reviews-sec__verified-badge">
                  <svg style="width:12px; height:12px; fill:#616161;" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                  Verified
                </span>
              </div>
              <div class="reviews-sec__date">{{ sample_dates[i] }}</div>

              <div class="reviews-sec__review-stars">
                {%- for j in (1..5) -%}
                  <svg viewBox="0 0 24 24"><path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.399 8.165-7.333-3.856-7.333 3.856 1.399-8.165-5.934-5.784 8.2-1.192zm0 0"/></svg>
                {%- endfor -%}
              </div>

              <p class="reviews-sec__review-body">{{ sample_texts[i] }}</p>

              <div class="reviews-sec__item-type">Item type: <strong>{{ sample_types[i] }}</strong></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</div>


{%- style -%}

/* SECTION */
.bestsellers-section-dtc {
  background-color: {{ section.settings.bg_color | default: '#ffffff' }};
  padding: 50px 0;
  font-family: 'Inter', sans-serif;
  overflow: hidden;
}

/* CONTAINER */
.bestsellers-container-dtc {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  flex-direction: column;
  gap: 28px;
}

/* HEADER */
.bestsellers-header-dtc {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.bestsellers__title-group-dtc {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

/* LEFT LABEL */
.bestsellers__eyebrow-dtc {
  color: #FF2D2D;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 1.5px;
}

/* LEFT HEADING */
.bestsellers__heading-dtc {
  font-size: clamp(24px, 3.5vw, 32px);
  font-weight: 800;
  color: #000;
  text-align: left;
  line-height: 1.2;
}

/* RIGHT LINK */
.bestsellers__view-all-dtc {
  font-size: 14px;
  font-weight: 600;
  color: #000;
  text-decoration: none;
}

/* SCROLL ROW */
.bestsellers__scroll-wrapper-dtc {
  display: flex;
  gap: 20px;
  overflow-x: auto;
  scroll-behavior: smooth;
  padding: 8px 0;
}

.bestsellers__scroll-wrapper-dtc::-webkit-scrollbar {
  display: none;
}

/* PRODUCT CARD */
.prod-card-dtc {
  flex: 0 0 280px;
  background: #fff;
  display: flex;
  flex-direction: column;
  gap: 12px;
  position: relative;
  box-sizing: border-box;
}

/* BADGE */
.prod-card-dtc__badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: #FF2D2D;
  color: #fff;
  font-size: 10px;
  padding: 4px 10px;
  border-radius: 20px;
  font-weight: 700;
  letter-spacing: 0.05em;
  z-index: 2;
}

/* IMAGE */
.prod-card-dtc__image-container {
  height: 220px;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f7f7f7;
  border-radius: 12px;
  overflow: hidden;
}

.prod-card-dtc__image {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.prod-card-dtc:hover .prod-card-dtc__image {
  transform: scale(1.05);
}

/* BRAND */
.prod-card-dtc__brand {
  font-size: 11px;
  color: #888;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin: 0;
}

/* TITLE */
.prod-card-dtc__title {
  font-size: 15px;
  font-weight: 700;
  color: #000;
  margin: 0;
  line-height: 1.3;
}

/* DESCRIPTION */
.prod-card-dtc__desc {
  font-size: 12px;
  color: #777;
  line-height: 1.4;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  height: 33.6px;
}

/* FOOTER */
.prod-card-dtc__footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
  padding-top: 8px;
}

/* PRICE */
.prod-card-dtc__price {
  font-size: 16px;
  font-weight: 700;
  color: #000000;
}

.prod-card-dtc__compare-price {
  font-size: 12px;
  color: #aaa;
  text-decoration: line-through;
}

/* BUTTON */
.prod-card-dtc__btn {
  background: #000;
  color: #fff;
  padding: 8px 16px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 700;
  border: none;
  cursor: pointer;
  transition: background-color 0.2s, transform 0.2s;
}

.prod-card-dtc__btn:hover {
  background: #FF2D2D;
  transform: translateY(-2px);
}

/* MOBILE */
@media (max-width: 768px) {
  .bestsellers-header-dtc {
    flex-direction: column;
    gap: 6px;
    text-align: center;
  }
}

{%- endstyle -%}

<section class="bestsellers-section-dtc">
  <div class="bestsellers-container-dtc">

    <!-- HEADER -->
    <div class="bestsellers-header-dtc">
      <div class="bestsellers__title-group-dtc">
        <span class="bestsellers__eyebrow-dtc">BEST SELLERS</span>
        <h2 class="bestsellers__heading-dtc">Bestselling Sneaker<br>Care</h2>
      </div>
      <a href="/collections/all" class="bestsellers__view-all-dtc">View All →</a>
    </div>

    <!-- PRODUCTS -->
    <div class="bestsellers__scroll-wrapper-dtc">

      {% for product in collections[section.settings.collection].products limit: 8 %}
        <div class="prod-card-dtc">

          {% if product.compare_at_price > product.price %}
            <span class="prod-card-dtc__badge">Sale</span>
          {% endif %}

          <div class="prod-card-dtc__image-container">
            <img src="{{ product.featured_image | image_url: width: 400 }}" class="prod-card-dtc__image">
          </div>

          <span class="prod-card-dtc__brand">HAGUEPROTECT</span>

          <h3 class="prod-card-dtc__title">{{ product.title }}</h3>

          <p class="prod-card-dtc__desc">
            {{ product.description | strip_html | truncate: 60 }}
          </p>

          <div class="prod-card-dtc__footer">
            <div>
              <div class="prod-card-dtc__price">{{ product.price | money }}</div>
              {% if product.compare_at_price > product.price %}
                <div class="prod-card-dtc__compare-price">{{ product.compare_at_price | money }}</div>
              {% endif %}
            </div>

            <form action="/cart/add" method="post">
              <input type="hidden" name="id" value="{{ product.variants.first.id }}">
              <button type="submit" class="prod-card-dtc__btn">Add</button>
            </form>
          </div>

        </div>
      {% endfor %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bestsellers",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Bestsellers"
    }
  ]
}
{% endschema %}
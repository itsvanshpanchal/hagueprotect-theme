{%- style -%}
  .bestsellers-section {
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    padding: 80px 0;
    font-family: 'Inter', sans-serif !important;
    overflow: hidden;
  }

  .bestsellers-container {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .bestsellers-header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-end;
    width: 100%;
    gap: 16px;
    text-align: left;
  }

  @media screen and (max-width: 768px) {
    .bestsellers-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }

  .bestsellers__eyebrow {
    color: #FF2B2B;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .bestsellers__heading {
    margin: 0;
    color: #000000;
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .bestsellers__heading span {
    display: block;
  }

  .bestsellers__view-all {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 700;
    color: #111111;
    text-decoration: none;
    margin-top: 12px;
    transition: color 0.2s ease;
  }

  .bestsellers__view-all:hover {
    color: #FF2B2B;
  }

  /* Horizontal Scroll Layout */
  .bestsellers__scroll-wrapper {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    -ms-overflow-style: none;
    scrollbar-width: none;
    padding: 8px 0;
    width: 100%;
  }

  .bestsellers__scroll-wrapper::-webkit-scrollbar {
    display: none;
  }

  /* Product Card Aesthetic */
  .prod-card-dtc {
    flex: 0 0 280px;
    scroll-snap-align: start;
    background-color: #ffffff;
    border-radius: 12px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
    border: 1px solid #f2f2f2;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .prod-card-dtc:hover {
    border-color: #e5e5e5;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.04);
    transform: translateY(-4px);
  }

  .prod-card-dtc__badge {
    position: absolute;
    top: 24px;
    left: 24px;
    background-color: #FF2B2B;
    color: #ffffff;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
    z-index: 2;
    letter-spacing: 0.05em;
  }

  .prod-card-dtc__image-container {
    background-color: #ffffff;
    border-radius: 8px;
    overflow: hidden;
    position: relative;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #f9f9f9;
  }

  .prod-card-dtc__image-wrapper {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .prod-card-dtc:hover .prod-card-dtc__image-wrapper {
    transform: scale(1.05);
  }

  .prod-card-dtc__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .prod-card-dtc__info {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex-grow: 1;
  }

  .prod-card-dtc__brand {
    font-size: 11px;
    font-weight: 700;
    color: #888888;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .prod-card-dtc__title {
    font-size: 15px;
    font-weight: 700;
    color: #000000;
    letter-spacing: -0.01em;
    margin: 0;
    text-decoration: none;
    line-height: 1.3;
  }

  .prod-card-dtc__desc {
    font-size: 12px;
    color: #777777;
    margin: 0;
    line-height: 1.4;
    white-space: normal;
  }

  .prod-card-dtc__rating {
    display: flex;
    gap: 3px;
    margin: 2px 0;
  }

  .prod-card-dtc__rating span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: #111111;
    display: inline-block;
  }
  .prod-card-dtc__rating span.grey {
    background-color: #dddddd;
  }

  .prod-card-dtc__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 8px;
  }

  .prod-card-dtc__price-wrapper {
    display: flex;
    flex-direction: column;
  }

  .prod-card-dtc__price {
    font-size: 16px;
    font-weight: 800;
    color: #000000;
  }

  .prod-card-dtc__compare-price {
    font-size: 12px;
    text-decoration: line-through;
    color: #9AA0A6;
  }

  .prod-card-dtc__btn {
    font-size: 13px;
    padding: 8px 16px;
    border-radius: 30px;
    border: none;
    font-weight: 700;
    background-color: #111111;
    color: #ffffff;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: center;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .prod-card-dtc__btn:hover {
    background-color: #FF2B2B;
    transform: translateY(-2px);
  }
{%- endstyle -%}

<section class="bestsellers-section" aria-label="Bestselling products">
  <div class="bestsellers-container">
    <div class="bestsellers-header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="bestsellers__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="bestsellers__heading">
        {%- if section.settings.heading != blank -%}
          {{ section.settings.heading | replace: ' ', '<br>' }}
        {%- else -%}
          Bestsellers<br>this season
        {%- endif -%}
      </h2>
      {%- assign collection_url = section.settings.view_all_link -%}
      {%- if collection_url == blank and section.settings.collection != blank -%}
        {%- assign collection_url = collections[section.settings.collection].url -%}
      {%- endif -%}
      {%- if collection_url == blank -%}
        {%- assign collection_url = '/collections/all' -%}
      {%- endif -%}
      <a href="{{ collection_url }}" class="bestsellers__view-all">
        {{ section.settings.view_all_text | default: 'View All' }}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <div class="bestsellers__scroll-wrapper">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'product_block' -%}
              {%- assign product = all_products[block.settings.product] -%}
              {%- if product != blank -%}
                <div class="prod-card-dtc" {{ block.shopify_attributes }}>
                  {%- if product.compare_at_price > product.price -%}
                    <span class="prod-card-dtc__badge">Sale</span>
                  {%- endif -%}

                  <div class="prod-card-dtc__image-container">
                    <a href="{{ product.url }}" class="prod-card-dtc__image-wrapper">
                      {%- if block.settings.image != blank -%}
                        <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ product.title | escape }}" class="prod-card-dtc__image" loading="lazy">
                      {%- elsif product.featured_image != blank -%}
                        <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" class="prod-card-dtc__image" loading="lazy">
                      {%- else -%}
                        {{ 'product-1' | placeholder_svg_tag: 'prod-card-dtc__image' }}
                      {%- endif -%}
                    </a>
                  </div>

                  <div class="prod-card-dtc__info">
                    <span class="prod-card-dtc__brand">HagueProtect</span>
                    <a href="{{ product.url }}" style="text-decoration: none;">
                      <h3 class="prod-card-dtc__title">{{ product.title }}</h3>
                    </a>
                    <p class="prod-card-dtc__desc">{{ product.description | strip_html | truncate: 50 | default: 'Premium care for high-end sneakers.' }}</p>
                    <div class="prod-card-dtc__rating">
                      <span></span><span></span><span></span><span></span><span class="grey"></span>
                    </div>
                  </div>

                  <div class="prod-card-dtc__footer">
                    <div class="prod-card-dtc__price-wrapper">
                      <span class="prod-card-dtc__price">{{ product.price | money }}</span>
                      {%- if product.compare_at_price > product.price -%}
                        <span class="prod-card-dtc__compare-price">{{ product.compare_at_price | money }}</span>
                      {%- endif -%}
                    </div>
                    <form action="/cart/add" method="post" enctype="multipart/form-data">
                      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                      <button type="submit" class="prod-card-dtc__btn">Add</button>
                    </form>
                  </div>
                </div>
              {%- endif -%}

            {%- when 'custom_card' -%}
              <div class="prod-card-dtc" {{ block.shopify_attributes }}>
                {%- if block.settings.compare_at_price != blank -%}
                  <span class="prod-card-dtc__badge">Best Seller</span>
                {%- endif -%}

                <div class="prod-card-dtc__image-container">
                  <a href="{{ block.settings.url | default: '#' }}" class="prod-card-dtc__image-wrapper">
                    {%- if block.settings.image != blank -%}
                      <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}" class="prod-card-dtc__image" loading="lazy">
                    {%- else -%}
                      {{ 'product-2' | placeholder_svg_tag: 'prod-card-dtc__image' }}
                    {%- endif -%}
                  </a>
                </div>

                <div class="prod-card-dtc__info">
                  <span class="prod-card-dtc__brand">HagueProtect</span>
                  <a href="{{ block.settings.url | default: '#' }}" style="text-decoration: none;">
                    <h3 class="prod-card-dtc__title">{{ block.settings.title | default: 'Custom Product' }}</h3>
                  </a>
                  {%- if block.settings.sub_title != blank -%}
                    <p class="prod-card-dtc__desc">{{ block.settings.sub_title }}</p>
                  {%- else -%}
                    <p class="prod-card-dtc__desc">Premium care for high-end sneakers.</p>
                  {%- endif -%}
                  <div class="prod-card-dtc__rating">
                    <span></span><span></span><span></span><span></span><span></span>
                  </div>
                </div>

                <div class="prod-card-dtc__footer">
                  <div class="prod-card-dtc__price-wrapper">
                    <span class="prod-card-dtc__price">{{ block.settings.price | default: '$0.00' }}</span>
                    {%- if block.settings.compare_at_price != blank -%}
                      <span class="prod-card-dtc__compare-price">{{ block.settings.compare_at_price }}</span>
                    {%- endif -%}
                  </div>
                  <a href="{{ block.settings.url | default: '#' }}" class="prod-card-dtc__btn">
                    {{ block.settings.button_text | default: 'Add' }}
                  </a>
                </div>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      {%- else -%}
        {%- assign collection = collections[section.settings.collection] -%}
        {%- if collection != blank and collection.products.size > 0 -%}
          {%- for product in collection.products limit: section.settings.products_to_show -%}
            <div class="prod-card-dtc">
              {%- if product.compare_at_price > product.price -%}
                <span class="prod-card-dtc__badge">Sale</span>
              {%- endif -%}

              <div class="prod-card-dtc__image-container">
                <a href="{{ product.url }}" class="prod-card-dtc__image-wrapper">
                  {%- if product.featured_image != blank -%}
                    <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" class="prod-card-dtc__image" loading="lazy">
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'prod-card-dtc__image' }}
                  {%- endif -%}
                </a>
              </div>

              <div class="prod-card-dtc__info">
                <span class="prod-card-dtc__brand">HagueProtect</span>
                <a href="{{ product.url }}" style="text-decoration: none;">
                  <h3 class="prod-card-dtc__title">{{ product.title }}</h3>
                </a>
                <p class="prod-card-dtc__desc">{{ product.description | strip_html | truncate: 50 | default: 'Premium care for high-end sneakers.' }}</p>
                <div class="prod-card-dtc__rating">
                  <span></span><span></span><span></span><span></span><span class="grey"></span>
                </div>
              </div>

              <div class="prod-card-dtc__footer">
                <div class="prod-card-dtc__price-wrapper">
                  <span class="prod-card-dtc__price">{{ product.price | money }}</span>
                  {%- if product.compare_at_price > product.price -%}
                    <span class="prod-card-dtc__compare-price">{{ product.compare_at_price | money }}</span>
                  {%- endif -%}
                </div>
                <form action="/cart/add" method="post" enctype="multipart/form-data">
                  <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                  <button type="submit" class="prod-card-dtc__btn">Add</button>
                </form>
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..6) -%}
            <div class="prod-card-dtc">
              {%- if i == 1 or i == 3 -%}
                <span class="prod-card-dtc__badge">Best Seller</span>
              {%- else -%}
                <span class="prod-card-dtc__badge">New</span>
              {%- endif -%}

              <div class="prod-card-dtc__image-container">
                <a href="/products/elite-kit" class="prod-card-dtc__image-wrapper" style="text-decoration: none;">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 300" class="prod-card-dtc__image">
                    <rect width="300" height="300" fill="#ffffff"/>
                    <circle cx="150" cy="150" r="100" fill="#ffffff"/>
                    <rect x="120" y="80" width="60" height="130" rx="12" fill="#ffffff" stroke="#eeeeee" stroke-width="2"/>
                    <rect x="135" y="60" width="30" height="20" fill="#111111" rx="4"/>
                    <rect x="130" y="110" width="40" height="4" fill="#FF2B2B"/>
                    <text x="150" y="240" font-family="Inter, sans-serif" font-size="10" font-weight="700" fill="#111111" opacity="0.3" text-anchor="middle" letter-spacing="1">HAGUEPROTECT</text>
                  </svg>
                </a>
              </div>

              <div class="prod-card-dtc__info">
                <span class="prod-card-dtc__brand">HagueProtect</span>
                <a href="/products/elite-kit" style="text-decoration: none;">
                  <h3 class="prod-card-dtc__title">
                    {%- if i == 1 -%}Elite Kit
                    {%- elsif i == 2 -%}Shield Guard
                    {%- elsif i == 3 -%}Restore Brush
                    {%- elsif i == 4 -%}Master Bundle
                    {%- elsif i == 5 -%}Deodorizer Citrus
                    {%- else -%}Signature Kit{%- endif -%}
                  </h3>
                </a>
                <p class="prod-card-dtc__desc">High-performance DTC cleaner for sneaker materials.</p>
                <div class="prod-card-dtc__rating">
                  <span></span><span></span><span></span><span></span><span></span>
                </div>
              </div>

              <div class="prod-card-dtc__footer">
                <div class="prod-card-dtc__price-wrapper">
                  <span class="prod-card-dtc__price">
                    {%- if i == 1 -%}₹3,499{%- elsif i == 2 -%}₹1,999{%- elsif i == 3 -%}₹1,299{%- elsif i == 4 -%}₹4,500{%- elsif i == 5 -%}₹999{%- else -%}₹2,499{%- endif -%}
                  </span>
                  {%- if i == 1 -%}
                    <span class="prod-card-dtc__compare-price">₹4,200</span>
                  {%- endif -%}
                </div>
                <a href="/products/elite-kit" class="prod-card-dtc__btn">Add</a>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bestsellers Section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Best Sellers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bestsellers this season"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection (Used if no custom blocks)"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View All Text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "product_block",
      "name": "Store Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Product Image (Optional)"
        }
      ]
    },
    {
      "type": "custom_card",
      "name": "Custom Product Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Upload Photo"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Elite Sneaker Shield"
        },
        {
          "type": "text",
          "id": "sub_title",
          "label": "Subtitle",
          "default": "Advanced Formula"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$35.00"
        },
        {
          "type": "text",
          "id": "compare_at_price",
          "label": "Compare Price",
          "default": "$45.00"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Add to Cart"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bestsellers Section"
    }
  ]
}
{% endschema %}

              </div>
              </div>
              </button>
            {%- endfor -%}
          {%- else -%}
            {%- assign mock_products = 'essential-indepth-shoe-sneaker-cleaning-kit|Essential In-Depth Cleaning Kit,hague-protect-quick-shoe-sneaker-cleaning-kit-shoes-care-kits|Quick Shoe Cleaning Kit,signature-shoe-sneaker-cleaning-kit|Signature Cleaning Kit,supreme-shoe-sneaker-cleaning-kit|Supreme Cleaning Kit,sneaker-shoe-cleaner-refill-pack|Cleaner Refill Pack,haguepr-essential-shoe-sneaker-cleaning-kit-sneakers-for-men|Essential Care Kit' | split: ',' -%}
            {%- for mock in mock_products limit: product_limit -%}
              {%- assign mock_parts = mock | split: '|' -%}
              {%- assign mock_handle = mock_parts[0] -%}
              {%- assign mock_title = mock_parts[1] -%}
              <button
                type="button"
                class="bs-coverflow-card"
                data-coverflow-card
                data-index="{{ forloop.index0 }}"

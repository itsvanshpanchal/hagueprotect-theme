{%- liquid
  assign products_to_show = collections[section.settings.collection].products
  assign product_limit = section.settings.products_limit | default: 8
  assign accent = section.settings.accent_color | default: '#B8B8B8'
  assign bs_bg = section.settings.bg_color | default: '#ffffff'
  assign bs_text = '#111111'
  assign bs_text_muted = '#666666'
  assign bg_brightness = bs_bg | color_brightness
  if bg_brightness < 128
    assign bs_text = '#ffffff'
    assign bs_text_muted = 'rgba(255, 255, 255, 0.72)'
  endif
-%}

{%- style -%}
  {% render 'section-typography-vars', section: section %}


  #shopify-section-{{ section.id }} .bs-coverflow {
    --homepage-corner: 20px;
    --bs-bg: {{ section.settings.bg_color | default: '#ffffff' }};
    --bs-accent: {{ accent }};
    --bs-accent-soft: color-mix(in srgb, {{ accent }} 35%, transparent);
    --bs-accent-glow: color-mix(in srgb, {{ accent }} 55%, transparent);
    --bs-card-w: 320px;
    --bs-media-h: 228px;
    --bs-spacing: 270px;
    --bs-perspective: 1400px;
    --bs-ease: cubic-bezier(0.23, 1, 0.32, 1);
    --bs-duration: 0.88s;
    background: var(--bs-bg);
    padding: 80px 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  overflow: hidden;
    position: relative;
  }

  #shopify-section-{{ section.id }} .bs-coverflow::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 50% 55%, color-mix(in srgb, {{ accent }} 8%, transparent), transparent 70%),
      radial-gradient(circle at 20% 20%, rgba(0, 0, 0, 0.02), transparent 40%);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__container {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 40px;
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 20px;
    max-width: var(--site-max-width, 1320px);
    margin-inline: auto;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__eyebrow {
    display: block;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__heading {
    color: {{ bs_text }} !important;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__view-all {
  font-size: 14px;
  font-weight: 600;
    color: {{ bs_text }};
  text-decoration: none;
    white-space: nowrap;
    transition: color 0.25s ease;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__view-all:hover {
    color: #e74c3c;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__stage {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: clamp(8px, 2vw, 20px);
    isolation: isolate;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__viewport {
    position: relative;
    height: clamp(440px, 52vw, 520px);
    perspective: var(--bs-perspective);
    perspective-origin: 50% 46%;
    overflow: visible;
    touch-action: pan-y pinch-zoom;
    padding-bottom: 16px;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__viewport.is-transitioning .bs-coverflow-card:not(.is-active) {
    /* Removed expensive blur filter that caused lag during transitions */
  }

  #shopify-section-{{ section.id }} .bs-coverflow__track {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card {
    position: absolute;
    left: 50%;
    top: 50%;
    width: var(--bs-card-w);
    height: auto;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    transform-style: preserve-3d;
    -webkit-tap-highlight-color: transparent;
    transition:
      transform var(--bs-duration) var(--bs-ease),
      opacity calc(var(--bs-duration) * 0.85) ease;
    will-change: transform, opacity;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    outline: none;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card:focus-visible .bs-coverflow-card__inner {
    outline: 2px solid var(--bs-accent);
    outline-offset: 4px;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__inner {
    position: relative;
    width: 100%;
    height: auto;
    min-height: 0;
  background: #ffffff;
    border-radius: var(--homepage-corner, 20px);
    overflow: hidden;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.1);
    transition:
      box-shadow 0.45s var(--bs-ease),
      transform 0.45s var(--bs-ease);
    transform: translateZ(0);
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card:hover .bs-coverflow-card__inner {
    transform: translateY(-6px) scale(1.02);
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card.is-active {
    pointer-events: auto;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card.is-active .bs-coverflow-card__inner {
    box-shadow:
      0 36px 72px rgba(0, 0, 0, 0.16),
      0 0 0 1px color-mix(in srgb, var(--bs-accent) 45%, #ffffff),
      0 0 36px var(--bs-accent-glow),
      0 0 72px var(--bs-accent-soft);
    animation: bs-float-{{ section.id }} 4.8s ease-in-out infinite;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card.is-active:hover .bs-coverflow-card__inner {
    animation-play-state: paused;
    transform: translateY(-14px) scale(1.025);
  }

  @keyframes bs-float-{{ section.id }} {
    0%, 100% { transform: translateY(-8px); }
    50% { transform: translateY(-16px); }
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__badge {
  position: absolute;
    top: 14px;
    right: 14px;
    z-index: 2;
    background: #e74c3c;
  color: #ffffff;
    font-size: 10px;
  font-weight: 700;
    letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 6px 12px;
    border-radius: 999px;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__glow-ring {
    position: absolute;
    inset: -3px;
    border-radius: var(--homepage-corner, 20px);
    background: linear-gradient(135deg, var(--bs-accent), transparent 55%, var(--bs-accent-soft));
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: 0;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card.is-active .bs-coverflow-card__glow-ring {
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__media {
    position: relative;
    flex: 0 0 var(--bs-media-h);
    min-height: var(--bs-media-h);
    max-height: var(--bs-media-h);
    background: linear-gradient(180deg, #f8f8fa 0%, #efeff2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
    padding: 20px 18px 16px;
  overflow: hidden;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__media::after {
    content: '';
    position: absolute;
    bottom: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 70%;
    height: 24%;
    background: radial-gradient(ellipse, rgba(0, 0, 0, 0.14), transparent 70%);
    filter: blur(4px);
    opacity: 0.55;
    transition: opacity 0.4s ease, transform 0.4s ease;
    will-change: opacity, transform;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card.is-active .bs-coverflow-card__media::after {
    opacity: 0.85;
    transform: translateX(-50%) scaleX(1.17);
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__image {
    width: 100%;
    height: 100%;
    max-height: calc(var(--bs-media-h) - 36px);
    object-fit: contain;
    transition: transform 0.55s var(--bs-ease);
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card.is-active .bs-coverflow-card__image {
    transform: scale(1.04);
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__body {
    flex: 0 0 auto;
    padding: 14px 18px 14px;
  display: flex;
  flex-direction: column;
    gap: 6px;
    text-align: left;
    position: relative;
    z-index: 1;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__rating {
  display: flex;
  align-items: center;
  gap: 8px;
}

  #shopify-section-{{ section.id }} .bs-coverflow-card__rating-badge {
    background: #2ecc71;
    color: #111111;
    font-size: 12px;
  font-weight: 700;
  padding: 4px 8px;
  border-radius: 6px;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__rating-count {
    font-size: 12px;
    color: #777777;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__title {
    font-size: clamp(15px, 1.8vw, 17px);
    font-weight: 600;
    color: #111111;
    line-height: 1.35;
  margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

  #shopify-section-{{ section.id }} .bs-coverflow-card__type {
    font-size: 12px;
  color: #888888;
  margin: 0;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__price-row {
  display: flex;
    align-items: baseline;
  gap: 8px;
    margin-top: 0;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__price {
    font-size: 20px;
    font-weight: 700;
    color: #111111;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__compare {
    font-size: 13px;
    color: #aaaaaa;
    text-decoration: line-through;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__cta {
    margin-top: 8px;
    margin-bottom: 0;
    display: inline-flex;
  align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 44px;
    padding: 0 18px;
    border-radius: 999px;
    background: #111111;
    color: #ffffff;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    flex-shrink: 0;
    box-sizing: border-box;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card.is-active .bs-coverflow-card__cta {
    background: linear-gradient(135deg, #111111 0%, #2a2a2a 100%);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.18);
  }

  #shopify-section-{{ section.id }} .bs-coverflow-nav {
    width: clamp(44px, 5vw, 54px);
    height: clamp(44px, 5vw, 54px);
  border-radius: 50%;
    border: 1px solid rgba(17, 17, 17, 0.08);
    background: #ffffff;
    color: #111111;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  cursor: pointer;
    flex-shrink: 0;
    z-index: 20;
    transition: transform 0.3s var(--bs-ease), background 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;
    animation: bs-nav-pulse-{{ section.id }} 2.6s ease-in-out infinite;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  #shopify-section-{{ section.id }} .bs-coverflow-nav:hover {
    transform: scale(1.08);
    background: #111111;
    color: #ffffff;
    animation: none;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.16);
  }

  #shopify-section-{{ section.id }} .bs-coverflow-nav:active {
    transform: scale(0.96);
  }

  @keyframes bs-nav-pulse-{{ section.id }} {
    0%, 100% { box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08), 0 0 0 0 var(--bs-accent-soft); }
    50% { box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08), 0 0 0 10px transparent; }
  }

  #shopify-section-{{ section.id }} .bs-coverflow__footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-top: clamp(20px, 4vw, 32px);
  }

  #shopify-section-{{ section.id }} .bs-coverflow__dots-row {
  display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__pager {
    display: none;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__counter {
    display: none;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  border: none;
    padding: 0;
    background: #d8d8d8;
  cursor: pointer;
    transition: transform 0.3s var(--bs-ease), background 0.3s ease, width 0.3s var(--bs-ease);
  }

  #shopify-section-{{ section.id }} .bs-coverflow__dot.is-active {
    background: var(--bs-accent);
    transform: scale(1.2);
    width: 22px;
    border-radius: 999px;
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .bs-coverflow {
      --bs-card-w: min(72vw, 252px);
      --bs-media-h: 156px;
      --bs-spacing: 152px;
      --bs-perspective: 900px;
      --bs-duration: 0.72s;
      padding: 40px 0;
      overflow: visible;
    }

    #shopify-section-{{ section.id }} .bs-coverflow__container {
      padding: 0 max(16px, var(--site-padding, 20px));
    }

    #shopify-section-{{ section.id }} .bs-coverflow__header {
      flex-direction: column;
      align-items: stretch;
      text-align: center;
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .bs-coverflow__heading {
      max-width: 18ch;
      margin-inline: 0;
      text-align: left;
    }

    #shopify-section-{{ section.id }} .bs-coverflow__view-all {
      font-size: 13px;
      padding: 8px 0;
    }

    #shopify-section-{{ section.id }} .bs-coverflow__stage {
      grid-template-columns: 1fr;
      gap: 0;
      min-height: 0;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 30;
      width: 44px;
      height: 44px;
      background: rgba(255, 255, 255, 0.94);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border: 1px solid rgba(17, 17, 17, 0.1);
      box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12);
      animation: none;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-nav--prev {
      left: max(6px, env(safe-area-inset-left, 0px));
    }

    #shopify-section-{{ section.id }} .bs-coverflow-nav--next {
      right: max(6px, env(safe-area-inset-right, 0px));
    }

    #shopify-section-{{ section.id }} .bs-coverflow-nav:active {
      transform: translateY(-50%) scale(0.94);
      background: #111111;
      color: #ffffff;
    }

    #shopify-section-{{ section.id }} .bs-coverflow__viewport {
      height: clamp(340px, 92vw, 390px);
      grid-column: 1;
      padding-bottom: 8px;
      perspective-origin: 50% 48%;
      touch-action: pan-x pan-y;
    }

    #shopify-section-{{ section.id }} .bs-coverflow__viewport.is-transitioning .bs-coverflow-card:not(.is-active) {
      /* filter: none; */
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card {
      height: auto;
      min-height: 0;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card__inner {
      min-height: 0;
      height: auto;
      border-radius: var(--homepage-corner, 20px);
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.1);
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card.is-active .bs-coverflow-card__inner {
      animation: none;
      transform: translateY(-4px);
      box-shadow:
        0 20px 40px rgba(0, 0, 0, 0.14),
        0 0 0 1px color-mix(in srgb, var(--bs-accent) 45%, #ffffff),
        0 0 24px var(--bs-accent-soft);
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card__badge {
      top: 10px;
      right: 10px;
      font-size: 9px;
      padding: 5px 10px;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card__media {
      padding: 14px 12px 10px;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card__image {
      max-height: calc(var(--bs-media-h) - 24px);
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card__body {
      padding: 10px 14px 10px;
      gap: 4px;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card__rating {
      margin-bottom: 2px;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card__title {
      font-size: 14px;
      line-height: 1.3;
      margin-bottom: 2px;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card__type {
      display: none;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card__price {
      font-size: 17px;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card__cta {
      min-height: 44px;
      font-size: 11px;
      margin-top: 6px;
      margin-bottom: 0;
    }

    #shopify-section-{{ section.id }} .bs-coverflow__footer {
      margin-top: 10px;
      gap: 0;
      flex-direction: column;
      align-items: center;
      padding-bottom: env(safe-area-inset-bottom, 0px);
    }

    #shopify-section-{{ section.id }} .bs-coverflow__dots-row {
      display: none;
    }

    #shopify-section-{{ section.id }} .bs-coverflow__pager {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      width: min(160px, 44vw);
    }

    #shopify-section-{{ section.id }} .bs-coverflow__counter {
      display: block;
      width: auto;
      text-align: center;
      font-size: 13px;
      font-weight: 600;
      color: {{ bs_text_muted }};
      letter-spacing: 0.06em;
      margin: 0;
      line-height: 1;
    }

    #shopify-section-{{ section.id }} .bs-coverflow__progress {
      width: 100%;
      height: 3px;
      border-radius: 999px;
      background: #e6e6e6;
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .bs-coverflow__progress-fill {
      display: block;
      height: 100%;
      width: 0;
      border-radius: inherit;
      background: var(--bs-accent);
      transition: width 0.45s var(--bs-ease);
    }
  }

  @media (max-width: 767px) and (hover: none) {
    #shopify-section-{{ section.id }} .bs-coverflow-card:hover .bs-coverflow-card__inner,
    #shopify-section-{{ section.id }} .bs-coverflow-card.is-active:hover .bs-coverflow-card__inner {
      transform: none;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card.is-active .bs-coverflow-card__inner {
      transform: translateY(-4px);
    }

    #shopify-section-{{ section.id }} .bs-coverflow-nav:hover {
      transform: translateY(-50%);
      background: rgba(255, 255, 255, 0.94);
      color: #111111;
    }
  }

  @media (max-width: 380px) {
    #shopify-section-{{ section.id }} .bs-coverflow {
      --bs-card-w: min(74vw, 236px);
      --bs-media-h: 146px;
      --bs-spacing: 138px;
    }

    #shopify-section-{{ section.id }} .bs-coverflow__viewport {
      height: 330px;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card,
    #shopify-section-{{ section.id }} .bs-coverflow-card__inner {
      min-height: 0;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-nav {
      width: 40px;
      height: 40px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .bs-coverflow-card,
    #shopify-section-{{ section.id }} .bs-coverflow-nav {
      animation: none !important;
      transition-duration: 0.01ms !important;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card.is-active {
      animation: none !important;
    }
  }
{%- endstyle -%}

<section
  class="bs-coverflow"
  aria-label="{{ section.settings.heading | default: 'Bestselling products' | escape }}"
  data-bs-coverflow
  data-spacing="270"
  data-mobile-spacing="152"
  data-mobile-spacing-min="138"
  data-mobile-spacing-max="162"
>
  <div class="bs-coverflow__container">
    <div class="bs-coverflow__header">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <span class="bs-coverflow__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="bs-coverflow__heading">{{ section.settings.heading | default: 'Bestselling Sneaker Care' }}</h2>
          </div>
      {%- if section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}" class="bs-coverflow__view-all">{{ section.settings.view_all_label | default: 'View All Ã¢â€ â€™' }}</a>
          {%- else -%}
        <a href="{{ routes.all_products_collection_url }}" class="bs-coverflow__view-all">{{ section.settings.view_all_label | default: 'View All Ã¢â€ â€™' }}</a>
          {%- endif -%}
    </div>

    <div class="bs-coverflow__stage">
      <button type="button" class="bs-coverflow-nav bs-coverflow-nav--prev" data-coverflow-prev aria-label="Previous product">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
      </button>

      <div class="bs-coverflow__viewport" data-coverflow-viewport>
        <div class="bs-coverflow__track" data-coverflow-track>
          {%- if products_to_show.size > 0 -%}
            {%- for product in products_to_show limit: product_limit -%}
              {%- assign card_variant = product.selected_or_first_available_variant -%}
              <button
                type="button"
                class="bs-coverflow-card"
                data-coverflow-card
                data-index="{{ forloop.index0 }}"
                data-url="{{ product.url }}"

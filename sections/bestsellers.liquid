{%- liquid
  assign products_to_show = collections[section.settings.collection].products
  assign product_limit = section.settings.products_limit | default: 8
  assign accent = section.settings.accent_color | default: '#FFC107'
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .bs-coverflow {
    --bs-bg: {{ section.settings.bg_color | default: '#ffffff' }};
    --bs-accent: {{ accent }};
    --bs-accent-soft: color-mix(in srgb, {{ accent }} 35%, transparent);
    --bs-accent-glow: color-mix(in srgb, {{ accent }} 55%, transparent);
    --bs-card-w: 320px;
    --bs-card-h: 460px;
    --bs-spacing: 270px;
    --bs-perspective: 1400px;
    --bs-ease: cubic-bezier(0.23, 1, 0.32, 1);
    --bs-duration: 0.88s;
    background: var(--bs-bg);
    padding: clamp(48px, 7vw, 88px) 0 clamp(56px, 8vw, 96px);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    overflow: hidden;
    position: relative;
  }

  #shopify-section-{{ section.id }} .bs-coverflow::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 50% 55%, color-mix(in srgb, {{ accent }} 8%, transparent), transparent 70%),
      radial-gradient(circle at 20% 20%, rgba(0, 0, 0, 0.02), transparent 40%);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 max(16px, var(--site-padding, 20px));
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 20px;
    margin-bottom: clamp(28px, 5vw, 44px);
  }

  #shopify-section-{{ section.id }} .bs-coverflow__eyebrow {
    color: #e74c3c;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 8px;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__heading {
    font-family: 'Bahnschrift', 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(26px, 4vw, 40px);
    font-weight: 600;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: #111111;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__view-all {
    font-size: 14px;
    font-weight: 600;
    color: #111111;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.25s ease;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__view-all:hover {
    color: #e74c3c;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__stage {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: clamp(8px, 2vw, 20px);
    isolation: isolate;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__viewport {
    position: relative;
    height: clamp(420px, 52vw, 520px);
    perspective: var(--bs-perspective);
    perspective-origin: 50% 42%;
    overflow: visible;
    touch-action: pan-y pinch-zoom;
  }

  #shopify-section-{{ section.id }} .bs-coverflow__viewport.is-transitioning .bs-coverflow-card:not(.is-active) {
    filter: blur(1.2px);
  }

  #shopify-section-{{ section.id }} .bs-coverflow__track {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card {
    position: absolute;
    left: 50%;
    top: 50%;
    width: var(--bs-card-w);
    height: var(--bs-card-h);
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    transform-style: preserve-3d;
    transition:
      transform var(--bs-duration) var(--bs-ease),
      opacity calc(var(--bs-duration) * 0.85) ease,
      filter calc(var(--bs-duration) * 0.6) ease;
    will-change: transform, opacity, filter;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    outline: none;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card:focus-visible .bs-coverflow-card__inner {
    outline: 2px solid var(--bs-accent);
    outline-offset: 4px;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__inner {
    width: 100%;
    height: 100%;
    background: #ffffff;
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.1);
    transition:
      box-shadow 0.45s var(--bs-ease),
      transform 0.45s var(--bs-ease);
    transform: translateZ(0);
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card:hover .bs-coverflow-card__inner {
    transform: translateY(-6px) scale(1.02);
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card.is-active {
    pointer-events: auto;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card.is-active .bs-coverflow-card__inner {
    box-shadow:
      0 36px 72px rgba(0, 0, 0, 0.16),
      0 0 0 1px color-mix(in srgb, var(--bs-accent) 45%, #ffffff),
      0 0 36px var(--bs-accent-glow),
      0 0 72px var(--bs-accent-soft);
    animation: bs-float-{{ section.id }} 4.8s ease-in-out infinite;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card.is-active:hover .bs-coverflow-card__inner {
    animation-play-state: paused;
    transform: translateY(-14px) scale(1.025);
  }

  @keyframes bs-float-{{ section.id }} {
    0%, 100% { transform: translateY(-8px); }
    50% { transform: translateY(-16px); }
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__badge {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 2;
    background: #e74c3c;
    color: #ffffff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 12px;
    border-radius: 999px;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__glow-ring {
    position: absolute;
    inset: -3px;
    border-radius: 22px;
    background: linear-gradient(135deg, var(--bs-accent), transparent 55%, var(--bs-accent-soft));
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: 0;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card.is-active .bs-coverflow-card__glow-ring {
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__media {
    position: relative;
    flex: 0 0 58%;
    background: linear-gradient(180deg, #f8f8fa 0%, #efeff2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 20px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__media::after {
    content: '';
    position: absolute;
    bottom: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 70%;
    height: 24%;
    background: radial-gradient(ellipse, rgba(0, 0, 0, 0.14), transparent 70%);
    filter: blur(8px);
    opacity: 0.55;
    transition: opacity 0.4s ease;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card.is-active .bs-coverflow-card__media::after {
    opacity: 0.85;
    width: 82%;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__image {
    width: 100%;
    height: 100%;
    max-height: 210px;
    object-fit: contain;
    transition: transform 0.55s var(--bs-ease);
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card.is-active .bs-coverflow-card__image {
    transform: scale(1.04);
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__body {
    flex: 1;
    padding: 18px 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-align: left;
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__rating {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__rating-badge {
    background: #2ecc71;
    color: #111111;
    font-size: 12px;
    font-weight: 700;
    padding: 4px 8px;
    border-radius: 6px;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__rating-count {
    font-size: 12px;
    color: #777777;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__title {
    font-size: clamp(15px, 1.8vw, 17px);
    font-weight: 600;
    color: #111111;
    line-height: 1.35;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__type {
    font-size: 12px;
    color: #888888;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-top: auto;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__price {
    font-size: 20px;
    font-weight: 700;
    color: #111111;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__compare {
    font-size: 13px;
    color: #aaaaaa;
    text-decoration: line-through;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card__cta {
    margin-top: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 18px;
    border-radius: 999px;
    background: #111111;
    color: #ffffff;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  #shopify-section-{{ section.id }} .bs-coverflow-card.is-active .bs-coverflow-card__cta {
    background: linear-gradient(135deg, #111111 0%, #2a2a2a 100%);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.18);
  }

  #shopify-section-{{ section.id }} .bs-coverflow-nav {
    width: clamp(44px, 5vw, 54px);
    height: clamp(44px, 5vw, 54px);
    border-radius: 50%;
    border: 1px solid rgba(17, 17, 17, 0.08);
    background: #ffffff;
    color: #111111;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    z-index: 20;
    transition: transform 0.3s var(--bs-ease), background 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;
    animation: bs-nav-pulse-{{ section.id }} 2.6s ease-in-out infinite;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  #shopify-section-{{ section.id }} .bs-coverflow-nav:hover {
    transform: scale(1.08);
    background: #111111;
    color: #ffffff;
    animation: none;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.16);
  }

  #shopify-section-{{ section.id }} .bs-coverflow-nav:active {
    transform: scale(0.96);
  }

  @keyframes bs-nav-pulse-{{ section.id }} {
    0%, 100% { box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08), 0 0 0 0 var(--bs-accent-soft); }
    50% { box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08), 0 0 0 10px transparent; }
  }

  #shopify-section-{{ section.id }} .bs-coverflow__footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-top: clamp(20px, 4vw, 32px);
  }

  #shopify-section-{{ section.id }} .bs-coverflow__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    padding: 0;
    background: #d8d8d8;
    cursor: pointer;
    transition: transform 0.3s var(--bs-ease), background 0.3s ease, width 0.3s var(--bs-ease);
  }

  #shopify-section-{{ section.id }} .bs-coverflow__dot.is-active {
    background: var(--bs-accent);
    transform: scale(1.2);
    width: 22px;
    border-radius: 999px;
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .bs-coverflow {
      --bs-card-w: 260px;
      --bs-card-h: 400px;
      --bs-spacing: 190px;
      --bs-perspective: 1000px;
    }

    #shopify-section-{{ section.id }} .bs-coverflow__header {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .bs-coverflow__stage {
      grid-template-columns: 1fr;
      gap: 0;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 30;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-nav--prev {
      left: 4px;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-nav--next {
      right: 4px;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-nav:hover {
      transform: translateY(-50%) scale(1.06);
    }

    #shopify-section-{{ section.id }} .bs-coverflow__viewport {
      height: 430px;
      grid-column: 1;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card__media {
      padding: 18px 14px;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card__image {
      max-height: 170px;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card__body {
      padding: 14px 16px 18px;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card__price {
      font-size: 17px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .bs-coverflow-card,
    #shopify-section-{{ section.id }} .bs-coverflow-nav {
      animation: none !important;
      transition-duration: 0.01ms !important;
    }

    #shopify-section-{{ section.id }} .bs-coverflow-card.is-active {
      animation: none !important;
    }
  }
{%- endstyle -%}

<section
  class="bs-coverflow"
  aria-label="{{ section.settings.heading | default: 'Bestselling products' | escape }}"
  data-bs-coverflow
  data-spacing="270"
  data-mobile-spacing="190"
>
  <div class="bs-coverflow__container">
    <div class="bs-coverflow__header">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <span class="bs-coverflow__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="bs-coverflow__heading">{{ section.settings.heading | default: 'Bestselling Sneaker Care' }}</h2>
      </div>
      {%- if section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}" class="bs-coverflow__view-all">{{ section.settings.view_all_label | default: 'View All →' }}</a>
      {%- else -%}
        <a href="{{ routes.all_products_collection_url }}" class="bs-coverflow__view-all">{{ section.settings.view_all_label | default: 'View All →' }}</a>
      {%- endif -%}
    </div>

    <div class="bs-coverflow__stage">
      <button type="button" class="bs-coverflow-nav bs-coverflow-nav--prev" data-coverflow-prev aria-label="Previous product">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
      </button>

      <div class="bs-coverflow__viewport" data-coverflow-viewport>
        <div class="bs-coverflow__track" data-coverflow-track>
          {%- if products_to_show.size > 0 -%}
            {%- for product in products_to_show limit: product_limit -%}
              {%- assign card_variant = product.selected_or_first_available_variant -%}
              <button
                type="button"
                class="bs-coverflow-card"
                data-coverflow-card
                data-index="{{ forloop.index0 }}"
                data-url="{{ product.url }}"
                aria-label="{{ product.title | escape }}"
              >
                <div class="bs-coverflow-card__glow-ring" aria-hidden="true"></div>
                <div class="bs-coverflow-card__inner">
                  <span class="bs-coverflow-card__badge">{{ section.settings.badge_text | default: 'Bestseller' }}</span>
                  <div class="bs-coverflow-card__media">
                    {%- if product.featured_image != blank -%}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}"
                        alt="{{ product.featured_image.alt | default: product.title | escape }}"
                        class="bs-coverflow-card__image"
                        loading="{% if forloop.index <= 3 %}eager{% else %}lazy{% endif %}"
                        width="600"
                        height="600"
                      >
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'bs-coverflow-card__image' }}
                    {%- endif -%}
                  </div>
                  <div class="bs-coverflow-card__body">
                    <div class="bs-coverflow-card__rating">
                      <span class="bs-coverflow-card__rating-badge">★ {{ section.settings.rating_value | default: '4.9' }}</span>
                      <span class="bs-coverflow-card__rating-count">({{ section.settings.rating_count | default: '4.8' }})</span>
                    </div>
                    <h3 class="bs-coverflow-card__title">{{ product.title }}</h3>
                    {%- if product.type != blank -%}
                      <p class="bs-coverflow-card__type">{{ product.type }}</p>
                    {%- endif -%}
                    <div class="bs-coverflow-card__price-row">
                      <span class="bs-coverflow-card__price">{{ product.price | money }}</span>
                      {%- if product.compare_at_price > product.price -%}
                        <span class="bs-coverflow-card__compare">{{ product.compare_at_price | money }}</span>
                      {%- endif -%}
                    </div>
                    <span class="bs-coverflow-card__cta">
                      {%- if card_variant.available -%}{{ section.settings.cta_text | default: 'Shop Now' }}{%- else -%}View Product{%- endif -%}
                    </span>
                  </div>
                </div>
              </button>
            {%- endfor -%}
          {%- else -%}
            {%- assign mock_products = 'essential-indepth-shoe-sneaker-cleaning-kit|Essential In-Depth Cleaning Kit,hague-protect-quick-shoe-sneaker-cleaning-kit-shoes-care-kits|Quick Shoe Cleaning Kit,signature-shoe-sneaker-cleaning-kit|Signature Cleaning Kit,supreme-shoe-sneaker-cleaning-kit|Supreme Cleaning Kit,sneaker-shoe-cleaner-refill-pack|Cleaner Refill Pack,haguepr-essential-shoe-sneaker-cleaning-kit-sneakers-for-men|Essential Care Kit' | split: ',' -%}
            {%- for mock in mock_products limit: product_limit -%}
              {%- assign mock_parts = mock | split: '|' -%}
              {%- assign mock_handle = mock_parts[0] -%}
              {%- assign mock_title = mock_parts[1] -%}
              <button
                type="button"
                class="bs-coverflow-card"
                data-coverflow-card
                data-index="{{ forloop.index0 }}"
                data-url="/products/{{ mock_handle }}"
                aria-label="{{ mock_title | escape }}"
              >
                <div class="bs-coverflow-card__glow-ring" aria-hidden="true"></div>
                <div class="bs-coverflow-card__inner">
                  <span class="bs-coverflow-card__badge">{{ section.settings.badge_text | default: 'Bestseller' }}</span>
                  <div class="bs-coverflow-card__media">
                    {{ 'product-1' | placeholder_svg_tag: 'bs-coverflow-card__image' }}
                  </div>
                  <div class="bs-coverflow-card__body">
                    <div class="bs-coverflow-card__rating">
                      <span class="bs-coverflow-card__rating-badge">★ {{ section.settings.rating_value | default: '4.9' }}</span>
                      <span class="bs-coverflow-card__rating-count">({{ section.settings.rating_count | default: '4.8' }})</span>
                    </div>
                    <h3 class="bs-coverflow-card__title">{{ mock_title }}</h3>
                    <p class="bs-coverflow-card__type">Premium Sneaker Care</p>
                    <div class="bs-coverflow-card__price-row">
                      <span class="bs-coverflow-card__price">Rs. 999</span>
                      <span class="bs-coverflow-card__compare">Rs. 1,299</span>
                    </div>
                    <span class="bs-coverflow-card__cta">{{ section.settings.cta_text | default: 'Shop Now' }}</span>
                  </div>
                </div>
              </button>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

      <button type="button" class="bs-coverflow-nav bs-coverflow-nav--next" data-coverflow-next aria-label="Next product">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>

    <div class="bs-coverflow__footer" data-coverflow-dots hidden></div>
  </div>
</section>

<script>
  (function () {
    var section = document.querySelector('#shopify-section-{{ section.id }} [data-bs-coverflow]');
    if (!section) return;

    var viewport = section.querySelector('[data-coverflow-viewport]');
    var cards = Array.prototype.slice.call(section.querySelectorAll('[data-coverflow-card]'));
    var prevBtn = section.querySelector('[data-coverflow-prev]');
    var nextBtn = section.querySelector('[data-coverflow-next]');
    var dotsWrap = section.querySelector('[data-coverflow-dots]');

    if (!cards.length) return;

    var index = 0;
    var transitioning = false;
    var transitionTimer = null;
    var autoplayTimer = null;
    var touchStartX = 0;
    var touchStartY = 0;
    var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var autoplay = {{ section.settings.autoplay | default: true | json }} && !reducedMotion;
    var autoplayMs = {{ section.settings.autoplay_speed | default: 5 | times: 1000 }};

    function spacing() {
      return window.innerWidth <= 767
        ? parseFloat(section.dataset.mobileSpacing || '190')
        : parseFloat(section.dataset.spacing || '270');
    }

    function wrapOffset(offset, total) {
      if (offset > total / 2) return offset - total;
      if (offset < -total / 2) return offset + total;
      return offset;
    }

    function setTransitioning(active) {
      transitioning = active;
      if (viewport) viewport.classList.toggle('is-transitioning', active);
      if (transitionTimer) window.clearTimeout(transitionTimer);
      if (active) {
        transitionTimer = window.setTimeout(function () {
          transitioning = false;
          if (viewport) viewport.classList.remove('is-transitioning');
        }, reducedMotion ? 0 : 900);
      }
    }

    function renderDots() {
      if (!dotsWrap) return;
      dotsWrap.innerHTML = '';
      if (cards.length <= 1) {
        dotsWrap.hidden = true;
        return;
      }
      dotsWrap.hidden = false;
      cards.forEach(function (_, i) {
        var dot = document.createElement('button');
        dot.type = 'button';
        dot.className = 'bs-coverflow__dot' + (i === index ? ' is-active' : '');
        dot.setAttribute('aria-label', 'Go to product ' + (i + 1));
        dot.addEventListener('click', function () { goTo(i); });
        dotsWrap.appendChild(dot);
      });
    }

    function layout() {
      var space = spacing();
      var total = cards.length;

      cards.forEach(function (card, i) {
        var offset = wrapOffset(i - index, total);
        var abs = Math.abs(offset);
        var isActive = offset === 0;
        var rotateY = offset * -42;
        var translateX = offset * space;
        var translateZ = -abs * 150;
        var scale = isActive ? 1 : Math.max(0.68, 1 - abs * 0.13);
        var opacity = abs > 3 ? 0 : (isActive ? 1 : Math.max(0.32, 1 - abs * 0.24));
        var pointer = abs > 2 ? 'none' : 'auto';

        card.style.transform = 'translate3d(calc(-50% + ' + translateX + 'px), -50%, ' + translateZ + 'px) rotateY(' + rotateY + 'deg) scale(' + scale + ')';

        card.style.opacity = opacity;
        card.style.zIndex = String(100 - abs);
        card.style.pointerEvents = pointer;
        card.classList.toggle('is-active', isActive);
        card.setAttribute('aria-hidden', abs > 1 ? 'true' : 'false');
        card.tabIndex = isActive ? 0 : -1;
      });

      renderDots();
    }

    function goTo(nextIndex) {
      if (!cards.length) return;
      var next = (nextIndex + cards.length) % cards.length;
      if (next === index) return;
      index = next;
      setTransitioning(true);
      layout();
      restartAutoplay();
    }

    function step(dir) {
      goTo(index + dir);
    }

    function restartAutoplay() {
      if (!autoplay || cards.length < 2) return;
      if (autoplayTimer) window.clearInterval(autoplayTimer);
      autoplayTimer = window.setInterval(function () { step(1); }, autoplayMs);
    }

    function stopAutoplay() {
      if (autoplayTimer) {
        window.clearInterval(autoplayTimer);
        autoplayTimer = null;
      }
    }

    cards.forEach(function (card, i) {
      card.addEventListener('click', function () {
        if (i === index) {
          var url = card.getAttribute('data-url');
          if (url) window.location.href = url;
        } else {
          goTo(i);
        }
      });
    });

    if (prevBtn) prevBtn.addEventListener('click', function () { step(-1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { step(1); });

    section.addEventListener('mouseenter', stopAutoplay);
    section.addEventListener('mouseleave', restartAutoplay);
    section.addEventListener('focusin', stopAutoplay);
    section.addEventListener('focusout', restartAutoplay);

    if (viewport) {
      viewport.addEventListener('touchstart', function (e) {
        if (!e.touches || !e.touches.length) return;
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        stopAutoplay();
      }, { passive: true });

      viewport.addEventListener('touchend', function (e) {
        if (!e.changedTouches || !e.changedTouches.length) return;
        var dx = e.changedTouches[0].clientX - touchStartX;
        var dy = e.changedTouches[0].clientY - touchStartY;
        if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
          step(dx > 0 ? -1 : 1);
        }
        restartAutoplay();
      }, { passive: true });

      viewport.addEventListener('wheel', function (e) {
        if (Math.abs(e.deltaX) < Math.abs(e.deltaY)) return;
        if (Math.abs(e.deltaX) < 18) return;
        e.preventDefault();
        step(e.deltaX > 0 ? 1 : -1);
      }, { passive: false });
    }

    section.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft') { e.preventDefault(); step(-1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); step(1); }
    });

    var resizeTimer;
    window.addEventListener('resize', function () {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(layout, 120);
    });

    layout();
    restartAutoplay();

    document.addEventListener('shopify:section:load', function (e) {
      if (e.target && e.target.contains(section)) {
        layout();
        restartAutoplay();
      }
    });
  })();
</script>


{%- style -%}

/* SECTION */
.bestsellers-section-dtc {
  background-color: {{ section.settings.bg_color | default: '#ffffff' }};
  padding: clamp(80px, 12vw, 140px) 0;
  font-family: 'Inter', system-ui, -apple-system, sans-serif !important;
  overflow: hidden;
}

/* CONTAINER — near full width */
.bestsellers-container-dtc {
  max-width: min(96vw, 1480px);
  margin: 0 auto;
  padding: 0 clamp(20px, 4vw, 48px);
  display: flex;
  flex-direction: column;
  gap: clamp(56px, 8vw, 96px);
  box-sizing: border-box;
}

/* HEADER — centered luxury */
.bestsellers-header-dtc {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  max-width: 680px;
  margin: 0 auto;
  gap: clamp(24px, 4vw, 36px);
}

.bestsellers__title-group-dtc {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: clamp(14px, 2.5vw, 22px);
  width: 100%;
}

.bestsellers__eyebrow-dtc {
  color: #E74C3C;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  margin: 0;
}

.bestsellers__heading-dtc {
  font-size: clamp(34px, 5.5vw, 56px);
  font-weight: 800;
  color: #1A1A1A;
  text-align: center;
  line-height: 1.06;
  letter-spacing: -0.03em;
  margin: 0;
}

.bestsellers__heading-dtc br {
  display: none;
}

.bestsellers__description-dtc {
  font-size: clamp(15px, 1.8vw, 18px);
  font-weight: 400;
  line-height: 1.7;
  color: #666666;
  margin: 0;
  max-width: 540px;
}

.bestsellers__view-all-dtc {
  font-size: 14px;
  font-weight: 600;
  color: #1A1A1A;
  text-decoration: none;
  letter-spacing: 0.02em;
  padding-bottom: 2px;
  border-bottom: 1px solid rgba(26, 26, 26, 0.2);
  transition: color 0.4s ease, border-color 0.4s ease, transform 0.4s ease;
}

.bestsellers__view-all-dtc:hover {
  color: #E74C3C;
  border-color: rgba(231, 76, 60, 0.4);
  transform: translateY(-1px);
}

/* SCROLL REVEAL */
.bestsellers-section-dtc [data-bestsellers-reveal] {
  opacity: 0;
  transform: translate3d(0, 40px, 0);
  transition:
    opacity 800ms ease-out,
    transform 800ms ease-out;
  will-change: transform, opacity;
}

.bestsellers-section-dtc [data-bestsellers-reveal].is-revealed {
  opacity: 1;
  transform: translate3d(0, 0, 0);
}

.bestsellers-section-dtc [data-bestsellers-reveal="heading"] {
  transition-delay: 0ms;
}

.bestsellers-section-dtc [data-bestsellers-reveal="description"] {
  transition-delay: 120ms;
}

.bestsellers-section-dtc [data-bestsellers-reveal="view-all"] {
  transition-delay: 200ms;
}

.bestsellers-section-dtc .prod-card-dtc[data-bestsellers-reveal="product"] {
  opacity: 0;
  transform: translate3d(0, 40px, 0);
  transition:
    opacity 800ms ease-out,
    transform 800ms ease-out,
    box-shadow 450ms ease,
    border-color 450ms ease;
  will-change: transform, opacity;
}

.bestsellers-section-dtc .prod-card-dtc[data-bestsellers-reveal="product"].is-revealed {
  opacity: 1;
  transform: translate3d(0, 0, 0);
}

/* MAGAZINE SHOWCASE — asymmetric editorial layout */
.bestsellers__showcase-dtc {
  display: grid;
  grid-template-columns: repeat(12, minmax(0, 1fr));
  grid-auto-rows: minmax(220px, auto);
  gap: clamp(24px, 3vw, 40px);
  align-items: stretch;
  overflow: visible;
  padding: 0;
}

.prod-card-dtc--featured {
  grid-column: 1 / 7;
  grid-row: 1 / 3;
  min-height: clamp(520px, 52vw, 680px);
}

.prod-card-dtc--editorial-a {
  grid-column: 7 / 10;
  grid-row: 1;
}

.prod-card-dtc--editorial-b {
  grid-column: 10 / 13;
  grid-row: 1;
}

.prod-card-dtc--editorial-c {
  grid-column: 7 / 9;
  grid-row: 2;
}

.prod-card-dtc--editorial-d {
  grid-column: 9 / 11;
  grid-row: 2;
}

.prod-card-dtc--editorial-e {
  grid-column: 11 / 13;
  grid-row: 2;
}

.prod-card-dtc--editorial-f {
  grid-column: 1 / 5;
  grid-row: 3;
}

.prod-card-dtc--editorial-g {
  grid-column: 5 / 9;
  grid-row: 3;
}

.prod-card-dtc--editorial-h {
  grid-column: 9 / 13;
  grid-row: 3;
}

/* Image-dominant card proportions */
.prod-card-dtc--featured .prod-card-dtc__image-container {
  height: auto;
  flex: 1 1 78%;
  min-height: clamp(300px, 38vw, 480px);
}

.prod-card-dtc--editorial-a .prod-card-dtc__image-container,
.prod-card-dtc--editorial-b .prod-card-dtc__image-container {
  height: auto;
  flex: 1 1 74%;
  min-height: clamp(180px, 16vw, 260px);
}

.prod-card-dtc--editorial-c .prod-card-dtc__image-container,
.prod-card-dtc--editorial-d .prod-card-dtc__image-container,
.prod-card-dtc--editorial-e .prod-card-dtc__image-container {
  height: auto;
  flex: 1 1 72%;
  min-height: clamp(140px, 12vw, 200px);
}

.prod-card-dtc--editorial-f .prod-card-dtc__image-container,
.prod-card-dtc--editorial-g .prod-card-dtc__image-container,
.prod-card-dtc--editorial-h .prod-card-dtc__image-container {
  height: auto;
  flex: 1 1 75%;
  min-height: clamp(200px, 18vw, 280px);
}

.prod-card-dtc--featured .prod-card-dtc__title {
  font-size: clamp(22px, 2.8vw, 28px);
}

.prod-card-dtc--featured .prod-card-dtc__price-new {
  font-size: clamp(24px, 2.5vw, 28px);
}

/* PRODUCT CARD TILE */
.prod-card-dtc {
  width: 100%;
  min-width: 0;
  background: #ffffff;
  border-radius: 12px;
  border: 1px solid rgba(26, 26, 26, 0.06);
  display: flex;
  flex-direction: column;
  position: relative;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
  overflow: hidden;
  transition:
    transform 500ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 500ms ease,
    border-color 500ms ease;
  height: 100%;
  backface-visibility: hidden;
}

.prod-card-dtc:hover {
  transform: translate3d(0, -5px, 0);
  box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
  border-color: rgba(26, 26, 26, 0.1);
}

/* BADGE */
.prod-card-dtc__badge {
  position: absolute;
  top: 12px;
  right: 12px;
  background-color: #E74C3C;
  color: #ffffff;
  font-size: 11.5px;
  font-weight: 700;
  text-transform: uppercase;
  padding: 6px 12px;
  border-radius: 20px;
  letter-spacing: 0.05em;
  z-index: 2;
}

/* IMAGE AREA */
.prod-card-dtc__image-container {
  height: 240px;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #EEEEEE;
  overflow: hidden;
  position: relative;
  box-sizing: border-box;
  padding: 16px;
}

.prod-card-dtc__image {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  opacity: 0.85;
  transform: scale(0.97);
  transition:
    transform 800ms ease-out,
    opacity 800ms ease-out;
  will-change: transform, opacity;
}

.prod-card-dtc.is-revealed .prod-card-dtc__image {
  opacity: 1;
  transform: scale(1);
}

.prod-card-dtc:hover .prod-card-dtc__image {
  transform: scale(1.03);
}

/* Remote element overlay inside image area */
.prod-card-dtc__remote-icon {
  position: absolute;
  bottom: 12px;
  right: 12px;
  width: 44px;
  height: 44px;
  background-color: #ffffff;
  border: 2px solid #E74C3C;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.9;
  z-index: 3;
}

/* LOWER CONTENT SECTION */
.prod-card-dtc__content {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex-grow: 1;
}

/* RATING ROW */
.prod-card-dtc__rating-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.prod-card-dtc__rating-badge {
  background-color: #2ECC71;
  color: #1A1A1A;
  font-size: 13px;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 6px;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  line-height: 1;
  letter-spacing: 0.2px;
}

.prod-card-dtc__rating-count {
  font-size: 13px;
  color: #666666;
  font-weight: 500;
}

/* TITLE AREA */
.prod-card-dtc__title {
  font-size: clamp(18px, 2.5vw, 20px);
  font-weight: 700;
  color: #1A1A1A;
  margin: 0;
  line-height: 1.3;
}

/* SUBTITLE */
.prod-card-dtc__subtitle {
  font-size: 13.5px;
  color: #888888;
  margin: 0;
  line-height: 1.4;
  font-weight: 400;
}

/* DESCRIPTION */
.prod-card-dtc__desc {
  font-size: 14.5px;
  font-weight: 600;
  color: #1A1A1A;
  margin: 0;
  line-height: 1.4;
}

/* COLOR SWATCHES ROW */
.prod-card-dtc__swatches {
  display: flex;
  gap: 8px;
  align-items: center;
}

.prod-card-dtc__swatch {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  cursor: pointer;
  border: 2px solid transparent;
  transition: all 200ms ease;
  box-sizing: border-box;
}

.prod-card-dtc__swatch:hover {
  transform: scale(1.1);
}

.prod-card-dtc__swatch.is-black {
  background-color: #000000;
}

.prod-card-dtc__swatch.is-white {
  background-color: #ffffff;
  border: 1px solid #e0e0e0;
}

.prod-card-dtc__swatch.active {
  border-color: #E74C3C;
  box-shadow: 0 0 6px rgba(231, 76, 60, 0.4);
}

/* PRICE SECTION */
.prod-card-dtc__price-box {
  display: flex;
  flex-direction: column;
  gap: 2px;
  text-align: left;
  margin-top: auto;
}

.prod-card-dtc__price-old {
  font-size: 12px;
  color: #CCCCCC;
  text-decoration: line-through;
  line-height: 1.1;
}

.prod-card-dtc__price-new {
  font-size: 21px;
  font-weight: 700;
  color: #1A1A1A;
  line-height: 1.1;
}

/* CTA BUTTON */
.prod-card-dtc__btn {
  background: #000000;
  color: #ffffff;
  font-size: 14.5px;
  font-weight: 700;
  padding: 13px 24px;
  border-radius: 8px;
  border: none;
  cursor: pointer;
  transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
  width: 100%;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  height: 48px;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.prod-card-dtc__btn:hover {
  opacity: 0.9;
  transform: translateY(-1px);
}

.prod-card-dtc__btn:active {
  opacity: 0.85;
  transform: translateY(0);
}

.prod-card-dtc__quick-add,
.prod-card-dtc__emi-row,
.prod-card-dtc__price-prefix {
  display: none;
}

@media (min-width: 768px) {
  .prod-card-dtc__content {
    align-items: stretch;
    text-align: left;
  }

  .prod-card-dtc__badge::before {
    content: none;
  }

  .prod-card-dtc__rating-row {
    order: 2;
    justify-content: flex-start;
    margin-top: 0;
    margin-bottom: 2px;
  }

  .prod-card-dtc__rating-badge {
    font-size: 13px;
  }

  .prod-card-dtc__rating-badge::after {
    content: none;
  }

  .prod-card-dtc__title {
    order: 1;
    text-align: left;
  }

  .prod-card-dtc__subtitle {
    order: 3;
  }

  .prod-card-dtc__desc {
    order: 4;
  }

  .prod-card-dtc__swatches {
    order: 5;
    justify-content: flex-start;
  }

  .prod-card-dtc__price-box {
    order: 6;
    flex-direction: column;
    text-align: left;
    align-items: flex-start;
  }

  .prod-card-dtc__price-old {
    order: 1;
  }

  .prod-card-dtc__price-new {
    order: 2;
    color: #1A1A1A;
    font-size: 21px;
  }

  .prod-card-dtc form:has(.prod-card-dtc__btn),
  .prod-card-dtc__content > .prod-card-dtc__btn {
    order: 7;
    display: block !important;
  }

  .prod-card-dtc__btn {
    display: inline-flex !important;
  }

  .prod-card-dtc__emi-row {
    display: none !important;
  }
}

/* TABLET — featured full width, asymmetric pairs */
@media (min-width: 768px) and (max-width: 1023px) {
  .bestsellers__showcase-dtc {
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 24px;
  }

  .prod-card-dtc--featured {
    grid-column: 1 / -1;
    grid-row: auto;
    min-height: clamp(440px, 60vw, 520px);
  }

  .prod-card-dtc--editorial-a,
  .prod-card-dtc--editorial-c,
  .prod-card-dtc--editorial-e,
  .prod-card-dtc--editorial-g {
    grid-column: span 3;
    grid-row: auto;
  }

  .prod-card-dtc--editorial-b,
  .prod-card-dtc--editorial-d,
  .prod-card-dtc--editorial-f,
  .prod-card-dtc--editorial-h {
    grid-column: span 3;
    grid-row: auto;
  }
}

/* MOBILE — featured first, elegant stack */
@media (max-width: 767px) {
  .bestsellers-section-dtc {
    padding: clamp(56px, 14vw, 80px) 0;
  }

  .bestsellers-section-dtc [data-bestsellers-reveal],
  .bestsellers-section-dtc .prod-card-dtc[data-bestsellers-reveal="product"] {
    transform: translate3d(0, 28px, 0);
  }

  .bestsellers-container-dtc {
    padding: 0 max(16px, var(--site-padding, 16px));
    gap: clamp(40px, 10vw, 56px);
  }

  .bestsellers__heading-dtc {
    font-size: clamp(28px, 8vw, 38px);
  }

  .bestsellers__description-dtc {
    font-size: 15px;
  }

  .bestsellers__showcase-dtc {
    display: flex;
    flex-direction: column;
    gap: clamp(28px, 7vw, 40px);
  }

  .prod-card-dtc--featured {
    min-height: auto;
  }

  .prod-card-dtc--featured .prod-card-dtc__image-container {
    min-height: clamp(280px, 72vw, 380px);
    flex: 1 1 76%;
  }

  .prod-card-dtc {
    flex: none;
    width: 100%;
    min-width: 0;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    background: #ffffff;
    overflow: hidden;
  }

  .prod-card-dtc:hover {
    transform: translate3d(0, -3px, 0);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.09);
  }

  .prod-card-dtc__badge {
    top: 0;
    left: 0;
    right: auto;
    background: transparent;
    color: #1A1A1A;
    font-size: 11px;
    font-weight: 700;
    padding: 0;
    border-radius: 0;
    letter-spacing: 0;
    text-transform: none;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .prod-card-dtc__badge::before {
    content: '★';
    color: #E74C3C;
    font-size: 12px;
  }

  .prod-card-dtc__image-container {
    height: auto;
    min-height: clamp(200px, 55vw, 280px);
    flex: 1 1 74%;
    aspect-ratio: auto;
    background-color: #EEEEEE;
    border-radius: 0;
    padding: clamp(16px, 4vw, 24px);
    margin-bottom: 0;
    position: relative;
  }

  .prod-card-dtc__remote-icon {
    display: none;
  }

  .prod-card-dtc__quick-add {
    position: absolute;
    bottom: 8px;
    right: 8px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1.5px solid #1A1A1A;
    background: #ffffff;
    color: #1A1A1A;
    font-size: 20px;
    line-height: 1;
    font-weight: 400;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 4;
    padding: 0;
  }

  .prod-card-dtc__content {
    padding: 0;
    gap: 6px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .prod-card-dtc__rating-row {
    order: 2;
    margin-top: 0;
    margin-bottom: 4px;
    gap: 6px;
    justify-content: center;
    width: 100%;
  }

  .prod-card-dtc__rating-badge {
    background-color: #2ECC71;
    color: #1A1A1A;
    font-size: 12px;
    font-weight: 700;
    padding: 4px 8px;
    border-radius: 6px;
  }

  .prod-card-dtc__rating-badge::after {
    content: none;
  }

  .prod-card-dtc__rating-count {
    font-size: 12px;
    color: #666666;
  }

  .prod-card-dtc__title {
    font-size: 14px;
    font-weight: 600;
    color: #2c3e50;
    line-height: 1.35;
    order: 1;
    margin-top: 0;
    text-align: center;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .prod-card-dtc__subtitle,
  .prod-card-dtc__desc,
  .prod-card-dtc__btn,
  .prod-card-dtc form {
    display: none !important;
  }

  .prod-card-dtc__swatches {
    order: 5;
    justify-content: center;
    margin-top: 4px;
  }

  .prod-card-dtc__swatch {
    width: 18px;
    height: 18px;
    border-radius: 4px;
  }

  .prod-card-dtc__price-box {
    order: 3;
    margin-top: 2px;
    gap: 0;
    flex-direction: row;
    align-items: baseline;
    justify-content: center;
    flex-wrap: wrap;
    column-gap: 6px;
    text-align: center;
  }

  .prod-card-dtc__price-old {
    font-size: 11px;
    color: #aaaaaa;
    order: 2;
  }

  .prod-card-dtc__price-new {
    font-size: 15px;
    font-weight: 700;
    color: #E74C3C;
    order: 1;
  }

  .prod-card-dtc__price-prefix {
    display: inline;
    font-size: 13px;
    font-weight: 600;
    color: #E74C3C;
  }

  .prod-card-dtc__emi-row {
    order: 4;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
    width: 100%;
  }

  .prod-card-dtc__emi-text {
    font-size: 11px;
    color: #888888;
    line-height: 1.3;
  }

  .prod-card-dtc__emi-badge {
    display: inline-flex;
    align-items: center;
    background: #E74C3C;
    color: #ffffff;
    font-size: 10px;
    font-weight: 700;
    padding: 4px 8px;
    border-radius: 4px;
    line-height: 1;
    white-space: nowrap;
  }
}

@media (max-width: 380px) {
  .bestsellers__showcase-dtc {
    gap: 24px;
  }

  .prod-card-dtc__image-container {
    min-height: 130px;
    padding: 16px 10px 10px;
  }

  .prod-card-dtc__title {
    font-size: 13px;
  }

  .prod-card-dtc__price-new {
    font-size: 14px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .bestsellers-section-dtc [data-bestsellers-reveal],
  .bestsellers-section-dtc .prod-card-dtc[data-bestsellers-reveal="product"] {
    opacity: 1;
    transform: none;
    transition: none;
  }

  .prod-card-dtc,
  .prod-card-dtc__image,
  .prod-card-dtc__btn,
  .bestsellers__view-all-dtc {
    transition: none !important;
  }

  .prod-card-dtc:hover {
    transform: none;
  }

  .prod-card-dtc__image {
    opacity: 1 !important;
    transform: none !important;
  }

  .prod-card-dtc:hover .prod-card-dtc__image {
    transform: none !important;
  }
}

{%- endstyle -%}

<section
  class="bestsellers-section-dtc"
  id="bestsellers-{{ section.id }}"
  aria-label="Bestseller products"
>
  <div class="bestsellers-container-dtc">

    <!-- HEADER -->
    <div class="bestsellers-header-dtc">
      <div class="bestsellers__title-group-dtc">
        <span class="bestsellers__eyebrow-dtc" data-bestsellers-reveal="heading">
          {{ section.settings.eyebrow | default: 'BESTSELLING COLLECTION' }}
        </span>
        <h2 class="bestsellers__heading-dtc" data-bestsellers-reveal="heading">
          {{ section.settings.heading | default: 'Bestselling Sneaker Care' }}
        </h2>
        {%- assign bestsellers_description = section.settings.description | default: 'Premium sneaker care essentials crafted for collectors and everyday wearers — clean, protect, and restore every pair with confidence.' -%}
        {%- if bestsellers_description != blank -%}
          <p class="bestsellers__description-dtc" data-bestsellers-reveal="description">
            {{ bestsellers_description }}
          </p>
        {%- endif -%}
      </div>
      {%- if section.settings.show_view_all -%}
        <a
          href="{{ section.settings.view_all_link | default: '/collections/all' }}"
          class="bestsellers__view-all-dtc"
          data-bestsellers-reveal="view-all"
        >
          {{ section.settings.view_all_text | default: 'View All' }} →
        </a>
      {%- endif -%}
    </div>

    <!-- PRODUCTS — magazine showcase -->
    <div class="bestsellers__showcase-dtc">

      {% assign products_to_show = collections[section.settings.collection].products %}
      {% if products_to_show.size > 0 %}
        {% for product in products_to_show limit: 8 %}
          {%- assign card_variant = product.selected_or_first_available_variant -%}
          {%- assign emi_monthly = product.price | divided_by: 3 -%}
          {%- case forloop.index -%}
            {%- when 1 -%}{%- assign editorial_class = 'prod-card-dtc--featured' -%}
            {%- when 2 -%}{%- assign editorial_class = 'prod-card-dtc--editorial-a' -%}
            {%- when 3 -%}{%- assign editorial_class = 'prod-card-dtc--editorial-b' -%}
            {%- when 4 -%}{%- assign editorial_class = 'prod-card-dtc--editorial-c' -%}
            {%- when 5 -%}{%- assign editorial_class = 'prod-card-dtc--editorial-d' -%}
            {%- when 6 -%}{%- assign editorial_class = 'prod-card-dtc--editorial-e' -%}
            {%- when 7 -%}{%- assign editorial_class = 'prod-card-dtc--editorial-f' -%}
            {%- when 8 -%}{%- assign editorial_class = 'prod-card-dtc--editorial-g' -%}
            {%- else -%}{%- assign editorial_class = 'prod-card-dtc--editorial-h' -%}
          {%- endcase -%}
          <div
            class="prod-card-dtc {{ editorial_class }}"
            data-bestsellers-reveal="product"
            data-reveal-index="{{ forloop.index0 }}"
            onclick="window.location.href='{{ product.url }}';"
            style="cursor: pointer;"
          >

            <span class="prod-card-dtc__badge">Bestseller</span>

            <div class="prod-card-dtc__image-container">
              {%- if forloop.first -%}
                {%- assign card_image_width = 900 -%}
              {%- else -%}
                {%- assign card_image_width = 450 -%}
              {%- endif -%}
              <img src="{{ product.featured_image | image_url: width: card_image_width }}" class="prod-card-dtc__image" loading="lazy" alt="{{ product.title | escape }}">
              <div class="prod-card-dtc__remote-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="7" y="2" width="10" height="20" rx="3" stroke="#E74C3C" stroke-width="2"/>
                  <circle cx="12" cy="7" r="1.5" fill="#E74C3C"/>
                  <circle cx="12" cy="11.5" r="1" fill="#E74C3C"/>
                  <circle cx="12" cy="15" r="1" fill="#E74C3C"/>
                </svg>
              </div>
              {%- if card_variant.available -%}
                <form action="{{ routes.cart_add_url }}" method="post" onclick="event.stopPropagation();">
                  <input type="hidden" name="id" value="{{ card_variant.id }}">
                  <button type="submit" class="prod-card-dtc__quick-add" aria-label="Add {{ product.title | escape }} to cart">+</button>
                </form>
              {%- endif -%}
            </div>

            <div class="prod-card-dtc__content">
              <h3 class="prod-card-dtc__title">{{ product.title }}</h3>

              <div class="prod-card-dtc__rating-row">
                <span class="prod-card-dtc__rating-badge">★ {{ section.settings.rating_value | default: '4.9' }}</span>
                <span class="prod-card-dtc__rating-count">({{ section.settings.rating_count | default: '4.8' }})</span>
              </div>

              {%- if product.type != blank -%}
                <p class="prod-card-dtc__subtitle">{{ product.type }}</p>
              {%- endif -%}

              {%- assign card_desc = product.description | strip_html | strip | truncate: 60 -%}
              {%- if card_desc != blank -%}
                <p class="prod-card-dtc__desc">{{ card_desc }}</p>
              {%- endif -%}

              <div class="prod-card-dtc__price-box">
                {%- if product.price_varies -%}
                  <span class="prod-card-dtc__price-prefix">From</span>
                {%- endif -%}
                <span class="prod-card-dtc__price-new">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="prod-card-dtc__price-old">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
              </div>

              <div class="prod-card-dtc__emi-row">
                <span class="prod-card-dtc__emi-text">or {{ emi_monthly | money }}/Month</span>
                <span class="prod-card-dtc__emi-badge">Buy on EMI &gt;</span>
              </div>

              {%- if product.variants.size > 1 -%}
                <div class="prod-card-dtc__swatches">
                  <div class="prod-card-dtc__swatch is-white active" title="Variant"></div>
                  <div class="prod-card-dtc__swatch is-black" title="Variant"></div>
                </div>
              {%- endif -%}

              {%- if card_variant.available -%}
                <form action="{{ routes.cart_add_url }}" method="post" onclick="event.stopPropagation();" style="margin: 0; padding: 0; width: 100%;">
                  <input type="hidden" name="id" value="{{ card_variant.id }}">
                  <button type="submit" class="prod-card-dtc__btn" aria-label="Add {{ product.title | escape }} to cart">Add to Cart</button>
                </form>
              {%- else -%}
                <button type="button" class="prod-card-dtc__btn" onclick="event.stopPropagation(); window.location.href='{{ product.url }}';">View Product</button>
              {%- endif -%}
            </div>

          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          {%- if i == 1 -%}
            {%- assign mock_handle = 'essential-indepth-shoe-sneaker-cleaning-kit' -%}
            {%- assign mock_title = 'Essential In-Depth Shoe Sneaker Cleaning Kit' -%}
            {%- assign editorial_class = 'prod-card-dtc--featured' -%}
          {%- elsif i == 2 -%}
            {%- assign mock_handle = 'hague-protect-quick-shoe-sneaker-cleaning-kit-shoes-care-kits' -%}
            {%- assign mock_title = 'Quick Shoe Sneaker Cleaning Kit' -%}
            {%- assign editorial_class = 'prod-card-dtc--editorial-a' -%}
          {%- elsif i == 3 -%}
            {%- assign mock_handle = 'signature-shoe-sneaker-cleaning-kit' -%}
            {%- assign mock_title = 'Signature Shoe Sneaker Cleaning Kit' -%}
            {%- assign editorial_class = 'prod-card-dtc--editorial-b' -%}
          {%- else -%}
            {%- assign mock_handle = 'sneaker-shoe-cleaner-refill-pack' -%}
            {%- assign mock_title = 'Sneaker Shoe Cleaner Refill Pack' -%}
            {%- assign editorial_class = 'prod-card-dtc--editorial-c' -%}
          {%- endif -%}

          <div
            class="prod-card-dtc {{ editorial_class }}"
            data-bestsellers-reveal="product"
            data-reveal-index="{{ i | minus: 1 }}"
            onclick="window.location.href='/products/{{ mock_handle }}';"
            style="cursor: pointer;"
          >
            <span class="prod-card-dtc__badge">Bestseller</span>

            <div class="prod-card-dtc__image-container">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 1000" class="prod-card-dtc__image" style="width:100%; height:100%;">
                <rect width="1000" height="1000" fill="#f7f7f7"/>
                <circle cx="500" cy="450" r="280" fill="#ffffff" stroke="#eeeeee" stroke-width="2"/>
                <path d="M500 450 L500 230 M500 450 L690 340 M500 450 L610 610 M500 450 L390 610 M500 450 L310 340" stroke="#FF4444" stroke-width="12" stroke-linecap="round"/>
                <circle cx="500" cy="450" r="40" fill="#222222"/>
              </svg>
              <div class="prod-card-dtc__remote-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="7" y="2" width="10" height="20" rx="3" stroke="#E74C3C" stroke-width="2"/>
                  <circle cx="12" cy="7" r="1.5" fill="#E74C3C"/>
                  <circle cx="12" cy="11.5" r="1" fill="#E74C3C"/>
                  <circle cx="12" cy="15" r="1" fill="#E74C3C"/>
                </svg>
              </div>
              <button type="button" class="prod-card-dtc__quick-add" aria-label="View {{ mock_title | escape }}">+</button>
            </div>

            <div class="prod-card-dtc__content">
              <h3 class="prod-card-dtc__title">{{ mock_title }}</h3>

              <div class="prod-card-dtc__rating-row">
                <span class="prod-card-dtc__rating-badge">★ {{ section.settings.rating_value | default: '4.9' }}</span>
                <span class="prod-card-dtc__rating-count">({{ section.settings.rating_count | default: '4.8' }})</span>
              </div>

              <p class="prod-card-dtc__subtitle">Premium | Maximum Care</p>
              <p class="prod-card-dtc__desc">Elite care and ultimate protection.</p>

              <div class="prod-card-dtc__price-box">
                <span class="prod-card-dtc__price-new">Rs. 999</span>
                <span class="prod-card-dtc__price-old">Rs. 1,299</span>
              </div>

              <div class="prod-card-dtc__emi-row">
                <span class="prod-card-dtc__emi-text">or ₹333/Month</span>
                <span class="prod-card-dtc__emi-badge">Buy on EMI &gt;</span>
              </div>

              <div class="prod-card-dtc__swatches">
                <div class="prod-card-dtc__swatch is-white active" title="White"></div>
                <div class="prod-card-dtc__swatch is-black" title="Black"></div>
              </div>

              <button type="button" class="prod-card-dtc__btn" onclick="event.stopPropagation(); window.location.href='/products/{{ mock_handle }}';">View Details</button>
            </div>
          </div>
        {% endfor %}
      {% endif %}

    </div>
  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('bestsellers-{{ section.id }}');
    if (!section) return;

    var headerItems = section.querySelectorAll('[data-bestsellers-reveal="heading"], [data-bestsellers-reveal="description"], [data-bestsellers-reveal="view-all"]');
    var products = section.querySelectorAll('[data-bestsellers-reveal="product"]');

    products.forEach(function (card) {
      var index = parseInt(card.getAttribute('data-reveal-index') || '0', 10);
      var delay = index === 0 ? 280 : 380 + (index - 1) * 100;
      card.style.transitionDelay = delay + 'ms';
    });

    function revealAll() {
      headerItems.forEach(function (el) { el.classList.add('is-revealed'); });
      products.forEach(function (el) { el.classList.add('is-revealed'); });
    }

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches || !('IntersectionObserver' in window)) {
      revealAll();
      return;
    }

    var revealed = false;
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting && !revealed) {
            revealed = true;
            revealAll();
            observer.disconnect();
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -6% 0px' }
    );

    observer.observe(section);

    document.addEventListener('shopify:section:load', function (event) {
      if (event.detail && event.detail.sectionId === '{{ section.id }}') {
        revealAll();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Bestsellers",
  "settings": [
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "BESTSELLING COLLECTION"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bestselling Sneaker Care"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Premium sneaker care essentials crafted for collectors and everyday wearers — clean, protect, and restore every pair with confidence."
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all link",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all link text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "rating_value",
      "label": "Rating score",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "rating_count",
      "label": "Rating count text",
      "default": "4.8"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Bestsellers"
    }
  ]
}
{% endschema %}
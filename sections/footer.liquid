{%- style -%}
  .footer-wrapper {
    background-color: #000000 !important;
    color: #ffffff !important;
    padding-top: clamp(48px, 6vw, 96px);
    padding-bottom: clamp(32px, 4vw, 64px);
    border-top: 1px solid #1a1a1a;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    margin-bottom: 60px;
  }

  @media screen and (max-width: 991px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
      margin-bottom: 48px;
    }

    .footer-col-newsletter {
      grid-column: 1 / -1;
    }
  }

  .footer__logo-link {
    font-size: 24px;
    font-weight: 800;
    color: #ffffff !important;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 16px;
  }

  .footer__logo-link span {
    color: var(--color-primary);
  }

  .footer__description {
    font-size: 14px;
    color: #e0e0e0 !important;
    line-height: 1.6;
    margin-bottom: 24px;
    max-width: 280px;
  }

  .footer__title {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    margin-bottom: 24px;
    color: #ffffff !important;
  }

  .footer__menu {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer__link {
    font-size: 14px;
    color: #cccccc !important;
    transition: var(--transition-fast);
  }

  .footer__link:hover {
    color: #ffffff !important;
    transform: translateX(4px);
  }

  .footer__newsletter {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer__newsletter-desc {
    font-size: 14px;
    color: #cccccc !important;
  }

  .footer__form {
    display: flex;
    gap: 10px;
    position: relative;
  }

  .footer__input {
    flex: 1;
    font-family: var(--font-family-sans);
    font-size: 14px;
    border: 1px solid #333333;
    background-color: #1a1a1a;
    color: #ffffff !important;
    border-radius: var(--border-radius-xl);
    padding: 14px 20px;
    outline: none;
    transition: var(--transition-fast);
  }

  .footer__input:focus {
    border-color: var(--color-primary);
  }

  .footer__form-btn {
    padding: 14px 24px;
    background-color: var(--color-primary);
    color: #ffffff;
    border-radius: var(--border-radius-xl);
    border: none;
    cursor: pointer;
    font-weight: 600;
    font-size: 14px;
    transition: var(--transition-smooth);
  }

  .footer__form-btn:hover {
    background-color: #e21c1c;
    box-shadow: 0 4px 12px rgba(255, 43, 43, 0.2);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid #1a1a1a;
    padding-top: 32px;
    font-size: 13px;
    color: #888888 !important;
  }

  @media screen and (max-width: 768px) {
    .footer-wrapper {
      padding-top: 48px;
      padding-bottom: 28px;
      overflow-x: hidden;
    }

    .footer-wrapper .container {
      padding-left: var(--site-padding, 20px);
      padding-right: var(--site-padding, 20px);
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 36px;
      margin-bottom: 40px;
    }

    .footer-col-info,
    .footer-col-menu,
    .footer-col-newsletter {
      text-align: center;
    }

    .footer__logo-link {
      justify-content: center;
      margin-bottom: 12px;
    }

    .footer__logo-link > span {
      flex-wrap: wrap;
      justify-content: center;
      font-size: clamp(17px, 4.8vw, 21px) !important;
      max-width: 100%;
      line-height: 1.3;
    }

    .footer__description {
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
      margin-bottom: 20px;
      font-size: 13px;
    }

    .footer__socials {
      justify-content: center;
      gap: 12px;
    }

    .footer__social-icon {
      width: 44px;
      height: 44px;
      min-width: 44px;
      min-height: 44px;
    }

    .footer__title {
      margin-bottom: 16px;
      font-size: 13px;
    }

    .footer__menu {
      gap: 4px;
      align-items: center;
    }

    .footer__link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 8px 12px;
      font-size: 15px;
      -webkit-tap-highlight-color: transparent;
    }

    .footer__link:hover {
      transform: none;
    }

    .footer__newsletter {
      align-items: center;
      max-width: 100%;
    }

    .footer__newsletter-desc {
      font-size: 13px;
      line-height: 1.55;
      max-width: 320px;
      margin: 0 auto;
    }

    .footer__form {
      flex-direction: column;
      width: 100%;
      max-width: 400px;
      margin: 0 auto;
      gap: 12px;
    }

    .footer__input {
      width: 100%;
      min-height: 48px;
      padding: 14px 18px;
      font-size: 16px;
    }

    .footer__form-btn {
      width: 100%;
      min-height: 48px;
      padding: 14px 20px;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 12px;
      text-align: center;
      padding-top: 24px;
      font-size: 12px;
      line-height: 1.5;
    }

    .footer__legal {
      max-width: 280px;
      margin: 0 auto;
    }
  }

  @media screen and (max-width: 480px) {
    .footer-grid {
      gap: 32px;
    }

    .footer__logo-link > span svg {
      width: 18px;
      height: 18px;
    }
  }

  .footer__socials {
    display: flex;
    gap: 16px;
  }

  .footer__social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background-color: #1a1a1a;
    border-radius: 50%;
    border: 1px solid #333333;
    color: #ffffff;
    transition: var(--transition-fast);
  }

  .footer__social-icon:hover {
    background-color: var(--color-primary);
    color: #ffffff;
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }
{%- endstyle -%}

<footer class="footer-wrapper" role="contentinfo">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col-info">
        <a href="/" class="footer__logo-link">
          {%- if section.settings.logo_image != blank -%}
            <img src="{{ section.settings.logo_image | image_url: width: 130 }}" alt="Hague Protect" style="height: 30px; width: auto; object-fit: contain; display: block;" width="130" height="30" loading="lazy" decoding="async">
          {%- elsif section.settings.logo_text == 'HAGUEPROTECT' or section.settings.logo_text contains '.' -%}
            {%- assign footer_logo = 'logo-hagueprotect.png' -%}
            {%- if section.settings.logo_text contains '.' -%}{%- assign footer_logo = section.settings.logo_text -%}{%- endif -%}
            <img src="{{ footer_logo | asset_url }}" alt="Hague Protect" style="height: 30px; width: auto; object-fit: contain; display: block;" width="130" height="30" loading="lazy" decoding="async">
          {%- else -%}
            <span style="font-family: 'Inter', sans-serif; font-size: 21px; font-weight: 700; color: #ffffff; letter-spacing: 0.05em; text-transform: uppercase; display: inline-flex; align-items: center; gap: 1px;">
              {{ section.settings.logo_text }}
            </span>
          {%- endif -%}
        </a>
        <p class="footer__description">
          {{ section.settings.description | default: 'Premium sneaker care solutions for professional-grade cleaning, protection, and restoration.' }}
        </p>
        <div class="footer__socials">
          <a href="https://www.youtube.com/@HagueProtect" class="footer__social-icon" aria-label="YouTube" target="_blank" rel="noopener noreferrer nofollow">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 4-8 4z"/></svg>
          </a>
          <a href="https://www.instagram.com/hagueprotect/" class="footer__social-icon" aria-label="Instagram" target="_blank" rel="noopener noreferrer nofollow">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.226-.149-4.771-1.664-4.919-4.919-.058-1.265-.07-1.644-.07-4.849 0-3.204 013-3.584.07-4.849.149-3.251 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-4.717 3.824-4.917 4.917-.058 1.279-.072 1.687-.072 4.948 0 3.261.014 3.668.072 4.948.2 4.358 3.824 4.716 4.917 4.917 1.28.058 1.688.072 4.947.072 3.26 0 3.668-.014 4.948-.072 4.354-.2 4.717-3.827 4.917-4.917.058-1.279.072-1.686.072-4.948 0-3.261-.014-3.668-.072-4.948-.2-4.358-3.824-4.718-4.917-4.917-1.28-.058-1.688-.072-4.948-.072zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.162 6.162 6.162 6.162-2.759 6.162-6.162-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="#" class="footer__social-icon" aria-label="TikTok">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.17-2.86-.74-3.94-1.74-.22-.2-.42-.43-.61-.67-.01 2.44-.01 4.88-.01 7.31-.03 3.69-2.38 7.24-6.05 8.16-3.85.96-8.15-1.12-9.45-4.84-1.44-4.12.98-8.91 5.25-9.66.19-.03.38-.05.58-.06v4.01c-.13.02-.26.04-.39.07-2.02.43-3.34 2.51-2.9 4.54.4 1.81 2.15 3.01 3.98 2.63 1.67-.35 2.67-2.01 2.56-3.69 0-3.3 0-6.6 0-9.9z"/></svg>
          </a>
          <a href="#" class="footer__social-icon" aria-label="X/Twitter">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.848 6.064-6.848zm-1.292 19.494h2.039L6.486 3.24H4.298l13.311 17.407z"/></svg>
          </a>
        </div>
      </div>

      <div class="footer-col-menu">
        <h3 class="footer__title">{{ section.settings.menu_title_1 | default: 'Quick Links' }}</h3>
        <nav class="footer__menu">
          <a href="/" class="footer__link">Home</a>
          <a href="/collections/all" class="footer__link">All Products</a>
          <a href="/pages/about-us" class="footer__link">About Us</a>
          <a href="/pages/faq" class="footer__link">FAQs</a>
          <a href="/pages/contact" class="footer__link">Contact</a>
        </nav>
      </div>

      <div class="footer-col-menu">
        <h3 class="footer__title">{{ section.settings.menu_title_2 | default: 'Customer Care' }}</h3>
        <nav class="footer__menu">
          {%- liquid
            if section.settings.privacy_policy_page != blank
              assign privacy_href = section.settings.privacy_policy_page.url
            elsif section.settings.privacy_policy_url != blank
              assign privacy_href = section.settings.privacy_policy_url
            elsif pages['privacy-policy'] != blank
              assign privacy_href = pages['privacy-policy'].url
            elsif shop.privacy_policy != blank
              assign privacy_href = shop.privacy_policy.url
            else
              assign privacy_href = '/pages/privacy-policy'
            endif

            if section.settings.terms_policy_page != blank
              assign terms_href = section.settings.terms_policy_page.url
            elsif section.settings.terms_of_service_url != blank
              assign terms_href = section.settings.terms_of_service_url
            elsif pages['terms-of-service'] != blank
              assign terms_href = pages['terms-of-service'].url
            elsif shop.terms_of_service != blank
              assign terms_href = shop.terms_of_service.url
            else
              assign terms_href = '/pages/terms-of-service'
            endif

            if section.settings.refund_policy_page != blank
              assign refund_href = section.settings.refund_policy_page.url
            elsif section.settings.refund_policy_url != blank
              assign refund_href = section.settings.refund_policy_url
            elsif pages['refund-policy'] != blank
              assign refund_href = pages['refund-policy'].url
            elsif shop.refund_policy != blank
              assign refund_href = shop.refund_policy.url
            else
              assign refund_href = '/pages/refund-policy'
            endif

            if section.settings.shipping_policy_page != blank
              assign shipping_href = section.settings.shipping_policy_page.url
            elsif section.settings.shipping_policy_url != blank
              assign shipping_href = section.settings.shipping_policy_url
            elsif pages['shipping-policy'] != blank
              assign shipping_href = pages['shipping-policy'].url
            elsif shop.shipping_policy != blank
              assign shipping_href = shop.shipping_policy.url
            else
              assign shipping_href = '/pages/shipping-policy'
            endif
          -%}
          <a href="{{ privacy_href }}" class="footer__link">Privacy Policy</a>
          <a href="{{ terms_href }}" class="footer__link">Terms of Service</a>
          <a href="{{ refund_href }}" class="footer__link">Refund Policy</a>
          <a href="{{ shipping_href }}" class="footer__link">Shipping Policy</a>
        </nav>
      </div>

      <div class="footer-col-newsletter">
        <h3 class="footer__title">{{ section.settings.newsletter_title | default: 'Newsletter' }}</h3>
        <div class="footer__newsletter">
          <p class="footer__newsletter-desc">Subscribe to unlock premium sneaker care tips, drops, and elite offers.</p>
          <form class="footer__form" action="/contact#contact_form" method="post">
            <input type="hidden" name="form_type" value="customer">
            <input type="hidden" name="utf8" value="✓">
            <input type="email" name="contact[email]" class="footer__input" placeholder="Enter your email" required aria-label="Email address">
            <button type="submit" class="footer__form-btn" aria-label="Subscribe">
              Submit
            </button>
          </form>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name | default: 'HAGUEPROTECT' }}. All rights reserved.
      </div>
      <div class="footer__legal">
        Designed for modern, elite sneaker preservation.
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "HAGUEPROTECT"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Premium sneaker care solutions for professional-grade cleaning, protection, and restoration."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fafafa"
    },
    {
      "type": "text",
      "id": "menu_title_1",
      "label": "Menu 1 Title",
      "default": "Quick Links"
    },
    {
      "type": "text",
      "id": "menu_title_2",
      "label": "Menu 2 Title",
      "default": "Customer Care"
    },
    {
      "type": "header",
      "content": "Policy pages"
    },
    {
      "type": "paragraph",
      "content": "Select each policy page you created in Shopify (works even if page titles are the same). Each footer link goes to that page's unique URL."
    },
    {
      "type": "page",
      "id": "privacy_policy_page",
      "label": "Privacy Policy page"
    },
    {
      "type": "page",
      "id": "terms_policy_page",
      "label": "Terms of Service page"
    },
    {
      "type": "page",
      "id": "refund_policy_page",
      "label": "Refund Policy page"
    },
    {
      "type": "page",
      "id": "shipping_policy_page",
      "label": "Shipping Policy page"
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Newsletter Title",
      "default": "Newsletter"
    }
  ]
}
{% endschema %}

{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .promo-banner {
    font-family: var(--font-family-sans);
    background-color: {{ section.settings.bg_color | default: '#FF2B2B' }};
    padding: clamp(100px, 12vw, 160px) 0;
    overflow: hidden;
    position: relative;
    color: #ffffff;
  }

  .promo-banner__container {
    max-width: var(--site-max-width);
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 48px;
    align-items: center;
  }

  @media screen and (max-width: 768px) {
    .promo-banner {
      padding: clamp(50px, 8vw, 60px) 0;
    }
    .promo-banner__container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 32px;
    }
  }

  .promo-banner__content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .promo-banner__eyebrow {
    font-size: clamp(14px, 2vw, 18px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
  }

  .promo-banner__heading {
    font-size: clamp(40px, 7vw, 76px);
    font-weight: 800;
    line-height: 1.05;
    margin: 0;
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }

  .promo-banner__cta {
    display: inline-flex;
    align-items: center;
    background-color: #ffffff;
    color: #000000;
    padding: 18px 40px;
    border-radius: 40px;
    font-size: clamp(14px, 1.6vw, 16px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: transform 0.2s, box-shadow 0.2s;
    width: fit-content;
  }

  @media screen and (max-width: 768px) {
    .promo-banner__cta {
      margin: 0 auto;
    }
  }

  .promo-banner__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.1);
  }

  .promo-banner__image-container {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .promo-banner__image {
    width: 100%;
    max-width: 460px;
    height: auto;
    border-radius: 24px;
    transform: rotate(4deg) scale(1.05);
    box-shadow: 0 24px 60px rgba(0,0,0,0.15);
    transition: transform 0.4s ease;
    display: block;
  }

  .promo-banner:hover .promo-banner__image {
    transform: rotate(0deg) scale(1.1);
  }

  @media screen and (max-width: 768px) {
    .promo-banner__image {
      transform: none;
      max-width: 360px;
      aspect-ratio: 1 / 1 !important;
      object-fit: cover !important;
    }
    .promo-banner:hover .promo-banner__image {
      transform: scale(1.05);
    }
  }

{%- endstyle -%}

<div class="promo-banner">
  <div class="promo-banner__container">
    {%- assign eyebrow = section.settings.eyebrow | default: 'HAGUE PROTECT SPECIAL' -%}
    {%- assign heading = section.settings.heading | default: 'YOU HAD ME AT CLEAN!' -%}
    {%- assign banner_img = section.settings.image -%}

    {%- for block in section.blocks -%}
      {%- if block.type == 'product_banner' and block.settings.product_select == product.handle -%}
        {%- if block.settings.image != blank -%}
          {%- assign banner_img = block.settings.image -%}
        {%- endif -%}
        {%- if block.settings.heading != blank -%}
          {%- assign heading = block.settings.heading -%}
        {%- endif -%}
        {%- if block.settings.eyebrow != blank -%}
          {%- assign eyebrow = block.settings.eyebrow -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}

    <div class="promo-banner__content">
      <div class="section-heading-stack">
        <p class="promo-banner__eyebrow">{{ eyebrow }}</p>
        <h2 class="promo-banner__heading">{{ heading }}</h2>
      </div>
      {%- if section.settings.button_text != blank -%}
        <a href="{{ section.settings.button_link | default: '#AddToCartForm' }}" class="promo-banner__cta">
          {{ section.settings.button_text }}
        </a>
      {%- endif -%}
    </div>

    <div class="promo-banner__image-container">
      {%- if banner_img != blank -%}
        <img src="{{ banner_img | image_url: width: 800 }}" alt="{{ heading | escape }}" class="promo-banner__image" loading="lazy">
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'promo-banner__image' }}
      {%- endif -%}
    </div>
  </div>
</div>


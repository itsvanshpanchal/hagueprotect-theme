{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .how-to-banner {
    position: relative;
    width: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    overflow: hidden;
  }
  .how-to-banner img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  .how-to-banner__content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    padding: 20px;
  }
  .how-to-banner__title {
    font-family: var(--font-family-heading);
    font-size: var(--heading-size-xl);
    font-weight: var(--font-weight-heading, 800);
    font-style: var(--font-style-heading, normal);
    margin: 0;
    color: {{ section.settings.text_color }};
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .how-to-banner__subtitle-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 3;
    background: rgba(0,0,0,0.75);
    padding: 16px 20px;
    text-align: center;
  }
  .how-to-banner__subtitle {
    font-family: var(--font-family-sans);
    font-size: var(--section-subheading-size, 22px);
    font-weight: var(--font-weight-sans, 700);
    font-style: var(--font-style-sans, normal);
    color: #fff;
    margin: 0;
    letter-spacing: 0.02em;
  }
  @media screen and (max-width: 989px) {
    .how-to-banner {
      min-height: 220px;
    }
    .how-to-banner__content {
      padding: 16px;
    }
    .how-to-banner__title {
      font-size: var(--heading-size-xl);
    }
    .how-to-banner__subtitle-bar {
      padding: 12px 16px;
    }
    .how-to-banner__subtitle {
      font-size: var(--section-subheading-size, 14px);
      line-height: 1.4;
    }
  }
  @media screen and (max-width: 480px) {
    .how-to-banner {
      min-height: 180px;
    }
  }
{%- endstyle -%}

<div class="how-to-banner">
  {%- if section.settings.image != blank -%}
    {{
      section.settings.image
      | image_url: width: 2000
      | image_tag:
        loading: 'lazy',
        widths: '375, 750, 1100, 1500, 2000',
        sizes: '(max-width: 768px) 100vw, 100vw'
    }}
  {%- endif -%}
  <div class="how-to-banner__content">
    <h1 class="how-to-banner__title">{{ section.settings.title }}</h1>
  </div>
  {%- if section.settings.subtitle != blank -%}
    <div class="how-to-banner__subtitle-bar">
      <p class="how-to-banner__subtitle">{{ section.settings.subtitle }}</p>
    </div>
  {%- endif -%}
</div>


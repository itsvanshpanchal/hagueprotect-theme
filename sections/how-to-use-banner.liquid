{%- style -%}
  .how-to-banner {
    position: relative;
    width: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    overflow: hidden;
  }
  .how-to-banner img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  .how-to-banner__content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    padding: 20px;
  }
  .how-to-banner__title {
    font-size: 48px;
    font-weight: 800;
    margin: 0;
    color: {{ section.settings.text_color }};
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  @media screen and (max-width: 768px) {
    .how-to-banner {
      min-height: 250px;
    }
    .how-to-banner__title {
      font-size: 32px;
    }
  }
{%- endstyle -%}

<div class="how-to-banner">
  {%- if section.settings.image != blank -%}
    {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy' }}
  {%- endif -%}
  <div class="how-to-banner__content">
    <h1 class="how-to-banner__title">{{ section.settings.title }}</h1>
  </div>
</div>

{% schema %}
{
  "name": "How to Use Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "How to Use"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "How to Use Banner"
    }
  ]
}
{% endschema %}

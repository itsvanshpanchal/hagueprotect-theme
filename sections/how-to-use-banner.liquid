{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .how-to-banner {
    position: relative;
    width: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    overflow: hidden;
  }
  .how-to-banner img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  .how-to-banner__content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    padding: 20px;
  }
  .how-to-banner__title {
    font-size: 48px;
    font-weight: 800;
    margin: 0;
    color: {{ section.settings.text_color }};
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .how-to-banner__subtitle-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 3;
    background: rgba(0,0,0,0.75);
    padding: 16px 20px;
    text-align: center;
  }
  .how-to-banner__subtitle {
    font-size: 22px;
    font-weight: 700;
    color: #fff;
    margin: 0;
    letter-spacing: 0.02em;
  }
  @media screen and (max-width: 768px) {
    .how-to-banner {
      min-height: 220px;
    }
    .how-to-banner__content {
      padding: 16px;
    }
    .how-to-banner__title {
      font-size: clamp(1.5rem, 8vw, 2rem);
    }
    .how-to-banner__subtitle-bar {
      padding: 12px 16px;
    }
    .how-to-banner__subtitle {
      font-size: 14px;
      line-height: 1.4;
    }
  }
  @media screen and (max-width: 480px) {
    .how-to-banner {
      min-height: 180px;
    }
  }
{%- endstyle -%}

<div class="how-to-banner">
  {%- if section.settings.image != blank -%}
    {{
      section.settings.image
      | image_url: width: 2000
      | image_tag:
        loading: 'lazy',
        widths: '375, 750, 1100, 1500, 2000',
        sizes: '(max-width: 768px) 100vw, 100vw'
    }}
  {%- endif -%}
  <div class="how-to-banner__content">
    <h1 class="how-to-banner__title">{{ section.settings.title }}</h1>
  </div>
  {%- if section.settings.subtitle != blank -%}
    <div class="how-to-banner__subtitle-bar">
      <p class="how-to-banner__subtitle">{{ section.settings.subtitle }}</p>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "How to Use Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "How to Use"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Bottom Subtitle",
      "default": "How To Use HAGUEPROTECT Shoe Cleaning & Protecting Products:"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
,
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "paragraph",
      "content": "Font and size for this section. Global defaults: Theme settings > Typography."
    },
    {
      "type": "checkbox",
      "id": "typography_override",
      "label": "Override theme typography for this section",
      "default": false
    },
    {
      "type": "select",
      "id": "h1_font_family",
      "label": "H1 font family",
      "options": [
        { "value": "bebas_neue", "label": "Bebas Neue" },
        { "value": "anton", "label": "Anton" },
        { "value": "oswald", "label": "Oswald" },
        { "value": "inter", "label": "Inter" },
        { "value": "montserrat", "label": "Montserrat" }
      ],
      "default": "bebas_neue"
    },
    {
      "type": "range",
      "id": "h1_font_size_desktop",
      "label": "H1 size (desktop)",
      "min": 24,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "h1_font_size_mobile",
      "label": "H1 size (mobile)",
      "min": 18,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "select",
      "id": "h2_font_family",
      "label": "H2 font family",
      "options": [
        { "value": "bebas_neue", "label": "Bebas Neue" },
        { "value": "anton", "label": "Anton" },
        { "value": "oswald", "label": "Oswald" },
        { "value": "inter", "label": "Inter" },
        { "value": "montserrat", "label": "Montserrat" }
      ],
      "default": "bebas_neue"
    },
    {
      "type": "range",
      "id": "h2_font_size_desktop",
      "label": "H2 size (desktop)",
      "min": 20,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "h2_font_size_mobile",
      "label": "H2 size (mobile)",
      "min": 16,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 34
    },
    {
      "type": "select",
      "id": "paragraph_font_family",
      "label": "Paragraph font family",
      "options": [
        { "value": "inter", "label": "Inter" },
        { "value": "montserrat", "label": "Montserrat" },
        { "value": "bebas_neue", "label": "Bebas Neue" },
        { "value": "oswald", "label": "Oswald" }
      ],
      "default": "inter"
    },
    {
      "type": "range",
      "id": "paragraph_font_size_desktop",
      "label": "Paragraph size (desktop)",
      "min": 11,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "paragraph_font_size_mobile",
      "label": "Paragraph size (mobile)",
      "min": 11,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "select",
      "id": "eyebrow_font_family",
      "label": "Eyebrow / label font family",
      "options": [
        { "value": "inter", "label": "Inter" },
        { "value": "montserrat", "label": "Montserrat" },
        { "value": "bebas_neue", "label": "Bebas Neue" },
        { "value": "oswald", "label": "Oswald" }
      ],
      "default": "inter"
    },
    {
      "type": "range",
      "id": "eyebrow_font_size_desktop",
      "label": "Eyebrow size (desktop)",
      "min": 9,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "eyebrow_font_size_mobile",
      "label": "Eyebrow size (mobile)",
      "min": 9,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    }

  ],
  "presets": [
    {
      "name": "How to Use Banner"
    }
  ]
}
{% endschema %}

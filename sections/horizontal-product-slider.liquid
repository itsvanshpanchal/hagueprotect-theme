{%- style -%}
  #shopify-section-{{ section.id }} {
    background: linear-gradient(to bottom, {{ section.settings.bg_color | default: '#ff1e43' }} 76%, {{ section.settings.bg_color_bottom | default: '#000000' }} 76%);
  }

  .hp-fam-sec {
    position: relative;
    padding: clamp(40px, 8vw, 80px) 0 0 0;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }

  .hp-fam-sec__container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
  }

  .hp-fam-sec__heading {
    font-size: clamp(32px, 6vw, 68px);
    font-weight: 800;
    color: #ffffff;
    margin: 0 0 32px 0;
    line-height: 1.05;
    letter-spacing: -0.03em;
    max-width: 700px;
  }

  /* CATEGORY TABS */
  .hp-fam-sec__tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 40px;
    align-items: center;
  }

  .hp-fam-sec__tab {
    background: transparent;
    border: none;
    padding: 10px 20px;
    border-radius: 100px;
    color: rgba(255, 255, 255, 0.85);
    font-size: clamp(12px, 1.5vw, 14px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    outline: none;
    text-decoration: none;
    display: inline-block;
  }

  .hp-fam-sec__tab:hover {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.1);
  }

  .hp-fam-sec__tab.is-active {
    background: #000000;
    color: #ffffff;
  }

  /* SLIDERS */
  .hp-fam-sec__slider-wrap {
    position: relative;
    width: 100%;
    margin-top: 10px;
  }

  .hp-fam-sec__slider {
    display: none;
    gap: clamp(20px, 4vw, 40px);
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    padding: 0 0 0 0;
    margin-bottom: 0;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
  }

  .hp-fam-sec__slider.is-active {
    display: flex;
  }

  .hp-fam-sec__slider:active {
    cursor: grabbing;
  }

  .hp-fam-sec__slider::-webkit-scrollbar {
    display: none;
  }

  .hp-fam-sec__slider {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* CARD */
  .hp-fam-sec__card {
    flex: 0 0 clamp(240px, 30vw, 360px);
    background: transparent;
    border: none;
    overflow: visible;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    transition: transform 0.3s ease;
    margin: 0;
    padding: 0;
  }

  .hp-fam-sec__card:hover {
    transform: translateY(-8px);
  }

  .hp-fam-sec__image {
    width: 100%;
    height: auto;
    max-height: clamp(280px, 45vh, 480px);
    object-fit: contain;
    display: block;
    pointer-events: none;
    margin-bottom: 0;
  }

  @media screen and (max-width: 767px) {
    .hp-fam-sec__heading {
      margin-bottom: 24px;
    }
    .hp-fam-sec__card {
      flex: 0 0 clamp(180px, 50vw, 220px);
    }
  }
{%- endstyle -%}

<div class="hp-fam-sec" id="fam-{{ section.id }}">
  <div class="hp-fam-sec__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="hp-fam-sec__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="hp-fam-sec__tabs">
        {%- for block in section.blocks -%}
          {%- assign collection = block.settings.collection -%}
          {%- if collection != blank or block.settings.title != blank -%}
            <button class="hp-fam-sec__tab {% if forloop.first %}is-active{% endif %}" data-target="slider-{{ block.id }}">
              {{ block.settings.title | default: collection.title | upcase }}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="hp-fam-sec__slider-wrap">

      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign collection = block.settings.collection -%}
          <div class="hp-fam-sec__slider {% if forloop.first %}is-active{% endif %}" id="slider-{{ block.id }}">
            
            {%- assign has_custom_images = false -%}
            {%- for i in (1..6) -%}
              {%- capture img_id -%}image_{{ i }}{%- endcapture -%}
              {%- if block.settings[img_id] != blank -%}
                {%- assign has_custom_images = true -%}
              {%- endif -%}
            {%- endfor -%}

            {%- if has_custom_images -%}
              {%- for i in (1..6) -%}
                {%- capture img_id -%}image_{{ i }}{%- endcapture -%}
                {%- capture url_id -%}url_{{ i }}{%- endcapture -%}
                {%- if block.settings[img_id] != blank -%}
                  <a href="{{ block.settings[url_id] | default: '#' }}" class="hp-fam-sec__card">
                    <img src="{{ block.settings[img_id] | image_url: width: 800 }}"
                         alt="Product"
                         class="hp-fam-sec__image"
                         loading="lazy">
                  </a>
                {%- endif -%}
              {%- endfor -%}
            {%- elsif collection != blank and collection.products.size > 0 -%}
              {%- for product in collection.products limit: section.settings.products_to_show -%}
                <a href="{{ product.url }}" class="hp-fam-sec__card">
                  {%- if product.featured_media != blank -%}
                    <img src="{{ product.featured_media | image_url: width: 800 }}"
                         alt="{{ product.title | escape }}"
                         class="hp-fam-sec__image"
                         loading="lazy">
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'hp-fam-sec__image' }}
                  {%- endif -%}
                </a>
              {%- endfor -%}
            {%- else -%}
              {%- for i in (1..4) -%}
                <div class="hp-fam-sec__card">
                  {%- capture current -%}{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                  {{ 'product-' | append: current | placeholder_svg_tag: 'hp-fam-sec__image' }}
                </div>
              {%- endfor -%}
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="hp-fam-sec__slider is-active">
          {%- for i in (1..4) -%}
            <div class="hp-fam-sec__card">
              {%- capture current -%}{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
              {{ 'product-' | append: current | placeholder_svg_tag: 'hp-fam-sec__image' }}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function() {
    const section = document.getElementById('fam-{{ section.id }}');
    if (!section) return;

    // Handle tab clicking
    const tabs = section.querySelectorAll('.hp-fam-sec__tab');
    const sliders = section.querySelectorAll('.hp-fam-sec__slider');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('is-active'));
        sliders.forEach(s => s.classList.remove('is-active'));

        tab.classList.add('is-active');
        const targetSlider = section.querySelector(`#${tab.getAttribute('data-target')}`);
        if (targetSlider) {
          targetSlider.classList.add('is-active');
        }
      });
    });

    // Add drag-to-scroll interactivity
    sliders.forEach(slider => {
      let isDown = false;
      let startX;
      let scrollLeft;

      slider.addEventListener('mousedown', (e) => {
        isDown = true;
        startX = e.pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
        slider.style.scrollBehavior = 'auto';
      });

      slider.addEventListener('mouseleave', () => {
        isDown = false;
      });

      slider.addEventListener('mouseup', () => {
        isDown = false;
        slider.style.scrollBehavior = 'smooth';
      });

      slider.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - slider.offsetLeft;
        const walk = (x - startX) * 1.5;
        slider.scrollLeft = scrollLeft - walk;
      });
    });
  })();
</script>


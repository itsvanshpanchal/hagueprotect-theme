{%- style -%}
  #shopify-section-{{ section.id }} {
    background: linear-gradient(to bottom, {{ section.settings.bg_color | default: '#ff1e43' }} 76%, {{ section.settings.bg_color_bottom | default: '#000000' }} 76%);
    position: relative;
  }

  .hp-fam-sec {
    position: relative;
    padding: clamp(40px, 8vw, 80px) 0 0 0;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }

  .hp-fam-sec__container {
    max-width: 1440px;
    width: 100%;
    margin: 0 auto;
    padding: 0 40px;
    position: relative;
    box-sizing: border-box;
    z-index: 2;
  }

  .hp-fam-sec__heading {
    font-size: clamp(32px, 6vw, 68px);
    font-weight: 800;
    color: #ffffff;
    margin: 0 0 32px 0;
    line-height: 1.05;
    letter-spacing: -0.03em;
    max-width: 700px;
  }

  /* CATEGORY TABS */
  .hp-fam-sec__tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 40px;
    align-items: center;
  }

  .hp-fam-sec__tab {
    background: transparent;
    border: none;
    padding: 10px 20px;
    border-radius: 100px;
    color: rgba(255, 255, 255, 0.85);
    font-size: clamp(12px, 1.5vw, 14px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    outline: none;
    text-decoration: none;
    display: inline-block;
  }

  .hp-fam-sec__tab:hover {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.1);
  }

  .hp-fam-sec__tab.is-active {
    background: #000000;
    color: #ffffff;
  }

  /* LAYOUT */
  .hp-fam-sec__main-flex {
    width: 100%;
  }

  .hp-fam-sec__slider-left {
    width: 100%;
  }

  /* SLIDERS */
  .hp-fam-sec__slider-wrap {
    position: relative;
    width: 100%;
    margin-top: 10px;
  }

  .hp-fam-sec__slider {
    display: none;
    gap: clamp(20px, 4vw, 40px);
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    touch-action: pan-y;
    padding: 0 0 0 0;
    margin-bottom: 0;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    align-items: flex-end;
  }

  .hp-fam-sec__slider.is-active {
    display: flex;
  }

  .hp-fam-sec__slider:active {
    cursor: grabbing;
  }

  .hp-fam-sec__slider.is-dragging .hp-fam-sec__card {
    pointer-events: none;
    cursor: grabbing;
  }

  .hp-fam-sec__slider::-webkit-scrollbar {
    display: none;
  }

  .hp-fam-sec__slider {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* CARD */
  .hp-fam-sec__card {
    flex: 0 0 clamp(280px, 36vw, 420px);
    background: transparent;
    border: none;
    overflow: visible;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    align-self: flex-end;
    transition: transform 0.3s ease;
    margin: 0;
    padding: 0;
    user-drag: none;
    -webkit-user-drag: none;
    -webkit-user-select: none;
    user-select: none;
  }

  .hp-fam-sec__card:hover {
    transform: translateY(-8px);
  }

  .hp-fam-sec__image {
    width: 100%;
    height: auto;
    max-height: clamp(350px, 55vh, 580px);
    object-fit: contain;
    display: block;
    pointer-events: none;
    margin-bottom: 0;
    user-drag: none;
    -webkit-user-drag: none;
    transform: translateY({{ section.settings.image_offset | default: 0 }}px);
  }

  /* PREMIUM FLOATING RAIL */
  .premium-floating-rail {
    position: absolute;
    right: 40px;
    top: 0;
    bottom: 0;
    width: 340px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    pointer-events: none;
  }

  .rail-mask {
    height: 100%;
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent);
    -webkit-mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent);
    pointer-events: auto;
  }

  .rail-track {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 100px 0;
    will-change: transform;
  }

  .rail-card {
    background: #ffffff;
    border: 1px solid #eeeeee;
    border-radius: 24px;
    padding: 16px;
    width: 100%;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
    gap: 12px;
    cursor: pointer;
  }

  .rail-card:hover {
    background: #fafafa;
    transform: translateY(-10px) scale(1.02);
    box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    border-color: #dddddd;
  }

  .rail-card-img {
    width: 100%;
    height: 180px;
    background: #000;
    border-radius: 16px;
    overflow: hidden;
  }

  .rail-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .rail-card:hover .rail-card-img img {
    transform: scale(1.1);
  }

  .rail-card-info {
    text-align: left;
  }

  .rail-card-title {
    color: #111111;
    font-size: 16px;
    font-weight: 700;
    margin: 0 0 4px 0;
    font-family: 'Inter', sans-serif;
  }

  .rail-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .rail-card-price {
    color: #ff1e43;
    font-weight: 800;
    font-size: 18px;
  }

  .rail-card-rating {
    color: #ffd700;
    font-size: 12px;
  }

  .rail-card-atc {
    background: #000;
    color: #fff;
    border: none;
    width: 100%;
    padding: 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.3s;
  }

  .rail-card-atc:hover {
    background: #ff1e43;
    color: #fff;
  }

  @media screen and (max-width: 1200px) {
    .premium-floating-rail {
      display: none;
    }
  }

  @media screen and (max-width: 767px) {
    .hp-fam-sec {
      padding: 32px 0 0 0;
    }
    .hp-fam-sec__container {
      padding: 0 16px;
    }
    .hp-fam-sec__heading {
      margin-bottom: 20px;
      font-size: clamp(28px, 8vw, 36px);
    }
    .hp-fam-sec__tabs {
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 4px;
      margin-bottom: 24px;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      gap: 8px;
    }
    .hp-fam-sec__tabs::-webkit-scrollbar {
      display: none;
    }
    .hp-fam-sec__tab {
      flex: 0 0 auto;
      padding: 8px 16px;
    }
    .hp-fam-sec__slider {
      gap: 12px;
      scroll-snap-type: x mandatory;
      padding-bottom: 20px;
    }
    .hp-fam-sec__card {
      flex: 0 0 75%;
      scroll-snap-align: center;
    }
    .hp-fam-sec__image {
      max-height: 280px;
    }
  }
{%- endstyle -%}

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

<div class="hp-fam-sec" id="fam-{{ section.id }}">
  <div class="hp-fam-sec__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="hp-fam-sec__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="hp-fam-sec__tabs">
        {%- for block in section.blocks -%}
          {%- if block.type == 'collection' or block.type == 'custom_images' -%}
            <button class="hp-fam-sec__tab {% if forloop.first %}is-active{% endif %}" data-target="slider-{{ block.id }}">
              {%- if block.type == 'collection' -%}
                {%- assign collection = block.settings.collection -%}
                {{ block.settings.title | default: collection.title | default: 'Collection' | upcase }}
              {%- else -%}
                {{ block.settings.title | default: 'Custom' | upcase }}
              {%- endif -%}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="hp-fam-sec__main-flex">
      <div class="hp-fam-sec__slider-left">
        <div class="hp-fam-sec__slider-wrap">
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'collection' or block.type == 'custom_images' -%}
                <div class="hp-fam-sec__slider {% if forloop.first %}is-active{% endif %}" id="slider-{{ block.id }}">
                  
                  {%- if block.type == 'custom_images' -%}
                    {%- for i in (1..6) -%}
                      {%- capture img_id -%}image_{{ i }}{%- endcapture -%}
                      {%- capture url_id -%}url_{{ i }}{%- endcapture -%}
                      {%- if block.settings[img_id] != blank -%}
                        <a href="{{ block.settings[url_id] | default: '#' }}" class="hp-fam-sec__card">
                          <img src="{{ block.settings[img_id] | image_url: width: 800 }}"
                                alt="Product"
                                class="hp-fam-sec__image"
                                loading="lazy"
                                draggable="false">
                        </a>
                      {%- endif -%}
                    {%- endfor -%}
                  {%- elsif block.type == 'collection' -%}
                    {%- assign collection = block.settings.collection -%}
                    {%- if collection != blank and collection.products.size > 0 -%}
                      {%- for product in collection.products limit: section.settings.products_to_show -%}
                        <a href="{{ product.url }}" class="hp-fam-sec__card">
                          {%- if product.featured_media != blank -%}
                            <img src="{{ product.featured_media | image_url: width: 800 }}"
                                 alt="{{ product.title | escape }}"
                                 class="hp-fam-sec__image"
                                 loading="lazy"
                                 draggable="false">
                          {%- else -%}
                            {{ 'product-1' | placeholder_svg_tag: 'hp-fam-sec__image' }}
                          {%- endif -%}
                        </a>
                      {%- endfor -%}
                    {%- else -%}
                      {%- for i in (1..4) -%}
                        <div class="hp-fam-sec__card">
                          {%- capture current -%}{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                          {{ 'product-' | append: current | placeholder_svg_tag: 'hp-fam-sec__image' }}
                        </div>
                      {%- endfor -%}
                    {%- endif -%}
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            <div class="hp-fam-sec__slider is-active">
              {%- for i in (1..4) -%}
                <div class="hp-fam-sec__card">
                  {%- capture current -%}{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                  {{ 'product-' | append: current | placeholder_svg_tag: 'hp-fam-sec__image' }}
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} FLOATING RAIL LAYER {%- endcomment -%}
  <div class="premium-floating-rail">
    <div class="rail-mask">
      <div class="rail-track" id="railTrack-{{ section.id }}">
        {%- liquid
          assign rail_collection = section.settings.rail_collection
          if rail_collection != blank
            assign rail_products = collections[rail_collection].products | limit: 10
          else
            assign rail_products = collections.all.products | limit: 10
          endif
        -%}
        
        {%- for i in (1..3) -%}
          {%- for product in rail_products -%}
            <div class="rail-card" onclick="window.location.href='{{ product.url }}'">
              <div class="rail-card-img">
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | img_url: '400x400', crop: 'center' }}" alt="{{ product.title }}" loading="lazy">
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag }}
                {%- endif -%}
              </div>
              <div class="rail-card-info">
                <h3 class="rail-card-title">{{ product.title }}</h3>
                <div class="rail-card-meta">
                  <span class="rail-card-price">{{ product.price | money_without_trailing_zeros }}</span>
                  <div class="rail-card-rating">★★★★★</div>
                </div>
                <button class="rail-card-atc">Add to Cart</button>
              </div>
            </div>
          {%- endfor -%}
        {%- endfor -%}

        {%- if rail_products.size == 0 -%}
           {%- for i in (1..18) -%}
              <div class="rail-card">
                <div class="rail-card-img">{{ 'product-1' | placeholder_svg_tag }}</div>
                <div class="rail-card-info">
                  <h3 class="rail-card-title">Premium Product {{ i }}</h3>
                  <div class="rail-card-meta">
                    <span class="rail-card-price">$49.00</span>
                    <div class="rail-card-rating">★★★★★</div>
                  </div>
                  <button class="rail-card-atc">Add to Cart</button>
                </div>
              </div>
           {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    const section = document.getElementById('fam-{{ section.id }}');
    if (!section) return;

    // Original Slider Tabs
    const tabs = section.querySelectorAll('.hp-fam-sec__tab');
    const sliders = section.querySelectorAll('.hp-fam-sec__slider');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('is-active'));
        sliders.forEach(s => s.classList.remove('is-active'));
        tab.classList.add('is-active');
        const targetSlider = section.querySelector(`#${tab.getAttribute('data-target')}`);
        if (targetSlider) targetSlider.classList.add('is-active');
      });
    });

    // Original Slider Drag
    sliders.forEach(slider => {
      let isDown = false, startX, scrollLeft;
      slider.addEventListener('pointerdown', (e) => {
        if (e.pointerType === 'mouse' && e.button !== 0) return;
        isDown = true;
        startX = e.pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
        slider.style.scrollBehavior = 'auto';
        slider.classList.add('is-dragging');
        slider.setPointerCapture(e.pointerId);
      });
      slider.addEventListener('pointerup', (e) => {
        if (isDown) {
          isDown = false;
          slider.style.scrollBehavior = 'smooth';
          slider.classList.remove('is-dragging');
          slider.releasePointerCapture(e.pointerId);
        }
      });
      slider.addEventListener('pointermove', (e) => {
        if (!isDown) return;
        const x = e.pageX - slider.offsetLeft;
        const walk = (x - startX) * 1.5;
        slider.scrollLeft = scrollLeft - walk;
      });
    });

    // PREMIUM RAIL ANIMATION
    const railTrack = document.getElementById('railTrack-{{ section.id }}');
    if (railTrack && typeof gsap !== 'undefined') {
      const totalHeight = railTrack.scrollHeight / 3;
      const animation = gsap.to(railTrack, {
        y: -totalHeight,
        ease: "none",
        duration: 35,
        repeat: -1
      });

      railTrack.addEventListener('mouseenter', () => animation.pause());
      railTrack.addEventListener('mouseleave', () => animation.resume());
    }
  })();
</script>


{% schema %}
{
  "name": "Horizontal Product Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Meet the Nuuk fam!"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Top Background Color (Red)",
      "default": "#ff1e43"
    },
    {
      "type": "color",
      "id": "bg_color_bottom",
      "label": "Bottom Background Color (Black)",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    },
    {
      "type": "range",
      "id": "image_offset",
      "min": -100,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Move images down/up",
      "default": 0
    },
    {
      "type": "header",
      "content": "Floating Rail Settings"
    },
    {
      "type": "collection",
      "id": "rail_collection",
      "label": "Rail Collection"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection Tab",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Tab Name override (e.g. FANS)"
        }
      ]
    },
    {
      "type": "custom_images",
      "name": "Custom Tab (Images)",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tab Name override (e.g. FANS)"
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Custom Image 1"
        },
        {
          "type": "url",
          "id": "url_1",
          "label": "Link 1"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Custom Image 2"
        },
        {
          "type": "url",
          "id": "url_2",
          "label": "Link 2"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Custom Image 3"
        },
        {
          "type": "url",
          "id": "url_3",
          "label": "Link 3"
        },
        {
          "type": "image_picker",
          "id": "image_4",
          "label": "Custom Image 4"
        },
        {
          "type": "url",
          "id": "url_4",
          "label": "Link 4"
        },
        {
          "type": "image_picker",
          "id": "image_5",
          "label": "Custom Image 5"
        },
        {
          "type": "url",
          "id": "url_5",
          "label": "Link 5"
        },
        {
          "type": "image_picker",
          "id": "image_6",
          "label": "Custom Image 6"
        },
        {
          "type": "url",
          "id": "url_6",
          "label": "Link 6"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Function and Category",
      "blocks": [
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
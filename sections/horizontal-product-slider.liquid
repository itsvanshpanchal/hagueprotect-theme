{%- style -%}
  #shopify-section-{{ section.id }} {
    background: linear-gradient(to bottom, {{ section.settings.bg_color | default: '#ff1e43' }} 76%, {{ section.settings.bg_color_bottom | default: '#000000' }} 76%);
  }

  .hp-fam-sec {
    position: relative;
    padding: clamp(40px, 8vw, 80px) 0 0 0;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }

  .hp-fam-sec__container {
    max-width: 1440px;
    width: 100%;
    margin: 0 auto;
    padding: 0 40px;
    position: relative;
    box-sizing: border-box;
  }

  .hp-fam-sec__heading {
    font-size: clamp(32px, 6vw, 68px);
    font-weight: 800;
    color: #ffffff;
    margin: 0 0 32px 0;
    line-height: 1.05;
    letter-spacing: -0.03em;
    max-width: 700px;
  }

  /* CATEGORY TABS */
  .hp-fam-sec__tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 40px;
    align-items: center;
  }

  .hp-fam-sec__tab {
    background: transparent;
    border: none;
    padding: 10px 20px;
    border-radius: 100px;
    color: rgba(255, 255, 255, 0.85);
    font-size: clamp(12px, 1.5vw, 14px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    outline: none;
    text-decoration: none;
    display: inline-block;
  }

  .hp-fam-sec__tab:hover {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.1);
  }

  .hp-fam-sec__tab.is-active {
    background: #000000;
    color: #ffffff;
  }

  /* TWO-COLUMN LAYOUT */
  .hp-fam-sec__main-flex {
    display: flex;
    gap: 32px;
    align-items: flex-end;
  }

  .hp-fam-sec__slider-left {
    flex: 1;
    min-width: 0;
  }

  .hp-fam-sec__vertical-right {
    flex: 0 0 clamp(260px, 22vw, 320px);
    display: flex;
    flex-direction: column;
    gap: 24px;
    position: relative;
    padding-right: 0;
    box-sizing: border-box;
  }

  /* SLIDERS */
  .hp-fam-sec__slider-wrap {
    position: relative;
    width: 100%;
    margin-top: 10px;
  }

  .hp-fam-sec__slider {
    display: none;
    gap: clamp(20px, 4vw, 40px);
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    padding: 0 0 0 0;
    margin-bottom: 0;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    align-items: flex-end;
  }

  .hp-fam-sec__slider.is-active {
    display: flex;
  }

  .hp-fam-sec__slider:active {
    cursor: grabbing;
  }

  .hp-fam-sec__slider.is-dragging .hp-fam-sec__card {
    pointer-events: none;
    cursor: grabbing;
  }

  .hp-fam-sec__slider::-webkit-scrollbar {
    display: none;
  }

  .hp-fam-sec__slider {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* CARD */
  .hp-fam-sec__card {
    flex: 0 0 clamp(280px, 36vw, 420px);
    background: transparent;
    border: none;
    overflow: visible;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    align-self: flex-end;
    transition: transform 0.3s ease;
    margin: 0;
    padding: 0;
    user-drag: none;
    -webkit-user-drag: none;
    -webkit-user-select: none;
    user-select: none;
  }

  .hp-fam-sec__card:hover {
    transform: translateY(-8px);
  }

  .hp-fam-sec__image {
    width: 100%;
    height: auto;
    max-height: clamp(350px, 55vh, 580px);
    object-fit: contain;
    display: block;
    pointer-events: none;
    margin-bottom: 0;
    user-drag: none;
    -webkit-user-drag: none;
    transform: translateY({{ section.settings.image_offset | default: 0 }}px);
  }

  /* FEATURED RIGHT SIDE CARD */
  .hp-fam-sec__sticky-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 16px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    position: relative;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    flex: 1;
    min-height: 380px;
  }

  .hp-fam-sec__card-badge {
    position: absolute;
    top: 14px;
    right: 14px;
    background: #ff1e43;
    color: #ffffff;
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hp-fam-sec__card-img-wrap {
    width: 100%;
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
    margin-top: 10px;
  }

  .hp-fam-sec__card-img-wrap img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .hp-fam-sec__card-rating {
    font-size: 11px;
    color: #0baf57;
    font-weight: 700;
    background: #e8f7ee;
    padding: 3px 8px;
    border-radius: 4px;
    display: inline-block;
  }

  .hp-fam-sec__card-title {
    font-size: 16px;
    font-weight: 800;
    color: #111111;
    margin: 8px 0 4px;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .hp-fam-sec__card-subtitle {
    font-size: 12px;
    color: #777777;
    margin: 0 0 8px 0;
  }

  .hp-fam-sec__card-desc {
    font-size: 13px;
    color: #111111;
    font-weight: 700;
    margin: 0 0 12px 0;
    line-height: 1.35;
  }

  .hp-fam-sec__card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 10px;
    border-top: 1px solid #f0f0f0;
  }

  .hp-fam-sec__card-pricing {
    display: flex;
    flex-direction: column;
  }

  .hp-fam-sec__card-compare {
    font-size: 12px;
    text-decoration: line-through;
    color: #999999;
  }

  .hp-fam-sec__card-price {
    font-size: 18px;
    font-weight: 800;
    color: #111111;
  }

  .hp-fam-sec__card-btn {
    background: #000000;
    color: #ffffff;
    border: none;
    border-radius: 30px;
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.3s ease;
  }

  .hp-fam-sec__card-btn:hover {
    background: #ff1e43;
  }

  @media screen and (max-width: 1024px) {
    .hp-fam-sec__main-flex {
      flex-direction: column;
    }
    .hp-fam-sec__vertical-right {
      flex: none;
      width: 100%;
      flex-direction: row;
      overflow-x: auto;
      gap: 16px;
      padding-bottom: 15px;
    }
    .hp-fam-sec__sticky-card {
      flex: 0 0 330px;
    }
  }

  @media screen and (max-width: 767px) {
    .hp-fam-sec__heading {
      margin-bottom: 24px;
    }
    .hp-fam-sec__card {
      flex: 0 0 clamp(220px, 60vw, 280px);
    }
    .hp-fam-sec__image {
      max-height: clamp(280px, 45vh, 360px);
    }
  }
{%- endstyle -%}

<div class="hp-fam-sec" id="fam-{{ section.id }}">
  <div class="hp-fam-sec__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="hp-fam-sec__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="hp-fam-sec__tabs">
        {%- for block in section.blocks -%}
          {%- if block.type == 'collection' or block.type == 'custom_images' -%}
            <button class="hp-fam-sec__tab {% if forloop.first %}is-active{% endif %}" data-target="slider-{{ block.id }}">
              {%- if block.type == 'collection' -%}
                {%- assign collection = block.settings.collection -%}
                {{ block.settings.title | default: collection.title | default: 'Collection' | upcase }}
              {%- else -%}
                {{ block.settings.title | default: 'Custom' | upcase }}
              {%- endif -%}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="hp-fam-sec__main-flex">
      <div class="hp-fam-sec__slider-left">
        <div class="hp-fam-sec__slider-wrap">
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'collection' or block.type == 'custom_images' -%}
                <div class="hp-fam-sec__slider {% if forloop.first %}is-active{% endif %}" id="slider-{{ block.id }}">
                  
                  {%- if block.type == 'custom_images' -%}
                    {%- for i in (1..6) -%}
                      {%- capture img_id -%}image_{{ i }}{%- endcapture -%}
                      {%- capture url_id -%}url_{{ i }}{%- endcapture -%}
                      {%- if block.settings[img_id] != blank -%}
                        <a href="{{ block.settings[url_id] | default: '#' }}" class="hp-fam-sec__card">
                          <img src="{{ block.settings[img_id] | image_url: width: 800 }}"
                               alt="Product"
                               class="hp-fam-sec__image"
                               loading="lazy"
                               draggable="false">
                        </a>
                      {%- endif -%}
                    {%- endfor -%}
                  {%- elsif block.type == 'collection' -%}
                    {%- assign collection = block.settings.collection -%}
                    {%- if collection != blank and collection.products.size > 0 -%}
                      {%- for product in collection.products limit: section.settings.products_to_show -%}
                        <a href="{{ product.url }}" class="hp-fam-sec__card">
                          {%- if product.featured_media != blank -%}
                            <img src="{{ product.featured_media | image_url: width: 800 }}"
                                 alt="{{ product.title | escape }}"
                                 class="hp-fam-sec__image"
                                 loading="lazy"
                                 draggable="false">
                          {%- else -%}
                            {{ 'product-1' | placeholder_svg_tag: 'hp-fam-sec__image' }}
                          {%- endif -%}
                        </a>
                      {%- endfor -%}
                    {%- else -%}
                      {%- for i in (1..4) -%}
                        <div class="hp-fam-sec__card">
                          {%- capture current -%}{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                          {{ 'product-' | append: current | placeholder_svg_tag: 'hp-fam-sec__image' }}
                        </div>
                      {%- endfor -%}
                    {%- endif -%}
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            <div class="hp-fam-sec__slider is-active">
              {%- for i in (1..4) -%}
                <div class="hp-fam-sec__card">
                  {%- capture current -%}{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                  {{ 'product-' | append: current | placeholder_svg_tag: 'hp-fam-sec__image' }}
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- assign has_right_cards = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'right_card' -%}
          {%- assign has_right_cards = true -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_right_cards -%}
        <div class="hp-fam-sec__vertical-right">
          {%- for block in section.blocks -%}
            {%- if block.type == 'right_card' -%}
              {%- assign product = block.settings.product -%}
              {%- if product != blank -%}
                <div class="hp-fam-sec__sticky-card">
                  {%- if block.settings.badge_text != blank -%}
                    <span class="hp-fam-sec__card-badge">{{ block.settings.badge_text }}</span>
                  {%- endif -%}
                  <div class="hp-fam-sec__card-img-wrap">
                    <img src="{{ product.featured_media | image_url: width: 400 }}" alt="{{ product.title | escape }}" loading="lazy">
                  </div>
                  <div class="hp-fam-sec__card-meta">
                    <span class="hp-fam-sec__card-rating">★ {{ block.settings.rating | default: '4.9' }} ({{ block.settings.review_count | default: '260' }})</span>
                    <h3 class="hp-fam-sec__card-title">{{ product.title }}</h3>
                    {%- if product.metafields.descriptors.subtitle != blank -%}
                      <p class="hp-fam-sec__card-subtitle">{{ product.metafields.descriptors.subtitle }}</p>
                    {%- endif -%}
                    {%- if block.settings.custom_desc != blank -%}
                      <p class="hp-fam-sec__card-desc">{{ block.settings.custom_desc }}</p>
                    {%- endif -%}
                    <div class="hp-fam-sec__card-footer">
                      <div class="hp-fam-sec__card-pricing">
                        {%- if product.compare_at_price > product.price -%}
                          <span class="hp-fam-sec__card-compare">{{ product.compare_at_price | money }}</span>
                        {%- endif -%}
                        <span class="hp-fam-sec__card-price">{{ product.price | money }}</span>
                      </div>
                      <form method="post" action="/cart/add">
                        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                        <button type="submit" class="hp-fam-sec__card-btn">{{ block.settings.cta_text | default: 'Add to Cart' }}</button>
                      </form>
                    </div>
                  </div>
                </div>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        {%- assign fallback_product = collections.all.products.first -%}
        {%- if fallback_product == blank -%}
          {%- assign fallback_product = all_products.first -%}
        {%- endif -%}
        {%- if fallback_product != blank -%}
          <div class="hp-fam-sec__vertical-right">
            <div class="hp-fam-sec__sticky-card">
              <span class="hp-fam-sec__card-badge">BESTSELLER</span>
              <div class="hp-fam-sec__card-img-wrap">
                <img src="{{ fallback_product.featured_media | image_url: width: 400 }}" alt="{{ fallback_product.title | escape }}" loading="lazy">
              </div>
              <div class="hp-fam-sec__card-meta">
                <span class="hp-fam-sec__card-rating">★ 4.9 (260)</span>
                <h3 class="hp-fam-sec__card-title">{{ fallback_product.title }}</h3>
                <p class="hp-fam-sec__card-desc">India's most silent air circulator</p>
                <div class="hp-fam-sec__card-footer">
                  <div class="hp-fam-sec__card-pricing">
                    {%- if fallback_product.compare_at_price > fallback_product.price -%}
                      <span class="hp-fam-sec__card-compare">{{ fallback_product.compare_at_price | money }}</span>
                    {%- endif -%}
                    <span class="hp-fam-sec__card-price">{{ fallback_product.price | money }}</span>
                  </div>
                  <form method="post" action="/cart/add">
                    <input type="hidden" name="id" value="{{ fallback_product.selected_or_first_available_variant.id }}">
                    <button type="submit" class="hp-fam-sec__card-btn">Add to Cart</button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function() {
    const section = document.getElementById('fam-{{ section.id }}');
    if (!section) return;

    // Handle tab clicking
    const tabs = section.querySelectorAll('.hp-fam-sec__tab');
    const sliders = section.querySelectorAll('.hp-fam-sec__slider');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('is-active'));
        sliders.forEach(s => s.classList.remove('is-active'));

        tab.classList.add('is-active');
        const targetSlider = section.querySelector(`#${tab.getAttribute('data-target')}`);
        if (targetSlider) {
          targetSlider.classList.add('is-active');
        }
      });
    });

    // Add drag-to-scroll interactivity
    sliders.forEach(slider => {
      let isDown = false;
      let startX;
      let scrollLeft;

      slider.addEventListener('mousedown', (e) => {
        isDown = true;
        startX = e.pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
        slider.style.scrollBehavior = 'auto';
        slider.classList.add('is-dragging');
      });

      window.addEventListener('mouseup', () => {
        if (isDown) {
          isDown = false;
          slider.style.scrollBehavior = 'smooth';
          slider.classList.remove('is-dragging');
        }
      });

      slider.addEventListener('mouseleave', () => {
        if (isDown) {
          isDown = false;
          slider.style.scrollBehavior = 'smooth';
          slider.classList.remove('is-dragging');
        }
      });

      slider.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - slider.offsetLeft;
        const walk = (x - startX) * 1.8;
        slider.scrollLeft = scrollLeft - walk;
      });
    });
  })();
</script>


{%- style -%}
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#c1121f' }};
  }

  .hp-slider-sec {
    position: relative;
    padding: clamp(40px, 6vw, 60px) 0;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }

  .hp-slider-sec__container {
    position: relative;
    width: 100%;
  }

  .hp-slider-sec__header {
    max-width: 1200px;
    margin: 0 auto 24px auto;
    padding: 0 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .hp-slider-sec__heading {
    font-size: clamp(20px, 3.5vw, 28px);
    font-weight: 800;
    color: #ffffff;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .hp-slider-sec__arrows {
    display: flex;
    gap: 12px;
  }

  .hp-slider-sec__arrow {
    width: 44px;
    height: 44px;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    border-radius: 50%;
    color: #ffffff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease, transform 0.2s ease;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 0;
    outline: none;
  }

  .hp-slider-sec__arrow:hover {
    background: rgba(255, 255, 255, 0.25);
    transform: scale(1.05);
  }

  .hp-slider-sec__arrow svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
    display: block;
  }

  .hp-slider-sec__slider {
    display: flex;
    gap: clamp(16px, 3vw, 24px);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    padding: 10px 20px 24px 20px;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
  }

  .hp-slider-sec__slider:active {
    cursor: grabbing;
  }

  .hp-slider-sec__slider::-webkit-scrollbar {
    display: none;
  }

  .hp-slider-sec__slider {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .hp-slider-sec__card {
    flex: 0 0 240px;
    background: #ffffff;
    border-radius: 20px;
    overflow: hidden;
    scroll-snap-align: start;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.3s ease;
    text-decoration: none;
    display: flex;
    flex-direction: column;
  }

  @media screen and (max-width: 767px) {
    .hp-slider-sec__card {
      flex: 0 0 180px;
      border-radius: 16px;
    }
  }

  .hp-slider-sec__card:hover {
    transform: translateY(-6px) scale(1.03);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.12);
  }

  .hp-slider-sec__image-wrap {
    width: 100%;
    height: 300px;
    position: relative;
    overflow: hidden;
    background: #f7f7f7;
  }

  @media screen and (max-width: 767px) {
    .hp-slider-sec__image-wrap {
      height: 220px;
    }
  }

  .hp-slider-sec__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    display: block;
  }

  .hp-slider-sec__card:hover .hp-slider-sec__image {
    transform: scale(1.05);
  }

  .hp-slider-sec__info {
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: #ffffff;
    flex-grow: 1;
  }

  .hp-slider-sec__title {
    font-size: clamp(13px, 2vw, 15px);
    font-weight: 600;
    color: #111111;
    margin: 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    height: 2.6em;
  }

  .hp-slider-sec__price {
    font-size: 13px;
    color: #444444;
    font-weight: 500;
    margin-top: auto;
  }

  /* Fade Hints on Left & Right */
  .hp-slider-sec__fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    pointer-events: none;
    z-index: 2;
    transition: opacity 0.3s ease;
  }

  .hp-slider-sec__fade--left {
    left: 0;
    background: linear-gradient(to right, {{ section.settings.bg_color | default: '#c1121f' }}, transparent);
  }

  .hp-slider-sec__fade--right {
    right: 0;
    background: linear-gradient(to left, {{ section.settings.bg_color | default: '#c1121f' }}, transparent);
  }

  @media screen and (max-width: 767px) {
    .hp-slider-sec__fade {
      width: 40px;
    }
  }
{%- endstyle -%}

<div class="hp-slider-sec" id="slider-{{ section.id }}">
  <div class="hp-slider-sec__container">
    {%- if section.settings.heading != blank -%}
      <div class="hp-slider-sec__header">
        <h2 class="hp-slider-sec__heading">{{ section.settings.heading }}</h2>
        <div class="hp-slider-sec__arrows">
          <button class="hp-slider-sec__arrow hp-slider-sec__arrow--prev" aria-label="Previous Products">
            <svg viewBox="0 0 24 24"><path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z"/></svg>
          </button>
          <button class="hp-slider-sec__arrow hp-slider-sec__arrow--next" aria-label="Next Products">
            <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>
          </button>
        </div>
      </div>
    {%- endif -%}

    <div class="hp-slider-sec__fade hp-slider-sec__fade--left"></div>
    <div class="hp-slider-sec__fade hp-slider-sec__fade--right"></div>

    <div class="hp-slider-sec__slider" id="scroller-{{ section.id }}">
      {%- assign collection = section.settings.collection -%}
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          <a href="{{ product.url }}" class="hp-slider-sec__card">
            <div class="hp-slider-sec__image-wrap">
              {%- if product.featured_media != blank -%}
                <img src="{{ product.featured_media | image_url: width: 600 }}"
                     alt="{{ product.title | escape }}"
                     class="hp-slider-sec__image"
                     loading="lazy"
                     width="300"
                     height="375">
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'hp-slider-sec__image' }}
              {%- endif -%}
            </div>
            <div class="hp-slider-sec__info">
              <h3 class="hp-slider-sec__title">{{ product.title }}</h3>
              <div class="hp-slider-sec__price">{{ product.price | money }}</div>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..6) -%}
          <div class="hp-slider-sec__card">
            <div class="hp-slider-sec__image-wrap">
              {%- capture current -%}{% cycle 1, 2, 3, 4, 5, 6 %}{%- endcapture -%}
              {{ 'product-' | append: current | placeholder_svg_tag: 'hp-slider-sec__image' }}
            </div>
            <div class="hp-slider-sec__info">
              <h3 class="hp-slider-sec__title">Sample Product Title {{ i }}</h3>
              <div class="hp-slider-sec__price">{{ 4999 | money }}</div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function() {
    const scroller = document.getElementById('scroller-{{ section.id }}');
    if (!scroller) return;

    // Mouse drag scrolling functionality
    let isDown = false;
    let startX;
    let scrollLeft;

    scroller.addEventListener('mousedown', (e) => {
      isDown = true;
      startX = e.pageX - scroller.offsetLeft;
      scrollLeft = scroller.scrollLeft;
      scroller.style.scrollBehavior = 'auto';
    });

    scroller.addEventListener('mouseleave', () => {
      isDown = false;
    });

    scroller.addEventListener('mouseup', () => {
      isDown = false;
      scroller.style.scrollBehavior = 'smooth';
    });

    scroller.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - scroller.offsetLeft;
      const walk = (x - startX) * 1.5; // Drag speed multiplier
      scroller.scrollLeft = scrollLeft - walk;
    });

    // Arrow controls
    const prevBtn = document.querySelector('#slider-{{ section.id }} .hp-slider-sec__arrow--prev');
    const nextBtn = document.querySelector('#slider-{{ section.id }} .hp-slider-sec__arrow--next');

    if (prevBtn && nextBtn) {
      prevBtn.addEventListener('click', () => {
        scroller.style.scrollBehavior = 'smooth';
        scroller.scrollLeft -= 264; // Approx width of card (240) + gap (24)
      });

      nextBtn.addEventListener('click', () => {
        scroller.style.scrollBehavior = 'smooth';
        scroller.scrollLeft += 264;
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Horizontal Product Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Shop Our Premium Best"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#c1121f"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Horizontal Product Slider",
      "settings": {
        "heading": "Shop Our Premium Best"
      }
    }
  ]
}
{% endschema %}

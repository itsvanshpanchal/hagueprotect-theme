{%- style -%}
  #shopify-section-{{ section.id }} {
    background: linear-gradient(to bottom, {{ section.settings.bg_color | default: '#ff1e43' }} 76%, {{ section.settings.bg_color_bottom | default: '#000000' }} 76%);
    position: relative;
  }

  .hp-fam-sec {
    position: relative;
    padding: clamp(40px, 8vw, 80px) 0 0 0;
    width: 100%;
    box-sizing: border-box;
    overflow: visible;
  }

  .hp-fam-sec__container {
    max-width: 1440px;
    width: 100%;
    margin: 0 auto;
    padding: 0 40px;
    position: relative;
    box-sizing: border-box;
    z-index: 2;
  }

  .hp-fam-sec__heading {
    font-size: clamp(32px, 6vw, 68px);
    font-family: 'Bahnschrift Bold', 'Bahnschrift', 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 600;
    color: #ffffff;
    margin: 0 0 32px 0;
    line-height: 1.05;
    letter-spacing: -0.02em;
    max-width: 700px;
  }

  /* CATEGORY TABS */
  .hp-fam-sec__tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 40px;
    align-items: center;
  }

  .hp-fam-sec__tab {
    background: transparent;
    border: none;
    padding: 10px 20px;
    border-radius: 100px;
    color: rgba(255, 255, 255, 0.85);
    font-size: clamp(12px, 1.5vw, 14px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    outline: none;
    text-decoration: none;
    display: inline-block;
  }

  .hp-fam-sec__tab:hover {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.1);
  }

  .hp-fam-sec__tab.is-active {
    background: #000000;
    color: #ffffff;
  }

  /* LAYOUT */
  .hp-fam-sec__main-flex {
    width: 100%;
  }

  .hp-fam-sec__slider-left {
    width: 100%;
  }

  /* SLIDERS */
  .hp-fam-sec__slider-wrap {
    position: relative;
    width: 100%;
    margin-top: 10px;
  }

  .hp-fam-sec__slider {
    display: none;
    gap: clamp(20px, 4vw, 40px);
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    touch-action: pan-y;
    padding: 0 0 0 0;
    margin-bottom: 0;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    align-items: flex-end;
  }

  .hp-fam-sec__slider.is-active {
    display: flex;
  }

  .hp-fam-sec__slider:active {
    cursor: grabbing;
  }

  .hp-fam-sec__slider.is-dragging .hp-fam-sec__card {
    pointer-events: none;
    cursor: grabbing;
  }

  .hp-fam-sec__slider::-webkit-scrollbar {
    display: none;
  }

  .hp-fam-sec__slider {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* CARD */
  .hp-fam-sec__card {
    flex: 0 0 clamp(280px, 36vw, 420px);
    background: transparent;
    border: none;
    overflow: visible;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    align-self: flex-end;
    transition: transform 0.3s ease;
    margin: 0;
    padding: 0;
    user-drag: none;
    -webkit-user-drag: none;
    -webkit-user-select: none;
    user-select: none;
  }

  .hp-fam-sec__card:hover {
    transform: translateY(-8px);
  }

  .hp-fam-sec__image {
    width: 100%;
    height: auto;
    max-height: clamp(350px, 55vh, 580px);
    object-fit: contain;
    display: block;
    pointer-events: none;
    margin-bottom: 0;
    user-drag: none;
    -webkit-user-drag: none;
    transform: translateY({{ section.settings.image_offset | default: 0 }}px);
  }

  /* PREMIUM FLOATING RAIL */
  .premium-floating-rail {
    position: absolute;
    right: 40px;
    top: 0;
    bottom: 0;
    width: 340px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    pointer-events: none;
  }

  .rail-mask {
    height: 100%;
    width: 100%;
    overflow-y: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    mask-image: linear-gradient(to bottom, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to bottom, transparent, black 10%, black 90%, transparent);
    pointer-events: auto;
  }

  .rail-mask::-webkit-scrollbar {
    display: none;
  }

  .rail-track {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 100px 0;
    will-change: transform;
  }

  .rail-card {
    background: #ffffff;
    border: 1px solid #eeeeee;
    border-radius: 12px;
    padding: 0;
    width: 100%;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    cursor: pointer;
    overflow: hidden;
    position: relative;
  }

  .rail-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.1);
  }

  .rail-card-img {
    width: 100%;
    height: 240px;
    background: #f5f5f7;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .rail-card-img img {
    width: 90%;
    height: 90%;
    object-fit: contain;
    transition: transform 0.6s ease;
  }

  .rail-badge-bestseller {
    position: absolute;
    top: 12px;
    right: 12px;
    background: #e5533d;
    color: #fff;
    padding: 6px 12px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    z-index: 2;
  }

  .rail-card-info {
    padding: 20px;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .rail-rating-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }

  .rail-rating-badge {
    background: #2ecc71;
    color: #000;
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 800;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .rail-rating-count {
    color: #666;
    font-size: 13px;
    font-weight: 600;
  }

  .rail-card-title {
    color: #111111;
    font-size: 20px;
    font-weight: 800;
    margin: 0;
    line-height: 1.2;
    font-family: 'Inter', sans-serif;
  }

  .rail-subtitle {
    color: #888;
    font-size: 14px;
    font-weight: 600;
    margin: 0;
  }

  .rail-elite-care {
    color: #111;
    font-size: 14px;
    font-weight: 700;
    margin: 4px 0;
  }

  .rail-price-row {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin: 8px 0;
  }

  .rail-price-compare {
    color: #bbb;
    text-decoration: line-through;
    font-size: 14px;
    font-weight: 600;
  }

  .rail-price-current {
    color: #111;
    font-size: 24px;
    font-weight: 800;
  }

  .rail-card-atc {
    background: #000;
    color: #fff;
    border: none;
    width: 100%;
    padding: 16px;
    border-radius: 10px;
    font-size: 16px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.3s;
    margin-top: 8px;
  }

  .rail-card-atc:hover {
    background: #333;
    transform: scale(1.02);
  }

  /* Mobile / tablet: horizontal product cards (desktop 1200px+ unchanged) */
  .hp-fam-sec__mobile-rail-wrap {
    display: none;
    width: 100%;
  }

  .hp-fam-sec__mobile-slider {
    display: none;
    --hp-fam-card-gap: 12px;
    gap: var(--hp-fam-card-gap);
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x proximity;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    touch-action: auto;
    overscroll-behavior-x: contain;
    overscroll-behavior-y: auto;
    padding: 4px 0 12px;
    padding-right: calc((100% - var(--hp-fam-card-gap)) / 3);
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .hp-fam-sec__mobile-slider.is-active {
    display: flex;
  }

  .hp-fam-sec__mobile-slider::-webkit-scrollbar {
    display: none;
  }

  .hp-fam-sec__mobile-slider:active {
    cursor: grabbing;
  }

  .hp-fam-sec__mobile-slider.is-dragging .rail-card {
    pointer-events: none;
  }

  .hp-fam-sec__mobile-slider .rail-card {
    flex: 0 0 calc((100% - var(--hp-fam-card-gap)) / 1.5);
    min-width: 0;
    max-width: none;
    scroll-snap-align: start;
    scroll-snap-stop: normal;
  }

  .hp-fam-sec__mobile-slider .rail-card-img {
    height: 200px;
  }

  .hp-fam-sec__mobile-slider .rail-card-title {
    font-size: 18px;
  }

  .hp-fam-sec__mobile-slider .rail-rating-badge {
    font-size: 12px;
    padding: 3px 8px;
  }

  .hp-fam-sec__mobile-slider .rail-rating-count {
    font-size: 12px;
  }

  .hp-fam-sec__mobile-slider .rail-price-current {
    font-size: 22px;
  }

  .hp-fam-sec__mobile-slider .rail-card-atc {
    padding: 14px;
    font-size: 14px;
  }

  @media screen and (max-width: 1199px) {
    #shopify-section-{{ section.id }} {
      background: {{ section.settings.bg_color | default: '#ff1e43' }} !important;
    }

    .hp-fam-sec__slider-left--desktop {
      display: none !important;
    }

    .hp-fam-sec__mobile-rail-wrap {
      display: block;
      padding-bottom: 36px;
      width: 100%;
      overflow: visible;
    }

    .premium-floating-rail {
      display: none !important;
    }
  }

  @media screen and (min-width: 1200px) {
    .hp-fam-sec__mobile-rail-wrap {
      display: none !important;
    }
  }

  @media screen and (max-width: 767px) {
    .hp-fam-sec {
      padding: 32px 0 0 0;
    }

    .hp-fam-sec__container {
      padding: 0 max(16px, var(--site-padding, 16px));
    }

    .hp-fam-sec__heading {
      margin-bottom: 20px;
      font-size: clamp(28px, 8vw, 40px);
    }

    .hp-fam-sec__tabs {
      flex-wrap: nowrap;
      overflow-x: auto;
      overflow-y: hidden;
      padding-bottom: 6px;
      margin-bottom: 20px;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      touch-action: auto;
      overscroll-behavior-x: contain;
      gap: 8px;
      scroll-snap-type: x proximity;
    }

    .hp-fam-sec__tabs::-webkit-scrollbar {
      display: none;
    }

    .hp-fam-sec__tab {
      flex: 0 0 auto;
      padding: 8px 16px;
      font-size: 12px;
      scroll-snap-align: start;
    }

    .hp-fam-sec__mobile-rail-wrap {
      margin-right: calc(-1 * max(16px, var(--site-padding, 16px)));
      padding-bottom: 28px;
    }

    .hp-fam-sec__mobile-slider {
      --hp-fam-card-gap: 12px;
      gap: var(--hp-fam-card-gap);
      padding-bottom: 8px;
      padding-right: max(16px, var(--site-padding, 16px));
    }

    .hp-fam-sec__mobile-slider .rail-card {
      flex: 0 0 calc((100% - var(--hp-fam-card-gap)) / 1.5);
      scroll-snap-align: start;
    }
  }

  .hp-fam-sec__video-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: 1;
    pointer-events: none;
    opacity: calc({{ section.settings.video_opacity | default: 100 }} / 100);
  }
  .hp-fam-sec__video-bg video {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    transform: translate(-50%, -50%);
    object-fit: cover;
    z-index: 1;
  }
  .hp-fam-sec__video-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, 
      {{ section.settings.bg_color | default: '#ff1e43' | color_modify: 'alpha', 0.4 }} 0%, 
      {{ section.settings.bg_color_bottom | default: '#000000' | color_modify: 'alpha', 0.85 }} 85%
    );
    z-index: 2;
    pointer-events: none;
    opacity: calc({{ section.settings.overlay_opacity | default: 100 }} / 100);
  }
{%- endstyle -%}

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

{%- liquid
  assign rail_collection_handle = section.settings.rail_collection
  if rail_collection_handle != blank
    assign default_rail_products = collections[rail_collection_handle].products
  else
    assign default_rail_products = collections.all.products
  endif
-%}

<div class="hp-fam-sec" id="fam-{{ section.id }}">
  {%- if section.settings.enable_video_bg -%}
    <div class="hp-fam-sec__video-bg">
      {%- if section.settings.video_bg != blank -%}
        {{ section.settings.video_bg | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false }}
      {%- elsif section.settings.video_bg_filename != blank -%}
        <video autoplay loop muted playsinline preload="auto" class="hp-fam-sec__video">
          <source src="{{ section.settings.video_bg_filename | asset_url }}" type="video/mp4">
        </video>
      {%- endif -%}
      <div class="hp-fam-sec__video-overlay"></div>
    </div>
  {%- endif -%}
  <div class="hp-fam-sec__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="hp-fam-sec__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="hp-fam-sec__tabs">
        {%- for block in section.blocks -%}
          {%- if block.type == 'collection' or block.type == 'custom_images' -%}
            <button
              class="hp-fam-sec__tab {% if forloop.first %}is-active{% endif %}"
              data-target="slider-{{ block.id }}"
              data-mobile-target="mobile-slider-{{ block.id }}"
            >
              {%- if block.type == 'collection' -%}
                {%- assign collection = block.settings.collection -%}
                {{ block.settings.title | default: collection.title | default: 'Collection' | upcase }}
              {%- else -%}
                {{ block.settings.title | default: 'Custom' | upcase }}
              {%- endif -%}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="hp-fam-sec__main-flex">
      <div class="hp-fam-sec__slider-left hp-fam-sec__slider-left--desktop">
        <div class="hp-fam-sec__slider-wrap">
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'collection' or block.type == 'custom_images' -%}
                <div class="hp-fam-sec__slider {% if forloop.first %}is-active{% endif %}" id="slider-{{ block.id }}">
                  
                  {%- if block.type == 'custom_images' -%}
                    {%- for i in (1..6) -%}
                      {%- capture img_id -%}image_{{ i }}{%- endcapture -%}
                      {%- capture url_id -%}url_{{ i }}{%- endcapture -%}
                      {%- if block.settings[img_id] != blank -%}
                        <a href="{{ block.settings[url_id] | default: '#' }}" class="hp-fam-sec__card">
                          <img src="{{ block.settings[img_id] | image_url: width: 800 }}"
                                alt="Product"
                                class="hp-fam-sec__image"
                                loading="lazy"
                                draggable="false">
                        </a>
                      {%- endif -%}
                    {%- endfor -%}
                  {%- elsif block.type == 'collection' -%}
                    {%- assign collection = block.settings.collection -%}
                    {%- if collection != blank and collection.products.size > 0 -%}
                      {%- for product in collection.products limit: section.settings.products_to_show -%}
                        <a href="{{ product.url }}" class="hp-fam-sec__card">
                          {%- if product.featured_media != blank -%}
                            <img src="{{ product.featured_media | image_url: width: 800 }}"
                                 alt="{{ product.title | escape }}"
                                 class="hp-fam-sec__image"
                                 loading="lazy"
                                 draggable="false">
                          {%- else -%}
                            {{ 'product-1' | placeholder_svg_tag: 'hp-fam-sec__image' }}
                          {%- endif -%}
                        </a>
                      {%- endfor -%}
                    {%- else -%}
                      {%- for i in (1..4) -%}
                        <div class="hp-fam-sec__card">
                          {%- capture current -%}{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                          {{ 'product-' | append: current | placeholder_svg_tag: 'hp-fam-sec__image' }}
                        </div>
                      {%- endfor -%}
                    {%- endif -%}
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            <div class="hp-fam-sec__slider is-active">
              {%- for i in (1..4) -%}
                <div class="hp-fam-sec__card">
                  {%- capture current -%}{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                  {{ 'product-' | append: current | placeholder_svg_tag: 'hp-fam-sec__image' }}
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} MOBILE: horizontal product cards {%- endcomment -%}
      <div class="hp-fam-sec__mobile-rail-wrap">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'collection' or block.type == 'custom_images' -%}
              <div class="hp-fam-sec__mobile-slider {% if forloop.first %}is-active{% endif %}" id="mobile-slider-{{ block.id }}">
                {%- if block.type == 'collection' -%}
                  {%- assign tab_collection = block.settings.collection -%}
                  {%- if tab_collection != blank and tab_collection.products.size > 0 -%}
                    {%- for product in tab_collection.products limit: section.settings.products_to_show -%}
                      {% render 'hp-fam-rail-card', product: product, rating_value: section.settings.rating_value, rating_count: section.settings.rating_count %}
                    {%- endfor -%}
                  {%- else -%}
                    {%- for product in default_rail_products limit: section.settings.products_to_show -%}
                      {% render 'hp-fam-rail-card', product: product, rating_value: section.settings.rating_value, rating_count: section.settings.rating_count %}
                    {%- endfor -%}
                  {%- endif -%}
                {%- else -%}
                  {%- for product in default_rail_products limit: section.settings.products_to_show -%}
                    {% render 'hp-fam-rail-card', product: product, rating_value: section.settings.rating_value, rating_count: section.settings.rating_count %}
                  {%- endfor -%}
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          <div class="hp-fam-sec__mobile-slider is-active" id="mobile-slider-default-{{ section.id }}">
            {%- for product in default_rail_products limit: section.settings.products_to_show -%}
              {% render 'hp-fam-rail-card', product: product, rating_value: section.settings.rating_value, rating_count: section.settings.rating_count %}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- comment -%} FLOATING RAIL LAYER (desktop only) {%- endcomment -%}
  <div class="premium-floating-rail">
    <div class="rail-mask">
      <div class="rail-track" id="railTrack-{{ section.id }}">
        {%- for product in default_rail_products limit: 10 -%}
          {% render 'hp-fam-rail-card', product: product, rating_value: section.settings.rating_value, rating_count: section.settings.rating_count %}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    const section = document.getElementById('fam-{{ section.id }}');
    if (!section) return;

    const tabs = section.querySelectorAll('.hp-fam-sec__tab');
    const sliders = section.querySelectorAll('.hp-fam-sec__slider');
    const mobileSliders = section.querySelectorAll('.hp-fam-sec__mobile-slider');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('is-active'));
        sliders.forEach(s => s.classList.remove('is-active'));
        mobileSliders.forEach(s => s.classList.remove('is-active'));
        tab.classList.add('is-active');

        const targetSlider = section.querySelector(`#${tab.getAttribute('data-target')}`);
        if (targetSlider) targetSlider.classList.add('is-active');

        const mobileTarget = tab.getAttribute('data-mobile-target');
        if (mobileTarget) {
          const targetMobile = section.querySelector(`#${mobileTarget}`);
          if (targetMobile) targetMobile.classList.add('is-active');
        }
      });
    });

    function bindHorizontalDrag(slider, desktopOnly) {
      if (desktopOnly && window.matchMedia('(max-width: 1199px)').matches) return;

      let isDown = false;
      let isDragging = false;
      let startX = 0;
      let startY = 0;
      let scrollLeft = 0;
      let activePointerId = null;

      function endDrag() {
        isDown = false;
        isDragging = false;
        activePointerId = null;
        slider.style.scrollBehavior = 'smooth';
        slider.classList.remove('is-dragging');
      }

      slider.addEventListener('pointerdown', (e) => {
        if (e.pointerType === 'mouse' && e.button !== 0) return;
        if (e.pointerType === 'touch') return;
        isDown = true;
        isDragging = false;
        activePointerId = e.pointerId;
        startX = e.pageX;
        startY = e.pageY;
        scrollLeft = slider.scrollLeft;
      });

      slider.addEventListener('pointerup', (e) => {
        if (activePointerId !== e.pointerId) return;
        if (isDragging) slider.releasePointerCapture(e.pointerId);
        endDrag();
      });

      slider.addEventListener('pointercancel', (e) => {
        if (activePointerId !== e.pointerId) return;
        if (isDragging) slider.releasePointerCapture(e.pointerId);
        endDrag();
      });

      slider.addEventListener('pointermove', (e) => {
        if (!isDown || activePointerId !== e.pointerId) return;

        const dx = e.pageX - startX;
        const dy = e.pageY - startY;

        if (!isDragging) {
          if (Math.abs(dx) < 6 && Math.abs(dy) < 6) return;
          if (Math.abs(dy) > Math.abs(dx)) {
            endDrag();
            return;
          }
          isDragging = true;
          slider.style.scrollBehavior = 'auto';
          slider.classList.add('is-dragging');
          slider.setPointerCapture(e.pointerId);
        }

        e.preventDefault();
        slider.scrollLeft = scrollLeft - dx * 1.5;
      });
    }

    sliders.forEach((slider) => bindHorizontalDrag(slider, false));
    mobileSliders.forEach((slider) => bindHorizontalDrag(slider, true));
  })();
</script>



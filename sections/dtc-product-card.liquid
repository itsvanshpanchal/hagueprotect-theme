{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .dtc-product-card-section {
    background-color: #ffffff;
    padding: 60px 0;
    font-family: 'Inter', sans-serif !important;
  }

  .dtc-product-card-container {
    max-width: var(--site-max-width);
    margin: 0 auto;
    padding: 0 16px;
    display: flex;
    justify-content: flex-start;
  }

  .dtc-product-card {
    width: 100%;
    max-width: 420px;
    background-color: #ffffff;
    display: flex;
    flex-direction: column;
    gap: 24px;
    text-align: left;
    box-sizing: border-box;
    position: relative;
    border-radius: 0;
  }

  .dtc-product-card__rating {
    background-color: #2ECC71;
    color: #ffffff;
    font-size: 12px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 6px;
    width: max-content;
    display: flex;
    align-items: center;
    gap: 4px;
    letter-spacing: 0.02em;
  }

  .dtc-product-card__title {
    font-size: clamp(20px, 3vw, 22px);
    font-weight: 800;
    color: #000000;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .dtc-product-card__subtitle {
    font-size: 14.5px;
    font-weight: 500;
    color: #999999;
    margin: -10px 0 0 0;
    line-height: 1.35;
  }

  .dtc-product-card__desc {
    font-size: 17px;
    font-weight: 600;
    color: #000000;
    margin: 0;
    line-height: 1.3;
  }

  .dtc-product-card__swatches {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-top: -4px;
  }

  .dtc-product-card__swatch-box {
    width: 15px;
    height: 15px;
    border-radius: 3px;
    border: 1px solid #e5e5e5;
    cursor: pointer;
    transition: all 0.2s;
  }

  .dtc-product-card__swatch-box.is-black { background-color: #000000; }
  .dtc-product-card__swatch-box.is-white { background-color: #ffffff; }

  .dtc-product-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-top: 8px;
    width: 100%;
  }

  .dtc-product-card__price-box {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: left;
  }

  .dtc-product-card__price-old {
    font-size: 13px;
    text-decoration: line-through;
    color: #aaaaaa;
    line-height: 1.1;
  }

  .dtc-product-card__price-new {
    font-size: 23px;
    font-weight: 800;
    color: #000000;
    line-height: 1.1;
  }

  .dtc-product-card__atc-btn {
    background-color: #000000;
    color: #ffffff;
    font-size: 15px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 16px 44px;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    text-align: center;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .dtc-product-card__atc-btn:hover {
    background-color: #FF2D2D;
    transform: translateY(-2px);
  }

  @media screen and (max-width: 768px) {
    .dtc-product-card-container {
      justify-content: center;
      padding: 0 20px;
    }
    .dtc-product-card {
      max-width: 100%;
    }
  }
{%- endstyle -%}



{%- assign card_product = section.settings.product -%}
<section class="dtc-product-card-section" aria-label="Featured product card">
  <div class="dtc-product-card-container">
    <div class="dtc-product-card">
      
      <!-- Top rating badge -->
      <div class="dtc-product-card__rating">Ã¢Ëœâ€¦ 4.9 (260)</div>

      <!-- Title -->
      <h2 class="dtc-product-card__title">{{ card_product.title | default: section.settings.title | default: 'HÃ„â‚¬LO v2' }}</h2>

      <!-- Subtitle -->
      <p class="dtc-product-card__subtitle">{{ section.settings.subtitle | default: 'HÃ„â‚¬LO v2 | 3D Air Circulation Fan with Mood Lamp' }}</p>

      <!-- Short selling line description -->
      <p class="dtc-product-card__desc">{{ section.settings.desc | default: "India's most silent air circulator" }}</p>

      <!-- Swatches -->
      <div class="dtc-product-card__swatches">
        <div class="dtc-product-card__swatch-box is-black" title="Black"></div>
        <div class="dtc-product-card__swatch-box is-white" title="White"></div>
      </div>

      <!-- Footer containing price and Buy Now button -->
      <div class="dtc-product-card__footer">
        <div class="dtc-product-card__price-box">
          <span class="dtc-product-card__price-old">{{ card_product.compare_at_price | money | default: section.settings.old_price | default: 'Rs. 15,999' }}</span>
          <span class="dtc-product-card__price-new">{{ card_product.price | money | default: section.settings.new_price | default: 'Rs. 10,999' }}</span>
        </div>

        <div style="display: flex; flex-direction: column; gap: 10px; width: 100%;">
          {%- if card_product != blank -%}
            {%- form 'product', card_product, id: 'AddToCartForm-dtc-card' -%}
              <input type="hidden" name="id" value="{{ card_product.selected_or_first_available_variant.id }}">
              <button type="submit" name="add" class="dtc-product-card__atc-btn" style="width: 100%;">Add to Cart</button>
              <div style="margin-top: 10px;">
                {{ form | payment_button }}
              </div>
            {%- endform -%}
          {%- else -%}
            <button type="button" class="dtc-product-card__atc-btn" style="width: 100%;">Buy Now</button>
            <p style="font-size: 10px; color: red; margin-top: 4px;">Please select a product in theme editor</p>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</section>


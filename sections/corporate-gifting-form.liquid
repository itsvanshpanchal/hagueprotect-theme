{%- style -%}
  .corp-form {
    padding: 80px 0;
    background-color: #ffffff;
  }
  .corp-form__container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .corp-form__card {
    background: #ffffff;
    border: 1px solid #eeeeee;
    padding: 48px;
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.04);
  }
  .corp-form__header {
    text-align: center;
    margin-bottom: 40px;
  }
  .corp-form__title {
    font-size: 28px;
    font-weight: 800;
    margin: 0 0 8px 0;
    color: #000;
  }
  .corp-form__subtitle {
    font-size: 14px;
    color: #666;
  }
  .corp-form__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }
  .corp-form__group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .corp-form__input {
    width: 100%;
    padding: 12px 0;
    border: none;
    border-bottom: 1px solid #ddd;
    font-family: inherit;
    font-size: 14px;
    outline: none;
    transition: border-color 0.3s;
  }
  .corp-form__input:focus {
    border-bottom-color: #000;
  }
  .corp-form__checklist-title {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 16px;
    color: #111;
  }
  .corp-form__checklist {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 32px;
  }
  .corp-form__checkbox-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: #444;
    cursor: pointer;
  }
  .corp-form__checkbox {
    width: 16px;
    height: 16px;
    accent-color: #000;
  }
  .corp-form__submit {
    width: 100%;
    background: #000;
    color: #fff;
    border: none;
    padding: 16px;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.3s;
  }
  .corp-form__submit:hover {
    background: #333;
  }

  @media screen and (max-width: 767px) {
    .corp-form {
      padding: 48px 0;
    }
    .corp-form__card {
      padding: 24px;
    }
    .corp-form__grid {
      grid-template-columns: 1fr;
    }
    .corp-form__checklist {
      grid-template-columns: 1fr 1fr;
    }
  }
{%- endstyle -%}

<div class="corp-form">
  <div class="corp-form__container">
    <div class="corp-form__card">
      <div class="corp-form__header">
        <h2 class="corp-form__title">Get in Touch</h2>
        <p class="corp-form__subtitle">Reach us at corporate@hagueprotect.com or WhatsApp: +91 99999 00000</p>
      </div>

      <form id="CorporateContactForm" class="corp-form__body">
        <div class="corp-form__grid">
          <div class="corp-form__group">
            <input type="text" class="corp-form__input" placeholder="Name *" required>
          </div>
          <div class="corp-form__group">
            <input type="text" class="corp-form__input" placeholder="Designation *">
          </div>
        </div>

        <div class="corp-form__group" style="margin-bottom: 24px;">
          <input type="tel" class="corp-form__input" placeholder="Phone *" required>
        </div>

        <div class="corp-form__checklist-group">
          <p class="corp-form__checklist-title">Interested in Products:</p>
          <div class="corp-form__checklist">
            <label class="corp-form__checkbox-label"><input type="checkbox" class="corp-form__checkbox"> 400</label>
            <label class="corp-form__checkbox-label"><input type="checkbox" class="corp-form__checkbox"> AM-10(6)</label>
            <label class="corp-form__checkbox-label"><input type="checkbox" class="corp-form__checkbox"> LV-8(8)</label>
            <label class="corp-form__checkbox-label"><input type="checkbox" class="corp-form__checkbox"> MP-5</label>
            <label class="corp-form__checkbox-label"><input type="checkbox" class="corp-form__checkbox"> Net World</label>
            <label class="corp-form__checkbox-label"><input type="checkbox" class="corp-form__checkbox"> P-10</label>
            <label class="corp-form__checkbox-label"><input type="checkbox" class="corp-form__checkbox"> P-50W</label>
            <label class="corp-form__checkbox-label"><input type="checkbox" class="corp-form__checkbox"> P-80(40.5.21)</label>
            <label class="corp-form__checkbox-label"><input type="checkbox" class="corp-form__checkbox"> LS-12(8)</label>
            <label class="corp-form__checkbox-label"><input type="checkbox" class="corp-form__checkbox"> M-10</label>
            <label class="corp-form__checkbox-label"><input type="checkbox" class="corp-form__checkbox"> LS-12(5)</label>
            <label class="corp-form__checkbox-label"><input type="checkbox" class="corp-form__checkbox"> MP-11(10)</label>
          </div>
        </div>

        <div class="corp-form__group" style="margin-bottom: 32px;">
          <textarea class="corp-form__input" placeholder="Message" rows="3"></textarea>
        </div>

        <button type="submit" class="corp-form__submit">Send</button>
      </form>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Corporate Form",
  "settings": []
}
{% endschema %}

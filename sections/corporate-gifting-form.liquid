{%- style -%}
  .corp-form {
    padding: 60px 0;
    background-color: #ffffff;
  }
  .corp-form__container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .corp-form__header {
    text-align: center;
    margin-bottom: 40px;
  }
  .corp-form__title {
    font-size: 28px;
    font-weight: 700;
    margin: 0 0 12px 0;
    color: #000;
  }
  .corp-form__subtitle {
    margin: 0;
  }
  .corp-form__subtitle a {
    color: #666;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .corp-form__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }
  .corp-form__group {
    display: flex;
    flex-direction: column;
    margin-bottom: 16px;
  }
  .corp-form__input-wrapper {
    display: flex;
    align-items: center;
    border: 1px solid #dcdcdc;
    border-radius: 6px;
    background: #fff;
    overflow: hidden;
    transition: border-color 0.3s;
  }
  .corp-form__input-wrapper:focus-within {
    border-color: #000;
  }
  .corp-form__input {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid #dcdcdc;
    border-radius: 6px;
    font-family: inherit;
    font-size: 14px;
    color: #333;
    outline: none;
    background: #fff;
    transition: border-color 0.3s;
    box-sizing: border-box;
  }
  .corp-form__input::placeholder {
    color: #666;
  }
  .corp-form__input:focus {
    border-color: #000;
  }
  .corp-form__input-wrapper .corp-form__input {
    border: none;
    border-radius: 0;
  }
  .corp-form__input-wrapper .corp-form__input:focus {
    border: none;
  }
  .corp-form__phone-prefix {
    display: flex;
    align-items: center;
    padding: 0 0 0 16px;
    gap: 8px;
    font-size: 14px;
    color: #333;
    background: #fff;
    white-space: nowrap;
  }
  textarea.corp-form__input {
    resize: vertical;
    min-height: 140px;
  }
  .corp-form__submit {
    width: 100%;
    background: #000;
    color: #fff;
    border: none;
    padding: 16px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.3s;
  }
  .corp-form__submit:hover {
    background: #333;
  }

  @media screen and (max-width: 767px) {
    .corp-form {
      padding: 40px 0;
    }
    .corp-form__grid {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<div class="corp-form">
  <div class="corp-form__container">
    <div class="corp-form__header">
      <h2 class="corp-form__title">Get in Touch</h2>
      <p class="corp-form__subtitle">
        You can also reach us at <a href="mailto:gifting@nuuk.in">gifting@nuuk.in</a> or on WhatsApp at <a href="https://wa.me/917009205008">7009205008</a>
      </p>
    </div>

    {%- form 'contact', id: 'CorporateContactForm', class: 'corp-form__body' -%}
      {%- if form.posted_successfully? -%}
        <div style="background: #E8F5E9; color: #2E7D32; padding: 16px; border-radius: 6px; text-align: center; margin-bottom: 24px; font-weight: 500;">
          Thanks for reaching out! We'll get back to you shortly.
        </div>
      {%- endif -%}

      <div class="corp-form__grid">
        <input type="text" name="contact[name]" class="corp-form__input" placeholder="Name *" required>
        <input type="text" name="contact[company]" class="corp-form__input" placeholder="Company Name *" required>
      </div>

      <div class="corp-form__group">
        <div class="corp-form__input-wrapper">
          <div class="corp-form__phone-prefix">
            <span>🇮🇳</span>
            <span>+91</span>
          </div>
          <input type="tel" name="contact[phone]" class="corp-form__input" placeholder="Phone *" required>
        </div>
      </div>

      <div class="corp-form__group">
        <textarea name="contact[body]" class="corp-form__input" placeholder="Message *" required></textarea>
      </div>

      <button type="submit" class="corp-form__submit">Submit</button>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Corporate Form",
  "settings": [],
  "presets": [
    {
      "name": "Corporate Form"
    }
  ]
}
{% endschema %}

{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .feature-grid {
    font-family: var(--font-family-sans, 'Inter', 'Helvetica Neue', sans-serif);
    background-color: #ffffff;
    padding: clamp(100px, 12vw, 160px) 0;
  }

  .feature-grid__container {
    max-width: var(--site-max-width);
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .feature-grid__header {
    text-align: center;
    max-width: 750px;
    margin: 0 auto;
  }

  .feature-grid__eyebrow {
    font-size: clamp(14px, 2vw, 18px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #FF2B2B;
    margin: 0;
    display: block;
  }

  .feature-grid__heading {
    font-size: clamp(38px, 6vw, 60px);
    font-weight: 800;
    color: #000;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .feature-grid__items {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  @media screen and (max-width: 991px) {
    .feature-grid {
      padding: clamp(50px, 8vw, 60px) 0;
    }
    .feature-grid__items {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
  }

  @media screen and (max-width: 576px) {
    .feature-grid__items {
      grid-template-columns: 1fr;
    }
  }

  .feature-grid__card {
    background-color: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 16px rgba(0,0,0,0.02);
  }

  .feature-grid__card:hover {
    transform: translateY(-4px);
    border-color: #000000;
    box-shadow: 0 16px 36px rgba(0,0,0,0.05);
  }

  .feature-grid__card-visual {
    --fg-icon-primary: #111111;
    --fg-icon-accent: #FF2B2B;
    width: 72px;
    height: 72px;
    background: linear-gradient(145deg, #fafafa 0%, #f0f0f0 100%);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04), inset 0 1px 0 rgba(255, 255, 255, 0.85);
    transition: background 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease, transform 0.35s ease;
  }

  .feature-grid__card-visual::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 28% 18%, rgba(255, 43, 43, 0.14), transparent 58%);
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .feature-grid__card:hover .feature-grid__card-visual {
    --fg-icon-primary: #ffffff;
    --fg-icon-accent: #FF2B2B;
    background: linear-gradient(145deg, #1a1a1a 0%, #000000 100%);
    border-color: #000000;
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.18);
    transform: translateY(-2px) scale(1.03);
  }

  .feature-grid__card:hover .feature-grid__card-visual::before {
    opacity: 1;
  }

  .feature-grid__card-icon {
    width: 42px;
    height: 42px;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .feature-grid__icon-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .feature-grid__icon-accent {
    filter: drop-shadow(0 0 3px rgba(255, 43, 43, 0.35));
    transition: filter 0.35s ease;
  }

  .feature-grid__card:hover .feature-grid__icon-accent {
    filter: drop-shadow(0 0 6px rgba(255, 43, 43, 0.65));
  }

  .feature-grid__card-visual img {
    width: 42px;
    height: 42px;
    object-fit: contain;
    position: relative;
    z-index: 1;
  }

  .feature-grid__card-heading {
    font-size: clamp(18px, 2vw, 22px);
    font-weight: 700;
    color: #000000;
    margin: 0;
  }

  .feature-grid__card-text {
    font-size: clamp(14px, 1.6vw, 16px);
    color: #555555;
    line-height: 1.6;
    margin: 0;
  }
{%- endstyle -%}

<div class="feature-grid">
  <div class="feature-grid__container">
    {%- if section.settings.heading != blank -%}
      <div class="feature-grid__header section-heading-stack section-heading-stack--center">
        <span class="feature-grid__eyebrow">{{ section.settings.eyebrow | default: 'THE HAGUE EFFECT' }}</span>
        <h2 class="feature-grid__heading">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="feature-grid__items">
      {%- for block in section.blocks -%}
        <div class="feature-grid__card" {{ block.shopify_attributes }}>
          <div class="feature-grid__card-visual">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 120 }}"
                alt="{{ block.settings.heading | escape }}"
                loading="lazy"
                width="42"
                height="42"
              >
            {%- else -%}
              <div class="feature-grid__card-icon">
                {% render 'feature-grid-icon',
                  preset: block.settings.icon_preset,
                  primary_color: 'var(--fg-icon-primary)',
                  accent_color: 'var(--fg-icon-accent)'
                %}
              </div>
            {%- endif -%}
          </div>
          <h3 class="feature-grid__card-heading">{{ block.settings.heading | default: 'Deep Cleaning Power' }}</h3>
          <p class="feature-grid__card-text">{{ block.settings.text | default: 'Extracts ground-in dirt without damaging fragile premium fibers.' }}</p>
        </div>
      {%- else -%}
        <!-- Fallbacks -->
        {%- assign fallback_icons = 'lasting,color,protection' | split: ',' -%}
        {%- for i in (1..3) -%}
          <div class="feature-grid__card">
            <div class="feature-grid__card-visual">
              <div class="feature-grid__card-icon">
                {% render 'feature-grid-icon',
                  preset: fallback_icons[forloop.index0],
                  primary_color: 'var(--fg-icon-primary)',
                  accent_color: 'var(--fg-icon-accent)'
                %}
              </div>
            </div>
            <h3 class="feature-grid__card-heading">
              {%- if i == 1 -%}Deep Cleaning Power{%- elsif i == 2 -%}Safe for All Materials{%- else -%}Long Lasting Protection{%- endif -%}
            </h3>
            <p class="feature-grid__card-text">
              {%- if i == 1 -%}Our advanced cinematic foam penetrates down to extract stubborn dirt particles with absolute precision.{%- elsif i == 2 -%}Carefully engineered pH-balanced formula safe for fine leather, suede, nubuck, and mesh.{%- else -%}Includes micro-shield tech that protects against fresh dirt long after cleaning.{%- endif -%}
            </p>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</div>


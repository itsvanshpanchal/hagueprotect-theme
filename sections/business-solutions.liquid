{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .biz-solutions {
    padding: clamp(80px, 10vw, 120px) 0;
    background: #f8f9fc;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .biz-solutions__container {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 max(20px, var(--site-padding, 24px));
  }

  .biz-solutions__header {
    text-align: center;
    max-width: 680px;
    margin: 0 auto clamp(48px, 6vw, 72px);
  }

  .biz-solutions__eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #4f8cff;
    margin: 0 0 12px;
  }

  .biz-solutions__heading {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(42px, 5.5vw, 68px);
    font-weight: 400;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #0a0c12 !important;
    margin: 0 0 16px;
    line-height: 1;
  }

  .biz-solutions__sub {
    font-size: 16px;
    line-height: 1.65;
    color: #5a6270;
    margin: 0;
  }

  .biz-solutions__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .biz-solutions__card {
    position: relative;
    border-radius: 20px;
    background: #ffffff;
    border: 1px solid #e8ecf4;
    padding: 32px 28px;
    min-height: 320px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    opacity: 1 !important;
    visibility: visible !important;
    transform: none !important;
  }

  .biz-solutions__card:hover {
    transform: translateY(-8px);
    box-shadow: 0 24px 60px rgba(10, 12, 18, 0.12);
    border-color: rgba(79, 140, 255, 0.3);
  }

  .biz-solutions__card--featured {
    background: linear-gradient(160deg, #0a0c12 0%, #141a28 100%);
    border-color: #1e2638;
    color: #ffffff;
  }

  .biz-solutions__card--featured .biz-solutions__card-title,
  .biz-solutions__card--featured .biz-solutions__card-text {
    color: #ffffff;
  }

  .biz-solutions__card--featured .biz-solutions__card-text {
    color: rgba(255, 255, 255, 0.65);
  }

  .biz-solutions__card-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 48px;
    line-height: 1;
    color: rgba(79, 140, 255, 0.15);
    margin-bottom: 16px;
  }

  .biz-solutions__card--featured .biz-solutions__card-num {
    color: rgba(255, 43, 43, 0.35);
  }

  .biz-solutions__card-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    background: linear-gradient(135deg, rgba(79, 140, 255, 0.12), rgba(255, 43, 43, 0.08));
    color: #4f8cff;
  }

  .biz-solutions__card--featured .biz-solutions__card-icon {
    background: linear-gradient(135deg, rgba(255, 43, 43, 0.25), rgba(79, 140, 255, 0.15));
    color: #ff6b6b;
  }

  .biz-solutions__card-img {
    width: 100%;
    height: 140px;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 20px;
  }

  .biz-solutions__card-title {
    font-size: 18px;
    font-weight: 700;
    color: #0a0c12;
    margin: 0 0 10px;
  }

  .biz-solutions__card-text {
    font-size: 14px;
    line-height: 1.65;
    color: #5a6270;
    margin: 0 0 auto;
    padding-bottom: 20px;
  }

  .biz-solutions__card-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #4f8cff;
    text-decoration: none;
    margin-top: auto;
  }

  .biz-solutions__card--featured .biz-solutions__card-link {
    color: #ff6b6b;
  }

  .biz-solutions__card-link:hover {
    gap: 12px;
  }

  @media screen and (max-width: 1100px) {
    .biz-solutions__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 600px) {
    .biz-solutions__grid {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<section class="biz-solutions" id="biz-solutions" data-no-typewriter>
  <div class="biz-solutions__container">
    <header class="biz-solutions__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="biz-solutions__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="biz-solutions__heading">{{ section.settings.heading | default: 'Business Solutions' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="biz-solutions__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>

    <div class="biz-solutions__grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'solution' -%}
            <article class="biz-solutions__card{% if block.settings.featured %} biz-solutions__card--featured{% endif %}" data-biz-reveal {{ block.shopify_attributes }}>
              <span class="biz-solutions__card-num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}" class="biz-solutions__card-img" loading="lazy">
              {%- else -%}
                <div class="biz-solutions__card-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                </div>
              {%- endif -%}
              <h3 class="biz-solutions__card-title">{{ block.settings.title }}</h3>
              <p class="biz-solutions__card-text">{{ block.settings.text }}</p>
              {%- if block.settings.link_label != blank -%}
                <a href="{{ block.settings.link | default: '#biz-inquiry' }}" class="biz-solutions__card-link">
                  {{ block.settings.link_label }}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                </a>
              {%- endif -%}
            </article>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <article class="biz-solutions__card" data-biz-reveal>
          <span class="biz-solutions__card-num">01</span>
          <div class="biz-solutions__card-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5z" stroke="currentColor" stroke-width="1.5"/></svg></div>
          <h3 class="biz-solutions__card-title">Wholesale Supply</h3>
          <p class="biz-solutions__card-text">Competitive margins with tiered pricing, flexible MOQs, and pan-India fulfillment for retailers and distributors.</p>
          <a href="#biz-inquiry" class="biz-solutions__card-link">Learn more <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2"/></svg></a>
        </article>
        <article class="biz-solutions__card biz-solutions__card--featured" data-biz-reveal>
          <span class="biz-solutions__card-num">02</span>
          <div class="biz-solutions__card-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" stroke="currentColor" stroke-width="1.5"/></svg></div>
          <h3 class="biz-solutions__card-title">Retail Partnerships</h3>
          <p class="biz-solutions__card-text">In-store displays, training materials, and co-marketing support to drive sell-through at your locations.</p>
          <a href="#biz-inquiry" class="biz-solutions__card-link">Learn more <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2"/></svg></a>
        </article>
        <article class="biz-solutions__card" data-biz-reveal>
          <span class="biz-solutions__card-num">03</span>
          <div class="biz-solutions__card-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M8 12h8M12 8v8" stroke="currentColor" stroke-width="1.5"/></svg></div>
          <h3 class="biz-solutions__card-title">White Label</h3>
          <p class="biz-solutions__card-text">Custom packaging and branding on our premium formulations Ã¢â‚¬â€ launch your own sneaker care line.</p>
          <a href="#biz-inquiry" class="biz-solutions__card-link">Learn more <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2"/></svg></a>
        </article>
        <article class="biz-solutions__card" data-biz-reveal>
          <span class="biz-solutions__card-num">04</span>
          <div class="biz-solutions__card-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z" stroke="currentColor" stroke-width="1.5"/></svg></div>
          <h3 class="biz-solutions__card-title">E-Commerce Programs</h3>
          <p class="biz-solutions__card-text">Dropship-ready inventory, marketplace listings support, and dedicated account managers for online brands.</p>
          <a href="#biz-inquiry" class="biz-solutions__card-link">Learn more <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2"/></svg></a>
        </article>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{

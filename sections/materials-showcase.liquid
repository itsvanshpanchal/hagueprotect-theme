{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .mat-section {
    box-sizing: border-box !important;
    font-family: var(--font-family-sans, 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif);
    --section-subheading-line-height: 1.05;
  }

  .mat-section *,
  .mat-section *::before,
  .mat-section *::after {
    box-sizing: border-box !important;
  }

  .mat-section .mat-headline {
    font-family: var(--font-family-h2, var(--font-family-heading)) !important;
  }

  .mat-section {
    width: 100% !important;
    position: relative !important;
    isolation: isolate !important;
    background-color: {{ section.settings.bg_color | default: '#111111' }} !important;
    padding-top: {{ section.settings.padding_top | default: 110 }}px !important;
    padding-bottom: {{ section.settings.padding_bottom | default: 110 }}px !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    overflow: hidden !important;
    min-height: min(72vh, 720px) !important;
  }

  .mat-container {
    position: relative !important;
    z-index: 3 !important;
    max-width: var(--site-max-width) !important;
    margin: 0 auto !important;
    padding-left: var(--homepage-section-gutter, 8px) !important;
    padding-right: var(--homepage-section-gutter, 8px) !important;
  }

  .mat-grid {
    display: grid !important;
    grid-template-columns: minmax(280px, 520px) 1fr !important;
    align-items: center !important;
    gap: 40px !important;
    min-height: inherit !important;
  }

  .mat-left {
    display: flex !important;
    flex-direction: column !important;
    align-items: flex-start !important;
    justify-content: center !important;
    position: relative !important;
    z-index: 3 !important;
    max-width: 560px !important;
  }

  .mat-right {
    display: none !important;
  }

  .mat-eyebrow {
    display: block !important;
  }

  .mat-headline {
    color: #ffffff !important;
    margin: 0 !important;
    font-size: var(--section-heading-size) !important;
    line-height: 1.05 !important;
  }

  #MainContent #shopify-section-{{ section.id }} .mat-desc,
  #MainContent .shopify-section .mat-section .mat-desc,
  #shopify-section-{{ section.id }} .mat-desc,
  .mat-section .mat-desc {
    color: rgba(255, 255, 255, 0.88) !important;
    line-height: 1.05 !important;
    margin-top: var(--section-subheading-spacing-top, 12px) !important;
    margin-bottom: 0 !important;
  }

  .mat-section .mat-headline,
  .mat-section .mat-headline .hp-heading-line--1 {
    color: #ffffff !important;
  }

  .mat-menu {
    display: flex !important;
    flex-direction: column !important;
    width: 100% !important;
    gap: 4px !important;
  }

  .mat-menu-item,
  .mat-menu-item-text {
    font-family: var(--font-family-h2, var(--font-family-heading)) !important;
    font-size: min({{ section.settings.menu_font_size | default: 52 }}px, 60px) !important;
    font-weight: var(--font-weight-h2, 400) !important;
    font-style: var(--font-style-h2, normal) !important;
    text-transform: none !important;
    text-decoration: none !important;
    transition: color 0.3s cubic-bezier(0.25, 1, 0.5, 1), transform 0.3s cubic-bezier(0.25, 1, 0.5, 1) !important;
    cursor: pointer !important;
    position: relative !important;
    transform-origin: left center !important;
    line-height: 1.1 !important;
    -webkit-font-smoothing: antialiased !important;
  }

  .mat-menu-item {
    display: flex !important;
    align-items: center !important;
    justify-content: flex-start !important;
    color: rgba(255, 255, 255, 0.55) !important;
  }

  .mat-menu-item-text {
    color: inherit !important;
  }

  .mat-menu-item:hover,
  .mat-menu-item.active,
  .mat-menu-item:hover .mat-menu-item-text,
  .mat-menu-item.active .mat-menu-item-text {
    color: {{ section.settings.active_color | default: '#D60000' }} !important;
    transform: scale(1.01) !important;
  }

  .mat-menu-arrow {
    display: inline-flex !important;
    align-items: center !important;
    opacity: 0 !important;
    transform: translateX(-8px) !important;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1) !important;
    margin-left: 10px !important;
    color: {{ section.settings.active_color | default: '#D60000' }} !important;
  }

  .mat-menu-item:hover .mat-menu-arrow,
  .mat-menu-item.active .mat-menu-arrow {
    opacity: 1 !important;
    transform: translateX(0) !important;
  }

  .mat-menu-arrow svg {
    width: 0.7em !important;
    height: 0.7em !important;
    fill: none !important;
    stroke: currentColor !important;
  }

  .mat-bg-stage {
    display: block !important;
    position: absolute !important;
    inset: 0 !important;
    width: 100% !important;
    height: 100% !important;
    z-index: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
    pointer-events: none !important;
  }

  .mat-bg-overlay {
    display: block !important;
    position: absolute !important;
    inset: 0 !important;
    z-index: 2 !important;
    pointer-events: none !important;
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, 0.78) 0%,
      rgba(0, 0, 0, 0.45) 42%,
      rgba(0, 0, 0, 0.18) 72%,
      rgba(0, 0, 0, 0.08) 100%
    ) !important;
  }

  .mat-bg-stage .mat-image-container {
    position: absolute !important;
    inset: 0 !important;
    max-width: none !important;
    width: 100% !important;
    height: 100% !important;
    border-radius: 0 !important;
    overflow: hidden !important;
  }

  .mat-bg-stage .mat-image-layer,
  .mat-bg-stage .mat-image-fallback {
    position: absolute !important;
    inset: 0 !important;
    width: 100% !important;
    height: 100% !important;
    opacity: 0 !important;
    transform: scale(1.06) !important;
    transition: opacity {{ section.settings.animation_speed | default: 400 }}ms cubic-bezier(0.25, 1, 0.5, 1),
                transform {{ section.settings.animation_speed | default: 500 }}ms cubic-bezier(0.25, 1, 0.5, 1) !important;
    z-index: 1 !important;
  }

  .mat-bg-stage .mat-image-layer {
    object-fit: cover !important;
    object-position: center center !important;
  }

  .mat-bg-stage .mat-image-fallback {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  .mat-bg-stage .mat-image-layer.active,
  .mat-bg-stage .mat-image-fallback.active {
    opacity: 1 !important;
    transform: scale(1) !important;
    z-index: 2 !important;
  }

  @media screen and (max-width: 1200px) {
    .mat-menu-item,
    .mat-menu-item-text {
      font-size: calc(min({{ section.settings.menu_font_size | default: 52 }}px, 60px) * 0.8) !important;
    }
  }

  @media screen and (max-width: 1024px) {
    .mat-grid {
      grid-template-columns: minmax(240px, 1fr) !important;
      gap: 0 !important;
    }
    .mat-menu-item,
    .mat-menu-item-text {
      font-size: calc(min({{ section.settings.menu_font_size | default: 52 }}px, 60px) * 0.7) !important;
    }
  }

  @media screen and (max-width: 768px) {
    .mat-section {
      --mat-mobile-gutter: var(--homepage-section-gutter, 6px);
      min-height: min(88dvh, 680px) !important;
      padding-top: 0 !important;
      padding-bottom: 0 !important;
    }

    .mat-bg-overlay {
      background: linear-gradient(
        180deg,
        rgba(0, 0, 0, 0.78) 0%,
        rgba(0, 0, 0, 0.42) 45%,
        rgba(0, 0, 0, 0.62) 100%
      ) !important;
    }

    .mat-container {
      max-width: none !important;
      width: 100% !important;
      padding-left: 0 !important;
      padding-right: 0 !important;
      min-height: min(88dvh, 680px) !important;
    }

    .mat-grid {
      display: block !important;
      min-height: min(88dvh, 680px) !important;
    }

    .mat-bg-stage .mat-image-container,
    .mat-bg-stage .mat-image-layer,
    .mat-bg-stage .mat-image-fallback {
      min-height: min(88dvh, 680px) !important;
    }

    .mat-bg-stage .mat-image-layer,
    .mat-bg-stage .mat-image-fallback {
      transform: scale(1.14) !important;
      transition: opacity 650ms cubic-bezier(0.25, 1, 0.5, 1),
                  transform 850ms cubic-bezier(0.25, 1, 0.5, 1) !important;
    }

    .mat-bg-stage .mat-image-layer.active,
    .mat-bg-stage .mat-image-fallback.active {
      transform: scale(1) !important;
    }

    .mat-left {
      align-items: var(--section-heading-items, flex-start) !important;
      text-align: var(--section-heading-align, left) !important;
      justify-content: flex-end !important;
      min-height: min(88dvh, 680px) !important;
      width: 100% !important;
      max-width: none !important;
      padding: 56px var(--mat-mobile-gutter) 32px var(--mat-mobile-gutter) !important;
    }

    .mat-eyebrow,
    .mat-headline,
    .mat-desc,
    .mat-menu,
    .mat-menu-item {
      align-self: var(--section-heading-items, flex-start) !important;
      width: 100% !important;
      max-width: 100% !important;
    }

    .mat-menu-item,
    .mat-menu-item-text {
      font-size: min({{ section.settings.menu_font_size | default: 36 }}px, 44px) !important;
      line-height: 1.08 !important;
    }

    .mat-menu-item {
      padding: 6px 0 !important;
      min-height: 40px !important;
    }

    .mat-menu-arrow {
      margin-left: 8px !important;
    }
  }

{%- endstyle -%}

<section class="mat-section" aria-label="Materials Showcase Section" data-mat-section>
  <div class="mat-bg-stage" aria-hidden="true">
    <div class="mat-image-container">
      {%- for block in section.blocks -%}
        {%- if block.type == 'material_item' -%}
          {%- if block.settings.image != blank -%}
            <img class="mat-image-layer{% if forloop.first %} active{% endif %}"
                 src="{{ block.settings.image | image_url: width: 2400 }}"
                 alt=""
                 data-index="{{ forloop.index0 }}"
                 loading="lazy">
          {%- else -%}
            <div class="mat-image-fallback{% if forloop.first %} active{% endif %}"
                 data-index="{{ forloop.index0 }}">
              <svg viewBox="0 0 700 520" preserveAspectRatio="xMidYMid slice" style="width: 100%; height: 100%;">
                <rect width="700" height="520" fill="#1a1a1a"/>
                <circle cx="350" cy="260" r="140" fill="{{ section.settings.active_color | default: '#D60000' }}" opacity="0.12"/>
                <text x="350" y="275" font-size="32" font-weight="900" fill="#ffffff" text-anchor="middle" opacity="0.2" letter-spacing="4px">{{ block.settings.title | uppercase }}</text>
              </svg>
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
    <div class="mat-bg-overlay"></div>
  </div>
  <div class="mat-container">
    <div class="mat-grid">
      <!-- LEFT COLUMN -->
      <div class="mat-left">
        <div class="section-heading-stack">
          {%- if section.settings.eyebrow != blank -%}
            <span class="mat-eyebrow">{{ section.settings.eyebrow }}</span>
          {%- endif -%}
          <h2 class="mat-headline">{% render 'section-heading-text', text: section.settings.heading, line2: section.settings.heading_line2, line2_color: section.settings.heading_line2_color %}</h2>
        </div>
        {%- if section.settings.description != blank -%}
          <p class="mat-desc">{{ section.settings.description }}</p>
        {%- endif -%}
        
        <div class="mat-menu">
          {%- for block in section.blocks -%}
            {%- if block.type == 'material_item' -%}
              {%- liquid
                assign mat_href = '#'
                assign mat_care_handle = ''
                assign mat_care_search = ''

                if block.settings.collection != blank
                  assign mat_href = block.settings.collection.url
                elsif block.settings.product != blank
                  assign mat_href = block.settings.product.url
                elsif block.settings.url != blank
                  assign mat_href = block.settings.url
                else
                  assign mat_key = block.settings.title | downcase | strip
                  case mat_key
                    when 'suede'
                      assign mat_care_handle = 'suede-care-kit'
                      assign mat_care_search = 'Suede Care Kit'
                    when 'nubuck'
                      assign mat_care_handle = 'nubuck-care-kit'
                      assign mat_care_search = 'Nubuck Care Kit'
                    when 'leather'
                      assign mat_care_handle = 'leather-care-kit'
                      assign mat_care_search = 'Leather Care Kit'
                    when 'fabrics', 'fabric'
                      assign mat_care_handle = 'fabric-care-kit'
                      assign mat_care_search = 'Fabric Care Kit'
                    when 'soles', 'sole'
                      assign mat_care_handle = 'soles-care-kit'
                      assign mat_care_search = 'Sole Cleaner'
                  endcase

                  if mat_care_handle != blank
                    assign mat_col = collections[mat_care_handle]
                    if mat_col != blank
                      assign mat_href = mat_col.url
                    else
                      assign mat_search_encoded = mat_care_search | url_encode
                      assign mat_href = routes.search_url | append: '?q=' | append: mat_search_encoded | append: '&type=product'
                    endif
                  endif
                endif
              -%}
              <a href="{{ mat_href }}"
                 class="mat-menu-item {% render 'material-font-class', source: block.settings.title %}{% if forloop.first %} active{% endif %}"
                 data-index="{{ forloop.index0 }}"
                 {% if mat_href != '#' %}data-mat-link{% endif %}
                 {{ block.shopify_attributes }}>
                <span class="mat-menu-item-text {% render 'material-font-class', source: block.settings.title %}">{{ block.settings.title }}</span>
                <span class="mat-menu-arrow">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </span>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const matSection = document.querySelector('[data-mat-section]');
    if (!matSection) return;

    const menuItems = matSection.querySelectorAll('.mat-menu-item');
    const mobileQuery = window.matchMedia('(max-width: 768px)');

    function getActiveLayers() {
      return matSection.querySelectorAll('.mat-bg-stage .mat-image-layer, .mat-bg-stage .mat-image-fallback');
    }

    menuItems.forEach(item => {
      item.addEventListener('mouseenter', function() {
        switchActiveMaterial(this);
      });
    });

    function switchActiveMaterial(activeItem) {
      const index = activeItem.getAttribute('data-index');

      menuItems.forEach(i => i.classList.remove('active'));
      activeItem.classList.add('active');

      getActiveLayers().forEach(layer => {
        const isMatch = layer.getAttribute('data-index') === index;
        layer.classList.toggle('active', isMatch);
      });

      matSection.classList.add('mat-section--switching');
      window.clearTimeout(matSection._matSwitchTimer);
      matSection._matSwitchTimer = window.setTimeout(function() {
        matSection.classList.remove('mat-section--switching');
      }, 700);
    }
  });
</script>


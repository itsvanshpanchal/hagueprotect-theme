{%- style -%}
  .mat-section,
  .mat-section * {
    box-sizing: border-box !important;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif !important;
  }

  .mat-section {
    width: 100% !important;
    background-color: {{ section.settings.bg_color | default: '#F7F7F7' }} !important;
    padding-top: {{ section.settings.padding_top | default: 110 }}px !important;
    padding-bottom: {{ section.settings.padding_bottom | default: 110 }}px !important;
    overflow: hidden !important;
  }

  .mat-container {
    max-width: 1400px !important;
    margin: 0 auto !important;
    padding-left: 60px !important;
    padding-right: 60px !important;
  }

  @media screen and (max-width: 1024px) {
    .mat-container {
      padding-left: 40px !important;
      padding-right: 40px !important;
    }
  }

  @media screen and (max-width: 768px) {
    .mat-container {
      padding-left: 20px !important;
      padding-right: 20px !important;
    }
  }

  .mat-grid {
    display: grid !important;
    grid-template-columns: 45% 55% !important;
    align-items: center !important;
    gap: 80px !important;
  }

  .mat-left {
    display: flex !important;
    flex-direction: column !important;
    align-items: flex-start !important;
    justify-content: center !important;
  }

  .mat-right {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  .mat-eyebrow {
    font-size: 14px !important;
    font-weight: 500 !important;
    letter-spacing: 5px !important;
    color: #7A7A7A !important;
    text-transform: uppercase !important;
    margin-bottom: 20px !important;
    display: block !important;
  }

  .mat-headline {
    font-size: clamp(32px, 4.5vw, 44px) !important;
    font-weight: 800 !important;
    color: #000000 !important;
    line-height: 1.15 !important;
    letter-spacing: -1px !important;
    margin: 0 0 15px 0 !important;
    text-transform: uppercase !important;
  }

  .mat-desc {
    max-width: 600px !important;
    font-size: 16px !important;
    font-weight: 400 !important;
    line-height: 1.6 !important;
    color: #565656 !important;
    margin: 0 0 35px 0 !important;
  }

  /* Material menu */
  .mat-menu {
    display: flex !important;
    flex-direction: column !important;
    width: 100% !important;
    gap: 8px !important;
  }

  .mat-menu-item {
    display: flex !important;
    align-items: center !important;
    justify-content: flex-start !important;
    font-size: {{ section.settings.menu_font_size | default: 48 }}px !important;
    font-weight: 800 !important;
    color: {{ section.settings.inactive_color | default: '#000000' }} !important;
    text-decoration: none !important;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1) !important;
    cursor: pointer !important;
    position: relative !important;
    transform-origin: left center !important;
    line-height: 1.3 !important;
    letter-spacing: -0.2px !important;
  }

  .mat-menu-item:hover,
  .mat-menu-item.active {
    color: {{ section.settings.active_color | default: '#D60000' }} !important;
    transform: scale(1.01) !important;
  }

  .mat-menu-arrow {
    display: inline-flex !important;
    align-items: center !important;
    opacity: 0 !important;
    transform: translateX(-8px) !important;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1) !important;
    margin-left: 10px !important;
    color: {{ section.settings.active_color | default: '#D60000' }} !important;
  }

  .mat-menu-item:hover .mat-menu-arrow,
  .mat-menu-item.active .mat-menu-arrow {
    opacity: 1 !important;
    transform: translateX(0) !important;
  }

  .mat-menu-arrow svg {
    width: 0.7em !important;
    height: 0.7em !important;
    fill: none !important;
    stroke: currentColor !important;
  }

  /* Image Area */
  .mat-image-container {
    width: 100% !important;
    max-width: 700px !important;
    height: 520px !important;
    border-radius: {{ section.settings.image_radius | default: 24 }}px !important;
    overflow: hidden !important;
    position: relative !important;
  }

  .mat-image-layer {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    opacity: 0 !important;
    transform: scale(1.05) !important;
    transition: opacity {{ section.settings.animation_speed | default: 400 }}ms cubic-bezier(0.25, 1, 0.5, 1), 
                transform {{ section.settings.animation_speed | default: 400 }}ms cubic-bezier(0.25, 1, 0.5, 1) !important;
    z-index: 1 !important;
  }

  .mat-image-layer.active {
    opacity: 1 !important;
    transform: scale(1) !important;
    z-index: 2 !important;
  }

  .mat-image-fallback {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    opacity: 0 !important;
    transform: scale(1.05) !important;
    transition: opacity {{ section.settings.animation_speed | default: 400 }}ms cubic-bezier(0.25, 1, 0.5, 1), 
                transform {{ section.settings.animation_speed | default: 400 }}ms cubic-bezier(0.25, 1, 0.5, 1) !important;
    z-index: 1 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  .mat-image-fallback.active {
    opacity: 1 !important;
    transform: scale(1) !important;
    z-index: 2 !important;
  }

  /* Responsiveness */
  @media screen and (max-width: 1200px) {
    .mat-grid {
      gap: 50px !important;
    }
    .mat-menu-item {
      font-size: calc({{ section.settings.menu_font_size | default: 48 }}px * 0.8) !important;
    }
  }

  @media screen and (max-width: 1024px) {
    .mat-grid {
      grid-template-columns: 48% 52% !important;
      gap: 40px !important;
    }
    .mat-menu-item {
      font-size: calc({{ section.settings.menu_font_size | default: 48 }}px * 0.7) !important;
    }
    .mat-image-container {
      height: 440px !important;
    }
  }

  @media screen and (max-width: 768px) {
    .mat-section {
      padding-top: 80px !important;
      padding-bottom: 80px !important;
    }
    .mat-grid {
      grid-template-columns: 1fr !important;
      gap: 50px !important;
    }
    .mat-left {
      align-items: center !important;
      text-align: center !important;
    }
    .mat-headline {
      margin-bottom: 25px !important;
    }
    .mat-desc {
      text-align: center !important;
      margin-bottom: 30px !important;
      font-size: 16px !important;
    }
    .mat-menu {
      align-items: center !important;
      gap: 8px !important;
    }
    .mat-menu-item {
      font-size: calc({{ section.settings.menu_font_size | default: 48 }}px * 0.6) !important;
      justify-content: center !important;
      letter-spacing: -0.2px !important;
      margin-bottom: 8px !important;
    }
    .mat-menu-arrow {
      margin-left: 10px !important;
    }
    .mat-image-container {
      height: 380px !important;
    }
  }
{%- endstyle -%}

<section class="mat-section" aria-label="Materials Showcase Section">
  <div class="mat-container">
    <div class="mat-grid">
      <!-- LEFT COLUMN -->
      <div class="mat-left">
        {%- if section.settings.eyebrow != blank -%}
          <span class="mat-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="mat-headline">{{ section.settings.heading }}</h2>
        {%- if section.settings.description != blank -%}
          <p class="mat-desc">{{ section.settings.description }}</p>
        {%- endif -%}
        
        <div class="mat-menu">
          {%- for block in section.blocks -%}
            {%- if block.type == 'material_item' -%}
              <a href="{{ block.settings.url | default: '#' }}" 
                 class="mat-menu-item{% if forloop.first %} active{% endif %}" 
                 data-index="{{ forloop.index0 }}" 
                 {{ block.shopify_attributes }}>
                <span class="mat-menu-item-text">{{ block.settings.title }}</span>
                <span class="mat-menu-arrow">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </span>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
      
      <!-- RIGHT COLUMN -->
      <div class="mat-right">
        <div class="mat-image-container">
          {%- for block in section.blocks -%}
            {%- if block.type == 'material_item' -%}
              {%- if block.settings.image != blank -%}
                <img class="mat-image-layer{% if forloop.first %} active{% endif %}" 
                     src="{{ block.settings.image | image_url: width: 1000 }}" 
                     alt="{{ block.settings.title | escape }}" 
                     data-index="{{ forloop.index0 }}" 
                     loading="lazy">
              {%- else -%}
                <!-- Vector Illustration Fallback Layer -->
                <div class="mat-image-fallback{% if forloop.first %} active{% endif %}" 
                     data-index="{{ forloop.index0 }}">
                  <svg viewBox="0 0 700 520" style="width: 100%; height: 100%;">
                    <rect width="700" height="520" fill="#EAEAEA"/>
                    <circle cx="350" cy="260" r="140" fill="{{ section.settings.active_color | default: '#D60000' }}" opacity="0.05" filter="blur(24px)"/>
                    <text x="350" y="275" font-size="32" font-weight="900" fill="#111111" text-anchor="middle" opacity="0.25" letter-spacing="4px">{{ block.settings.title | uppercase }}</text>
                  </svg>
                </div>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const matSection = document.querySelector('.mat-section');
    if (!matSection) return;

    const menuItems = matSection.querySelectorAll('.mat-menu-item');
    const imageLayers = matSection.querySelectorAll('.mat-image-layer, .mat-image-fallback');

    menuItems.forEach(item => {
      // Click handler
      item.addEventListener('click', function(e) {
        e.preventDefault();
        switchActiveMaterial(this);
      });

      // Hover handler (mouse enter)
      item.addEventListener('mouseenter', function() {
        switchActiveMaterial(this);
      });
    });

    function switchActiveMaterial(activeItem) {
      const index = activeItem.getAttribute('data-index');
      
      menuItems.forEach(i => i.classList.remove('active'));
      activeItem.classList.add('active');

      imageLayers.forEach(layer => {
        if (layer.getAttribute('data-index') === index) {
          layer.classList.add('active');
        } else {
          layer.classList.remove('active');
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Materials Showcase",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F7F7F7"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "MATERIALS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "FOR EVERY MATERIAL."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "default": "Leather, suede, nubuck, fabric, soles. Every material deserves specific care. Find yours."
    },
    {
      "type": "color",
      "id": "active_color",
      "label": "Active Color",
      "default": "#D60000"
    },
    {
      "type": "color",
      "id": "inactive_color",
      "label": "Inactive Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "menu_font_size",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Menu Font Size (Desktop)",
      "default": 48
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Image Border Radius",
      "default": 24
    },
    {
      "type": "range",
      "id": "animation_speed",
      "min": 200,
      "max": 1000,
      "step": 50,
      "unit": "ms",
      "label": "Animation Speed",
      "default": 400
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 110
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 110
    }
  ],
  "blocks": [
    {
      "type": "material_item",
      "name": "Material Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Material Name",
          "default": "Suede"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Material Image"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Material Collection URL"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Material Description (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Materials Showcase",
      "blocks": [
        {
          "type": "material_item",
          "settings": {
            "title": "Suede"
          }
        },
        {
          "type": "material_item",
          "settings": {
            "title": "Leather"
          }
        },
        {
          "type": "material_item",
          "settings": {
            "title": "Nubuck"
          }
        },
        {
          "type": "material_item",
          "settings": {
            "title": "Fabrics"
          }
        },
        {
          "type": "material_item",
          "settings": {
            "title": "Soles"
          }
        }
      ]
    }
  ]
}
{% endschema %}

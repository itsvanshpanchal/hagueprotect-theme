{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .biz-process {
    padding: clamp(80px, 10vw, 120px) 0;
    background: #ffffff;
    font-family: var(--font-family-sans);
  }

  .biz-process__container {
    max-width: var(--site-max-width);
    margin: 0 auto;
    padding: 0 max(20px, var(--site-padding, 24px));
  }

  .biz-process__header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto clamp(56px, 7vw, 80px);
  }

  .biz-process__eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #4f8cff;
    margin: 0 0 12px;
  }

  .biz-process__heading {
    font-family: var(--font-family-heading);
    font-size: clamp(42px, 5.5vw, 68px);
    font-weight: 400;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #0a0c12 !important;
    margin: 0 0 16px;
    line-height: 1;
  }

  .biz-process__sub {
    font-size: 16px;
    line-height: 1.65;
    color: #5a6270;
    margin: 0;
  }

  .biz-process__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    position: relative;
  }

  .biz-process__grid::before {
    content: '';
    position: absolute;
    top: 36px;
    left: 12.5%;
    right: 12.5%;
    height: 2px;
    background: linear-gradient(90deg, #4f8cff 0%, #ff2b2b 50%, #4f8cff 100%);
    z-index: 0;
  }

  .biz-process__step {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 20px;
    opacity: 1 !important;
    visibility: visible !important;
    transform: none !important;
  }

  .biz-process__step-num {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: #ffffff;
    border: 2px solid #e8ecf4;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
    font-family: var(--font-family-heading);
    font-size: 28px;
    color: #0a0c12;
    transition: border-color 0.3s ease, background 0.3s ease, color 0.3s ease;
  }

  .biz-process__step:hover .biz-process__step-num {
    background: #0a0c12;
    border-color: #0a0c12;
    color: #ffffff;
  }

  .biz-process__step-title {
    font-size: 17px;
    font-weight: 700;
    color: #0a0c12 !important;
    margin: 0 0 10px;
  }

  .biz-process__step-text {
    font-size: 14px;
    line-height: 1.65;
    color: #5a6270 !important;
    margin: 0;
  }

  @media screen and (max-width: 900px) {
    .biz-process__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .biz-process__grid::before {
      display: none;
    }
  }
{%- endstyle -%}

<section class="biz-process" data-no-typewriter>
  <div class="biz-process__container">
    <header class="biz-process__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="biz-process__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="biz-process__heading">{{ section.settings.heading | default: 'How It Works' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="biz-process__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>

    <div class="biz-process__grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' -%}
            <article class="biz-process__step" data-biz-reveal {{ block.shopify_attributes }}>
              <div class="biz-process__step-num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
              <h3 class="biz-process__step-title">{{ block.settings.title }}</h3>
              <p class="biz-process__step-text">{{ block.settings.text }}</p>
            </article>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <article class="biz-process__step" data-biz-reveal>
          <div class="biz-process__step-num">01</div>
          <h3 class="biz-process__step-title">Apply</h3>
          <p class="biz-process__step-text">Share your business details, locations, and volume requirements through our partner form.</p>
        </article>
        <article class="biz-process__step" data-biz-reveal>
          <div class="biz-process__step-num">02</div>
          <h3 class="biz-process__step-title">Onboard</h3>
          <p class="biz-process__step-text">Get matched with a dedicated account manager and receive your custom pricing proposal.</p>
        </article>
        <article class="biz-process__step" data-biz-reveal>
          <div class="biz-process__step-num">03</div>
          <h3 class="biz-process__step-title">Launch</h3>
          <p class="biz-process__step-text">Receive your first shipment with POS materials, training, and marketing support.</p>
        </article>
        <article class="biz-process__step" data-biz-reveal>
          <div class="biz-process__step-num">04</div>
          <h3 class="biz-process__step-title">Scale</h3>
          <p class="biz-process__step-text">Grow with reorder incentives, seasonal campaigns, and expanded product access.</p>
        </article>
      {%- endif -%}
    </div>
  </div>
</section>


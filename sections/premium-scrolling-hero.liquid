{%- style -%}
  .premium-hero-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background: linear-gradient(to bottom, #FF1F3D 55%, #111111 55%);
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 80px 0;
    color: #ffffff;
  }

  .premium-hero-container {
    display: flex;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    padding: 0 40px;
    align-items: center;
    gap: 40px;
  }

  .premium-hero-left {
    flex: 0 0 65%;
    z-index: 5;
  }

  .premium-hero-left h1 {
    font-family: 'Inter', sans-serif;
    font-size: clamp(48px, 8vw, 96px);
    font-weight: 900;
    color: #FFFFFF;
    line-height: 0.95;
    text-transform: uppercase;
    margin-bottom: 40px;
    letter-spacing: -0.04em;
    filter: drop-shadow(0 10px 20px rgba(0,0,0,0.2));
  }

  .premium-custom-btn {
    display: inline-block;
    background-color: #111111;
    color: #FFFFFF;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 800;
    text-transform: uppercase;
    padding: 18px 56px;
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    border: 1px solid rgba(255, 255, 255, 0.1);
    letter-spacing: 0.1em;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  .premium-custom-btn:hover {
    background-color: #ffffff;
    color: #111111;
    transform: translateY(-5px) scale(1.05);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }

  .premium-hero-right {
    flex: 0 0 35%;
    height: 85vh;
    position: relative;
    display: flex;
    justify-content: center;
    perspective: 1000px;
  }

  .premium-rail-wrapper {
    position: relative;
    width: 320px;
    height: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent);
    -webkit-mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent);
  }

  .premium-rail-track {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 100px 0;
    will-change: transform;
  }

  .premium-product-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    padding: 16px;
    width: 100%;
    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    cursor: pointer;
    position: relative;
    box-shadow: 0 15px 35px rgba(0,0,0,0.2);
  }

  .premium-product-card:hover {
    transform: translateZ(30px) translateY(-10px) rotateX(5deg);
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
    box-shadow: 0 30px 60px rgba(0,0,0,0.4), 0 0 20px rgba(255,255,255,0.05);
  }

  .card-image-wrapper {
    width: 100%;
    height: 220px;
    border-radius: 18px;
    overflow: hidden;
    margin-bottom: 16px;
    background: #000;
  }

  .card-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .premium-product-card:hover .card-image-wrapper img {
    transform: scale(1.15);
  }

  .card-info {
    text-align: left;
  }

  .card-title {
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 4px 0;
    color: #ffffff;
  }

  .card-desc {
    font-size: 13px;
    color: rgba(255,255,255,0.6);
    margin: 0 0 12px 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.4;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .card-price {
    font-size: 18px;
    font-weight: 800;
    color: #FF1F3D;
  }

  .card-rating {
    display: flex;
    gap: 2px;
    color: #FFD700;
    font-size: 12px;
  }

  .card-atc {
    width: 100%;
    background: #ffffff;
    color: #000;
    border: none;
    padding: 12px;
    border-radius: 12px;
    font-weight: 800;
    text-transform: uppercase;
    font-size: 12px;
    letter-spacing: 0.05em;
    transition: all 0.3s;
    cursor: pointer;
  }

  .card-atc:hover {
    background: #FF1F3D;
    color: #ffffff;
  }

  @media screen and (max-width: 1024px) {
    .premium-hero-container {
      flex-direction: column;
      padding: 0 20px;
      text-align: center;
    }
    .premium-hero-left {
      flex: 0 0 100%;
    }
    .premium-hero-right {
      width: 100%;
      height: 400px;
      flex: 0 0 100%;
    }
    .premium-rail-wrapper {
      width: 100%;
      mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
      -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    }
    .premium-rail-track {
      flex-direction: row;
      padding: 20px 0;
      height: 100%;
    }
    .premium-product-card {
      width: 260px;
      flex-shrink: 0;
    }
  }

  @media screen and (max-width: 768px) {
    .premium-hero-{{ section.id }} {
      background: linear-gradient(to bottom, #FF1F3D 100%, #111111 0%);
    }
  }
{%- endstyle -%}

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

<section class="premium-hero-{{ section.id }}">
  <div class="premium-hero-container">
    <div class="premium-hero-left">
      <h1>{{ section.settings.heading }}</h1>
      <a href="{{ section.settings.button_link }}" class="premium-custom-btn">
        {{ section.settings.button_label }}
      </a>
    </div>

    <div class="premium-hero-right">
      <div class="premium-rail-wrapper">
        <div class="premium-rail-track" id="railTrack-{{ section.id }}">
          {%- liquid
            assign rail_items_count = 0
            if section.blocks.size > 0
              assign rail_items = section.blocks
              assign rail_items_count = section.blocks.size
            else
              assign rail_items = collections[section.settings.collection].products | limit: 10
              assign rail_items_count = rail_items.size
            endif
          -%}

          {%- if rail_items_count > 0 -%}
            {%- for i in (1..3) -%}
              {%- for item in rail_items -%}
                {%- liquid
                  if section.blocks.size > 0
                    assign product_obj = item.settings.product
                    assign item_title = item.settings.title | default: product_obj.title
                    assign item_price = product_obj.price | money_without_trailing_zeros
                    assign item_desc = item.settings.description | default: product_obj.description
                    assign item_image = item.settings.image | default: product_obj.featured_image
                    assign item_url = product_obj.url
                  else
                    assign product_obj = item
                    assign item_title = product_obj.title
                    assign item_price = product_obj.price | money_without_trailing_zeros
                    assign item_desc = product_obj.description
                    assign item_image = product_obj.featured_image
                    assign item_url = product_obj.url
                  endif
                -%}
                <div class="premium-product-card" onclick="window.location.href='{{ item_url }}'">
                  <div class="card-image-wrapper">
                    {%- if item_image -%}
                      <img src="{{ item_image | img_url: '600x800', crop: 'center' }}" alt="{{ item_title }}" loading="lazy">
                    {%- else -%}
                      {{ 'product-' | append: forloop.index | placeholder_svg_tag }}
                    {%- endif -%}
                  </div>
                  <div class="card-info">
                    <h3 class="card-title">{{ item_title }}</h3>
                    <p class="card-desc">{{ item_desc | strip_html | truncate: 80 }}</p>
                    <div class="card-meta">
                      <span class="card-price">{{ item_price }}</span>
                      <div class="card-rating">★★★★★</div>
                    </div>
                    <button class="card-atc">Add to Cart</button>
                  </div>
                </div>
              {%- endfor -%}
            {%- endfor -%}
          {%- else -%}
             {%- for i in (1..6) -%}
                <div class="premium-product-card">
                  <div class="card-image-wrapper">
                    {{ 'product-' | append: i | placeholder_svg_tag }}
                  </div>
                  <div class="card-info">
                    <h3 class="card-title">Premium Product {{ i }}</h3>
                    <p class="card-desc">Experience the ultimate in luxury care for your high-end footwear collection.</p>
                    <div class="card-meta">
                      <span class="card-price">$49.00</span>
                      <div class="card-rating">★★★★★</div>
                    </div>
                    <button class="card-atc">Add to Cart</button>
                  </div>
                </div>
             {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.getElementById('railTrack-{{ section.id }}');
    if (!track) return;

    const isMobile = window.innerWidth <= 1024;
    
    if (isMobile) {
      gsap.to(track, {
        xPercent: -50,
        ease: "none",
        duration: 20,
        repeat: -1
      });
    } else {
      const totalHeight = track.scrollHeight / 3;
      gsap.to(track, {
        y: -totalHeight,
        ease: "none",
        duration: 40,
        repeat: -1
      });
    }

    track.addEventListener('mouseenter', () => gsap.getTweensOf(track).forEach(t => t.pause()));
    track.addEventListener('mouseleave', () => gsap.getTweensOf(track).forEach(t => t.resume()));
  });
</script>

{% schema %}
{
  "name": "Premium Scrolling Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop Our Premium Best"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Fallback Collection"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "CUSTOM"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image (Optional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title (Optional)"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Custom Description (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Scrolling Hero",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}

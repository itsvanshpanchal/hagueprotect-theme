{%- style -%}
  .hero-fullscreen {
    height: 100vh;
    min-height: 600px;
    width: 100%;
    max-width: 100vw;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    padding-bottom: 80px;
    color: #ffffff;
    overflow-x: hidden;
    overflow-y: hidden;
    text-align: center;
    box-sizing: border-box;
  }

  .hero-fullscreen__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    overflow: hidden;
    background: linear-gradient(135deg, #111 0%, #333 100%);
  }

  .hero-fullscreen__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  .hero-fullscreen__bg picture {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Overlay to make content/text highly visible and legible */
  .hero-fullscreen__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(0deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.15) 50%, rgba(0,0,0,0.3) 100%);
    z-index: 2;
  }

  .hero-fullscreen__content {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: 800px;
    padding-left: var(--site-padding);
    padding-right: var(--site-padding);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    box-sizing: border-box;
  }

  .hero-fullscreen__eyebrow {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary);
  }

  .hero-fullscreen__heading {
    font-family: var(--font-family-sans) !important;
    font-size: clamp(2.2rem, 5vw, 4.5rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.04em;
    color: #ffffff;
    margin: 0;
    width: 100%;
    max-width: 100%;
    overflow-wrap: break-word;
    word-wrap: break-word;
    hyphens: manual;
  }

  .hero-fullscreen__heading .hero-static-part,
  .hero-fullscreen__heading .hero-typing-part {
    display: inline;
  }

  .hero-fullscreen__heading .hero-typing-cursor {
    display: inline-block;
    width: 3px;
    height: 0.85em;
    background-color: var(--color-primary, #ff2b2b);
    margin-left: 4px;
    vertical-align: middle;
    animation: hero-cursor-blink 1.2s infinite;
    transition: opacity 0.25s ease;
  }

  @keyframes hero-cursor-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-fullscreen__subheading {
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    color: rgba(255, 255, 255, 0.85);
    max-width: 600px;
    line-height: 1.5;
    margin-bottom: 12px;
  }

  .hero-fullscreen__actions {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .hero-fullscreen__btn {
    box-shadow: 0 16px 36px rgba(255, 43, 43, 0.35);
    font-size: 16px;
    padding: 18px 48px;
    background-color: var(--color-primary);
    color: #ffffff;
  }

  .hero-fullscreen__btn:hover {
    background-color: #e21c1c;
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgba(255, 43, 43, 0.5);
  }

  /* Desktop / laptop: left-aligned hero copy + typing animation */
  @media screen and (min-width: 769px) {
    .hero-fullscreen {
      align-items: flex-start;
      text-align: left;
      padding-left: var(--site-padding);
      padding-right: var(--site-padding);
    }

    .hero-fullscreen__overlay {
      background: linear-gradient(
        90deg,
        rgba(0, 0, 0, 0.72) 0%,
        rgba(0, 0, 0, 0.35) 45%,
        rgba(0, 0, 0, 0.15) 100%
      ),
      linear-gradient(
        0deg,
        rgba(0, 0, 0, 0.65) 0%,
        rgba(0, 0, 0, 0.1) 50%,
        rgba(0, 0, 0, 0.25) 100%
      );
    }

    .hero-fullscreen__content {
      align-items: flex-start;
      text-align: left;
      margin-left: 0;
      margin-right: auto;
      max-width: min(800px, 55vw);
    }

    .hero-fullscreen__heading {
      text-align: left;
    }

    .hero-fullscreen__subheading {
      text-align: left;
      margin-left: 0;
      margin-right: auto;
    }

    .hero-fullscreen__actions {
      justify-content: flex-start;
    }
  }

  @media screen and (max-width: 768px) {
    .hero-fullscreen {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: center;
      width: 100%;
      max-width: 100vw;
      height: auto;
      min-height: min(82svh, 620px);
      max-height: 92svh;
      padding: 0 0 clamp(24px, 5vw, 36px);
      overflow: hidden;
      text-align: center;
      background: #111;
    }

    .hero-fullscreen--mobile-art {
      min-height: 0;
      max-height: none;
      aspect-ratio: var(--hero-mobile-aspect, 4 / 5);
    }

    .hero-fullscreen__bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      line-height: 0;
    }

    .hero-fullscreen__bg picture {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
    }

    .hero-fullscreen__bg-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center center;
      display: block;
    }

    .hero-fullscreen__overlay {
      display: block;
      background: linear-gradient(
        0deg,
        rgba(0, 0, 0, 0.9) 0%,
        rgba(0, 0, 0, 0.55) 38%,
        rgba(0, 0, 0, 0.15) 68%,
        transparent 100%
      );
    }

    .hero-fullscreen__content {
      position: relative;
      z-index: 3;
      flex: 0 0 auto;
      width: 100%;
      align-items: center;
      text-align: center;
      gap: 12px;
      padding: 0 max(16px, var(--site-padding));
      margin: 0 auto;
      background: transparent;
      box-sizing: border-box;
    }

    .hero-fullscreen__heading {
      text-align: center;
      font-size: clamp(1.35rem, 5.5vw, 1.85rem);
      line-height: 1.25;
      letter-spacing: -0.02em;
      padding: 0 4px;
      text-shadow: 0 2px 16px rgba(0, 0, 0, 0.45);
    }

    .hero-fullscreen__subheading {
      text-align: center;
      font-size: clamp(0.9rem, 3.4vw, 1.05rem);
      line-height: 1.45;
      margin-bottom: 4px;
      max-width: 100%;
      padding: 0 6px;
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.4);
    }

    .hero-fullscreen__actions {
      justify-content: center;
      margin-top: 4px;
    }

    .hero-fullscreen__btn {
      padding: 16px 32px;
      font-size: 15px;
      width: 100%;
      max-width: 280px;
    }
  }

  @media screen and (max-width: 380px) {
    .hero-fullscreen__heading {
      font-size: 1.22rem;
    }

    .hero-fullscreen__bg-img {
      object-position: center 40%;
    }
  }
{%- endstyle -%}

{%- liquid
  assign desktop_banner = section.settings.image
  assign has_dedicated_mobile = false
  if section.settings.image_mobile != blank
    assign mobile_banner = section.settings.image_mobile
    assign has_dedicated_mobile = true
  else
    assign mobile_banner = section.settings.image
  endif
  if desktop_banner == blank and mobile_banner != blank
    assign desktop_banner = mobile_banner
  endif
  assign hero_img_class = 'hero-fullscreen__bg-img'
-%}

<section
  class="hero-fullscreen{% if has_dedicated_mobile %} hero-fullscreen--mobile-art{% endif %} animate-fade-in"
  aria-label="HAGUEPROTECT Fullscreen Hero Section"
  {% if has_dedicated_mobile and mobile_banner.width and mobile_banner.height %}
    style="--hero-mobile-aspect: {{ mobile_banner.width }} / {{ mobile_banner.height }};"
  {% endif %}
>
  <div class="hero-fullscreen__bg">
    {%- if desktop_banner != blank -%}
      <picture>
        {%- if mobile_banner != blank -%}
          <source
            media="(max-width: 768px)"
            srcset="
              {{ mobile_banner | image_url: width: 400 }} 400w,
              {{ mobile_banner | image_url: width: 600 }} 600w,
              {{ mobile_banner | image_url: width: 800 }} 800w,
              {{ mobile_banner | image_url: width: 1000 }} 1000w
            "
            sizes="100vw"
          >
        {%- endif -%}
        {%- if has_dedicated_mobile -%}
          {{
            desktop_banner
            | image_url: width: 2800
            | image_tag:
              class: hero_img_class,
              loading: 'eager',
              fetchpriority: 'high',
              widths: '750, 1100, 1500, 2000, 2800',
              sizes: '(min-width: 769px) 100vw, 100vw',
              alt: ''
          }}
        {%- else -%}
          {{
            desktop_banner
            | image_url: width: 2800
            | image_tag:
              class: hero_img_class,
              loading: 'eager',
              fetchpriority: 'high',
              widths: '750, 1100, 1500, 2000, 2800',
              sizes: '(min-width: 769px) 100vw, 0px',
              alt: ''
          }}
        {%- endif -%}
      </picture>
    {%- endif -%}
  </div>
  <div class="hero-fullscreen__overlay"></div>

  <div class="hero-fullscreen__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="hero-fullscreen__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h1 class="hero-fullscreen__heading">{{ section.settings.heading | default: 'Bring Your Sneakers Back to Life' }}</h1>
    <p class="hero-fullscreen__subheading">{{ section.settings.subheading | default: 'Professional-grade cleaning for everyday wear. Advanced protection formulas designed for premium materials.' }}</p>
    <div class="hero-fullscreen__actions">
      <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="btn btn-primary hero-fullscreen__btn">
        {{ section.settings.cta_text | default: 'Shop Now' }}
      </a>
    </div>
  </div>
</section>

<script>
  (function() {
    function initHeroTyping() {
      const heading = document.querySelector('.hero-fullscreen__heading');
      if (!heading) return;

      const originalText = heading.textContent.trim();
      const regex = /(MAKE\s*['’]?\s*EM\s*HEAT\.?)/i;
      const match = originalText.match(regex);

      if (!match) return;

      const isMobile = window.matchMedia('(max-width: 768px)').matches;
      if (isMobile) {
        heading.textContent = originalText;
        return;
      }

      const matchedText = match[0];
      const index = originalText.indexOf(matchedText);

      const staticPart = originalText.substring(0, index);
      const typingPart = originalText.substring(index);

      const cleanStaticPart = staticPart.replace(/\s{2,}/g, ' ').trim() + ' ';

      heading.innerHTML =
        '<span class="hero-static-part">' +
        cleanStaticPart +
        '</span><span class="hero-typing-part"></span><span class="hero-typing-cursor"></span>';

      const typingSpan = heading.querySelector('.hero-typing-part');
      const cursorSpan = heading.querySelector('.hero-typing-cursor');

      let autoTypingActive = true;
      let currentLength = 0;

      function typeWord() {
        if (!autoTypingActive) return;
        if (currentLength <= typingPart.length) {
          typingSpan.textContent = typingPart.substring(0, currentLength);
          currentLength++;
          setTimeout(typeWord, 100);
        } else {
          autoTypingActive = false;
        }
      }

      typeWord();

      const scrollMax = 350;

      function handleScroll() {
        autoTypingActive = false;

        const scrollTop = window.scrollY;
        const fraction = 1 - Math.min(scrollTop / scrollMax, 1);
        const charsToShow = Math.round(fraction * typingPart.length);

        typingSpan.textContent = typingPart.substring(0, charsToShow);

        if (charsToShow === 0) {
          cursorSpan.style.opacity = '0';
        } else {
          cursorSpan.style.opacity = '1';
        }
      }

      window.addEventListener('scroll', handleScroll, { passive: true });

      if (window.scrollY > 0) {
        handleScroll();
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeroTyping);
    } else {
      initHeroTyping();
    }

    // Support Shopify Theme Editor dynamic reloading
    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        initHeroTyping();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Premium Care"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bring Your Sneakers Back to Life"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Professional-grade cleaning for everyday wear. Advanced protection formulas designed for premium materials."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    },
    {
      "type": "header",
      "content": "Banner images"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop banner image",
      "info": "Displayed on tablets, laptops, and desktops. Wide landscape images work best."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile banner image",
      "info": "Displayed on phones and screens 768px wide or smaller. Square or portrait images work best. If empty, the desktop banner is used."
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}

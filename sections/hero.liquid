{%- style -%}
  .hero-fullscreen {
    height: 100vh;
    min-height: 600px;
    width: 100%;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    padding-bottom: 80px;
    color: #ffffff;
    overflow: hidden;
    text-align: center;
  }

  /* Support the user's specific image as the background */
  .hero-fullscreen__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    {%- if section.settings.image != blank -%}
      background-image: url('{{ section.settings.image | image_url: width: 2800 }}');
    {%- else -%}
      /* Temporarily link the requested local image directly */
      background-image: url('file:///C:/Users/vansh/Downloads/ChatGPT%20Image%20Apr%2030,%202026,%2010_44_56%20PM.png'), url('C:/Users/vansh/Downloads/ChatGPT Image Apr 30, 2026, 10_44_56 PM.png'), linear-gradient(135deg, #111 0%, #333 100%);
    {%- endif -%}
    transition: var(--transition-smooth);
  }

  /* Overlay to make content/text highly visible and legible */
  .hero-fullscreen__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(0deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.15) 50%, rgba(0,0,0,0.3) 100%);
    z-index: 2;
  }

  .hero-fullscreen__content {
    position: relative;
    z-index: 3;
    max-width: 800px;
    padding-left: var(--site-padding);
    padding-right: var(--site-padding);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .hero-fullscreen__eyebrow {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary);
  }

  .hero-fullscreen__heading {
    font-size: clamp(2.2rem, 5vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.04em;
    color: #ffffff;
    margin: 0;
  }

  .hero-fullscreen__heading .hero-typing-cursor {
    display: inline-block;
    width: 3px;
    height: 0.85em;
    background-color: var(--color-primary, #ff2b2b);
    margin-left: 4px;
    vertical-align: middle;
    animation: hero-cursor-blink 1.2s infinite;
    transition: opacity 0.25s ease;
  }

  @keyframes hero-cursor-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-fullscreen__subheading {
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    color: rgba(255, 255, 255, 0.85);
    max-width: 600px;
    line-height: 1.5;
    margin-bottom: 12px;
  }

  .hero-fullscreen__actions {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .hero-fullscreen__btn {
    box-shadow: 0 16px 36px rgba(255, 43, 43, 0.35);
    font-size: 16px;
    padding: 18px 48px;
    background-color: var(--color-primary);
    color: #ffffff;
  }

  .hero-fullscreen__btn:hover {
    background-color: #e21c1c;
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgba(255, 43, 43, 0.5);
  }

  @media screen and (max-width: 768px) {
    .hero-fullscreen {
      height: auto;
      min-height: calc(100svh - 80px);
      padding-top: clamp(100px, 15vh, 140px);
      padding-bottom: clamp(60px, 10vh, 100px);
      justify-content: center;
    }
    .hero-fullscreen__content {
      gap: 16px;
      padding-left: 20px;
      padding-right: 20px;
    }
    .hero-fullscreen__heading {
      font-size: clamp(1.8rem, 8vw, 2.8rem);
      line-height: 1.15;
    }
    .hero-fullscreen__subheading {
      font-size: clamp(0.95rem, 3.5vw, 1.1rem);
      line-height: 1.4;
      margin-bottom: 8px;
    }
    .hero-fullscreen__btn {
      padding: 16px 36px;
      font-size: 15px;
      width: 100%;
      max-width: 320px;
    }
  }
{%- endstyle -%}

<section class="hero-fullscreen animate-fade-in" aria-label="HAGUEPROTECT Fullscreen Hero Section">
  <div class="hero-fullscreen__bg"></div>
  <div class="hero-fullscreen__overlay"></div>

  <div class="hero-fullscreen__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="hero-fullscreen__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h1 class="hero-fullscreen__heading">{{ section.settings.heading | default: 'Bring Your Sneakers Back to Life' }}</h1>
    <p class="hero-fullscreen__subheading">{{ section.settings.subheading | default: 'Professional-grade cleaning for everyday wear. Advanced protection formulas designed for premium materials.' }}</p>
    <div class="hero-fullscreen__actions">
      <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="btn btn-primary hero-fullscreen__btn">
        {{ section.settings.cta_text | default: 'Shop Now' }}
      </a>
    </div>
  </div>
</section>

<script>
  (function() {
    function initHeroTyping() {
      const heading = document.querySelector('.hero-fullscreen__heading');
      if (!heading) return;

      const originalText = heading.textContent.trim();
      const regex = /(MAKE\s*['’]?\s*EM\s*HEAT\.?)/i;
      const match = originalText.match(regex);
      
      if (!match) return;

      const matchedText = match[0];
      const index = originalText.indexOf(matchedText);

      const staticPart = originalText.substring(0, index);
      const typingPart = originalText.substring(index);
      
      // Clean up multiple spaces and add a single space after "WE"
      const cleanStaticPart = staticPart.replace(/\s{2,}/g, '<br>').trim() + ' ';

      heading.innerHTML = `
        <span class="hero-static-part">${cleanStaticPart}</span><span class="hero-typing-part"></span><span class="hero-typing-cursor"></span>
      `;

      const typingSpan = heading.querySelector('.hero-typing-part');
      const cursorSpan = heading.querySelector('.hero-typing-cursor');

      let autoTypingActive = true;
      let currentLength = 0;

      function typeWord() {
        if (!autoTypingActive) return;
        if (currentLength <= typingPart.length) {
          typingSpan.textContent = typingPart.substring(0, currentLength);
          currentLength++;
          setTimeout(typeWord, 100);
        } else {
          autoTypingActive = false;
        }
      }

      // Start the auto-typing effect on initial load
      typeWord();

      const scrollMax = 350;

      function handleScroll() {
        // If the user scrolls, stop auto-typing and let scroll drive typing progress
        autoTypingActive = false;

        const scrollTop = window.scrollY;
        // Text is fully typed (1.0) at scrollTop = 0, and untyped (0.0) at scrollTop = scrollMax
        const fraction = 1 - Math.min(scrollTop / scrollMax, 1);
        const charsToShow = Math.round(fraction * typingPart.length);

        typingSpan.textContent = typingPart.substring(0, charsToShow);

        if (charsToShow === 0) {
          cursorSpan.style.opacity = '0';
        } else {
          cursorSpan.style.opacity = '1';
        }
      }

      window.addEventListener('scroll', handleScroll, { passive: true });

      // If page is loaded scrolled, immediately apply the scroll position
      if (window.scrollY > 0) {
        handleScroll();
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeroTyping);
    } else {
      initHeroTyping();
    }

    // Support Shopify Theme Editor dynamic reloading
    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        initHeroTyping();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Premium Care"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bring Your Sneakers Back to Life"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Professional-grade cleaning for everyday wear. Advanced protection formulas designed for premium materials."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fullscreen Hero Image"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}

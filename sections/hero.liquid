{%- liquid
  assign hero_title_desktop = section.settings.h1_font_size_desktop | default: settings.font_hero_h1_size_desktop | default: settings.font_h1_size_desktop | default: 72
  assign hero_title_mobile = section.settings.h1_font_size_mobile | default: settings.font_hero_h1_size_mobile | default: settings.font_h1_size_mobile | default: 44
-%}
{%- style -%}
  {% render 'section-typography-vars', section: section %}

  /* Biggest title sizes — literal px from Typography (high specificity beats global CSS) */
  #MainContent #shopify-section-{{ section.id }} h1.hero-fullscreen__heading,
  #MainContent #shopify-section-{{ section.id }} .hero-fullscreen__heading,
  #MainContent #shopify-section-{{ section.id }} .hero-fullscreen__heading .hp-typewriter-text,
  #MainContent #shopify-section-{{ section.id }} .hero-fullscreen__heading > span[aria-hidden="true"],
  #MainContent #shopify-section-{{ section.id }} .hero-fullscreen__heading .hero-heading-line,
  #shopify-section-{{ section.id }} h1.hero-fullscreen__heading,
  #shopify-section-{{ section.id }} .hero-fullscreen__heading,
  #shopify-section-{{ section.id }} .hero-fullscreen__heading .hp-typewriter-text,
  #shopify-section-{{ section.id }} .hero-fullscreen__heading > span[aria-hidden="true"],
  #shopify-section-{{ section.id }} .hero-fullscreen__heading .hero-heading-line {
    font-size: {{ hero_title_desktop }}px !important;
  }

  @media screen and (max-width: 989px) {
    #MainContent #shopify-section-{{ section.id }} h1.hero-fullscreen__heading,
    #MainContent #shopify-section-{{ section.id }} .hero-fullscreen__heading,
    #MainContent #shopify-section-{{ section.id }} .hero-fullscreen__heading .hp-typewriter-text,
    #MainContent #shopify-section-{{ section.id }} .hero-fullscreen__heading > span[aria-hidden="true"],
    #MainContent #shopify-section-{{ section.id }} .hero-fullscreen__heading .hero-heading-line,
    #shopify-section-{{ section.id }} h1.hero-fullscreen__heading,
    #shopify-section-{{ section.id }} .hero-fullscreen__heading,
    #shopify-section-{{ section.id }} .hero-fullscreen__heading .hp-typewriter-text,
    #shopify-section-{{ section.id }} .hero-fullscreen__heading > span[aria-hidden="true"],
    #shopify-section-{{ section.id }} .hero-fullscreen__heading .hero-heading-line {
      font-size: {{ hero_title_mobile }}px !important;
    }
  }

  .hero-fullscreen {
    height: 100vh;
    min-height: 600px;
    width: 100%;
    max-width: 100vw;
    position: relative;
    display: block;
    color: #ffffff;
    overflow-x: hidden;
    overflow-y: hidden;
    box-sizing: border-box;
  }

  .hero-fullscreen__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    overflow: hidden;
    background: #f5f5f5;
  }

  .hero-fullscreen__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
    filter: brightness(1.18) contrast(1.04) saturate(1.08);
  }

  .hero-fullscreen__bg picture {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Overlay disabled Ã¢â‚¬â€ show hero image without dark shadow */
  .hero-fullscreen__overlay {
    display: none;
  }

  .hero-fullscreen__content {
    position: absolute;
    z-index: 3;
    left: var(--hero-content-x, 5%);
    top: var(--hero-content-y, 18%);
    transform: translate(var(--hero-content-tx, 0), 0);
    width: max-content;
    max-width: min(800px, 55vw);
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: var(--hero-content-items, flex-start);
    gap: 0;
    box-sizing: border-box;
    text-align: var(--hero-content-align, left);
  }

  .hero-fullscreen__eyebrow {
    display: block;
    margin: 0 0 var(--section-label-to-title-gap, 12px) 0;
  }

  .hero-fullscreen__heading {
    font-family: var(--font-family-heading, 'Bebas Neue', 'Impact', sans-serif) !important;
    font-size: var(--heading-size-hero) !important;
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin: 0;
    width: 100%;
    max-width: 100%;
    overflow-wrap: break-word;
    word-wrap: break-word;
    hyphens: manual;
    text-transform: none !important;
    text-align: var(--hero-content-align, left) !important;
    align-self: stretch;
  }

  .hero-fullscreen__heading .hero-heading-line {
    display: block;
    text-transform: lowercase !important;
    color: inherit;
  }

  .hero-fullscreen__heading .hero-heading-line--1::first-letter {
    text-transform: uppercase !important;
  }

  .hero-fullscreen__heading .hero-heading-line--3 {
    color: {{ section.settings.heading_line3_color | default: '#c8c8c8' }} !important;
    font-style: italic !important;
    /* Pull the leading apostrophe's glyph side-bearing back so its visual
       left edge lines up flush with the lines above it. */
    text-indent: {{ section.settings.heading_line3_indent | default: '-0.11em' }};
  }

  .hero-fullscreen__heading .hp-typewriter-cursor {
    background-color: var(--color-primary, #ff2b2b);
  }

  .hero-fullscreen__subheading {
    max-width: none;
    width: 100%;
    font-family: var(--font-family-sans);
    font-size: var(--section-subheading-size, 16px);
    margin: var(--section-subheading-spacing-top, 12px) 0 0 0;
    padding: 0;
    text-align: var(--hero-content-align, left) !important;
    align-self: stretch;
  }

  .hero-fullscreen__actions {
    display: flex;
    justify-content: var(--hero-content-actions, flex-start);
    width: 100%;
    margin-top: 20px;
  }

  .hero-fullscreen__btn {
    box-shadow: 0 16px 36px rgba(255, 43, 43, 0.35);
    font-size: 16px;
    padding: 18px 48px;
    background-color: var(--color-primary);
    color: #ffffff;
  }

  .hero-fullscreen__btn:hover {
    background-color: #e21c1c;
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgba(255, 43, 43, 0.5);
  }

  /* Desktop / laptop: typing animation */
  @media screen and (min-width: 769px) {
    .hero-fullscreen__heading {
      text-align: var(--hero-content-align, left);
      max-width: min(800px, 55vw);
    }

    .hero-fullscreen__subheading {
      text-align: var(--hero-content-align, left);
      margin-left: 0;
      margin-right: auto;
    }
  }

  @media screen and (max-width: 768px) {
    .hero-fullscreen {
      position: relative;
      width: 100%;
      max-width: 100vw;
      height: auto;
      min-height: min(82svh, 620px);
      max-height: 92svh;
      overflow: hidden;
      background: transparent;
    }

    .hero-fullscreen--mobile-art {
      min-height: 0;
      max-height: none;
      aspect-ratio: var(--hero-mobile-aspect, 4 / 5);
    }

    .hero-fullscreen__content {
      left: var(--hero-content-x-mobile, 5%);
      top: var(--hero-content-y-mobile, 12%);
      transform: translate(var(--hero-content-tx-mobile, 0), 0);
      align-items: var(--hero-content-items-mobile, flex-start);
      text-align: var(--hero-content-align-mobile, left);
      max-width: calc(100% - (var(--homepage-section-gutter, 6px) * 2));
      width: 100%;
      padding: 0;
      gap: 0;
    }

    .hero-fullscreen__content .hero-fullscreen__actions {
      justify-content: var(--hero-content-actions-mobile, center);
      margin-top: 12px;
    }

    .hero-fullscreen__bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      line-height: 0;
    }

    .hero-fullscreen__bg picture {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
    }

    .hero-fullscreen__bg-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center center;
      display: block;
    }

    .hero-fullscreen__heading {
      font-family: var(--font-family-heading, 'Bebas Neue', 'Impact', 'Arial Narrow', sans-serif) !important;
      font-size: var(--heading-size-hero) !important;
      font-weight: 400;
      line-height: 1.05;
      letter-spacing: -0.02em;
      text-transform: none !important;
      padding: 0;
      text-align: var(--hero-content-align-mobile, left) !important;
      width: 100%;
    }

    .hero-fullscreen__subheading {
      max-width: 100%;
      padding: 0;
      text-align: var(--hero-content-align-mobile, left) !important;
    }

    .hero-fullscreen__btn {
      padding: 16px 32px;
      font-size: 15px;
      width: 100%;
      max-width: 280px;
    }
  }

  @media screen and (max-width: 380px) {
    .hero-fullscreen__heading {
      font-size: var(--heading-size-hero) !important;
    }

    .hero-fullscreen__bg-img {
      object-position: center 40%;
    }
  }
{%- endstyle -%}

{%- liquid
  assign desktop_banner = section.settings.image
  assign has_dedicated_mobile = false
  if section.settings.image_mobile != blank
    assign mobile_banner = section.settings.image_mobile
    assign has_dedicated_mobile = true
  else
    assign mobile_banner = section.settings.image
  endif
  if desktop_banner == blank and mobile_banner != blank
    assign desktop_banner = mobile_banner
  endif
  assign hero_img_class = 'hero-fullscreen__bg-img'

  assign content_x = section.settings.content_position_x | default: 5
  assign content_y = section.settings.content_position_y | default: 18
  assign content_align = section.settings.content_align | default: 'left'
  assign content_x_mobile = section.settings.content_position_x_mobile | default: 50
  assign content_y_mobile = section.settings.content_position_y_mobile | default: 12
  assign content_align_mobile = section.settings.content_align_mobile | default: 'left'

  case content_align
    when 'center'
      assign content_tx = '-50%'
      assign content_items = 'center'
      assign content_actions = 'center'
    when 'right'
      assign content_tx = '-100%'
      assign content_items = 'flex-end'
      assign content_actions = 'flex-end'
    else
      assign content_tx = '0'
      assign content_items = 'flex-start'
      assign content_actions = 'flex-start'
  endcase

  case content_align_mobile
    when 'center'
      assign content_tx_mobile = '-50%'
      assign content_items_mobile = 'center'
      assign content_actions_mobile = 'center'
    when 'right'
      assign content_tx_mobile = '-100%'
      assign content_items_mobile = 'flex-end'
      assign content_actions_mobile = 'flex-end'
    else
      assign content_tx_mobile = '0'
      assign content_items_mobile = 'flex-start'
      assign content_actions_mobile = 'flex-start'
  endcase

  assign hero_style = '--hero-content-x: ' | append: content_x | append: '%; --hero-content-y: ' | append: content_y | append: '%; --hero-content-tx: ' | append: content_tx | append: '; --hero-content-align: ' | append: content_align | append: '; --hero-content-items: ' | append: content_items | append: '; --hero-content-actions: ' | append: content_actions | append: '; --hero-content-x-mobile: ' | append: content_x_mobile | append: '%; --hero-content-y-mobile: ' | append: content_y_mobile | append: '%; --hero-content-tx-mobile: ' | append: content_tx_mobile | append: '; --hero-content-align-mobile: ' | append: content_align_mobile | append: '; --hero-content-items-mobile: ' | append: content_items_mobile | append: '; --hero-content-actions-mobile: ' | append: content_actions_mobile | append: ';'
  if has_dedicated_mobile and mobile_banner.width and mobile_banner.height
    assign hero_style = hero_style | append: ' --hero-mobile-aspect: ' | append: mobile_banner.width | append: ' / ' | append: mobile_banner.height | append: ';'
  endif
-%}

<section
  class="hero-fullscreen{% if has_dedicated_mobile %} hero-fullscreen--mobile-art{% endif %}"
  aria-label="HAGUEPROTECT Fullscreen Hero Section"
  style="{{ hero_style }}"
>
  <div class="hero-fullscreen__bg">
    {%- if desktop_banner != blank -%}
      <picture>
        {%- if mobile_banner != blank -%}
          <source
            media="(max-width: 768px)"
            srcset="
              {{ mobile_banner | image_url: width: 400 }} 400w,
              {{ mobile_banner | image_url: width: 600 }} 600w,
              {{ mobile_banner | image_url: width: 800 }} 800w,
              {{ mobile_banner | image_url: width: 1000 }} 1000w
            "
            sizes="100vw"
          >
        {%- endif -%}
        {%- if has_dedicated_mobile -%}
          {{
            desktop_banner
            | image_url: width: 2800
            | image_tag:
              class: hero_img_class,
              loading: 'eager',
              fetchpriority: 'high',
              widths: '750, 1100, 1500, 2000, 2800',
              sizes: '(min-width: 769px) 100vw, 100vw',
              alt: ''
          }}
        {%- else -%}
          {{
            desktop_banner
            | image_url: width: 2800
            | image_tag:
              class: hero_img_class,
              loading: 'eager',
              fetchpriority: 'high',
              widths: '750, 1100, 1500, 2000, 2800',
              sizes: '(min-width: 769px) 100vw, 0px',
              alt: ''
          }}
        {%- endif -%}
      </picture>
    {%- endif -%}
  </div>
  <div class="hero-fullscreen__overlay"></div>

  <div class="hero-fullscreen__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="hero-fullscreen__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- liquid
      assign hero_line2 = section.settings.heading_line2
      assign hero_line3 = section.settings.heading_line3
      comment
        Older saved settings still hold "WE MAKE 'EM HEAT." on one line —
        split it so 'EM HEAT always lands on its own third line.
      endcomment
      if hero_line3 == blank and hero_line2 contains "'EM "
        assign hero_parts = hero_line2 | split: "'EM "
        assign hero_line3 = "'EM " | append: hero_parts[1]
        assign hero_line2 = hero_parts[0] | strip
      endif
    -%}
    <h1 class="hero-fullscreen__heading">
      <span class="hero-heading-line hero-heading-line--1">{{ section.settings.heading | default: 'Bring Your Sneakers Back to Life' }}</span>
      {%- if hero_line2 != blank -%}
        <span class="hero-heading-line hero-heading-line--2">{{ hero_line2 }}</span>
      {%- endif -%}
      {%- if hero_line3 != blank -%}
        <span class="hero-heading-line hero-heading-line--3">{{ hero_line3 }}</span>
      {%- endif -%}
    </h1>
    <p class="hero-fullscreen__subheading">{{ section.settings.subheading | default: 'Professional-grade cleaning for everyday wear. Advanced protection formulas designed for premium materials.' }}</p>

  </div>
</section>


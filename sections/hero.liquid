{%- style -%}
  .hero-fullscreen {
    height: 100vh;
    min-height: 600px;
    width: 100%;
    max-width: 100vw;
    position: relative;
    display: block;
    color: #ffffff;
    overflow-x: hidden;
    overflow-y: hidden;
    box-sizing: border-box;
  }

  .hero-fullscreen__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    overflow: hidden;
    background: #f5f5f5;
  }

  .hero-fullscreen__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
    filter: brightness(1.18) contrast(1.04) saturate(1.08);
  }

  .hero-fullscreen__bg picture {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Overlay disabled — show hero image without dark shadow */
  .hero-fullscreen__overlay {
    display: none;
  }

  .hero-fullscreen__content {
    position: absolute;
    z-index: 3;
    left: var(--hero-content-x, 5%);
    top: var(--hero-content-y, 18%);
    width: max-content;
    max-width: min(800px, 55vw);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
    box-sizing: border-box;
  }

  .hero-fullscreen__content--align-left .hero-fullscreen__subheading {
    margin-left: 0;
    margin-right: auto;
  }

  .hero-fullscreen__content--align-center .hero-fullscreen__subheading {
    margin-left: auto;
    margin-right: auto;
  }

  .hero-fullscreen__content--align-right .hero-fullscreen__subheading {
    margin-left: auto;
    margin-right: 0;
  }

  @media screen and (min-width: 769px) {
    .hero-fullscreen__content--align-left {
      transform: translate(0, 0);
      text-align: left;
      align-items: flex-start;
    }

    .hero-fullscreen__content--align-center {
      transform: translate(-50%, 0);
      text-align: center;
      align-items: center;
    }

    .hero-fullscreen__content--align-right {
      transform: translate(-100%, 0);
      text-align: right;
      align-items: flex-end;
    }

    .hero-fullscreen__content--align-left .hero-fullscreen__actions {
      justify-content: flex-start;
    }

    .hero-fullscreen__content--align-center .hero-fullscreen__actions {
      justify-content: center;
    }

    .hero-fullscreen__content--align-right .hero-fullscreen__actions {
      justify-content: flex-end;
    }
  }

  .hero-fullscreen__eyebrow {
    display: block;
  }

  .hero-fullscreen__heading {
    font-family: var(--font-family-heading, 'Bebas Neue', 'Impact', sans-serif) !important;
    font-size: clamp(48px, 8vw, 88px);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: 0.03em;
    color: #ffffff;
    margin: 0;
    width: 100%;
    max-width: 100%;
    overflow-wrap: break-word;
    word-wrap: break-word;
    hyphens: manual;
    text-transform: uppercase;
  }

  .hero-fullscreen__heading .hp-typewriter-cursor {
    background-color: var(--color-primary, #ff2b2b);
  }

  .hero-fullscreen__subheading {
    max-width: 600px;
  }

  .hero-fullscreen__actions {
    display: flex;
    width: 100%;
  }

  .hero-fullscreen__btn {
    box-shadow: 0 16px 36px rgba(255, 43, 43, 0.35);
    font-size: 16px;
    padding: 18px 48px;
    background-color: var(--color-primary);
    color: #ffffff;
  }

  .hero-fullscreen__btn:hover {
    background-color: #e21c1c;
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgba(255, 43, 43, 0.5);
  }

  /* Desktop / laptop */
  @media screen and (min-width: 769px) {
    .hero-fullscreen__heading {
      max-width: min(800px, 55vw);
      text-align: inherit;
    }

    .hero-fullscreen__subheading {
      text-align: inherit;
    }
  }

  @media screen and (max-width: 768px) {
    .hero-fullscreen {
      position: relative;
      width: 100%;
      max-width: 100vw;
      height: auto;
      min-height: min(82svh, 620px);
      max-height: 92svh;
      overflow: hidden;
      background: transparent;
    }

    .hero-fullscreen--mobile-art {
      min-height: 0;
      max-height: none;
      aspect-ratio: var(--hero-mobile-aspect, 4 / 5);
    }

    .hero-fullscreen__content {
      left: var(--hero-content-x-mobile, 50%);
      top: var(--hero-content-y-mobile, 12%);
      max-width: calc(100% - 32px);
      width: 100%;
      padding: 0 max(16px, var(--site-padding));
      gap: 12px;
    }

    .hero-fullscreen__content--align-mobile-left {
      transform: translate(0, 0);
      text-align: left;
      align-items: flex-start;
    }

    .hero-fullscreen__content--align-mobile-center {
      transform: translate(-50%, 0);
      text-align: center;
      align-items: center;
    }

    .hero-fullscreen__content--align-mobile-right {
      transform: translate(-100%, 0);
      text-align: right;
      align-items: flex-end;
    }

    .hero-fullscreen__content--align-mobile-left .hero-fullscreen__actions {
      justify-content: flex-start;
    }

    .hero-fullscreen__content--align-mobile-center .hero-fullscreen__actions {
      justify-content: center;
    }

    .hero-fullscreen__content--align-mobile-right .hero-fullscreen__actions {
      justify-content: flex-end;
    }

    .hero-fullscreen__bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      line-height: 0;
    }

    .hero-fullscreen__bg picture {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
    }

    .hero-fullscreen__bg-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center center;
      display: block;
    }

    .hero-fullscreen__heading {
      font-family: 'Bebas Neue', 'Impact', 'Arial Narrow', sans-serif !important;
      font-size: clamp(40px, 11vw, 64px);
      font-weight: 400;
      line-height: 1.02;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      padding: 0 4px;
      text-align: inherit;
      width: 100%;
    }

    .hero-fullscreen__subheading {
      max-width: 100%;
      padding: 0 6px;
      text-align: inherit;
    }

    .hero-fullscreen__btn {
      padding: 16px 32px;
      font-size: 15px;
      width: 100%;
      max-width: 280px;
    }
  }

  @media screen and (max-width: 380px) {
    .hero-fullscreen__heading {
      font-size: clamp(36px, 10vw, 48px);
    }

    .hero-fullscreen__bg-img {
      object-position: center 40%;
    }
  }
{%- endstyle -%}

{%- liquid
  assign desktop_banner = section.settings.image
  assign has_dedicated_mobile = false
  if section.settings.image_mobile != blank
    assign mobile_banner = section.settings.image_mobile
    assign has_dedicated_mobile = true
  else
    assign mobile_banner = section.settings.image
  endif
  if desktop_banner == blank and mobile_banner != blank
    assign desktop_banner = mobile_banner
  endif
  assign hero_img_class = 'hero-fullscreen__bg-img'

  assign content_x = section.settings.content_position_x | default: 5 | plus: 0
  assign content_y = section.settings.content_position_y | default: 18 | plus: 0
  assign content_align = section.settings.content_align | default: 'left'
  assign content_x_mobile = section.settings.content_position_x_mobile | default: 50 | plus: 0
  assign content_y_mobile = section.settings.content_position_y_mobile | default: 12 | plus: 0
  assign content_align_mobile = section.settings.content_align_mobile | default: 'center'

  assign anchor_x = content_x
  if content_align == 'center' and anchor_x <= 15
    assign anchor_x = 50
  elsif content_align == 'right' and anchor_x <= 20
    assign anchor_x = 90
  endif

  assign anchor_x_mobile = content_x_mobile
  if content_align_mobile == 'center' and anchor_x_mobile <= 20
    assign anchor_x_mobile = 50
  elsif content_align_mobile == 'right' and anchor_x_mobile <= 25
    assign anchor_x_mobile = 90
  endif

  assign hero_style = '--hero-content-x: ' | append: anchor_x | append: '%; --hero-content-y: ' | append: content_y | append: '%; --hero-content-x-mobile: ' | append: anchor_x_mobile | append: '%; --hero-content-y-mobile: ' | append: content_y_mobile | append: '%;'
  if has_dedicated_mobile and mobile_banner.width and mobile_banner.height
    assign hero_style = hero_style | append: ' --hero-mobile-aspect: ' | append: mobile_banner.width | append: ' / ' | append: mobile_banner.height | append: ';'
  endif
-%}

<section
  class="hero-fullscreen{% if has_dedicated_mobile %} hero-fullscreen--mobile-art{% endif %}"
  aria-label="HAGUEPROTECT Fullscreen Hero Section"
  style="{{ hero_style }}"
>
  <div class="hero-fullscreen__bg">
    {%- if desktop_banner != blank -%}
      <picture>
        {%- if mobile_banner != blank -%}
          <source
            media="(max-width: 768px)"
            srcset="
              {{ mobile_banner | image_url: width: 400 }} 400w,
              {{ mobile_banner | image_url: width: 600 }} 600w,
              {{ mobile_banner | image_url: width: 800 }} 800w,
              {{ mobile_banner | image_url: width: 1000 }} 1000w
            "
            sizes="100vw"
          >
        {%- endif -%}
        {%- if has_dedicated_mobile -%}
          {{
            desktop_banner
            | image_url: width: 2800
            | image_tag:
              class: hero_img_class,
              loading: 'eager',
              fetchpriority: 'high',
              widths: '750, 1100, 1500, 2000, 2800',
              sizes: '(min-width: 769px) 100vw, 100vw',
              alt: ''
          }}
        {%- else -%}
          {{
            desktop_banner
            | image_url: width: 2800
            | image_tag:
              class: hero_img_class,
              loading: 'eager',
              fetchpriority: 'high',
              widths: '750, 1100, 1500, 2000, 2800',
              sizes: '(min-width: 769px) 100vw, 0px',
              alt: ''
          }}
        {%- endif -%}
      </picture>
    {%- endif -%}
  </div>
  <div class="hero-fullscreen__overlay"></div>

  <div class="hero-fullscreen__content hero-fullscreen__content--align-{{ content_align }} hero-fullscreen__content--align-mobile-{{ content_align_mobile }}">
    {%- if section.settings.eyebrow != blank -%}
      <span class="hero-fullscreen__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h1 class="hero-fullscreen__heading">
      {{ section.settings.heading | default: 'Bring Your Sneakers Back to Life' }}
      {%- if section.settings.heading_line2 != blank -%}
        <br>{{ section.settings.heading_line2 }}
      {%- endif -%}
    </h1>
    <p class="hero-fullscreen__subheading">{{ section.settings.subheading | default: 'Professional-grade cleaning for everyday wear. Advanced protection formulas designed for premium materials.' }}</p>

  </div>
</section>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Premium Care"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (Line 1)",
      "default": "DIRTY KICKS?"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading (Line 2)",
      "default": "WE MAKE 'EM HEAT."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Professional-grade cleaning for everyday wear. Advanced protection formulas designed for premium materials."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    },
    {
      "type": "header",
      "content": "Text position (desktop)"
    },
    {
      "type": "range",
      "id": "content_position_x",
      "label": "Horizontal position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 5,
      "info": "Left: distance from left edge. Center: anchor point (50 = page center). Right: anchor point (90 = near right edge)."
    },
    {
      "type": "range",
      "id": "content_position_y",
      "label": "Vertical position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 18
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Text position (mobile)"
    },
    {
      "type": "range",
      "id": "content_position_x_mobile",
      "label": "Horizontal position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 5,
      "info": "Left: distance from left edge. Center: anchor point (50 = page center). Right: anchor point (90 = near right edge)."0
    },
    {
      "type": "range",
      "id": "content_position_y_mobile",
      "label": "Vertical position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 12
    },
    {
      "type": "select",
      "id": "content_align_mobile",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Banner images"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop banner image",
      "info": "Displayed on tablets, laptops, and desktops. Wide landscape images work best."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile banner image",
      "info": "Displayed on phones and screens 768px wide or smaller. Square or portrait images work best. If empty, the desktop banner is used."
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}

        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="vr-price-compare">{{ current_variant.compare_at_price | money }}</span>
          {%- assign savings = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
          <span class="vr-price-save">{{ savings }}% OFF</span>
        {%- endif -%}
      </div>

      {%- comment -%} Stock {%- endcomment -%}
      {%- if current_variant.available -%}
        <div class="vr-stock">
          <span class="vr-stock__dot"></span>
          In Stock Ã¢â‚¬â€ Ready to Ship
        </div>
      {%- else -%}

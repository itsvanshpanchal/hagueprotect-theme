{%- style -%}
  .how-to-videos {
    padding: 80px 20px;
    background-color: #ffffff;
  }
  .how-to-videos__container {
    max-width: 1440px;
    margin: 0 auto;
  }
  .how-to-videos__heading {
    font-size: 26px;
    font-weight: 800;
    text-align: center;
    color: #111;
    margin: 0 0 48px;
    letter-spacing: 0.02em;
  }
  .how-to-videos__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }
  @media screen and (max-width: 1024px) {
    .how-to-videos__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }
  @media screen and (max-width: 767px) {
    .how-to-videos {
      padding: 48px var(--site-padding, 20px);
    }
    .how-to-videos__heading {
      font-size: clamp(1.125rem, 4.5vw, 1.5rem);
      margin-bottom: 32px;
      padding: 0 4px;
      line-height: 1.35;
    }
    .how-to-videos__grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .how-to-video-title {
      font-size: 16px;
      margin-top: 16px;
    }
    .how-to-video-item video,
    .how-to-video-item iframe {
      object-fit: contain;
    }
  }
  .how-to-video-wrapper {
    width: 100%;
  }
  .how-to-video-item {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    background: #000;
    aspect-ratio: 16 / 9;
    position: relative;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }
  .how-to-video-item video,
  .how-to-video-item iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
    object-fit: cover;
  }
  .how-to-video-title {
    margin-top: 20px;
    font-size: 18px;
    font-weight: 700;
    text-align: center;
    color: #111;
  }
  .how-to-video-text {
    margin-top: 8px;
    font-size: 14px;
    text-align: center;
    color: #555;
  }
{%- endstyle -%}

<div class="how-to-videos">
  <div class="how-to-videos__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="how-to-videos__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="how-to-videos__grid">
      {%- for block in section.blocks -%}
        <div class="how-to-video-wrapper" {{ block.shopify_attributes }}>
          <div class="how-to-video-item">
            {%- if block.settings.video_url != blank -%}
              {%- if block.settings.video_url.type == 'youtube' -%}
                <iframe src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?rel=0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
              {%- elsif block.settings.video_url.type == 'vimeo' -%}
                <iframe src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}" allow="autoplay; fullscreen" allowfullscreen></iframe>
              {%- endif -%}
            {%- elsif block.settings.html5_video != blank -%}
              <video src="{{ block.settings.html5_video.sources[1].url }}" controls playsinline preload="metadata"></video>
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          {%- if block.settings.title != blank -%}
            <h3 class="how-to-video-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="how-to-video-text">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "How to Use Videos",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "How To Use HAGUEPROTECT Shoe Cleaning & Protecting Products:"
    }
  ],
  "max_blocks": 8,
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Video Title",
          "default": "Step Instructions"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Video Description"
        },
        {
          "type": "video",
          "id": "html5_video",
          "label": "Shopify Video (Upload)"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "accept": ["youtube", "vimeo"],
          "label": "YouTube/Vimeo Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How to Use Videos",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}

{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .premium-htu-{{ section.id }} {
    --brand-red: #e3000f;
    --text-dark: #111111;
    --text-light: #555555;
    --bg-light: #f9f9f9;
    --bg-white: #ffffff;
    --overlay-bg: rgba(0, 0, 0, 0.85);
    --border-radius: 16px;
    --transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    
    padding: 80px 20px;
    background-color: var(--bg-light);
    font-family: var(--font-body-family, sans-serif);
  }
  
  .premium-htu__container {
    max-width: var(--site-max-width);
    margin: 0 auto;
  }

  .premium-htu__header {
    text-align: center;
    margin-bottom: 50px;
  }
  
  .premium-htu__title {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    color: var(--text-dark);
    margin: 0;
  }

  .premium-htu__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 30px;
  }

  @media (max-width: 768px) {
    .premium-htu__grid {
      display: grid;
      grid-template-columns: 1fr;
    }
  }

  .premium-htu__card {
    position: relative;
    background: var(--bg-white);
    border-radius: var(--border-radius);
    overflow: hidden;
    cursor: pointer;
    box-shadow: 0 10px 30px rgba(0,0,0,0.06);
    transition: var(--transition);
    border: 2px solid transparent;
  }

  @media (hover: hover) {
    .premium-htu__card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(0,0,0,0.12);
      border-color: var(--brand-red);
    }
  }
  .premium-htu__card.is-active {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.12);
    border-color: var(--brand-red);
  }

  .premium-htu__card-thumb {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #000;
  }

  .premium-htu__card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition);
  }

  .premium-htu__card:hover .premium-htu__card-thumb img {
    transform: scale(1.05);
  }

  .premium-htu__card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: var(--transition);
  }

  .premium-htu__card:hover .premium-htu__card-overlay,
  .premium-htu__card.is-active .premium-htu__card-overlay {
    opacity: 1;
  }

  .premium-htu__play-icon {
    width: 60px;
    height: 60px;
    background: var(--brand-red);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transform: scale(0.8);
    transition: var(--transition);
  }

  .premium-htu__card:hover .premium-htu__play-icon,
  .premium-htu__card.is-active .premium-htu__play-icon {
    transform: scale(1);
  }

  .premium-htu__play-icon svg {
    width: 24px;
    height: 24px;
    fill: currentColor;
    margin-left: 4px;
  }

  .premium-htu__card-badges {
    position: absolute;
    top: 12px;
    left: 12px;
    display: flex;
    gap: 8px;
    z-index: 2;
  }

  .premium-htu__badge {
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(4px);
    color: var(--text-dark);
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
  }

  .premium-htu__card-info {
    padding: 20px;
  }

  .premium-htu__card-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-dark);
    margin: 0 0 8px;
  }

  .premium-htu__card-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    color: var(--text-light);
  }

  .premium-htu__modal {
    position: fixed;
    inset: 0;
    z-index: 999999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .premium-htu__modal.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .premium-htu__modal-backdrop {
    position: absolute;
    inset: 0;
    background: var(--overlay-bg);
    backdrop-filter: blur(8px);
  }

  .premium-htu__modal-close {
    position: absolute;
    top: 24px;
    right: 24px;
    width: 48px;
    height: 48px;
    background: rgba(255,255,255,0.1);
    border: none;
    border-radius: 50%;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    transition: var(--transition);
  }

  .premium-htu__modal-close:hover {
    background: var(--brand-red);
    transform: rotate(90deg);
  }

  .premium-htu__modal-close svg {
    width: 24px;
    height: 24px;
    fill: currentColor;
  }

  .premium-htu__modal-container {
    position: relative;
    width: 95vw;
    height: 90vh;
    max-width: var(--site-max-width);
    background: var(--bg-white);
    border-radius: 24px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transform: scale(0.95);
    transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 40px 100px rgba(0,0,0,0.5);
  }

  .premium-htu__modal.is-open .premium-htu__modal-container {
    transform: scale(1);
  }

  .premium-htu__modal-content-wrapper {
    display: flex;
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  .premium-htu__crossfade-item {
    position: absolute;
    inset: 0;
    display: flex;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
    z-index: 1;
    background: var(--bg-white);
  }

  .premium-htu__crossfade-item.is-active {
    opacity: 1;
    pointer-events: auto;
    z-index: 2;
  }

  .premium-htu__modal-left {
    flex: 0 0 65%;
    background: #000;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow-y: auto;
  }

  .premium-htu__modal-left::-webkit-scrollbar {
    width: 6px;
  }
  .premium-htu__modal-left::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,0.3);
    border-radius: 10px;
  }

  .premium-htu__video-wrapper {
    width: 100%;
    aspect-ratio: 16/9;
    background: #000;
  }

  .premium-htu__video-wrapper video,
  .premium-htu__video-wrapper iframe {
    width: 100%;
    height: 100%;
    border: none;
    object-fit: cover;
  }

  .premium-htu__modal-info {
    padding: 40px;
    color: white;
  }

  .premium-htu__modal-info-title {
    font-size: 32px;
    font-weight: 800;
    margin: 0 0 16px;
  }

  .premium-htu__modal-info-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    margin-bottom: 24px;
    font-size: 15px;
    color: #ccc;
  }
  
  .premium-htu__modal-info-meta div strong {
    color: white;
    margin-right: 6px;
  }

  .premium-htu__modal-right {
    flex: 0 0 35%;
    background: var(--bg-white);
    padding: 40px;
    overflow-y: auto;
    position: relative;
  }

  .premium-htu__modal-right::-webkit-scrollbar {
    width: 6px;
  }
  .premium-htu__modal-right::-webkit-scrollbar-thumb {
    background: rgba(0,0,0,0.2);
    border-radius: 10px;
  }

  .premium-htu__timeline {
    margin-bottom: 40px;
  }

  .premium-htu__timeline-step {
    display: flex;
    margin-bottom: 24px;
    position: relative;
  }

  .premium-htu__timeline-step::before {
    content: '';
    position: absolute;
    top: 36px;
    bottom: -24px;
    left: 17px;
    width: 2px;
    background: #eee;
    z-index: 1;
  }

  .premium-htu__timeline-step:last-child::before {
    display: none;
  }

  .premium-htu__timeline-indicator {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--brand-red);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    margin-right: 20px;
    z-index: 2;
    flex-shrink: 0;
  }

  .premium-htu__timeline-content {
    flex: 1;
    padding-top: 6px;
  }

  .premium-htu__timeline-title {
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 8px;
    color: var(--text-dark);
  }

  .premium-htu__timeline-desc {
    font-size: 15px;
    color: var(--text-light);
    line-height: 1.6;
    margin: 0;
  }

  .premium-htu__timeline-duration {
    font-size: 13px;
    color: var(--brand-red);
    font-weight: 600;
    margin-top: 8px;
    display: inline-block;
  }

  .premium-htu__accordion {
    border-bottom: 1px solid #eee;
  }

  .premium-htu__accordion-header {
    width: 100%;
    text-align: left;
    padding: 20px 0;
    background: none;
    border: none;
    font-size: 16px;
    font-weight: 700;
    color: var(--text-dark);
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    transition: var(--transition);
  }

  .premium-htu__accordion-header:hover {
    color: var(--brand-red);
  }

  .premium-htu__accordion-icon {
    position: relative;
    width: 14px;
    height: 14px;
  }

  .premium-htu__accordion-icon::before,
  .premium-htu__accordion-icon::after {
    content: '';
    position: absolute;
    background: currentColor;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    transition: var(--transition);
  }

  .premium-htu__accordion-icon::before {
    width: 14px;
    height: 2px;
  }

  .premium-htu__accordion-icon::after {
    width: 2px;
    height: 14px;
  }

  .premium-htu__accordion.is-open .premium-htu__accordion-icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
    opacity: 0;
  }

  .premium-htu__accordion-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0, 1, 0, 1);
  }

  .premium-htu__accordion.is-open .premium-htu__accordion-content {
    max-height: 2000px;
    transition: max-height 0.8s ease-in-out;
  }

  .premium-htu__accordion-inner {
    padding-bottom: 24px;
    font-size: 15px;
    color: var(--text-light);
    line-height: 1.6;
  }

  .premium-htu__products {
    margin-top: 40px;
  }
  
  .premium-htu__products-title {
    font-size: 20px;
    font-weight: 800;
    margin-bottom: 20px;
  }

  .premium-htu__product-card {
    display: flex;
    gap: 16px;
    padding: 16px;
    border: 1px solid #eee;
    border-radius: 12px;
    margin-bottom: 16px;
    transition: var(--transition);
  }

  .premium-htu__product-card:hover {
    border-color: var(--brand-red);
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  }

  .premium-htu__product-img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 8px;
    background: #f5f5f5;
  }

  .premium-htu__product-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .premium-htu__product-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-dark);
    margin: 0 0 4px;
    text-decoration: none;
  }

  .premium-htu__product-price {
    font-size: 14px;
    color: var(--text-light);
    margin: 0 0 8px;
  }

  .premium-htu__product-btn {
    display: inline-block;
    padding: 6px 12px;
    background: #111;
    color: white;
    text-decoration: none;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    align-self: flex-start;
    transition: var(--transition);
  }

  .premium-htu__product-btn:hover {
    background: var(--brand-red);
  }


  @media (max-width: 1024px) {
    .premium-htu__crossfade-item {
      flex-direction: column;
      overflow-y: auto;
    }
    .premium-htu__modal-left,
    .premium-htu__modal-right {
      flex: none;
      width: 100%;
      overflow-y: visible;
    }
    .premium-htu__modal-right {
      padding: 24px;
    }
    .premium-htu__modal-info {
      padding: 24px;
    }
    .premium-htu__modal-container {
      width: 100%;
      height: 100%;
      border-radius: 0;
    }
    .premium-htu__modal-close {
      top: 12px;
      right: 12px;
      background: rgba(0,0,0,0.5);
    }
  }
{%- endstyle -%}

<div class="premium-htu premium-htu-{{ section.id }}">
  <div class="premium-htu__container">
    {%- if section.settings.heading != blank -%}
      <div class="premium-htu__header">
        <h2 class="premium-htu__title">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="premium-htu__grid">
      {%- for block in section.blocks -%}
        <div class="premium-htu__card" data-tutorial-id="{{ block.id }}" tabindex="0" role="button" aria-label="Play {{ block.settings.title }}">
          <div class="premium-htu__card-thumb">
            {%- if block.settings.thumbnail != blank -%}
              {{ block.settings.thumbnail | image_url: width: 800 | image_tag: loading: 'lazy' }}
            {%- elsif block.settings.html5_video != blank and block.settings.html5_video.preview_image -%}
              {{ block.settings.html5_video.preview_image | image_url: width: 800 | image_tag: loading: 'lazy' }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
            
            <div class="premium-htu__card-badges">
              {%- if block.settings.duration != blank -%}
                <div class="premium-htu__badge">{{ block.settings.duration }}</div>
              {%- endif -%}
              {%- if block.settings.difficulty != blank -%}
                <div class="premium-htu__badge">{{ block.settings.difficulty }}</div>
              {%- endif -%}
            </div>

            <div class="premium-htu__card-overlay">
              <div class="premium-htu__play-icon">
                <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </div>
            </div>
          </div>
          
          <div class="premium-htu__card-info">
            <h3 class="premium-htu__card-title">{{ block.settings.title | default: 'Tutorial Video' }}</h3>
            {%- if block.settings.text != blank -%}
              <p class="premium-htu__card-desc" style="font-size: 14px; color: var(--text-light); margin: 0 0 8px;">{{ block.settings.text }}</p>
            {%- endif -%}
            <div class="premium-htu__card-meta">
              {%- if block.settings.category != blank -%}
                <span>{{ block.settings.category }}</span>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>

  <div class="premium-htu__modal" aria-hidden="true" role="dialog">
    <div class="premium-htu__modal-backdrop"></div>
    <div class="premium-htu__modal-container">
      <button class="premium-htu__modal-close" aria-label="Close modal">
        <svg viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
      </button>
      
      <div class="premium-htu__modal-content-wrapper">
        <!-- Render each tutorial's content inside an absolute crossfade item -->
        {%- for block in section.blocks -%}
          <div class="premium-htu__crossfade-item" id="tutorial-content-{{ block.id }}" data-tutorial-id="{{ block.id }}">
            <div class="premium-htu__modal-left">
              <div class="premium-htu__video-wrapper">
                {%- if block.settings.html5_video != blank -%}
                  <video data-src="{{ block.settings.html5_video.sources[1].url }}" controls playsinline preload="none"></video>
                {%- elsif block.settings.video_url != blank -%}
                  {%- if block.settings.video_url.type == 'youtube' -%}
                    <iframe data-src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?rel=0&enablejsapi=1" allow="autoplay; encrypted-media" allowfullscreen></iframe>
                  {%- elsif block.settings.video_url.type == 'vimeo' -%}
                    <iframe data-src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}" allow="autoplay; fullscreen" allowfullscreen></iframe>
                  {%- endif -%}
                {%- endif -%}
              </div>
              
              <div class="premium-htu__modal-info">
                <h2 class="premium-htu__modal-info-title">{{ block.settings.title }}</h2>
                {%- if block.settings.text != blank -%}
                  <p class="premium-htu__modal-info-desc" style="font-size: 16px; color: #eee; margin-top: -8px; margin-bottom: 24px;">{{ block.settings.text }}</p>
                {%- endif -%}
                <div class="premium-htu__modal-info-meta">
                  {%- if block.settings.duration != blank -%}
                    <div><strong>Est. Time:</strong> {{ block.settings.duration }}</div>
                  {%- endif -%}
                  {%- if block.settings.difficulty != blank -%}
                    <div><strong>Difficulty:</strong> {{ block.settings.difficulty }}</div>
                  {%- endif -%}
                  {%- if block.settings.material_compatibility != blank -%}
                    <div><strong>Material:</strong> {{ block.settings.material_compatibility }}</div>
                  {%- endif -%}
                  {%- if block.settings.category != blank -%}
                    <div><strong>Category:</strong> {{ block.settings.category }}</div>
                  {%- endif -%}
                  {%- if block.settings.products_used != blank -%}
                    <div><strong>Products:</strong> {{ block.settings.products_used }}</div>
                  {%- endif -%}
                </div>
              </div>
            </div>

            <div class="premium-htu__modal-right">
              <!-- Timeline Steps -->
              <div class="premium-htu__timeline">
                {%- for i in (1..8) -%}
                  {%- assign step_title_key = 'step_' | append: i | append: '_title' -%}
                  {%- assign step_desc_key = 'step_' | append: i | append: '_desc' -%}
                  {%- assign step_duration_key = 'step_' | append: i | append: '_duration' -%}
                  
                  {%- assign step_title = block.settings[step_title_key] -%}
                  {%- assign step_desc = block.settings[step_desc_key] -%}
                  {%- assign step_dur = block.settings[step_duration_key] -%}

                  {%- if step_title != blank or step_desc != blank -%}
                    <div class="premium-htu__timeline-step">
                      <div class="premium-htu__timeline-indicator">{{ i }}</div>
                      <div class="premium-htu__timeline-content">
                        {%- if step_title != blank -%}
                          <h4 class="premium-htu__timeline-title">{{ step_title }}</h4>
                        {%- endif -%}
                        {%- if step_desc != blank -%}
                          <p class="premium-htu__timeline-desc">{{ step_desc }}</p>
                        {%- endif -%}
                        {%- if step_dur != blank -%}
                          <span class="premium-htu__timeline-duration">{{ step_dur }}</span>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>

              <!-- Accordions -->
              <div class="premium-htu__accordions">
                {%- assign accordions = 'things_to_avoid,best_results_tips,compatible_materials,maintenance_tips,warnings,safety_notes,faqs,additional_notes,after_cleaning_checklist' | split: ',' -%}
                {%- assign accordion_titles = 'Things to Avoid,Best Results Tips,Compatible Materials,Maintenance Tips,Warnings,Safety Notes,FAQs,Additional Notes,After Cleaning Checklist' | split: ',' -%}

                {%- for acc in accordions -%}
                  {%- assign acc_content = block.settings[acc] -%}
                  {%- if acc_content != blank -%}
                    <div class="premium-htu__accordion">
                      <button class="premium-htu__accordion-header">
                        {{ accordion_titles[forloop.index0] }}
                        <span class="premium-htu__accordion-icon"></span>
                      </button>
                      <div class="premium-htu__accordion-content">
                        <div class="premium-htu__accordion-inner">
                          {{ acc_content }}
                        </div>
                      </div>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>

              <!-- Recommended Products -->
              {%- assign has_products = false -%}
              {%- for i in (1..4) -%}
                {%- assign prod_key = 'product_' | append: i -%}
                {%- if block.settings[prod_key] != blank -%}
                  {%- assign has_products = true -%}
                {%- endif -%}
              {%- endfor -%}

              {%- if has_products -%}
                <div class="premium-htu__products">
                  <h4 class="premium-htu__products-title">Recommended Products</h4>
                  {%- for i in (1..4) -%}
                    {%- assign prod_key = 'product_' | append: i -%}
                    {%- assign prod = block.settings[prod_key] -%}
                    {%- if prod != blank -%}
                      <div class="premium-htu__product-card">
                        {%- if prod.featured_image -%}
                          {{ prod.featured_image | image_url: width: 160 | image_tag: class: 'premium-htu__product-img', loading: 'lazy' }}
                        {%- endif -%}
                        <div class="premium-htu__product-info">
                          <a href="{{ prod.url }}" class="premium-htu__product-title">{{ prod.title }}</a>
                          <p class="premium-htu__product-price">{{ prod.price | money }}</p>
                          <a href="{{ prod.url }}" class="premium-htu__product-btn">View Product</a>
                        </div>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>


    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sectionId = '{{ section.id }}';
    const section = document.querySelector(`.premium-htu-${sectionId}`);
    if (!section) return;

    const cards = section.querySelectorAll('.premium-htu__card');
    const modal = section.querySelector('.premium-htu__modal');
    const closeBtn = section.querySelector('.premium-htu__modal-close');
    const backdrop = section.querySelector('.premium-htu__modal-backdrop');
    const sliderItems = section.querySelectorAll('.premium-htu__slider-item');
    const crossfadeItems = section.querySelectorAll('.premium-htu__crossfade-item');
    
    let activeId = null;

    function openModal() {
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      document.documentElement.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      document.documentElement.style.overflow = '';
      pauseAllVideos();
      activeId = null;
    }

    function pauseAllVideos() {
      crossfadeItems.forEach(item => {
        const video = item.querySelector('video');
        if (video) video.pause();
        const iframe = item.querySelector('iframe');
        if (iframe) {
          // Send pause command if youtube/vimeo
          const src = iframe.src;
          iframe.src = src; // reload iframe stops it, cheap trick but works consistently
        }
      });
    }

    function playVideo(item) {
      const video = item.querySelector('video');
      if (video) {
        if (!video.src && video.dataset.src) {
          video.src = video.dataset.src;
        }
        video.play().catch(e => console.log('Autoplay prevented', e));
      }
      const iframe = item.querySelector('iframe');
      if (iframe && !iframe.src && iframe.dataset.src) {
        iframe.src = iframe.dataset.src;
      }
    }

    function activateTutorial(id) {
      if (activeId === id) return;
      activeId = id;
      
      pauseAllVideos();

      // Update crossfade items
      crossfadeItems.forEach(item => {
        if (item.dataset.tutorialId === id) {
          item.classList.add('is-active');
          playVideo(item);
        } else {
          item.classList.remove('is-active');
        }
      });

      // Update slider items active state
      sliderItems.forEach(item => {
        if (item.dataset.targetId === id) {
          item.classList.add('is-active');
          item.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        } else {
          item.classList.remove('is-active');
        }
      });
      
      // Update main cards
      cards.forEach(card => {
        if (card.dataset.tutorialId === id) {
          card.classList.add('is-active');
        } else {
          card.classList.remove('is-active');
        }
      });
    }

    // Event Listeners for Cards (Hover desktop / Tap mobile)
    cards.forEach(card => {
      const id = card.dataset.tutorialId;

      card.addEventListener('click', () => {
        activateTutorial(id);
        openModal();
      });
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          activateTutorial(id);
          openModal();
        }
      });
    });

    // Slider clicks
    sliderItems.forEach(item => {
      item.addEventListener('click', () => {
        activateTutorial(item.dataset.targetId);
      });
    });

    // Accordions
    crossfadeItems.forEach(item => {
      const headers = item.querySelectorAll('.premium-htu__accordion-header');
      headers.forEach(header => {
        header.addEventListener('click', () => {
          const acc = header.parentElement;
          const isOpen = acc.classList.contains('is-open');
          
          // Close others in this specific tutorial panel
          item.querySelectorAll('.premium-htu__accordion').forEach(a => a.classList.remove('is-open'));
          
          if (!isOpen) {
            acc.classList.add('is-open');
          }
        });
      });
    });

    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) {
        closeModal();
      }
    });
  });
</script>


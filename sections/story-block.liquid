{%- style -%}
  .story-banner-wrapper {
    width: 100%;
    max-width: 100vw;
    overflow: hidden;
    background-color: #ffffff;
    padding: {{ section.settings.padding_top | default: 0 }}px 0 {{ section.settings.padding_bottom | default: 0 }}px 0;
  }

  .story-banner {
    width: 100%;
    margin: 0 auto;
    position: relative;
    max-width: 1440px;
    aspect-ratio: 1440 / 560;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius | default: 0 }}px;
    background-color: #f6f6f6;
  }

  .story-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .story-banner:hover .story-banner__image {
    transform: scale(1.02);
  }

  @media screen and (max-width: 768px) {
    .story-banner {
      aspect-ratio: 1 / 1;
    }
  }
{%- endstyle -%}

<div class="story-banner-wrapper">
  <div class="story-banner">
    {%- assign banner_img = section.settings.image -%}

    {%- for block in section.blocks -%}
      {%- if block.type == 'product_banner' and block.settings.product_select == product.handle -%}
        {%- if block.settings.image != blank -%}
          {%- assign banner_img = block.settings.image -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if banner_img != blank -%}
      <img src="{{ banner_img | image_url: width: 1440 }}" alt="{{ banner_img.alt | default: product.title | default: shop.name | escape }} story banner" class="story-banner__image" loading="lazy">
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'story-banner__image' }}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Story Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback Banner Image (1440x560px)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Border Radius",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "product_banner",
      "name": "Per-Product Image",
      "settings": [
        {
          "type": "product",
          "id": "product_select",
          "label": "Select Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Specific Image for this Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Story Banner"
    }
  ]
}
{% endschema %}

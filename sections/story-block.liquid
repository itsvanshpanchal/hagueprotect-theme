{%- style -%}
  {% render 'section-typography-css',
    section: section,
    h1_selector: '.story-banner__heading',
    h2_selector: '.story-banner__subheading',
    paragraph_selector: '.story-banner__paragraph',
    eyebrow_selector: '.story-banner__eyebrow',
    h1_size_desktop_default: settings.font_h1_size_desktop,
    h1_size_mobile_default: settings.font_h1_size_mobile
  %}

  .story-banner-wrapper-{{ section.id }} {
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    overflow: hidden;
    background-color: #ffffff;
    padding: {{ section.settings.padding_top | default: 40 }}px 0 {{ section.settings.padding_bottom | default: 40 }}px 0;
    box-sizing: border-box;
  }

  .story-banner-wrapper-{{ section.id }} .story-banner {
    width: 100%;
    margin: 0;
    position: relative;
    max-width: none;
    aspect-ratio: 1440 / 560;
    overflow: hidden;
    border-radius: var(--homepage-corner, 20px);
    background-color: #f6f6f6;
  }

  .story-banner-wrapper-{{ section.id }} .story-banner__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 12px;
    padding: clamp(24px, 6vw, 72px);
    pointer-events: none;
  }

  .story-banner-wrapper-{{ section.id }} .story-banner__eyebrow {
    color: #e74c3c;
    margin: 0;
  }

  .story-banner-wrapper-{{ section.id }} .story-banner__heading {
    font-family: var(--font-family-heading);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: #111111;
    margin: 0;
    max-width: 720px;
  }

  .story-banner-wrapper-{{ section.id }} .story-banner__subheading {
    font-family: var(--font-family-h2, var(--font-family-heading));
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: #111111;
    margin: 0;
    max-width: 720px;
  }

  .story-banner-wrapper-{{ section.id }} .story-banner__paragraph {
    color: #444444 !important;
    max-width: 560px;
  }

  .story-banner-wrapper-{{ section.id }} .story-banner picture,
  .story-banner-wrapper-{{ section.id }} .story-banner__image {
    width: 100%;
    height: 100%;
    display: block;
  }

  .story-banner-wrapper-{{ section.id }} .story-banner__image {
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .story-banner-wrapper-{{ section.id }} .story-banner:hover .story-banner__image {
    transform: scale(1.03);
  }

  @media screen and (max-width: 749px) {
    .story-banner-wrapper-{{ section.id }} {
      padding: {{ section.settings.padding_top | divided_by: 2 | default: 20 }}px 0 {{ section.settings.padding_bottom | divided_by: 2 | default: 20 }}px 0;
    }

    .story-banner-wrapper-{{ section.id }} .story-banner {
      aspect-ratio: 1 / 1;
      min-height: 320px;
      border-radius: var(--homepage-corner, 20px);
    }
  }
{%- endstyle -%}

{%- liquid
  assign show_section = true
  assign assigned_product = section.settings.assigned_product
  assign banner_img = section.settings.image
  assign mobile_img = section.settings.image_mobile | default: section.settings.image

  if product != blank
    assign show_section = false

    if assigned_product != blank and assigned_product.handle == product.handle
      assign show_section = true
    endif

    for block in section.blocks
      if block.type == 'product_banner' and block.settings.product_select != blank
        assign block_product = block.settings.product_select
        if block_product.handle == product.handle
          assign show_section = true
          if block.settings.image != blank
            assign banner_img = block.settings.image
            assign mobile_img = block.settings.image_mobile | default: block.settings.image
          endif
          break
        endif
      endif
    endfor

    if product.metafields.custom.story_banner_desktop != blank
      assign banner_img = product.metafields.custom.story_banner_desktop
      assign mobile_img = product.metafields.custom.story_banner_mobile | default: product.metafields.custom.story_banner_desktop
      assign show_section = true
    endif
  elsif assigned_product != blank
    assign show_section = false
  endif

  if request.design_mode and assigned_product == blank and product != blank
    assign show_section = true
  endif
-%}

{%- if show_section -%}
<div class="story-banner-wrapper story-banner-wrapper-{{ section.id }}">
  <div class="story-banner">
    {%- if banner_img != blank -%}
      <picture>
        {%- if mobile_img != blank -%}
          <source media="(max-width: 749px)" srcset="{{ mobile_img | image_url: width: 800 }}">
        {%- endif -%}
        <img 
          src="{{ banner_img | image_url: width: 1440 }}" 
          srcset="{{ banner_img | image_url: width: 1000 }} 1000w, {{ banner_img | image_url: width: 1440 }} 1440w, {{ banner_img | image_url: width: 1920 }} 1920w"
          sizes="100vw"
          alt="{{ banner_img.alt | default: product.title | default: shop.name | escape }} story banner" 
          class="story-banner__image" 
          loading="eager"
          fetchpriority="high"
        >
      </picture>
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'story-banner__image' }}
    {%- endif -%}

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank or section.settings.paragraph != blank -%}
      <div class="story-banner__content">
        {%- if section.settings.eyebrow != blank -%}
          <span class="story-banner__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="story-banner__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <h3 class="story-banner__subheading">{{ section.settings.subheading }}</h3>
        {%- endif -%}
        {%- if section.settings.paragraph != blank -%}
          <p class="story-banner__paragraph">{{ section.settings.paragraph }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Story Banner",
  "settings": [
    {
      "type": "product",
      "id": "assigned_product",
      "label": "Assign to product",
      "info": "Required for product pages. Duplicate this section for each product, assign the product, then upload its banner images."
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop Banner Image (1440x560px)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Banner Image (Optional)"
    },
    {
      "type": "header",
      "content": "Optional text overlay"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "H1 heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "H2 subheading"
    },
    {
      "type": "textarea",
      "id": "paragraph",
      "label": "Paragraph text"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "paragraph",
      "content": "Edit fonts and sizes for story banner text. Leave text fields empty to show image only."
    },
    {
      "type": "select",
      "id": "h1_font_family",
      "label": "H1 font family",
      "options": [
        { "value": "bebas_neue", "label": "Bebas Neue" },
        { "value": "anton", "label": "Anton" },
        { "value": "oswald", "label": "Oswald" },
        { "value": "inter", "label": "Inter" },
        { "value": "montserrat", "label": "Montserrat" }
      ],
      "default": "bebas_neue"
    },
    {
      "type": "range",
      "id": "h1_font_size_desktop",
      "label": "H1 size (desktop)",
      "min": 28,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "h1_font_size_mobile",
      "label": "H1 size (mobile)",
      "min": 20,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "select",
      "id": "h2_font_family",
      "label": "H2 font family",
      "options": [
        { "value": "bebas_neue", "label": "Bebas Neue" },
        { "value": "anton", "label": "Anton" },
        { "value": "oswald", "label": "Oswald" },
        { "value": "inter", "label": "Inter" },
        { "value": "montserrat", "label": "Montserrat" }
      ],
      "default": "bebas_neue"
    },
    {
      "type": "range",
      "id": "h2_font_size_desktop",
      "label": "H2 size (desktop)",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "h2_font_size_mobile",
      "label": "H2 size (mobile)",
      "min": 18,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 34
    },
    {
      "type": "select",
      "id": "paragraph_font_family",
      "label": "Paragraph font family",
      "options": [
        { "value": "inter", "label": "Inter" },
        { "value": "montserrat", "label": "Montserrat" },
        { "value": "bebas_neue", "label": "Bebas Neue" },
        { "value": "oswald", "label": "Oswald" }
      ],
      "default": "inter"
    },
    {
      "type": "range",
      "id": "paragraph_font_size_desktop",
      "label": "Paragraph size (desktop)",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "paragraph_font_size_mobile",
      "label": "Paragraph size (mobile)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "select",
      "id": "eyebrow_font_family",
      "label": "Eyebrow font family",
      "options": [
        { "value": "inter", "label": "Inter" },
        { "value": "montserrat", "label": "Montserrat" },
        { "value": "bebas_neue", "label": "Bebas Neue" },
        { "value": "oswald", "label": "Oswald" }
      ],
      "default": "inter"
    },
    {
      "type": "range",
      "id": "eyebrow_font_size_desktop",
      "label": "Eyebrow size (desktop)",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "eyebrow_font_size_mobile",
      "label": "Eyebrow size (mobile)",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Border Radius",
      "default": 20,
      "info": "Matches the bestsellers section card corner (20px)."
    }
  ],
  "blocks": [
    {
      "type": "product_banner",
      "name": "Per-Product Image",
      "settings": [
        {
          "type": "product",
          "id": "product_select",
          "label": "Select Product",
          "info": "This banner only appears on the selected product's page."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Specific Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Specific Mobile Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Story Banner"
    }
  ]
}
{% endschema %}


{%- style -%}
  {% render 'section-typography-vars', section: section %}

  .story-banner-wrapper-{{ section.id }} {
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    overflow: hidden;
    background-color: #ffffff;
    padding: {{ section.settings.padding_top | default: 40 }}px 0 {{ section.settings.padding_bottom | default: 40 }}px 0;
    box-sizing: border-box;
  }

  .story-banner-wrapper-{{ section.id }} .story-banner {
    width: 100%;
    margin: 0;
    position: relative;
    max-width: none;
    aspect-ratio: 1440 / 560;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius | default: 20 }}px;
    background-color: #f6f6f6;
  }

  .story-banner-wrapper-{{ section.id }} .story-banner__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: {{ section.settings.text_vertical_position | default: 'center' }};
    align-items: {% case section.settings.text_align %}{% when 'center' %}center{% when 'right' %}flex-end{% else %}flex-start{% endcase %};
    gap: 12px;
    padding: clamp(24px, 6vw, 72px);
    text-align: {{ section.settings.text_align | default: 'left' }};
    pointer-events: none;
    {%- if section.settings.show_text_shadow -%}
      text-shadow: 0 2px 16px rgba(0, 0, 0, 0.35);
    {%- endif -%}
  }

  .story-banner-wrapper-{{ section.id }} .story-banner__content > * {
    pointer-events: auto;
    max-width: {{ section.settings.text_max_width | default: 720 }}px;
    width: 100%;
  }

  #MainContent .shopify-section .story-banner-wrapper-{{ section.id }} .story-banner__eyebrow,
  .story-banner-wrapper-{{ section.id }} .story-banner__eyebrow {
    display: block;
    margin: 0;
    font-family: var(--font-family-eyebrow, var(--font-family-sans)) !important;
    font-size: var(--section-label-size) !important;
    font-weight: var(--font-weight-eyebrow, 700) !important;
    font-style: var(--font-style-eyebrow, normal) !important;
    letter-spacing: 0.14em !important;
    text-transform: uppercase !important;
    line-height: 1.4 !important;
    color: {{ section.settings.eyebrow_color | default: '#2563eb' }} !important;
  }

  #MainContent .shopify-section .story-banner-wrapper-{{ section.id }} .story-banner__heading,
  .story-banner-wrapper-{{ section.id }} .story-banner__heading {
    font-family: var(--font-family-heading) !important;
    font-size: var(--heading-size-xl) !important;
    font-weight: var(--font-weight-heading, 400) !important;
    font-style: var(--font-style-heading, normal) !important;
    line-height: 1.05 !important;
    letter-spacing: 0.03em !important;
    text-transform: uppercase !important;
    color: {{ section.settings.heading_color | default: '#111111' }} !important;
    margin: 0 !important;
  }

  #MainContent .shopify-section .story-banner-wrapper-{{ section.id }} .story-banner__subheading,
  .story-banner-wrapper-{{ section.id }} .story-banner__subheading {
    font-family: var(--font-family-h2, var(--font-family-heading)) !important;
    font-size: var(--section-heading-size) !important;
    font-weight: var(--font-weight-h2, 400) !important;
    font-style: var(--font-style-h2, normal) !important;
    line-height: 1.1 !important;
    letter-spacing: 0.03em !important;
    text-transform: uppercase !important;
    color: {{ section.settings.subheading_color | default: '#111111' }} !important;
    margin: 0 !important;
  }

  #MainContent .shopify-section .story-banner-wrapper-{{ section.id }} .story-banner__paragraph,
  .story-banner-wrapper-{{ section.id }} .story-banner__paragraph {
    font-family: var(--font-family-sans) !important;
    font-size: var(--section-subheading-size, var(--body-font-size)) !important;
    font-weight: var(--font-weight-sans, 400) !important;
    font-style: var(--font-style-sans, normal) !important;
    line-height: 1.55 !important;
    letter-spacing: normal !important;
    text-transform: none !important;
    color: {{ section.settings.paragraph_color | default: '#444444' }} !important;
    margin-top: var(--section-subheading-spacing-top) !important;
    margin-right: 0 !important;
    margin-bottom: 0 !important;
    margin-left: 0 !important;
  }

  .story-banner-wrapper-{{ section.id }} .story-banner picture,
  .story-banner-wrapper-{{ section.id }} .story-banner__image {
    width: 100%;
    height: 100%;
    display: block;
  }

  .story-banner-wrapper-{{ section.id }} .story-banner__image {
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .story-banner-wrapper-{{ section.id }} .story-banner:hover .story-banner__image {
    transform: scale(1.03);
  }

  @media screen and (max-width: 749px) {
    .story-banner-wrapper-{{ section.id }} {
      padding: {{ section.settings.padding_top | divided_by: 2 | default: 20 }}px 0 {{ section.settings.padding_bottom | divided_by: 2 | default: 20 }}px 0;
    }

    .story-banner-wrapper-{{ section.id }} .story-banner {
      aspect-ratio: 1 / 1;
      min-height: 320px;
    }

    .story-banner-wrapper-{{ section.id }} .story-banner__subheading {
      font-size: var(--section-heading-size-mobile, var(--section-heading-size)) !important;
    }
  }
{%- endstyle -%}

{%- liquid
  assign show_section = true
  assign assigned_product = section.settings.assigned_product
  assign banner_img = section.settings.image
  assign mobile_img = section.settings.image_mobile | default: section.settings.image
  assign banner_eyebrow = section.settings.eyebrow
  assign banner_heading = section.settings.heading
  assign banner_subheading = section.settings.subheading
  assign banner_paragraph = section.settings.paragraph

  if product != blank
    assign show_section = false

    if assigned_product != blank and assigned_product.handle == product.handle
      assign show_section = true
    endif

    for block in section.blocks
      if block.type == 'product_banner' and block.settings.product_select != blank
        assign block_product = block.settings.product_select
        if block_product.handle == product.handle
          assign show_section = true
          if block.settings.image != blank
            assign banner_img = block.settings.image
            assign mobile_img = block.settings.image_mobile | default: block.settings.image
          endif
          if block.settings.eyebrow != blank
            assign banner_eyebrow = block.settings.eyebrow
          endif
          if block.settings.heading != blank
            assign banner_heading = block.settings.heading
          endif
          if block.settings.subheading != blank
            assign banner_subheading = block.settings.subheading
          endif
          if block.settings.paragraph != blank
            assign banner_paragraph = block.settings.paragraph
          endif
          break
        endif
      endif
    endfor

    if product.metafields.custom.story_banner_desktop != blank
      assign banner_img = product.metafields.custom.story_banner_desktop
      assign mobile_img = product.metafields.custom.story_banner_mobile | default: product.metafields.custom.story_banner_desktop
      assign show_section = true
    endif
  elsif assigned_product != blank
    assign show_section = false
  endif

  if request.design_mode and assigned_product == blank and product != blank
    assign show_section = true
  endif

  assign has_text = false
  if banner_eyebrow != blank or banner_heading != blank or banner_subheading != blank or banner_paragraph != blank
    assign has_text = true
  endif
-%}

{%- if show_section -%}
<div class="story-banner-wrapper story-banner-wrapper-{{ section.id }}">
  <div class="story-banner">
    {%- if banner_img != blank -%}
      <picture>
        {%- if mobile_img != blank -%}
          <source media="(max-width: 749px)" srcset="{{ mobile_img | image_url: width: 800 }}">
        {%- endif -%}
        <img
          src="{{ banner_img | image_url: width: 1440 }}"
          srcset="{{ banner_img | image_url: width: 1000 }} 1000w, {{ banner_img | image_url: width: 1440 }} 1440w, {{ banner_img | image_url: width: 1920 }} 1920w"
          sizes="100vw"
          alt="{{ banner_img.alt | default: banner_heading | default: product.title | default: shop.name | escape }} story banner"
          class="story-banner__image"
          loading="eager"
          fetchpriority="high"
        >
      </picture>
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'story-banner__image' }}
    {%- endif -%}

    {%- if has_text -%}
      <div class="story-banner__content">
        {%- if banner_eyebrow != blank or banner_heading != blank -%}
          <div class="section-heading-stack">
            {%- if banner_eyebrow != blank -%}
              <span class="story-banner__eyebrow">{{ banner_eyebrow }}</span>
            {%- endif -%}
            {%- if banner_heading != blank -%}
              <div class="story-banner__heading" role="heading" aria-level="2">{{ banner_heading }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}
        {%- if banner_subheading != blank -%}
          <div class="story-banner__subheading" role="heading" aria-level="3">{{ banner_subheading }}</div>
        {%- endif -%}
        {%- if banner_paragraph != blank -%}
          <p class="story-banner__paragraph">{{ banner_paragraph }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>
{%- endif -%}


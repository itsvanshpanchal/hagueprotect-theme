{%- style -%}
  .caplus-slider-{{ section.id }} {
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    background: {{ section.settings.bg_color | default: '#ffffff' }};
    padding: {{ section.settings.padding_top | default: 24 }}px 0 {{ section.settings.padding_bottom | default: 24 }}px;
    box-sizing: border-box;
  }

  .caplus-slider-{{ section.id }}__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 max(16px, var(--site-padding, 20px));
  }

  .caplus-slider-{{ section.id }}__heading {
    font-family: 'Bahnschrift', 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 600;
    color: #111111;
    margin: 0 0 20px;
    letter-spacing: -0.02em;
  }

  .caplus-slider-{{ section.id }}__viewport {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius | default: 0 }}px;
    background: #f5f5f7;
  }

  .caplus-slider-{{ section.id }}__track {
    display: flex;
    transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .caplus-slider-{{ section.id }}__slide {
    flex: 0 0 100%;
    width: 100%;
    aspect-ratio: 2 / 1;
    position: relative;
  }

  .caplus-slider-{{ section.id }}__slide-link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  .caplus-slider-{{ section.id }}__slide picture,
  .caplus-slider-{{ section.id }}__slide img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .caplus-slider-{{ section.id }}__slide img {
    object-fit: cover;
  }

  .caplus-slider-{{ section.id }}__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 16px;
  }

  .caplus-slider-{{ section.id }}__arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid #cccccc;
    background: #ffffff;
    color: #111111;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .caplus-slider-{{ section.id }}__arrow:hover {
    background: #ff2b2b;
    border-color: #ff2b2b;
    color: #ffffff;
  }

  .caplus-slider-{{ section.id }}__dots {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .caplus-slider-{{ section.id }}__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: none;
    padding: 0;
    background: #d9d9d9;
    cursor: pointer;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .caplus-slider-{{ section.id }}__dot.is-active {
    background: #ff2b2b;
    transform: scale(1.15);
  }

  @media screen and (max-width: 749px) {
    .caplus-slider-{{ section.id }}__slide {
      aspect-ratio: 4 / 5;
      min-height: 280px;
    }
  }
{%- endstyle -%}

{%- assign slide_count = section.blocks.size -%}

<section class="caplus-slider-{{ section.id }}" aria-label="{{ section.settings.label | default: 'A+ banner slider' | escape }}" data-aplus-slider>
  <div class="caplus-slider-{{ section.id }}__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="caplus-slider-{{ section.id }}__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if slide_count > 0 -%}
      <div class="caplus-slider-{{ section.id }}__viewport" data-aplus-viewport>
        <div class="caplus-slider-{{ section.id }}__track" data-aplus-track>
          {%- for block in section.blocks -%}
            {%- if block.type == 'slide' -%}
              {%- liquid
                assign desktop_img = block.settings.image
                assign mobile_img = block.settings.image_mobile | default: block.settings.image
                assign slide_alt = block.settings.alt_text | default: desktop_img.alt | default: 'Banner slide'
              -%}
              <div class="caplus-slider-{{ section.id }}__slide" data-aplus-slide {{ block.shopify_attributes }}>
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="caplus-slider-{{ section.id }}__slide-link">
                {%- endif -%}

                {%- if desktop_img != blank -%}
                  <picture>
                    {%- if mobile_img != blank -%}
                      <source media="(max-width: 749px)" srcset="{{ mobile_img | image_url: width: 1080 }}">
                    {%- endif -%}
                    <img
                      src="{{ desktop_img | image_url: width: 2800 }}"
                      srcset="{{ desktop_img | image_url: width: 1400 }} 1400w, {{ desktop_img | image_url: width: 2000 }} 2000w, {{ desktop_img | image_url: width: 2800 }} 2800w"
                      sizes="100vw"
                      alt="{{ slide_alt | escape }}"
                      loading="lazy"
                      width="{{ desktop_img.width }}"
                      height="{{ desktop_img.height }}"
                    >
                  </picture>
                {%- else -%}
                  {{ 'lifestyle-1' | placeholder_svg_tag }}
                {%- endif -%}

                {%- if block.settings.link != blank -%}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      {%- if slide_count > 1 -%}
        <div class="caplus-slider-{{ section.id }}__controls">
          <button type="button" class="caplus-slider-{{ section.id }}__arrow" data-aplus-prev aria-label="Previous slide">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <div class="caplus-slider-{{ section.id }}__dots" data-aplus-dots>
            {%- for block in section.blocks -%}
              {%- if block.type == 'slide' -%}
                <button type="button" class="caplus-slider-{{ section.id }}__dot{% if forloop.first %} is-active{% endif %}" data-aplus-dot="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <button type="button" class="caplus-slider-{{ section.id }}__arrow" data-aplus-next aria-label="Next slide">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="caplus-slider-{{ section.id }}__viewport">
        <div class="caplus-slider-{{ section.id }}__slide">
          {{ 'lifestyle-2' | placeholder_svg_tag }}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    var root = document.querySelector('.caplus-slider-{{ section.id }}');
    if (!root) return;

    var track = root.querySelector('[data-aplus-track]');
    var dots = root.querySelectorAll('[data-aplus-dot]');
    var prevBtn = root.querySelector('[data-aplus-prev]');
    var nextBtn = root.querySelector('[data-aplus-next]');
    if (!track) return;

    var slides = track.querySelectorAll('[data-aplus-slide]');
    var total = slides.length;
    if (total <= 1) return;

    var index = 0;
    var timer = null;
    var autoplay = {{ section.settings.autoplay | default: true | json }};
    var interval = {{ section.settings.autoplay_speed | default: 5 | times: 1000 }};

    function goTo(nextIndex) {
      index = (nextIndex + total) % total;
      track.style.transform = 'translateX(-' + (index * 100) + '%)';
      dots.forEach(function (dot, i) {
        dot.classList.toggle('is-active', i === index);
      });
    }

    function startAutoplay() {
      if (!autoplay) return;
      stopAutoplay();
      timer = window.setInterval(function () {
        goTo(index + 1);
      }, interval);
    }

    function stopAutoplay() {
      if (timer) {
        window.clearInterval(timer);
        timer = null;
      }
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', function () {
        goTo(index - 1);
        startAutoplay();
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function () {
        goTo(index + 1);
        startAutoplay();
      });
    }

    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        goTo(parseInt(dot.getAttribute('data-aplus-dot'), 10));
        startAutoplay();
      });
    });

    root.addEventListener('mouseenter', stopAutoplay);
    root.addEventListener('mouseleave', startAutoplay);
    root.addEventListener('focusin', stopAutoplay);
    root.addEventListener('focusout', startAutoplay);

    startAutoplay();
  })();
</script>

{% schema %}
{
  "name": "Collection A+ Slider",
  "tag": "section",
  "class": "section-collection-aplus-slider",
  "max_blocks": 3,
  "enabled_on": {
    "templates": ["collection", "page"]
  },
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label (accessibility)",
      "default": "A+ banner slider"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Optional heading above slider"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Auto-rotate speed",
      "default": 5
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Corner radius",
      "default": 0
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Banner slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop slide image",
          "info": "Recommended: 2800 x 1400 px (2:1)"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile slide image",
          "info": "Recommended: 1080 x 1350 px (4:5)"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Image alt text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Slide link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection A+ Slider",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}

          </a>
          <a href="{{ vanrosector_url }}" class="brand-dropdown__item" role="menuitem" aria-label="Vanrosector">
            <img src="{{ vr_logo_url }}" alt="Vanrosector" class="brand-dropdown__logo" height="36" loading="lazy" decoding="async">
          </a>
          <a href="{{ science_of_raw_url }}" class="brand-dropdown__item" role="menuitem" aria-label="Science of Raw">

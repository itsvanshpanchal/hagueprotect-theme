{%- style -%}
  .header-wrapper {
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    border-bottom: 1px solid #e5e5e5;
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding-top: 14px;
    padding-bottom: 14px;
    transition: all 0.2s ease;
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 100%;
    margin: 0;
    padding: 0 16px;
    width: 100%;
    gap: 12px;
  }

  .header__logo-link {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    flex-shrink: 1;
    min-width: 0;
  }

  .header__logo-text {
    font-family: 'Inter', sans-serif;
    font-size: 21px;
    font-weight: 700;
    color: #000000;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 1px;
    line-height: 1.2;
    white-space: nowrap;
  }

  .header__logo-icon {
    width: 22px;
    height: 22px;
    color: #000000;
    margin: 0 -1px;
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
  }

  .header__navigation {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-left: auto;
  }

  @media screen and (max-width: 1024px) {
    .header__navigation {
      display: none;
    }
  }

  .nav-item {
    padding: 12px 0;
  }

  .header__menu-link {
    font-family: 'Inter', sans-serif !important;
    font-size: 13.5px;
    font-weight: 700;
    color: #111111;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .header__menu-link:hover {
    color: #FF2B2B;
  }

  .menu-pill {
    background-color: #111111;
    color: #ffffff !important;
    padding: 8px 18px;
    border-radius: 4px;
    font-family: 'Inter', sans-serif !important;
    font-size: 15px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .menu-pill:hover {
    background-color: #333333;
    transform: translateY(-1px);
    color: #ffffff !important;
  }

  .menu-link {
    font-family: 'Inter', sans-serif !important;
    font-size: 15px;
    font-weight: 800;
    color: #111111 !important;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .menu-link:hover {
    color: #FF2B2B !important;
  }

  /* Full Width Mega Menu Dropdown Panel */
  .megamenu-panel {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background-color: #ffffff !important;
    border-top: 1px solid #e5e5e5;
    border-bottom: 1px solid #e5e5e5;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.08);
    display: none;
    z-index: 1001;
    padding: 48px 0;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .megamenu-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 32px;
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 24px;
    width: 100%;
    align-items: start;
  }

  .megamenu-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .megamenu-heading {
    font-family: 'Inter', sans-serif !important;
    font-size: 14px;
    font-weight: 800;
    color: #111111 !important;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 1.2;
  }

  .megamenu-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .megamenu-link-item a {
    font-family: 'Inter', sans-serif !important;
    font-size: 13.5px;
    font-weight: 500;
    color: #555555 !important;
    text-decoration: none;
    transition: all 0.2s ease;
    display: inline-block;
    line-height: 1.4;
  }

  .megamenu-link-item a:hover {
    color: #FF2B2B !important;
    transform: translateX(3px);
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-left: 32px;
    flex-shrink: 0;
  }

  .header__cart-link,
  .header__account-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter', sans-serif !important;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background-color: #fafafa;
    border: 1px solid #e5e5e5;
    padding: 11px;
    border-radius: 4px;
    color: #111111;
    text-decoration: none;
    transition: all 0.2s;
    width: 42px;
    height: 42px;
  }

  .header__cart-link:hover,
  .header__account-btn:hover {
    background-color: #111111;
    color: #ffffff;
    border-color: #111111;
  }

  .header__mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: #111;
  }

  @media screen and (max-width: 1024px) {
    .header-wrapper {
      overflow: hidden;
      padding-top: 10px;
      padding-bottom: 10px;
    }

    .header-container {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      padding: 0 var(--site-padding, 16px);
      gap: 8px;
    }

    .header__logo-link {
      max-width: 100%;
      overflow: hidden;
    }

    .header__logo-text {
      font-size: clamp(14px, 3.6vw, 18px);
      letter-spacing: 0.03em;
      max-width: 100%;
    }

    .header__logo-icon {
      width: 18px;
      height: 18px;
    }

    .header__actions {
      margin-left: 0;
      gap: 6px;
    }

    .header__account-container {
      display: none;
    }

    .header__mobile-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      order: 10;
      min-width: 40px;
      min-height: 40px;
      padding: 6px;
      flex-shrink: 0;
    }

    .header__cart-link,
    .header__account-btn {
      width: 40px;
      height: 40px;
      min-width: 40px;
      min-height: 40px;
      padding: 8px;
      flex-shrink: 0;
    }

    .header__search-btn {
      order: 1;
    }

    .header__cart-btn {
      order: 2;
    }
  }

  @media screen and (max-width: 380px) {
    .header__logo-text {
      font-size: 13px;
    }

    .header__logo-icon {
      width: 16px;
      height: 16px;
    }

    .header__actions {
      gap: 4px;
    }

    .header__cart-link,
    .header__account-btn,
    .header__mobile-toggle {
      width: 36px;
      height: 36px;
      min-width: 36px;
      min-height: 36px;
    }
  }

  /* Mobile menu drawer */
  .mobile-menu-drawer {
    position: fixed;
    top: 0;
    left: -100%;
    width: 320px;
    max-width: calc(100vw - 40px);
    height: 100%;
    background: #ffffff;
    box-shadow: 8px 0 32px rgba(0,0,0,0.1);
    z-index: 10002;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    overflow-y: auto;
    transition: left 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-menu-drawer.is-active {
    left: 0;
  }

  .mobile-menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.4);
    z-index: 10001;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .mobile-menu-overlay.is-active {
    opacity: 1;
    visibility: visible;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .mobile-nav-link {
    font-family: 'Inter', sans-serif !important;
    font-size: 15px;
    font-weight: 700;
    color: #111111;
    text-transform: uppercase;
    text-decoration: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .mobile-accordion-content {
    display: none;
    flex-direction: column;
    gap: 16px;
    padding: 8px 0 8px 12px;
  }

  .mobile-accordion-category-heading {
    font-family: 'Inter', sans-serif !important;
    font-size: 13px;
    font-weight: 700;
    color: #111;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  /* Profile Dropdown Styles */
  .header__account-container {
    position: relative;
    display: inline-block;
  }

  .profile-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    width: 240px;
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.12);
    display: none;
    z-index: 1002;
    margin-top: 12px;
    padding: 16px 0;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header__account-container:hover .profile-dropdown {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  .dropdown-header {
    padding: 0 20px 12px;
    border-bottom: 1px solid #f0f0f0;
    margin-bottom: 8px;
  }

  .dropdown-user-name {
    display: block;
    font-size: 14px;
    font-weight: 800;
    color: #111;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .dropdown-user-email {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: #888;
  }

  .dropdown-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 20px;
    color: #111;
    text-decoration: none;
    font-size: 13.5px;
    font-weight: 700;
    transition: all 0.2s;
  }

  .dropdown-link:hover {
    background-color: #fafafa;
    color: #FF2B2B;
    padding-left: 24px;
  }

  .dropdown-link svg {
    color: #888;
    transition: color 0.2s;
  }

  .dropdown-link:hover svg {
    color: #FF2B2B;
  }

  .dropdown-footer {
    border-top: 1px solid #f0f0f0;
    margin-top: 8px;
    padding-top: 8px;
  }

  .logout-btn {
    width: 100%;
    background: none;
    border: none;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 20px;
    color: #FF2B2B;
    font-size: 13.5px;
    font-weight: 700;
    cursor: pointer;
    text-align: left;
    transition: all 0.2s;
  }

  .logout-btn:hover {
    background-color: #FFF3F3;
    padding-left: 24px;
  }
{%- endstyle -%}

<header class="header-wrapper" role="banner">
  <div class="header-container">
    
    <!-- Logo -->
    <a href="/" class="header__logo-link" aria-label="{{ shop.name | default: 'HAGUEPROTECT' }} home">
      <span class="header__logo-text">
        HAGUE<span style="color: #FF2B2B;">PR</span><svg class="header__logo-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" aria-hidden="true"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4.5"/><circle cx="12" cy="12" r="1.5"/></svg>TECT
      </span>
    </a>

    <nav class="header__navigation" role="navigation">
      <div class="nav-item">
        <a href="javascript:void(0)" class="menu-pill" id="ShopTrigger">
          SHOP ALL
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-left: 2px;">
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
      <div class="nav-item">
        <a href="/search?view=how-to-use" class="menu-link">HOW TO USE</a>
      </div>
      <div class="nav-item">
        <a href="/search?view=corporate-gifting" class="menu-link">CORPORATE GIFTING</a>
      </div>
      <div class="nav-item">
        <a href="/pages/contact-us" class="menu-link">BUSINESS</a>
      </div>
      <div class="nav-item">
        <a href="/collections/all" class="menu-link">OFFERS</a>
      </div>
    </nav>

    <!-- Actions -->
    <div class="header__actions">
      <!-- Mobile Toggle -->
      <button type="button" class="header__mobile-toggle" onclick="openMobileMenu()" aria-label="Open navigation menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Search Toggle -->
      <button type="button" class="header__cart-link header__search-btn" onclick="openSearch()" aria-label="Open search">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M21 21L16.65 16.65" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Login/Profile Button with Dropdown -->
      <div class="header__account-container">
        <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" class="header__account-btn" aria-label="Account Login">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="7.5" r="4" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M4 20C4 16.13 7.58 13 12 13C16.42 13 20 16.13 20 20" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        
        {%- if customer -%}
        <!-- Profile Dropdown (Native Shopify) -->
        <div class="profile-dropdown" id="ProfileDropdown">
          <div class="dropdown-header">
            <span class="dropdown-user-name">{{ customer.first_name | default: 'Member' | upcase }}</span>
            <span class="dropdown-user-email">{{ customer.email }}</span>
          </div>
          <a href="{{ routes.account_url }}" class="dropdown-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Dashboard
          </a>
          <a href="{{ routes.account_url }}#history" class="dropdown-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Order History
          </a>
          <a href="{{ routes.account_addresses_url }}" class="dropdown-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="10" r="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            My Addresses
          </a>
          <a href="/pages/faq" class="dropdown-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3m0 4h.01" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Support Center
          </a>
          <div class="dropdown-footer">
            <a href="{{ routes.account_logout_url }}" class="logout-btn" style="text-decoration: none;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3H7a2 2 0 00-2 2v14a2 2 0 002 2h8m4-9l-4-4m4 4l-4 4m4-4H9" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Sign Out
            </a>
          </div>
        </div>
        {%- endif -%}
      </div>

      <!-- Cart Button -->
      <a href="/cart" id="HeaderCartBtn" class="header__cart-link header__cart-btn" aria-label="View Cart">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M2 2H4L5.32 8.59C5.52 9.59 6.4 10.32 7.42 10.32H16.14C17.16 10.32 18.04 9.59 18.24 8.59L19.5 2.25H4.25" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="8" cy="19" r="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="16" cy="19" r="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- UNCONSTRAINED FULL-WIDTH MEGA MENU dropdown right inside the header wrapper -->

       data-vr-href="/collections/all?view=vanrosector"
       data-sor-href="/collections/all?view=science-of-raw"
       data-hp-href="/"
       data-brand="{{ brand_context }}">
      {%- if brand_context == 'vanrosector' -%}
        {%- if section.settings.logo_vr != blank -%}
          <img src="{{ section.settings.logo_vr | image_url: width: 150 }}" alt="Vanrosector" class="header__logo-img" width="150" height="55" loading="eager" decoding="async">
        {%- else -%}
          <img src="{{ 'logo-vanrosector.svg' | asset_url }}" alt="Vanrosector" class="header__logo-img" width="150" height="55" loading="eager" decoding="async">
        {%- endif -%}
      {%- elsif brand_context == 'science-of-raw' -%}
        {%- if section.settings.logo_sor != blank -%}

        </div>
        <div class="nav-item">
          <a href="/pages/contact-us" class="menu-link">Business</a>
        </div>
        <div class="nav-item">
          <a href="/collections/all" class="menu-link">Offers</a>
        </div>
      {% endif %}
    </nav>


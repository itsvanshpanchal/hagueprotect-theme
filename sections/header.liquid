  <!-- UNCONSTRAINED FULL-WIDTH MEGA MENU dropdown right inside the header wrapper -->
  {%- assign shop_all_linklist    = linklists[section.settings.shop_all_menu] -%}
  {%- assign vanrosector_linklist = linklists[section.settings.vanrosector_menu] -%}
  {%- assign sor_linklist         = linklists[section.settings.sor_menu] -%}

  <div class="megamenu-panel" id="MegaMenuPanel">

    <!-- ── Brand Tab Bar ─────────────────────────────────── -->
    <div class="megamenu-brand-tabs">

      <!-- Hague Protect tab -->
      <button class="megamenu-brand-tab is-active" data-brand-tab="hp" type="button">
        <img src="{{ hp_logo_url }}" alt="Hague Protect" class="megamenu-tab-logo" width="130" height="24" loading="lazy" decoding="async">
      </button>

      {%- if vanrosector_linklist.links.size > 0 or section.settings.vanrosector_menu != blank -%}
      <button class="megamenu-brand-tab" data-brand-tab="vanrosector" type="button">
        <img src="{{ 'logo-vanrosector.svg' | asset_url }}" alt="Vanrosector" class="megamenu-tab-logo">
      </button>
      {%- endif -%}

      {%- if sor_linklist.links.size > 0 or section.settings.sor_menu != blank -%}
      <button class="megamenu-brand-tab" data-brand-tab="sor" type="button">
        <img src="{{ 'logo-science-of-raw.svg' | asset_url }}" alt="Science of Raw" class="megamenu-tab-logo">
      </button>
      {%- endif -%}

    </div>

    <!-- ── PANE 1: Hague Protect (existing blocks – untouched) ── -->
    <div class="megamenu-brand-pane is-active" id="MegaPane-hp">
      {%- assign megamenu_cols = section.blocks.size -%}
      {%- if shop_all_linklist.links.size > 0 -%}
        {%- assign megamenu_cols = megamenu_cols | plus: 1 -%}
      {%- endif -%}
      {%- if megamenu_cols < 1 -%}{%- assign megamenu_cols = 1 -%}{%- endif -%}
      <div class="megamenu-grid" style="grid-template-columns: repeat({{ megamenu_cols }}, 1fr); gap: 40px;">
        {%- for block in section.blocks -%}
          {%- render 'mega-menu-column', block: block, mode: 'desktop' -%}
        {%- endfor -%}
        {%- if shop_all_linklist.links.size > 0 -%}
          <div class="megamenu-col">
            <h3 class="megamenu-heading" style="color: #FF2B2B !important; margin-bottom: 12px;">{{ shop_all_linklist.title | default: 'More Products' }}</h3>
            <ul class="megamenu-links">
              {%- for link in shop_all_linklist.links -%}
                <li class="megamenu-link-item"><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- ── PANE 2: Vanrosector ──────────────────────────────── -->
    <div class="megamenu-brand-pane" id="MegaPane-vanrosector">
      {%- if vanrosector_linklist.links.size > 0 -%}
        {%- comment -%} Group links by their parent titles if nested, else show flat columns {%- endcomment -%}
        <div class="megamenu-grid" style="grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 40px;">
          {%- assign vr_current_heading = '' -%}
          {%- assign vr_in_col = false -%}
          {%- for link in vanrosector_linklist.links -%}
            {%- if link.links.size > 0 -%}
              {%- if vr_in_col -%}</ul></div>{%- endif -%}
              <div class="megamenu-col">
                <h3 class="megamenu-heading" style="margin-bottom: 12px;">{{ link.title }}</h3>
                <ul class="megamenu-links">
                  {%- for sub in link.links -%}
                    <li class="megamenu-link-item"><a href="{{ sub.url }}">{{ sub.title }}</a></li>
                  {%- endfor -%}
                </ul>
              </div>
              {%- assign vr_in_col = false -%}
            {%- else -%}
              {%- unless vr_in_col -%}<div class="megamenu-col"><ul class="megamenu-links">{%- assign vr_in_col = true -%}{%- endunless -%}
              <li class="megamenu-link-item"><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endif -%}
          {%- endfor -%}
          {%- if vr_in_col -%}</ul></div>{%- endif -%}
        </div>
      {%- else -%}
        <div style="max-width:1320px;margin:0 auto;padding:0 24px;">
          <p style="font-family:'Inter',sans-serif;font-size:13px;color:#aaa;padding:20px 0;">No menu assigned — go to <strong>Theme Editor → Header → Vanrosector Menu</strong> and select a Shopify navigation menu.</p>
        </div>
      {%- endif -%}
    </div>

    <!-- ── PANE 3: Science of Raw ───────────────────────────── -->
    <div class="megamenu-brand-pane" id="MegaPane-sor">
      {%- if sor_linklist.links.size > 0 -%}
        <div class="megamenu-grid" style="grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 40px;">
          {%- assign sor_in_col = false -%}
          {%- for link in sor_linklist.links -%}
            {%- if link.links.size > 0 -%}
              {%- if sor_in_col -%}</ul></div>{%- endif -%}
              <div class="megamenu-col">
                <h3 class="megamenu-heading" style="margin-bottom: 12px;">{{ link.title }}</h3>
                <ul class="megamenu-links">
                  {%- for sub in link.links -%}
                    <li class="megamenu-link-item"><a href="{{ sub.url }}">{{ sub.title }}</a></li>
                  {%- endfor -%}
                </ul>
              </div>
              {%- assign sor_in_col = false -%}
            {%- else -%}
              {%- unless sor_in_col -%}<div class="megamenu-col"><ul class="megamenu-links">{%- assign sor_in_col = true -%}{%- endunless -%}
              <li class="megamenu-link-item"><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endif -%}
          {%- endfor -%}
          {%- if sor_in_col -%}</ul></div>{%- endif -%}
        </div>
      {%- else -%}
        <div style="max-width:1320px;margin:0 auto;padding:0 24px;">
          <p style="font-family:'Inter',sans-serif;font-size:13px;color:#aaa;padding:20px 0;">No menu assigned — go to <strong>Theme Editor → Header → Science of Raw Menu</strong> and select a Shopify navigation menu.</p>
        </div>
      {%- endif -%}
    </div>

  </div>

  <!-- Premium Full-Screen Search Overlay -->
  <div id="ThemeSearchView" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.98); z-index: 10000; backdrop-filter: blur(8px);">
    <div style="position: absolute; top: 24px; right: 24px;">
      <button onclick="closeSearch()" style="background: none; border: none; cursor: pointer; color: #111; padding: 12px; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: background 0.2s;" onmouseover="this.style.backgroundColor='#eee';" onmouseout="this.style.backgroundColor='transparent';">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
    
    <div style="max-width: 800px; width: 100%; margin: 15vh auto; padding: 0 24px;">
      <h2 style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 800; color: #FF2B2B; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 16px; text-align: center;">Search our store</h2>
      <form action="/search" method="get" role="search" style="position: relative;">
        <input type="text" 
               name="q" 
               id="SearchInput" 
               placeholder="What are you looking for?" 
               autocomplete="off"
               style="width: 100%; background: transparent; border: none; border-bottom: 2px solid #111; padding: 16px 0; font-family: 'Inter', sans-serif; font-size: clamp(24px, 4vw, 42px); font-weight: 800; color: #111; outline: none; transition: border-color 0.3s;"
               onfocus="this.style.borderBottomColor='#FF2B2B'"
               onblur="this.style.borderBottomColor='#111'">
        <button type="submit" style="position: absolute; right: 0; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: #111;">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="M21 21L16.65 16.65"/></svg>
        </button>
        <!-- Predictive Search Results Container -->
        <div id="PredictiveSearchContainer" style="position: absolute; top: 100%; left: 0; width: 100%; background: #fff; border-radius: 0 0 16px 16px; box-shadow: 0 20px 40px rgba(0,0,0,0.1); display: none; z-index: 10; margin-top: 4px; overflow: hidden; border-top: 1px solid #f0f0f0;">
          <div id="PredictiveSearchResults" style="max-height: 450px; overflow-y: auto; padding: 16px;"></div>
        </div>
      </form>
      <div style="margin-top: 40px; display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;">
        <span style="font-size: 13px; color: #888; font-weight: 600; text-transform: uppercase;">Popular:</span>
        <a href="/search?q=kit" style="font-size: 13px; color: #111; text-decoration: none; font-weight: 700; border-bottom: 1px solid #ddd;">Kits</a>
        <a href="/search?q=cleaner" style="font-size: 13px; color: #111; text-decoration: none; font-weight: 700; border-bottom: 1px solid #ddd;">Cleaners</a>
        <a href="/search?q=suede" style="font-size: 13px; color: #111; text-decoration: none; font-weight: 700; border-bottom: 1px solid #ddd;">Suede Care</a>
      </div>
    </div>
  </div>
</header>


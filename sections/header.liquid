        <img
          src="{{ logo_one_url }}"
          alt="{{ logo_one_alt }}"
          class="{{ logo_one_img_class }}"
          width="{{ logo_one_width }}"
          height="46"
          loading="eager"
          decoding="async"
        >
      </a>

      <div class="header__logo-partners" aria-label="Partner brands">
        <a href="{{ logo_two_link }}" class="{{ logo_two_link_class }}" aria-label="{{ logo_two_alt }}">
          <img
            src="{{ logo_two_url }}"
            alt="{{ logo_two_alt }}"
            class="{{ logo_two_img_class }}"
            height="46"
            loading="eager"
            decoding="async"
          >
        </a>

        <a href="{{ logo_three_link }}" class="{{ logo_three_link_class }}" aria-label="{{ logo_three_alt }}">
          <img
            src="{{ logo_three_url }}"
            alt="{{ logo_three_alt }}"
            class="{{ logo_three_img_class }}"
            height="54"
            loading="eager"
            decoding="async"
          >
        </a>
      </div>
    </div>


{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .header-wrapper {
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    border-bottom: 1px solid #e5e5e5;
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding-top: 14px;
    padding-bottom: 14px;
    transition: all 0.2s ease;
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--site-max-width);
    margin-left: auto;
    margin-right: auto;
    padding: 0 var(--site-padding, 16px);
    width: 100%;
    gap: 12px;
  }

  .header__logo-link {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    flex-shrink: 1;
    min-width: 0;
  }

  .header__logo-text {
    font-family: var(--font-family-heading) !important;
    font-size: var(--heading-size-xl, 21px) !important;
    font-weight: var(--font-weight-heading, 700) !important;
    font-style: var(--font-style-heading, normal) !important;
    color: #000000;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 1px;
    line-height: 1.2;
    white-space: nowrap;
  }

  .header__logo-icon {
    width: 22px;
    height: 22px;
    color: #000000;
    margin: 0 -1px;
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
  }

  .header__logo-img {
    height: auto;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    display: block;
  }

  .header__logo-group {
    display: flex;
    align-items: center;
    gap: clamp(18px, 3vw, 36px);
    flex-shrink: 1;
    min-width: 0;
  }

  .header__logo-partners {
    display: flex;
    align-items: center;
    gap: {{ section.settings.partner_logo_gap | default: 8 }}px;
    flex-shrink: 0;
  }

  .header__logo-partners .header__logo-link {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    width: auto;
    line-height: 0;
  }

  .header__logo-partners .header__logo-link:first-child .header__logo-img {
    object-position: right center;
  }

  .header__logo-partners .header__logo-link:last-child .header__logo-img {
    object-position: left center;
  }

  .header__logo-partners .header__logo-link:last-child {
    margin-left: -6px;
  }

  .header__logo-link--primary .header__logo-img {
    max-width: var(--logo-primary-max, 200px);
  }

  .header__logo-link--brand .header__logo-img {
    height: 46px;
    width: auto;
    max-width: 168px;
    object-fit: contain;
  }

  .header__logo-link--sor .header__logo-img {
    height: 54px;
    width: auto;
    max-width: 176px;
    object-fit: contain;
  }

  .header__logo-link--sor-main .header__logo-img {
    height: auto;
    max-width: 220px;
  }

  .header__navigation {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-left: auto;
  }

  @media screen and (max-width: 1024px) {
    .header__navigation {
      display: none;
    }
  }

  .nav-item {
    padding: 12px 0;
  }

  .header__brand-nav {
    position: relative;
  }

  .header__brand-nav .menu-link {
    gap: 6px;
  }

  .brand-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    min-width: 190px;
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.12);
    padding: 12px;
    display: none;
    opacity: 0;
    z-index: 1002;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .header__brand-nav.is-open .brand-dropdown {
    display: block;
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .brand-dropdown__item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px 14px;
    border-radius: 8px;
    text-decoration: none;
    color: #111111;
    font-family: var(--font-family-sans) !important;
    font-size: 13px;
    font-weight: var(--font-weight-sans, 700) !important;
    font-style: var(--font-style-sans, normal) !important;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .brand-dropdown__item:hover {
    background-color: #fafafa;
    color: #FF2B2B;
  }

  .brand-dropdown__logo {
    height: 36px;
    width: auto;
    max-width: 150px;
    object-fit: contain;
    display: block;
    flex-shrink: 0;
  }

  .brand-dropdown__logo--sor {
    height: 40px;
    max-width: 132px;
  }

  .mobile-brand-link {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 8px;
    color: #666;
    text-decoration: none;
    font-family: var(--font-family-sans) !important;
    font-size: 14px;
    font-weight: var(--font-weight-sans, 600) !important;
    font-style: var(--font-style-sans, normal) !important;
  }

  .mobile-brand-link img {
    height: 28px;
    width: auto;
    max-width: 120px;
    object-fit: contain;
  }

  .header__menu-link {
    font-family: var(--font-family-sans) !important;
    font-size: 13.5px;
    font-weight: var(--font-weight-sans, 700) !important;
    font-style: var(--font-style-sans, normal) !important;
    color: #111111;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .header__menu-link:hover {
    color: #FF2B2B;
  }

  .menu-pill {
    background-color: #111111;
    color: #ffffff !important;
    padding: 8px 18px;
    border-radius: 4px;
    font-family: var(--font-family-sans) !important;
    font-size: var(--body-font-size, 15px) !important;
    font-weight: var(--font-weight-sans, 800) !important;
    font-style: var(--font-style-sans, normal) !important;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .menu-pill:hover {
    background-color: #333333;
    transform: translateY(-1px);
    color: #ffffff !important;
  }

  .menu-link {
    font-family: var(--font-family-sans) !important;
    font-size: var(--body-font-size, 15px) !important;
    font-weight: var(--font-weight-sans, 800) !important;
    font-style: var(--font-style-sans, normal) !important;
    color: #111111 !important;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .menu-link:hover {
    color: #FF2B2B !important;
  }

  /* Full Width Mega Menu Dropdown Panel */
  .megamenu-panel {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background-color: #ffffff !important;
    border-top: 1px solid #e5e5e5;
    border-bottom: 1px solid #e5e5e5;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.08);
    display: none;
    z-index: 1001;
    padding: 48px 0;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .megamenu-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 32px;
    max-width: var(--site-max-width);
    margin: 0 auto;
    padding: 0 24px;
    width: 100%;
    align-items: start;
  }

  .megamenu-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Mega menu: titles + subcategory links share the same editor font group */
  #shopify-section-{{ section.id }} h3.megamenu-heading,
  #shopify-section-{{ section.id }} .megamenu-heading,
  #shopify-section-{{ section.id }} h4.mobile-accordion-category-heading,
  #shopify-section-{{ section.id }} .mobile-accordion-category-heading,
  .megamenu-heading {
    font-family: var(--font-family-h2, var(--font-family-heading)) !important;
    font-size: var(--section-heading-size, 14px) !important;
    font-weight: var(--font-weight-h2, 800) !important;
    font-style: var(--font-style-h2, normal) !important;
    color: #111111 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.08em !important;
    margin: 0;
    line-height: 1.2 !important;
  }

  .megamenu-heading-link__a {
    font-family: inherit !important;
    font-size: inherit !important;
    font-weight: inherit !important;
    font-style: inherit !important;
    color: inherit !important;
    text-transform: inherit !important;
    letter-spacing: inherit !important;
    line-height: inherit !important;
    text-decoration: none;
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .megamenu-heading-link__a:hover {
    color: #FF2B2B !important;
  }

  .megamenu-heading-link--accent .megamenu-heading-link__a {
    color: #FF2B2B !important;
  }

  .megamenu-heading-link--accent .megamenu-heading-link__a:hover {
    color: #cc2222 !important;
  }

  .mobile-accordion-category-heading.megamenu-heading-link {
    margin-bottom: 6px;
  }

  .mobile-accordion-category-heading.megamenu-heading-link--accent {
    color: #FF2B2B !important;
  }

  .mobile-accordion-category-heading .megamenu-heading-link__a {
    width: 100%;
  }

  .megamenu-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .megamenu-panel,
  #shopify-section-{{ section.id }} .megamenu-panel a,
  #shopify-section-{{ section.id }} .megamenu-panel span,
  #shopify-section-{{ section.id }} .megamenu-link-item,
  #shopify-section-{{ section.id }} .megamenu-link-item a,
  #shopify-section-{{ section.id }} .mobile-menu-drawer a,
  #shopify-section-{{ section.id }} .mobile-accordion-content a,
  .megamenu-link-item a {
    font-family: var(--font-family-h2, var(--font-family-heading)) !important;
    font-style: var(--font-style-h2, normal) !important;
  }

  #shopify-section-{{ section.id }} .megamenu-link-item a,
  #shopify-section-{{ section.id }} .mobile-accordion-content a,
  .megamenu-link-item a {
    font-size: var(--section-heading-size, 13.5px) !important;
    font-weight: var(--font-weight-h2, 500) !important;
    color: #555555 !important;
    text-decoration: none;
    transition: all 0.2s ease;
    display: inline-block;
    line-height: 1.4;
  }

  #shopify-section-{{ section.id }} .megamenu-panel span {
    font-weight: var(--font-weight-h2, 700) !important;
  }

  .megamenu-link-item a:hover {
    color: #FF2B2B !important;
    transform: translateX(3px);
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-left: 32px;
    flex-shrink: 0;
  }

  .header__cart-link,
  .header__account-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-family-sans) !important;
    font-size: 13px;
    font-weight: var(--font-weight-sans, 700) !important;
    font-style: var(--font-style-sans, normal) !important;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background-color: #fafafa;
    border: 1px solid #e5e5e5;
    padding: 11px;
    border-radius: 4px;
    color: #111111;
    text-decoration: none;
    transition: all 0.2s;
    width: 42px;
    height: 42px;
  }

  .header__cart-link:hover,
  .header__account-btn:hover {
    background-color: #111111;
    color: #ffffff;
    border-color: #111111;
  }

  .header__mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: #111;
  }

  @media screen and (max-width: 1024px) {
    .header-wrapper {
      padding-top: 8px;
      padding-bottom: 8px;
    }

    .header-container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 var(--site-padding, 16px);
      gap: 10px;
    }

    .header__logo-group {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      grid-template-rows: auto auto;
      column-gap: 10px;
      row-gap: 5px;
      align-items: center;
      flex: 1;
      min-width: 0;
      max-width: calc(100% - 118px);
    }

    .header__logo-link--primary {
      grid-column: 1;
      grid-row: 1 / 3;
      align-self: center;
      flex-shrink: 0;
    }

    .header__logo-link--primary .header__logo-img {
      height: 34px;
      width: auto;
      max-width: min(var(--logo-primary-max, 200px), 38vw) !important;
      object-fit: contain;
    }

    .header__logo-partners {
      grid-column: 2;
      grid-row: 1 / 3;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      gap: {{ section.settings.partner_logo_gap | default: 8 | at_most: 10 }}px;
      min-width: 0;
      padding-left: 12px;
      border-left: 1px solid #e8e8e8;
    }

    .header__logo-partners .header__logo-link {
      display: flex;
      align-items: center;
      max-width: 100%;
      line-height: 0;
    }

    .header__logo-partners .header__logo-img {
      height: 22px !important;
      width: auto !important;
      max-width: min(42vw, 128px) !important;
      object-fit: contain;
      object-position: left center;
    }

    .header__logo-partners .header__logo-link--sor .header__logo-img,
    .header__logo-partners .header__logo-link--sor-main .header__logo-img {
      height: 24px !important;
      max-width: min(44vw, 132px) !important;
    }

    .header__logo-text {
      font-size: var(--heading-size-xl, 18px) !important;
      letter-spacing: 0.03em;
      max-width: 100%;
    }

    .header__logo-icon {
      width: 18px;
      height: 18px;
    }

    .header__actions {
      margin-left: 0;
      gap: 4px;
      flex-shrink: 0;
    }

    .header__account-container {
      display: none;
    }

    .header__mobile-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      min-width: 38px;
      min-height: 38px;
      padding: 6px;
      flex-shrink: 0;
    }

    .header__cart-link,
    .header__account-btn {
      width: 38px;
      height: 38px;
      min-width: 38px;
      min-height: 38px;
      padding: 7px;
      flex-shrink: 0;
    }
  }

  @media screen and (min-width: 600px) and (max-width: 1024px) {
    .header__logo-partners {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      gap: {{ section.settings.partner_logo_gap | default: 8 }}px;
    }

    .header__logo-partners .header__logo-img {
      height: 24px !important;
      max-width: min(22vw, 120px) !important;
    }
  }

  @media screen and (max-width: 480px) {
    .header__logo-group {
      column-gap: 8px;
      max-width: calc(100% - 108px);
    }

    .header__logo-link--primary .header__logo-img {
      height: 30px;
      max-width: min(var(--logo-primary-max, 200px), 34vw) !important;
    }

    .header__logo-partners {
      padding-left: 8px;
      gap: {{ section.settings.partner_logo_gap | default: 8 | at_most: 8 }}px;
    }

    .header__logo-partners .header__logo-img {
      height: 20px !important;
      max-width: min(40vw, 108px) !important;
    }

    .header__logo-partners .header__logo-link--sor .header__logo-img,
    .header__logo-partners .header__logo-link--sor-main .header__logo-img {
      height: 22px !important;
      max-width: min(42vw, 112px) !important;
    }
  }

  @media screen and (max-width: 380px) {
    .header__logo-text {
      font-size: var(--heading-size-xl, 13px) !important;
    }

    .header__logo-icon {
      width: 16px;
      height: 16px;
    }

    .header__actions {
      gap: 2px;
    }

    .header__cart-link,
    .header__account-btn,
    .header__mobile-toggle {
      width: 34px;
      height: 34px;
      min-width: 34px;
      min-height: 34px;
      padding: 6px;
    }

    .header__logo-group {
      max-width: calc(100% - 98px);
    }
  }

  /* Mobile menu drawer */
  .mobile-menu-drawer {
    position: fixed;
    top: 0;
    left: -100%;
    width: 320px;
    max-width: calc(100vw - 40px);
    height: 100%;
    background: #ffffff;
    box-shadow: 8px 0 32px rgba(0,0,0,0.1);
    z-index: 10002;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    overflow-y: auto;
    transition: left 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-menu-drawer.is-active {
    left: 0;
  }

  .mobile-menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.4);
    z-index: 10001;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .mobile-menu-overlay.is-active {
    opacity: 1;
    visibility: visible;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .mobile-nav-link {
    font-family: var(--font-family-sans) !important;
    font-size: 15px;
    font-weight: var(--font-weight-sans, 700) !important;
    font-style: var(--font-style-sans, normal) !important;
    color: #111111;
    text-transform: uppercase;
    text-decoration: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .mobile-accordion-content {
    display: none;
    flex-direction: column;
    gap: 16px;
    padding: 8px 0 8px 12px;
  }

  #shopify-section-{{ section.id }} .mobile-accordion-category-heading,
  .mobile-accordion-category-heading {
    font-family: var(--font-family-h2, var(--font-family-heading)) !important;
    font-size: var(--section-heading-size, 13px) !important;
    font-weight: var(--font-weight-h2, 700) !important;
    font-style: var(--font-style-h2, normal) !important;
    color: #111 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.06em !important;
    margin-bottom: 6px;
    line-height: 1.2 !important;
  }
  /* Profile Dropdown Styles */
  .header__account-container {
    position: relative;
    display: inline-block;
  }

  .profile-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    width: 240px;
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.12);
    display: none;
    z-index: 1002;
    margin-top: 12px;
    padding: 16px 0;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header__account-container:hover .profile-dropdown {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  .dropdown-header {
    padding: 0 20px 12px;
    border-bottom: 1px solid #f0f0f0;
    margin-bottom: 8px;
  }

  .dropdown-user-name {
    display: block;
    font-family: var(--font-family-sans) !important;
    font-size: 14px;
    font-weight: var(--font-weight-sans, 800) !important;
    font-style: var(--font-style-sans, normal) !important;
    color: #111;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .dropdown-user-email {
    display: block;
    font-family: var(--font-family-sans) !important;
    font-size: 12px;
    font-weight: var(--font-weight-sans, 500) !important;
    font-style: var(--font-style-sans, normal) !important;
    color: #888;
  }

  .dropdown-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 20px;
    color: #111;
    text-decoration: none;
    font-family: var(--font-family-sans) !important;
    font-size: 13.5px;
    font-weight: var(--font-weight-sans, 700) !important;
    font-style: var(--font-style-sans, normal) !important;
    transition: all 0.2s;
  }

  .dropdown-link:hover {
    background-color: #fafafa;
    color: #FF2B2B;
    padding-left: 24px;
  }

  .dropdown-link svg {
    color: #888;
    transition: color 0.2s;
  }

  .dropdown-link:hover svg {
    color: #FF2B2B;
  }

  .dropdown-footer {
    border-top: 1px solid #f0f0f0;
    margin-top: 8px;
    padding-top: 8px;
  }

  .logout-btn {
    width: 100%;
    background: none;
    border: none;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 20px;
    color: #FF2B2B;
    font-size: 13.5px;
    font-weight: 700;
    cursor: pointer;
    text-align: left;
    transition: all 0.2s;
  }

  .logout-btn:hover {
    background-color: #FFF3F3;
    padding-left: 24px;
  }
{%- endstyle -%}

<header class="header-wrapper" role="banner">
  {%- liquid
    assign header_logo_width = section.settings.logo_width | default: 200
    if section.settings.logo_image != blank
      assign header_logo_url = section.settings.logo_image | image_url: width: 400
    elsif section.settings.logo_text != blank and section.settings.logo_text contains '.'
      assign header_logo_url = section.settings.logo_text | asset_url
    else
      assign header_logo_url = 'logo-hagueprotect.png' | asset_url
    endif

    assign vanrosector_url = section.settings.vanrosector_link | default: '/collections/all?view=vanrosector'
    assign science_of_raw_url = section.settings.sor_link | default: '/collections/all?view=science-of-raw'

    if section.settings.logo_vr != blank
      assign vr_logo_url = section.settings.logo_vr | image_url: width: 400
    else
      assign vr_logo_url = 'logo-vanrosector.svg' | asset_url
    endif

    if section.settings.logo_sor != blank
      assign sor_logo_url = section.settings.logo_sor | image_url: width: 400
    else
      assign sor_logo_url = 'logo-science-of-raw.svg' | asset_url
    endif

    assign hague_home_url = routes.root_url
    if section.settings.brand_hague_link != blank
      assign hague_home_url = section.settings.brand_hague_link
    endif
    assign brand_menu_label = section.settings.brand_menu_label | default: 'BRAND'
    assign active_brand = 'hague'

    if template.suffix == 'vanrosector' or request.path contains 'vanrosector'
      assign active_brand = 'vanrosector'
    elsif template.suffix == 'science-of-raw' or request.path contains 'science-of-raw'
      assign active_brand = 'science-of-raw'
    endif

    assign logo_one_url = header_logo_url
    assign logo_one_alt = 'Hague Protect'
    assign logo_one_link = hague_home_url
    assign logo_one_width = header_logo_width
    assign logo_one_link_class = 'header__logo-link'
    assign logo_one_img_class = 'header__logo-img'

    assign logo_two_url = vr_logo_url
    assign logo_two_alt = 'Vanrosector'
    assign logo_two_link = vanrosector_url
    assign logo_two_link_class = 'header__logo-link header__logo-link--brand'
    assign logo_two_img_class = 'header__logo-img'

    assign logo_three_url = sor_logo_url
    assign logo_three_alt = 'Science of Raw'
    assign logo_three_link = science_of_raw_url
    assign logo_three_link_class = 'header__logo-link header__logo-link--brand header__logo-link--sor'
    assign logo_three_img_class = 'header__logo-img'

    if active_brand == 'vanrosector'
      assign logo_one_url = vr_logo_url
      assign logo_one_alt = 'Vanrosector'
      assign logo_one_link = vanrosector_url
      assign logo_one_width = header_logo_width
      assign logo_one_link_class = 'header__logo-link'
      assign logo_one_img_class = 'header__logo-img'

      assign logo_two_url = header_logo_url
      assign logo_two_alt = 'Hague Protect'
      assign logo_two_link = hague_home_url
      assign logo_two_link_class = 'header__logo-link header__logo-link--brand'
      assign logo_two_img_class = 'header__logo-img'
    elsif active_brand == 'science-of-raw'
      assign logo_one_url = sor_logo_url
      assign logo_one_alt = 'Science of Raw'
      assign logo_one_link = science_of_raw_url
      assign logo_one_width = header_logo_width
      assign logo_one_link_class = 'header__logo-link header__logo-link--sor-main'
      assign logo_one_img_class = 'header__logo-img'

      assign logo_two_url = header_logo_url
      assign logo_two_alt = 'Hague Protect'
      assign logo_two_link = hague_home_url
      assign logo_two_link_class = 'header__logo-link header__logo-link--brand'
      assign logo_two_img_class = 'header__logo-img'

      assign logo_three_url = vr_logo_url
      assign logo_three_alt = 'Vanrosector'
      assign logo_three_link = vanrosector_url
      assign logo_three_link_class = 'header__logo-link header__logo-link--brand'
      assign logo_three_img_class = 'header__logo-img'
    endif
  -%}

  <div class="header-container">
    

          src="{{ hp_logo_url }}"
          alt="HagueProtect"
          class="header__logo-img header__logo-img--hp"
          width="260"
          height="36"
          loading="eager"
          decoding="async"
        >
      {%- endif -%}
    </a>
    <script>
      (function(){
        var el = document.getElementById('HeaderLogoLink');
        if (!el) return;
        var loc = (window.location.pathname + window.location.search + window.location.hash).toLowerCase();
        var currentBrand = el.getAttribute('data-brand') || 'hagueprotect';
        var needBrand = 'hagueprotect';
        if (loc.indexOf('vanrosector') !== -1) needBrand = 'vanrosector';
        else if (loc.indexOf('science-of-raw') !== -1 || loc.indexOf('science_of_raw') !== -1) needBrand = 'science-of-raw';
        if (needBrand !== currentBrand) {
          if (needBrand === 'vanrosector') {
            el.href = el.getAttribute('data-vr-href');
            el.innerHTML = '<img src="' + el.getAttribute('data-vr-logo') + '" alt="Vanrosector" class="header__logo-img" width="150" height="55">';
          } else if (needBrand === 'science-of-raw') {
            el.href = el.getAttribute('data-sor-href');
            el.innerHTML = '<img src="' + el.getAttribute('data-sor-logo') + '" alt="Science of Raw" class="header__logo-img" width="150" height="75">';
          } else if (needBrand === 'hagueprotect') {
            el.href = el.getAttribute('data-hp-href') || '/';
            var hpLogo = el.getAttribute('data-hp-logo');
            el.innerHTML = '<img src="' + hpLogo + '" alt="HagueProtect" class="header__logo-img header__logo-img--hp" width="260" height="36">';
          }
        }
      })();

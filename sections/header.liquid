{%- style -%}
  .header-wrapper {
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    border-bottom: 1px solid #e5e5e5;
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding-top: 14px;
    padding-bottom: 14px;
    transition: all 0.2s ease;
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 100%;
    margin: 0;
    padding: 0 16px;
    width: 100%;
    gap: 12px;
  }

  .header__logo-link {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    flex-shrink: 1;
    min-width: 0;
  }

  .header__logo-text {
    font-family: 'Inter', sans-serif;
    font-size: 21px;
    font-weight: 700;
    color: #000000;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 1px;
    line-height: 1.2;
    white-space: nowrap;
  }

  .header__logo-icon {
    width: 22px;
    height: 22px;
    color: #000000;
    margin: 0 -1px;
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
  }

  .header__logo-img {
    height: 38px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  .header__logo-img--hp {
    height: 36px;
    width: auto;
    max-width: min(260px, 52vw);
    object-fit: contain;
  }

  @media screen and (max-width: 1024px) {
    .header__logo-img {
      height: 28px;
    }

    .header__logo-img--hp {
      height: 26px;
      max-width: min(200px, 48vw);
    }
  }

  .header__navigation {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-left: auto;
  }

  @media screen and (max-width: 1024px) {
    .header__navigation {
      display: none;
    }
  }

  .nav-item {
    padding: 12px 0;
  }

  .header__menu-link {
    font-family: 'Inter', sans-serif !important;
    font-size: 13.5px;
    font-weight: 700;
    color: #111111;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .header__menu-link:hover {
    color: #FF2B2B;
  }

  .menu-pill {
    background-color: #111111;
    color: #ffffff !important;
    padding: 8px 18px;
    border-radius: 4px;
    font-family: 'Inter', sans-serif !important;
    font-size: 15px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .menu-pill:hover {
    background-color: #333333;
    transform: translateY(-1px);
    color: #ffffff !important;
  }

  .menu-link {
    font-family: 'Inter', sans-serif !important;
    font-size: 15px;
    font-weight: 800;
    color: #111111 !important;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .menu-link:hover {
    color: #FF2B2B !important;
  }

  /* Full Width Mega Menu Dropdown Panel */
  .megamenu-panel {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background-color: #ffffff !important;
    border-top: 1px solid #e5e5e5;
    border-bottom: 1px solid #e5e5e5;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.08);
    display: none;
    z-index: 1001;
    padding: 0;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  /* ── Brand tab bar inside megamenu ───────────────────────── */
  .megamenu-brand-tabs {
    display: flex;
    align-items: center;
    gap: 0;
    border-bottom: 1px solid #ebebeb;
    padding: 0 40px;
    background: #fafafa;
  }

  .megamenu-brand-tab {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #888;
    padding: 14px 24px;
    cursor: pointer;
    border: none;
    background: none;
    border-bottom: 3px solid transparent;
    margin-bottom: -1px;
    transition: color 0.2s, border-color 0.2s;
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }

  .megamenu-brand-tab:hover {
    color: #111;
  }

  .megamenu-brand-tab.is-active {
    color: #111;
    border-bottom-color: #FF2B2B;
  }

  .megamenu-tab-logo {
    height: 18px;
    width: auto;
    display: block;
    opacity: 0.55;
    transition: opacity 0.2s;
  }

  .megamenu-brand-tab:hover .megamenu-tab-logo,
  .megamenu-brand-tab.is-active .megamenu-tab-logo {
    opacity: 1;
  }

  /* ── Brand panes ─────────────────────────────────────────── */
  .megamenu-brand-pane {
    display: none;
    padding: 40px 0;
  }

  .megamenu-brand-pane.is-active {
    display: block;
  }

  .megamenu-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 32px;
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 24px;
    width: 100%;
    align-items: start;
  }

  .megamenu-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .megamenu-heading {
    font-family: 'Inter', sans-serif !important;
    font-size: 14px;
    font-weight: 800;
    color: #111111 !important;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 1.2;
  }

  .megamenu-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .megamenu-link-item a {
    font-family: 'Inter', sans-serif !important;
    font-size: 13.5px;
    font-weight: 500;
    color: #555555 !important;
    text-decoration: none;
    transition: all 0.2s ease;
    display: inline-block;
    line-height: 1.4;
  }

  .megamenu-link-item a:hover {
    color: #FF2B2B !important;
    transform: translateX(3px);
  }

  /* ── Mobile brand section headings ──────────────────────── */
  .mobile-brand-section-heading {
    font-family: 'Inter', sans-serif !important;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    color: #FF2B2B;
    text-transform: uppercase;
    padding: 14px 0 6px;
    border-top: 1px solid #f0f0f0;
    margin-top: 4px;
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-left: 32px;
    flex-shrink: 0;
  }

  .header__cart-link,
  .header__account-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter', sans-serif !important;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background-color: #fafafa;
    border: 1px solid #e5e5e5;
    padding: 11px;
    border-radius: 4px;
    color: #111111;
    text-decoration: none;
    transition: all 0.2s;
    width: 42px;
    height: 42px;
  }

  .header__cart-link:hover,
  .header__account-btn:hover {
    background-color: #111111;
    color: #ffffff;
    border-color: #111111;
  }

  .header__mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: #111;
  }

  @media screen and (max-width: 1024px) {
    .header-wrapper {
      overflow: hidden;
      padding-top: 10px;
      padding-bottom: 10px;
    }

    .header-container {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      padding: 0 var(--site-padding, 16px);
      gap: 8px;
    }

    .header__logo-link {
      max-width: 100%;
      overflow: hidden;
    }

    .header__logo-text {
      font-size: clamp(14px, 3.6vw, 18px);
      letter-spacing: 0.03em;
      max-width: 100%;
    }

    .header__logo-icon {
      width: 18px;
      height: 18px;
    }

    .header__actions {
      margin-left: 0;
      gap: 6px;
    }

    .header__account-container {
      display: none;
    }

    .header__mobile-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      order: 10;
      min-width: 40px;
      min-height: 40px;
      padding: 6px;
      flex-shrink: 0;
    }

    .header__cart-link,
    .header__account-btn {
      width: 40px;
      height: 40px;
      min-width: 40px;
      min-height: 40px;
      padding: 8px;
      flex-shrink: 0;
    }

    .header__search-btn {
      order: 1;
    }

    .header__cart-btn {
      order: 2;
    }
  }

  @media screen and (max-width: 380px) {
    .header__logo-text {
      font-size: 13px;
    }

    .header__logo-icon {
      width: 16px;
      height: 16px;
    }

    .header__actions {
      gap: 4px;
    }

    .header__cart-link,
    .header__account-btn,
    .header__mobile-toggle {
      width: 36px;
      height: 36px;
      min-width: 36px;
      min-height: 36px;
    }
  }

  /* Mobile menu drawer */
  .mobile-menu-drawer {
    position: fixed;
    top: 0;
    left: -100%;
    width: 320px;
    max-width: calc(100vw - 40px);
    height: 100%;
    background: #ffffff;
    box-shadow: 8px 0 32px rgba(0,0,0,0.1);
    z-index: 10002;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    overflow-y: auto;
    transition: left 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-menu-drawer.is-active {
    left: 0;
  }

  .mobile-menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.4);
    z-index: 10001;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .mobile-menu-overlay.is-active {
    opacity: 1;
    visibility: visible;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .mobile-nav-link {
    font-family: 'Inter', sans-serif !important;
    font-size: 15px;
    font-weight: 700;
    color: #111111;
    text-transform: uppercase;
    text-decoration: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .mobile-accordion-content {
    display: none;
    flex-direction: column;
    gap: 16px;
    padding: 8px 0 8px 12px;
  }

  .mobile-accordion-category-heading {
    font-family: 'Inter', sans-serif !important;
    font-size: 13px;
    font-weight: 700;
    color: #111;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  /* Profile Dropdown Styles */
  .header__account-container {
    position: relative;
    display: inline-block;
  }

  .profile-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    width: 240px;
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.12);
    display: none;
    z-index: 1002;
    margin-top: 12px;
    padding: 16px 0;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header__account-container:hover .profile-dropdown {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  .dropdown-header {
    padding: 0 20px 12px;
    border-bottom: 1px solid #f0f0f0;
    margin-bottom: 8px;
  }

  .dropdown-user-name {
    display: block;
    font-size: 14px;
    font-weight: 800;
    color: #111;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .dropdown-user-email {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: #888;
  }

  .dropdown-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 20px;
    color: #111;
    text-decoration: none;
    font-size: 13.5px;
    font-weight: 700;
    transition: all 0.2s;
  }

  .dropdown-link:hover {
    background-color: #fafafa;
    color: #FF2B2B;
    padding-left: 24px;
  }

  .dropdown-link svg {
    color: #888;
    transition: color 0.2s;
  }

  .dropdown-link:hover svg {
    color: #FF2B2B;
  }

  .dropdown-footer {
    border-top: 1px solid #f0f0f0;
    margin-top: 8px;
    padding-top: 8px;
  }

  .logout-btn {
    width: 100%;
    background: none;
    border: none;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 20px;
    color: #FF2B2B;
    font-size: 13.5px;
    font-weight: 700;
    cursor: pointer;
    text-align: left;
    transition: all 0.2s;
  }

  .logout-btn:hover {
    background-color: #FFF3F3;
    padding-left: 24px;
  }

  /* ============================================================
     OUR BRANDS — multi-brand navigation bar (hardcoded assets)
     ============================================================ */
  .brand-bar {
    background-color: #ffffff;
    border-bottom: 1px solid #ececec;
    width: 100%;
    position: relative;
    z-index: 1001;
    padding: 12px 16px;
  }

  .brand-bar__inner {
    max-width: 1320px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 9px;
  }

  .brand-bar__eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.22em;
    color: #9a9a9a;
    text-transform: uppercase;
    user-select: none;
    margin: 0;
  }

  .brand-bar__logos {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(28px, 6vw, 72px);
    width: 100%;
  }

  /* fixed-height clickable cell → perfect vertical alignment + no layout shift */
  .brand-bar__item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 36px;
    padding: 0 4px;
    text-decoration: none;
    opacity: 0.72;
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform, opacity;
  }

  .brand-bar__item:hover,
  .brand-bar__item:focus-visible {
    opacity: 1;
    transform: scale(1.05);
  }

  .brand-bar__item:focus-visible {
    outline: 2px solid #FF2B2B;
    outline-offset: 4px;
    border-radius: 4px;
  }

  .brand-bar__img {
    display: block;
    height: 32px;
    width: auto;
    max-width: 170px;
    object-fit: contain;
  }

  /* subtle separators between brands */
  .brand-bar__divider {
    width: 1px;
    height: 26px;
    background: #e3e3e3;
    flex-shrink: 0;
  }

  /* Hague Protect reuses the store's text/SVG logo, scaled to row height */
  .brand-bar__hague {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    font-weight: 700;
    color: #000000;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 1px;
    line-height: 1;
    white-space: nowrap;
  }

  .brand-bar__hague-icon {
    width: 17px;
    height: 17px;
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
    margin: 0 -1px;
  }

  @media screen and (max-width: 1024px) {
    .brand-bar { padding: 10px 14px; }
    .brand-bar__item { height: 32px; }
    .brand-bar__img { height: 28px; }
    .brand-bar__hague { font-size: 15px; }
    .brand-bar__hague-icon { width: 15px; height: 15px; }
    .brand-bar__divider { height: 22px; }
  }

  @media screen and (max-width: 600px) {
    .brand-bar { padding: 9px 10px; }
    .brand-bar__logos { gap: clamp(14px, 5vw, 28px); }
    .brand-bar__item { height: auto; padding: 6px 8px; }
    .brand-bar__img { height: 22px; max-width: 96px; }
    .brand-bar__hague { font-size: 12.5px; letter-spacing: 0.02em; }
    .brand-bar__hague-icon { width: 13px; height: 13px; }
    .brand-bar__divider { height: 18px; }
    .brand-bar__eyebrow { font-size: 9px; letter-spacing: 0.18em; }
  }

  @media screen and (max-width: 360px) {
    .brand-bar__logos { gap: 12px; }
    .brand-bar__img { height: 19px; max-width: 80px; }
    .brand-bar__hague { font-size: 11px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-bar__item { transition: opacity 0.3s ease; }
    .brand-bar__item:hover,
    .brand-bar__item:focus-visible { transform: none; }
  }
{%- endstyle -%}

<header class="header-wrapper" role="banner">
  {%- liquid
    assign brand_context = 'hagueprotect'
    assign _path = request.path | downcase
    assign _canon = canonical_url | downcase
    assign _tsuffix = template.suffix | default: '' | downcase
    assign _tname = template.name | default: '' | downcase

    comment
      1. Template suffix — most reliable for alternate templates
    endcomment
    if _tsuffix == 'vanrosector'
      assign brand_context = 'vanrosector'
    elsif _tsuffix == 'science-of-raw'
      assign brand_context = 'science-of-raw'
    endif

    comment
      2. URL path and canonical URL
    endcomment
    if brand_context == 'hagueprotect'
      if _path contains 'vanrosector' or _canon contains 'vanrosector'
        assign brand_context = 'vanrosector'
      elsif _path contains 'science-of-raw' or _path contains 'science_of_raw' or _canon contains 'science-of-raw' or _canon contains 'science_of_raw'
        assign brand_context = 'science-of-raw'
      endif
    endif

    comment
      3. Collection handle
    endcomment
    if brand_context == 'hagueprotect' and collection != blank
      if collection.handle == 'vanrosector'
        assign brand_context = 'vanrosector'
      elsif collection.handle == 'science-of-raw'
        assign brand_context = 'science-of-raw'
      endif
    endif

    comment
      4. Product handle
    endcomment
    if brand_context == 'hagueprotect' and product != blank
      if product.handle contains 'vanrosector'
        assign brand_context = 'vanrosector'
      elsif product.handle contains 'science-of-raw'
        assign brand_context = 'science-of-raw'
      endif
    endif

    comment
      5. Page handle
    endcomment
    if brand_context == 'hagueprotect' and page != blank
      if page.handle contains 'vanrosector'
        assign brand_context = 'vanrosector'
      elsif page.handle contains 'science-of-raw'
        assign brand_context = 'science-of-raw'
      endif
    endif

    comment
      6. Product collections fallback
    endcomment
    if brand_context == 'hagueprotect' and _tname == 'product' and product != blank
      for c in product.collections
        if c.handle == 'vanrosector'
          assign brand_context = 'vanrosector'
          break
        elsif c.handle == 'science-of-raw'
          assign brand_context = 'science-of-raw'
          break
        endif
      endfor
    endif

    assign logo_link = '/'
    if brand_context == 'vanrosector'
      assign logo_link = '/collections/all?view=vanrosector'
    elsif brand_context == 'science-of-raw'
      assign logo_link = '/collections/all?view=science-of-raw'
    endif

    assign hp_logo_asset = 'logo-hagueprotect.png'
    if section.settings.logo_hp != blank
      assign hp_logo_url = section.settings.logo_hp | image_url: width: 320
    else
      assign hp_logo_url = hp_logo_asset | asset_url
    endif
  -%}
  {%- comment -%}
    ============================================================
    OUR BRANDS — multi-brand navigation bar
    Logos are uploaded to Shopify Assets and referenced directly.
    To repoint a brand, edit only the two URLs below.
    Required asset files:  logo-vanrosector.svg · logo-science-of-raw.svg
    ============================================================
  {%- endcomment -%}
  {%- comment -%} Alternate collection templates — work without an Admin Page. See templates/collection.vanrosector.liquid. {%- endcomment -%}
  {%- assign vanrosector_url    = '/collections/all?view=vanrosector' -%}
  {%- assign science_of_raw_url = '/collections/all?view=science-of-raw' -%}

  <div class="brand-bar" role="navigation" aria-label="Our brands">
    <div class="brand-bar__inner">
      <p class="brand-bar__eyebrow">Our Brands</p>
      <div class="brand-bar__logos">

        {%- comment -%} 1 · Hague Protect → current store homepage {%- endcomment -%}
        <a href="/" class="brand-bar__item" aria-label="Hague Protect — Home">
          <img src="{{ hp_logo_url }}" alt="Hague Protect" class="brand-bar__img" width="130" height="24" loading="lazy" decoding="async">
        </a>

        <span class="brand-bar__divider" aria-hidden="true"></span>

        {%- comment -%} 2 · Vanrosector (native 940×343) {%- endcomment -%}
        <a href="{{ vanrosector_url }}" class="brand-bar__item" aria-label="Vanrosector">
          {%- if section.settings.logo_vr != blank -%}
            <img src="{{ section.settings.logo_vr | image_url: width: 200 }}" alt="Vanrosector" class="brand-bar__img" width="200" height="73" loading="lazy" decoding="async">
          {%- else -%}
            <img src="{{ 'logo-vanrosector.svg' | asset_url }}" alt="Vanrosector" class="brand-bar__img" width="200" height="73" loading="lazy" decoding="async">
          {%- endif -%}
        </a>

        <span class="brand-bar__divider" aria-hidden="true"></span>

        {%- comment -%} 3 · Science of Raw (native 1000×500) {%- endcomment -%}
        <a href="{{ science_of_raw_url }}" class="brand-bar__item" aria-label="Science of Raw">
          {%- if section.settings.logo_sor != blank -%}

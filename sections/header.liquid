        </ul>
      </div>

      <!-- Column 2: Shop by Use & More -->
      <div class="megamenu-col">
        <h3 class="megamenu-heading" style="margin-bottom: 12px;">Shop by Use</h3>
        <ul class="megamenu-links" style="margin-bottom: 24px;">
          <li class="megamenu-link-item">{% render 'header-menu-link', handle: 'delicate-clean', search: 'delicate clean', label: '1. Delicate Clean' %}</li>
          <li class="megamenu-link-item">{% render 'header-menu-link', handle: 'deep-clean', search: 'deep clean', label: '2. Deep Clean' %}</li>
          <li class="megamenu-link-item">{% render 'header-menu-link', handle: 'on-the-go-clean', search: 'on the go', label: '3. On the Go Clean' %}</li>

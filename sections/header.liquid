{%- style -%}
  .header-wrapper {
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    border-bottom: 1px solid #e5e5e5;
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding-top: 14px;
    padding-bottom: 14px;
    transition: all 0.2s ease;
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 100%;
    margin: 0;
    padding: 0 16px;
    width: 100%;
    gap: 12px;
  }

  .header__logo-link {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    flex-shrink: 1;
    min-width: 0;
  }

  .header__logo-text {
    font-family: 'Inter', sans-serif;
    font-size: 21px;
    font-weight: 700;
    color: #000000;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 1px;
    line-height: 1.2;
    white-space: nowrap;
  }

  .header__logo-icon {
    width: 22px;
    height: 22px;
    color: #000000;
    margin: 0 -1px;
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
  }

  .header__navigation {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-left: auto;
  }

  @media screen and (max-width: 1024px) {
    .header__navigation {
      display: none;
    }
  }

  .nav-item {
    padding: 12px 0;
  }

  .header__menu-link {
    font-family: 'Inter', sans-serif !important;
    font-size: 13.5px;
    font-weight: 700;
    color: #111111;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .header__menu-link:hover {
    color: #FF2B2B;
  }

  .menu-pill {
    background-color: #111111;
    color: #ffffff !important;
    padding: 8px 18px;
    border-radius: 4px;
    font-family: 'Inter', sans-serif !important;
    font-size: 15px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .menu-pill:hover {
    background-color: #333333;
    transform: translateY(-1px);
    color: #ffffff !important;
  }

  .menu-link {
    font-family: 'Inter', sans-serif !important;
    font-size: 15px;
    font-weight: 800;
    color: #111111 !important;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .menu-link:hover {
    color: #FF2B2B !important;
  }

  /* Full Width Mega Menu Dropdown Panel */
  .megamenu-panel {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background-color: #ffffff !important;
    border-top: 1px solid #e5e5e5;
    border-bottom: 1px solid #e5e5e5;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.08);
    display: none;
    z-index: 1001;
    padding: 48px 0;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .megamenu-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 32px;
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 24px;
    width: 100%;
    align-items: start;
  }

  .megamenu-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .megamenu-heading {
    font-family: 'Inter', sans-serif !important;
    font-size: 14px;
    font-weight: 800;
    color: #111111 !important;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 1.2;
  }

  .megamenu-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .megamenu-link-item a {
    font-family: 'Inter', sans-serif !important;
    font-size: 13.5px;
    font-weight: 500;
    color: #555555 !important;
    text-decoration: none;
    transition: all 0.2s ease;
    display: inline-block;
    line-height: 1.4;
  }

  .megamenu-link-item a:hover {
    color: #FF2B2B !important;
    transform: translateX(3px);
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-left: 32px;
    flex-shrink: 0;
  }

  .header__cart-link,
  .header__account-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter', sans-serif !important;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background-color: #fafafa;
    border: 1px solid #e5e5e5;
    padding: 11px;
    border-radius: 4px;
    color: #111111;
    text-decoration: none;
    transition: all 0.2s;
    width: 42px;
    height: 42px;
  }

  .header__cart-link:hover,
  .header__account-btn:hover {
    background-color: #111111;
    color: #ffffff;
    border-color: #111111;
  }

  .header__mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: #111;
  }

  @media screen and (max-width: 1024px) {
    .header-wrapper {
      overflow: hidden;
      padding-top: 10px;
      padding-bottom: 10px;
    }

    .header-container {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      padding: 0 var(--site-padding, 16px);
      gap: 8px;
    }

    .header__logo-link {
      max-width: 100%;
      overflow: hidden;
    }

    .header__logo-text {
      font-size: clamp(14px, 3.6vw, 18px);
      letter-spacing: 0.03em;
      max-width: 100%;
    }

    .header__logo-icon {
      width: 18px;
      height: 18px;
    }

    .header__actions {
      margin-left: 0;
      gap: 6px;
    }

    .header__account-container {
      display: none;
    }

    .header__mobile-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      order: 10;
      min-width: 40px;
      min-height: 40px;
      padding: 6px;
      flex-shrink: 0;
    }

    .header__cart-link,
    .header__account-btn {
      width: 40px;
      height: 40px;
      min-width: 40px;
      min-height: 40px;
      padding: 8px;
      flex-shrink: 0;
    }

    .header__search-btn {
      order: 1;
    }

    .header__cart-btn {
      order: 2;
    }
  }

  @media screen and (max-width: 380px) {
    .header__logo-text {
      font-size: 13px;
    }

    .header__logo-icon {
      width: 16px;
      height: 16px;
    }

    .header__actions {
      gap: 4px;
    }

    .header__cart-link,
    .header__account-btn,
    .header__mobile-toggle {
      width: 36px;
      height: 36px;
      min-width: 36px;
      min-height: 36px;
    }
  }

  /* Mobile menu drawer */
  .mobile-menu-drawer {
    position: fixed;
    top: 0;
    left: -100%;
    width: 320px;
    max-width: calc(100vw - 40px);
    height: 100%;
    background: #ffffff;
    box-shadow: 8px 0 32px rgba(0,0,0,0.1);
    z-index: 10002;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    overflow-y: auto;
    transition: left 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-menu-drawer.is-active {
    left: 0;
  }

  .mobile-menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.4);
    z-index: 10001;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .mobile-menu-overlay.is-active {
    opacity: 1;
    visibility: visible;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .mobile-nav-link {
    font-family: 'Inter', sans-serif !important;
    font-size: 15px;
    font-weight: 700;
    color: #111111;
    text-transform: uppercase;
    text-decoration: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .mobile-accordion-content {
    display: none;
    flex-direction: column;
    gap: 16px;
    padding: 8px 0 8px 12px;
  }

  .mobile-accordion-category-heading {
    font-family: 'Inter', sans-serif !important;
    font-size: 13px;
    font-weight: 700;
    color: #111;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  /* Profile Dropdown Styles */
  .header__account-container {
    position: relative;
    display: inline-block;
  }

  .profile-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    width: 240px;
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.12);
    display: none;
    z-index: 1002;
    margin-top: 12px;
    padding: 16px 0;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header__account-container:hover .profile-dropdown {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  .dropdown-header {
    padding: 0 20px 12px;
    border-bottom: 1px solid #f0f0f0;
    margin-bottom: 8px;
  }

  .dropdown-user-name {
    display: block;
    font-size: 14px;
    font-weight: 800;
    color: #111;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .dropdown-user-email {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: #888;
  }

  .dropdown-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 20px;
    color: #111;
    text-decoration: none;
    font-size: 13.5px;
    font-weight: 700;
    transition: all 0.2s;
  }

  .dropdown-link:hover {
    background-color: #fafafa;
    color: #FF2B2B;
    padding-left: 24px;
  }

  .dropdown-link svg {
    color: #888;
    transition: color 0.2s;
  }

  .dropdown-link:hover svg {
    color: #FF2B2B;
  }

  .dropdown-footer {
    border-top: 1px solid #f0f0f0;
    margin-top: 8px;
    padding-top: 8px;
  }

  .logout-btn {
    width: 100%;
    background: none;
    border: none;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 20px;
    color: #FF2B2B;
    font-size: 13.5px;
    font-weight: 700;
    cursor: pointer;
    text-align: left;
    transition: all 0.2s;
  }

  .logout-btn:hover {
    background-color: #FFF3F3;
    padding-left: 24px;
  }
{%- endstyle -%}

<header class="header-wrapper" role="banner">
  <div class="header-container">
    
    <!-- Logo -->
    <a href="/" class="header__logo-link" aria-label="{{ shop.name | default: 'HAGUEPROTECT' }} home">
      <span class="header__logo-text">
        HAGUE<span style="color: #FF2B2B;">PR</span><svg class="header__logo-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" aria-hidden="true"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4.5"/><circle cx="12" cy="12" r="1.5"/></svg>TECT
      </span>
    </a>

    <nav class="header__navigation" role="navigation">
      <div class="nav-item">
        <a href="javascript:void(0)" class="menu-pill" id="ShopTrigger">
          SHOP ALL
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-left: 2px;">
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
      <div class="nav-item">
        <a href="/search?view=how-to-use" class="menu-link">HOW TO USE</a>
      </div>
      <div class="nav-item">
        <a href="/search?view=corporate-gifting" class="menu-link">CORPORATE GIFTING</a>
      </div>
      <div class="nav-item">
        <a href="/pages/contact-us" class="menu-link">BUSINESS</a>
      </div>
      <div class="nav-item">
        <a href="/collections/all" class="menu-link">OFFERS</a>
      </div>
    </nav>

    <!-- Actions -->
    <div class="header__actions">
      <!-- Mobile Toggle -->
      <button type="button" class="header__mobile-toggle" onclick="openMobileMenu()" aria-label="Open navigation menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Search Toggle -->
      <button type="button" class="header__cart-link header__search-btn" onclick="openSearch()" aria-label="Open search">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M21 21L16.65 16.65" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Login/Profile Button with Dropdown -->
      <div class="header__account-container">
        <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" class="header__account-btn" aria-label="Account Login">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="7.5" r="4" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M4 20C4 16.13 7.58 13 12 13C16.42 13 20 16.13 20 20" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        
        {%- if customer -%}
        <!-- Profile Dropdown (Native Shopify) -->
        <div class="profile-dropdown" id="ProfileDropdown">
          <div class="dropdown-header">
            <span class="dropdown-user-name">{{ customer.first_name | default: 'Member' | upcase }}</span>
            <span class="dropdown-user-email">{{ customer.email }}</span>
          </div>
          <a href="{{ routes.account_url }}" class="dropdown-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Dashboard
          </a>
          <a href="{{ routes.account_url }}#history" class="dropdown-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Order History
          </a>
          <a href="{{ routes.account_addresses_url }}" class="dropdown-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="10" r="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            My Addresses
          </a>
          <a href="/pages/faq" class="dropdown-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3m0 4h.01" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Support Center
          </a>
          <div class="dropdown-footer">
            <a href="{{ routes.account_logout_url }}" class="logout-btn" style="text-decoration: none;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3H7a2 2 0 00-2 2v14a2 2 0 002 2h8m4-9l-4-4m4 4l-4 4m4-4H9" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Sign Out
            </a>
          </div>
        </div>
        {%- endif -%}
      </div>

      <!-- Cart Button -->
      <a href="/cart" id="HeaderCartBtn" class="header__cart-link header__cart-btn" aria-label="View Cart">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M2 2H4L5.32 8.59C5.52 9.59 6.4 10.32 7.42 10.32H16.14C17.16 10.32 18.04 9.59 18.24 8.59L19.5 2.25H4.25" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="8" cy="19" r="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="16" cy="19" r="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- UNCONSTRAINED FULL-WIDTH MEGA MENU dropdown right inside the header wrapper -->
  <div class="megamenu-panel" id="MegaMenuPanel">
    {%- assign mega_links = linklists[section.settings.shop_all_menu] -%}
    {%- if mega_links != blank and mega_links.links.size > 0 -%}
    <div class="megamenu-grid" style="grid-template-columns: repeat({{ mega_links.links.size }}, 1fr); gap: 40px;">
      {%- for column_link in mega_links.links -%}
        {%- assign col_index = forloop.index -%}
        {%- assign col_heading_color = '#111111' -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'mega_column_style' and block.settings.column_index == col_index -%}
            {%- assign col_heading_color = block.settings.heading_color -%}
          {%- endif -%}
        {%- endfor -%}
        <div class="megamenu-col">
          {%- for heading_link in column_link.links -%}
            <h3 class="megamenu-heading" style="color: {{ col_heading_color }} !important; margin-bottom: 12px;">{{ heading_link.title }}</h3>
            {%- if heading_link.links.size > 0 -%}
            <ul class="megamenu-links" style="margin-bottom: 24px;">
              {%- for product_link in heading_link.links -%}
                <li class="megamenu-link-item">
                  {%- assign link_parts = product_link.title | split: '|' -%}
                  {%- if link_parts.size > 1 -%}
                    <span style="font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; display: block; margin-top: 5px;">{{ link_parts[0] | strip }}</span>
                    <a href="{{ product_link.url }}" style="font-size: 13px;">{{ link_parts[1] | strip }}</a>
                  {%- else -%}
                    <a href="{{ product_link.url }}">{{ product_link.title }}</a>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endfor -%}
    </div>
    {%- else -%}
    <div class="megamenu-grid" style="grid-template-columns: 1fr; gap: 40px;">
      <div class="megamenu-col" style="text-align: center; padding: 24px;">
        <h3 class="megamenu-heading" style="color: #FF2B2B !important; margin-bottom: 12px;">Shop All Menu</h3>
        <p style="font-size: 14px; color: #888; font-weight: 500; margin-bottom: 16px;">Configure the mega menu in Theme Settings &rarr; Header &rarr; &ldquo;Shop All Mega Menu&rdquo;.</p>
        <a href="/collections/all" style="font-size: 14px; color: #FF2B2B; font-weight: 700; text-decoration: none;">Browse All Products &rarr;</a>
      </div>
    </div>
    {%- endif -%}
  </div>

  <!-- Premium Full-Screen Search Overlay -->
  <div id="ThemeSearchView" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.98); z-index: 10000; backdrop-filter: blur(8px);">
    <div style="position: absolute; top: 24px; right: 24px;">
      <button onclick="closeSearch()" style="background: none; border: none; cursor: pointer; color: #111; padding: 12px; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: background 0.2s;" onmouseover="this.style.backgroundColor='#eee';" onmouseout="this.style.backgroundColor='transparent';">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
    
    <div style="max-width: 800px; width: 100%; margin: 15vh auto; padding: 0 24px;">
      <h2 style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 800; color: #FF2B2B; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 16px; text-align: center;">Search our store</h2>
      <form action="/search" method="get" role="search" style="position: relative;">
        <input type="text" 
               name="q" 
               id="SearchInput" 
               placeholder="What are you looking for?" 
               autocomplete="off"
               style="width: 100%; background: transparent; border: none; border-bottom: 2px solid #111; padding: 16px 0; font-family: 'Inter', sans-serif; font-size: clamp(24px, 4vw, 42px); font-weight: 800; color: #111; outline: none; transition: border-color 0.3s;"
               onfocus="this.style.borderBottomColor='#FF2B2B'"
               onblur="this.style.borderBottomColor='#111'">
        <button type="submit" style="position: absolute; right: 0; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: #111;">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="M21 21L16.65 16.65"/></svg>
        </button>
        <!-- Predictive Search Results Container -->
        <div id="PredictiveSearchContainer" style="position: absolute; top: 100%; left: 0; width: 100%; background: #fff; border-radius: 0 0 16px 16px; box-shadow: 0 20px 40px rgba(0,0,0,0.1); display: none; z-index: 10; margin-top: 4px; overflow: hidden; border-top: 1px solid #f0f0f0;">
          <div id="PredictiveSearchResults" style="max-height: 450px; overflow-y: auto; padding: 16px;"></div>
        </div>
      </form>
      <div style="margin-top: 40px; display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;">
        <span style="font-size: 13px; color: #888; font-weight: 600; text-transform: uppercase;">Popular:</span>
        <a href="/search?q=kit" style="font-size: 13px; color: #111; text-decoration: none; font-weight: 700; border-bottom: 1px solid #ddd;">Kits</a>
        <a href="/search?q=cleaner" style="font-size: 13px; color: #111; text-decoration: none; font-weight: 700; border-bottom: 1px solid #ddd;">Cleaners</a>
        <a href="/search?q=suede" style="font-size: 13px; color: #111; text-decoration: none; font-weight: 700; border-bottom: 1px solid #ddd;">Suede Care</a>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Navigation Drawer -->
<div id="MobileMenuOverlay" class="mobile-menu-overlay" onclick="closeMobileMenu()"></div>
<div id="MobileMenuDrawer" class="mobile-menu-drawer">
  <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 16px;">
    <h2 style="font-size: 18px; font-weight: 800; color: #111; margin: 0; text-transform: uppercase; letter-spacing: -0.02em;">Menu</h2>
    <button type="button" onclick="closeMobileMenu()" style="background: none; border: none; cursor: pointer; color: #111;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>

  <div class="mobile-nav-links">
    <div>
      <a href="javascript:void(0)" onclick="toggleMobileAccordion()" class="mobile-nav-link">
        SHOP ALL
        <svg width="12" height="8" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="2"/></svg>
      </a>
      <div class="mobile-accordion-content" id="MobileShopContent" style="flex-direction: column;">
        {%- assign mega_links_mobile = linklists[section.settings.shop_all_menu] -%}
        {%- if mega_links_mobile != blank and mega_links_mobile.links.size > 0 -%}
          {%- for column_link in mega_links_mobile.links -%}
            {%- assign col_index_m = forloop.index -%}
            {%- assign mobile_heading_color = '#111' -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'mega_column_style' and block.settings.column_index == col_index_m -%}
                {%- assign mobile_heading_color = block.settings.heading_color -%}
              {%- endif -%}
            {%- endfor -%}
            {%- for heading_link in column_link.links -%}
              <div>
                <h4 class="mobile-accordion-category-heading" style="color: {{ mobile_heading_color }};">{{ heading_link.title }}</h4>
                {%- if heading_link.links.size > 0 -%}
                <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; padding-left: 8px;">
                  {%- for product_link in heading_link.links -%}
                    {%- assign link_parts_m = product_link.title | split: '|' -%}
                    {%- if link_parts_m.size > 1 -%}
                      <a href="{{ product_link.url }}" style="color:#666; text-decoration:none; font-size:14px;">{{ link_parts_m[0] | strip }} &mdash; {{ link_parts_m[1] | strip }}</a>
                    {%- else -%}
                      <a href="{{ product_link.url }}" style="color:#666; text-decoration:none; font-size:14px;">{{ product_link.title }}</a>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
                {%- endif -%}
              </div>
            {%- endfor -%}
          {%- endfor -%}
        {%- else -%}
          <div style="padding: 16px 0;">
            <p style="font-size: 13px; color: #888;">Menu not configured. Visit Theme Settings to set up the Shop All menu.</p>
            <a href="/collections/all" style="color:#FF2B2B; text-decoration:none; font-size:14px; font-weight: 700;">Browse All Products &rarr;</a>
          </div>
        {%- endif -%}
      </div>
    </div>
    
    {%- if customer -%}
      <a href="{{ routes.account_url }}" class="mobile-nav-link" style="color: #FF2B2B;">My Account ({{ customer.first_name }})</a>
      <a href="{{ routes.account_logout_url }}" class="mobile-nav-link" style="font-size: 13px; opacity: 0.7;">Sign Out</a>
    {%- else -%}
      <a href="{{ routes.account_login_url }}" class="mobile-nav-link" style="color: #FF2B2B;">Login / Register</a>
    {%- endif -%}
    <a href="/search?view=how-to-use" class="mobile-nav-link">HOW TO USE</a>
    <a href="/search?view=corporate-gifting" class="mobile-nav-link">CORPORATE GIFTING</a>
    <a href="/pages/contact-us" class="mobile-nav-link">BUSINESS</a>
    <a href="/collections/all" class="mobile-nav-link">OFFERS</a>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const trigger = document.getElementById('ShopTrigger');
    const panel = document.getElementById('MegaMenuPanel');

    if (trigger && panel) {
      let timeoutId;
      const openPanel = () => {
        clearTimeout(timeoutId);
        panel.style.display = 'block';
        setTimeout(() => {
          panel.style.opacity = '1';
          panel.style.transform = 'translateY(0)';
        }, 10);
      };

      const closePanel = () => {
        timeoutId = setTimeout(() => {
          panel.style.opacity = '0';
          panel.style.transform = 'translateY(12px)';
          setTimeout(() => {
            if (panel.style.opacity === '0') {
              panel.style.display = 'none';
            }
          }, 300);
        }, 100);
      };

      trigger.addEventListener('mouseenter', openPanel);
      trigger.addEventListener('mouseleave', closePanel);
      panel.addEventListener('mouseenter', openPanel);
      panel.addEventListener('mouseleave', closePanel);
    }
  });

  function openMobileMenu() {
    document.getElementById('MobileMenuOverlay').classList.add('is-active');
    document.getElementById('MobileMenuDrawer').classList.add('is-active');
  }
  function closeMobileMenu() {
    document.getElementById('MobileMenuOverlay').classList.remove('is-active');
    document.getElementById('MobileMenuDrawer').classList.remove('is-active');
  }
  function toggleMobileAccordion() {
    const content = document.getElementById('MobileShopContent');
    const isHidden = window.getComputedStyle(content).display === 'none';
    if (isHidden) {
      content.style.display = 'flex';
    } else {
      content.style.display = 'none';
    }
  }

  function handleHeaderLogin(e) {
    // Native Shopify login handles redirects automatically
  }

  function openSearch() {
    const searchView = document.getElementById('ThemeSearchView');
    searchView.style.display = 'block';
    document.body.style.overflow = 'hidden';
    setTimeout(() => {
      document.getElementById('SearchInput').focus();
    }, 100);
  }

  function closeSearch() {
    document.getElementById('ThemeSearchView').style.display = 'none';
    document.body.style.overflow = '';
  }

  // Close search on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch();
  });

  // Predictive Search Logic
  const searchInput = document.getElementById('SearchInput');
  const predictiveResults = document.getElementById('PredictiveSearchResults');
  const predictiveContainer = document.getElementById('PredictiveSearchContainer');
  let debounceTimer;
  let selectedIndex = -1;

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      const query = searchInput.value.trim();
      selectedIndex = -1;

      if (query.length < 2) {
        predictiveContainer.style.display = 'none';
        return;
      }

      debounceTimer = setTimeout(() => {
        fetch(`/search/suggest.json?q=${encodeURIComponent(query)}&resources[type]=product,collection&resources[limit]=6`)
          .then(response => response.json())
          .then(suggestions => {
            const products = suggestions.resources.results.products || [];
            const collections = suggestions.resources.results.collections || [];

            if (products.length === 0 && collections.length === 0) {
              const safeQuery = query.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
              predictiveResults.innerHTML = `<p style="padding: 24px; color: #888; text-align: center; font-size: 14px; font-weight: 500;">No suggestions found for "${safeQuery}"</p>`;
              predictiveContainer.style.display = 'block';
              return;
            }

            let html = '';

            if (collections.length > 0) {
              html += '<div style="margin-bottom: 24px;"><h3 style="font-size: 10px; font-weight: 800; text-transform: uppercase; color: #FF2B2B; letter-spacing: 0.15em; margin-bottom: 12px; padding: 0 12px;">Suggested Categories</h3>';
              collections.forEach(col => {
                html += `<a href="${col.url}" class="predictive-item" style="display: block; padding: 12px; color: #111; text-decoration: none; font-size: 15px; font-weight: 700; border-radius: 8px; transition: all 0.2s;">${col.title}</a>`;
              });
              html += '</div>';
            }

            if (products.length > 0) {
              html += '<div><h3 style="font-size: 10px; font-weight: 800; text-transform: uppercase; color: #FF2B2B; letter-spacing: 0.15em; margin-bottom: 12px; padding: 0 12px;">Suggested Products</h3>';
              products.forEach(prod => {
                html += `
                  <a href="${prod.url}" class="predictive-item" style="display: flex; align-items: center; gap: 16px; padding: 12px; text-decoration: none; border-radius: 10px; transition: all 0.2s; margin-bottom: 4px;">
                    <div style="width: 56px; height: 56px; background: #f9f9f9; border-radius: 6px; overflow: hidden; flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                      <img src="${prod.image}" style="max-width: 100%; max-height: 100%; object-fit: contain;" loading="lazy" decoding="async">
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 2px;">
                      <span style="font-size: 15px; font-weight: 700; color: #111; line-height: 1.2;">${prod.title}</span>
                      <span style="font-size: 13px; color: #FF2B2B; font-weight: 800; letter-spacing: 0.02em;">${prod.price}</span>
                    </div>
                  </a>
                `;
              });
              html += '</div>';
            }

            predictiveResults.innerHTML = html;
            predictiveContainer.style.display = 'block';

            // Inject hover styles dynamically
            if (!document.getElementById('PredictiveStyles')) {
              const style = document.createElement('style');
              style.id = 'PredictiveStyles';
              style.innerHTML = `
                .predictive-item:hover, .predictive-item.is-selected { background: #f7f7f7 !important; transform: translateX(4px); }
                #PredictiveSearchResults::-webkit-scrollbar { width: 6px; }
                #PredictiveSearchResults::-webkit-scrollbar-track { background: transparent; }
                #PredictiveSearchResults::-webkit-scrollbar-thumb { background: #eee; border-radius: 10px; }
              `;
              document.head.appendChild(style);
            }
          });
      }, 250);
    });

    // Keyboard Navigation
    searchInput.addEventListener('keydown', (e) => {
      const items = predictiveResults.querySelectorAll('.predictive-item');
      if (items.length === 0) return;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        selectedIndex = (selectedIndex + 1) % items.length;
        updateSelection(items);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        selectedIndex = (selectedIndex - 1 + items.length) % items.length;
        updateSelection(items);
      } else if (e.key === 'Enter' && selectedIndex > -1) {
        e.preventDefault();
        items[selectedIndex].click();
      }
    });

    function updateSelection(items) {
      items.forEach((item, index) => {
        if (index === selectedIndex) {
          item.classList.add('is-selected');
          item.scrollIntoView({ block: 'nearest' });
        } else {
          item.classList.remove('is-selected');
        }
      });
    }

    // Close suggestions when clicking outside
    document.addEventListener('click', (e) => {
      if (!predictiveContainer.contains(e.target) && e.target !== searchInput) {
        predictiveContainer.style.display = 'none';
      }
    });
  }

  // Cleaned up localStorage greeting logic as we now use native Liquid customer objects
  document.addEventListener('DOMContentLoaded', () => {
      const dropdown = document.getElementById('ProfileDropdown');
      if (dropdown) {
        dropdown.style.display = 'none'; // Will show on hover due to CSS
      }
  });
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "shop_all_menu",
      "label": "Shop All Mega Menu",
      "info": "Select a 3-level navigation menu: Level 1 = Columns, Level 2 = Category Headings, Level 3 = Product Links. Tip: Use a pipe character | in link titles to show subtitles on desktop (e.g. 1. Leather|Leather Care Kit)."
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "HAGUEPROTECT"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "mega_column_style",
      "name": "Column Heading Color",
      "limit": 8,
      "settings": [
        {
          "type": "range",
          "id": "column_index",
          "min": 1,
          "max": 8,
          "step": 1,
          "label": "Column Number",
          "default": 1,
          "info": "Which column in the Shop All menu to apply this color to"
        },
        {
          "type": "color",
          "id": "heading_color",
          "label": "Heading Color",
          "default": "#FF2B2B"
        }
      ]
    }
  ]
}
{% endschema %}

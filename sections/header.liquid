{%- style -%}
  .header-wrapper {
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    border-bottom: 1px solid #e5e5e5;
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding-top: 14px;
    padding-bottom: 14px;
    transition: all 0.2s ease;
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 100%;
    margin: 0;
    padding: 0 16px;
    width: 100%;
  }

  .header__logo-link {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .header__navigation {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-left: auto;
  }

  @media screen and (max-width: 1024px) {
    .header__navigation {
      display: none;
    }
  }

  .nav-item {
    padding: 12px 0;
  }

  .header__menu-link {
    font-family: 'Inter', sans-serif !important;
    font-size: 13.5px;
    font-weight: 700;
    color: #111111;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .header__menu-link:hover {
    color: #FF2B2B;
  }

  .menu-pill {
    background-color: #111111;
    color: #ffffff !important;
    padding: 8px 18px;
    border-radius: 4px;
    font-family: 'Inter', sans-serif !important;
    font-size: 15px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .menu-pill:hover {
    background-color: #333333;
    transform: translateY(-1px);
    color: #ffffff !important;
  }

  .menu-link {
    font-family: 'Inter', sans-serif !important;
    font-size: 15px;
    font-weight: 800;
    color: #111111 !important;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .menu-link:hover {
    color: #FF2B2B !important;
  }

  /* Full Width Mega Menu Dropdown Panel */
  .megamenu-panel {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background-color: #ffffff !important;
    border-top: 1px solid #e5e5e5;
    border-bottom: 1px solid #e5e5e5;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.08);
    display: none;
    z-index: 1001;
    padding: 48px 0;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .megamenu-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 32px;
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 24px;
    width: 100%;
    align-items: start;
  }

  .megamenu-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .megamenu-heading {
    font-family: 'Inter', sans-serif !important;
    font-size: 14px;
    font-weight: 800;
    color: #111111 !important;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 1.2;
  }

  .megamenu-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .megamenu-link-item a {
    font-family: 'Inter', sans-serif !important;
    font-size: 13.5px;
    font-weight: 500;
    color: #555555 !important;
    text-decoration: none;
    transition: all 0.2s ease;
    display: inline-block;
    line-height: 1.4;
  }

  .megamenu-link-item a:hover {
    color: #FF2B2B !important;
    transform: translateX(3px);
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-left: 32px;
  }

  .header__cart-link {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter', sans-serif !important;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background-color: #fafafa;
    border: 1px solid #e5e5e5;
    padding: 11px;
    border-radius: 4px;
    color: #111111;
    text-decoration: none;
    transition: all 0.2s;
    width: 42px;
    height: 42px;
  }

  .header__cart-link:hover {
    background-color: #111111;
    color: #ffffff;
    border-color: #111111;
  }

  .header__mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: #111;
  }

  @media screen and (max-width: 1024px) {
    .header__mobile-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }

  /* Mobile menu drawer */
  .mobile-menu-drawer {
    position: fixed;
    top: 0;
    left: -100%;
    width: 320px;
    max-width: calc(100vw - 40px);
    height: 100%;
    background: #ffffff;
    box-shadow: 8px 0 32px rgba(0,0,0,0.1);
    z-index: 10002;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    overflow-y: auto;
    transition: left 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-menu-drawer.is-active {
    left: 0;
  }

  .mobile-menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.4);
    z-index: 10001;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .mobile-menu-overlay.is-active {
    opacity: 1;
    visibility: visible;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .mobile-nav-link {
    font-family: 'Inter', sans-serif !important;
    font-size: 15px;
    font-weight: 700;
    color: #111111;
    text-transform: uppercase;
    text-decoration: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .mobile-accordion-content {
    display: none;
    flex-direction: column;
    gap: 16px;
    padding: 8px 0 8px 12px;
  }

  .mobile-accordion-category-heading {
    font-family: 'Inter', sans-serif !important;
    font-size: 13px;
    font-weight: 700;
    color: #111;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
{%- endstyle -%}


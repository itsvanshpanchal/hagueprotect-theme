{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .social-proof-section {
    background-color: {{ section.settings.bg_color | default: '#fcfcfd' }};
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .social-proof-header {
    text-align: center;
    margin-bottom: 56px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .social-proof__eyebrow {
    color: var(--color-primary);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .social-proof__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  @media screen and (max-width: 991px) {
    .social-proof__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  @media screen and (max-width: 575px) {
    .social-proof__grid {
      grid-template-columns: 1fr;
    }
  }

  .social-card {
    background-color: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-md);
    overflow: hidden;
    transition: var(--transition-smooth);
    display: flex;
    flex-direction: column;
  }

  .social-card:hover {
    border-color: transparent;
    box-shadow: 0 16px 48px rgba(0,0,0,0.06);
    transform: translateY(-4px);
  }

  .social-card__visuals {
    position: relative;
    aspect-ratio: 4 / 3;
    background-color: #fcfcfc;
    overflow: hidden;
  }

  .social-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition-smooth);
  }

  .social-card:hover .social-card__image {
    transform: scale(1.04);
  }

  .social-card__video-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .social-card__video-wrapper video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .social-card__before-after {
    display: flex;
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(0deg, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 100%);
    padding: 12px 20px;
    justify-content: space-between;
    z-index: 3;
  }

  .social-card__label {
    color: #ffffff;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(8px);
    padding: 4px 10px;
    border-radius: var(--border-radius-xl);
  }

  .social-card__label.after-label {
    background: var(--color-primary);
  }

  .social-card__content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-grow: 1;
  }

  .social-card__author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .social-card__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: var(--color-bg-alt);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 13px;
    color: var(--color-text-main);
    border: 1px solid var(--color-border);
  }

  .social-card__author-info {
    display: flex;
    flex-direction: column;
  }

  .social-card__author-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text-main);
  }

  .social-card__author-handle {
    font-size: 12px;
    color: var(--color-text-light);
  }

  .social-card__review {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }
{%- endstyle -%}

<section class="social-proof-section section-spacing" aria-label="Real sneaker results">
  <div class="container">
    <div class="social-proof-header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="social-proof__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="h2">{{ section.settings.heading | default: 'Real Results from Customers' }}</h2>
    </div>

    <div class="social-proof__grid">
      {%- for block in section.blocks -%}
        <div class="social-card animate-fade-in" {{ block.shopify_attributes }}>
          <div class="social-card__visuals">
            {%- if block.settings.video != blank -%}
              <div class="social-card__video-wrapper">
                {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: true }}
              </div>
            {%- elsif block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 800 }}" alt="Real cleaning results" class="social-card__image" loading="lazy">
            {%- else -%}
              <!-- Vector Illustration Fallback -->
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 300" class="social-card__image">
                <rect width="400" height="300" fill="#fafafa"/>
                <line x1="200" y1="0" x2="200" y2="300" stroke="#eeeeee" stroke-width="2" stroke-dasharray="6"/>
                <!-- Dirty side -->
                <circle cx="120" cy="150" r="50" fill="#e8e8ea" opacity="0.6"/>
                <path d="M100 140l20-10 20 20-20 10-20-20zm-10 20h40" stroke="#888888" stroke-width="2" opacity="0.3"/>
                <!-- Pristine clean side -->
                <circle cx="280" cy="150" r="50" fill="#ffffff" filter="drop-shadow(0 8px 24px rgba(0,0,0,0.04))"/>
                <path d="M260 140l20-10 20 20-20 10-20-20zm-10 20h40" stroke="#FF2B2B" stroke-width="2" opacity="0.8"/>
              </svg>
            {%- endif -%}
            
            <div class="social-card__before-after">
              <span class="social-card__label">Before</span>
              <span class="social-card__label after-label">After</span>
            </div>
          </div>

          <div class="social-card__content">
            <div class="social-card__author">
              <div class="social-card__avatar">
                {{ block.settings.author_name | slice: 0 | default: 'A' }}
              </div>
              <div class="social-card__author-info">
                <span class="social-card__author-name">{{ block.settings.author_name | default: 'Alex Rivera' }}</span>
                <span class="social-card__author-handle">{{ block.settings.author_handle | default: '@alex_kicks' }}</span>
              </div>
            </div>
            <p class="social-card__review">{{ block.settings.review | default: '"I was amazed at how easily this cleaned my dirty leather shoes. They honestly look brand new again!"' }}</p>
          </div>
        </div>
      {%- else -%}
        <!-- Fallback cards when no blocks exist in the customizer -->
        {%- for i in (1..3) -%}
          <div class="social-card animate-fade-in">
            <div class="social-card__visuals">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 300" class="social-card__image">
                <rect width="400" height="300" fill="#fafafa"/>
                <line x1="200" y1="0" x2="200" y2="300" stroke="#eeeeee" stroke-width="2" stroke-dasharray="6"/>
                <circle cx="120" cy="150" r="45" fill="#f4f4f4"/>
                <circle cx="280" cy="150" r="45" fill="#ffffff" filter="drop-shadow(0 12px 32px rgba(0,0,0,0.03))"/>
                <text x="120" y="225" font-family="Inter, sans-serif" font-size="10" font-weight="700" fill="#888" text-anchor="middle">RESTORE</text>
                <text x="280" y="225" font-family="Inter, sans-serif" font-size="10" font-weight="700" fill="#FF2B2B" text-anchor="middle">PRISTINE</text>
              </svg>
              <div class="social-card__before-after">
                <span class="social-card__label">Before</span>
                <span class="social-card__label after-label">After</span>
              </div>
            </div>

            <div class="social-card__content">
              <div class="social-card__author">
                <div class="social-card__avatar">
                  {%- if i == 1 -%}M{%- elsif i == 2 -%}J{%- else -%}L{%- endif -%}
                </div>
                <div class="social-card__author-info">
                  <span class="social-card__author-name">
                    {%- if i == 1 -%}Marcus Vance{%- elsif i == 2 -%}Jessica King{%- else -%}Leo Zhang{%- endif -%}
                  </span>
                  <span class="social-card__author-handle">
                    {%- if i == 1 -%}@mvance_kickz{%- elsif i == 2 -%}@jess_sneaks{%- else -%}@leoz_kicks{%- endif -%}
                  </span>
                </div>
              </div>
              <p class="social-card__review">
                {%- if i == 1 -%}
                  "My white Air Force 1s were covered in mud. The Elite kit dissolved it all effortlessly without ruining the leather."
                {%- elsif i == 2 -%}
                  "Fantastic results on my favorite suede sneakers! I used the restoration brush and it worked perfectly."
                {%- else -%}
                  "Best cleaning kit I've ever owned. Worth every penny for professional sneaker maintenance."
                {%- endif -%}
              </p>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>


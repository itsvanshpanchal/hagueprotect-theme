{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .biz-form {
    padding: clamp(80px, 10vw, 120px) 0;
    background: #f0f2f8;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .biz-form__wrap {
    max-width: var(--site-max-width);
    margin: 0 auto;
    padding: 0 max(20px, var(--site-padding, 24px));
  }

  .biz-form__grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 32px 90px rgba(10, 12, 18, 0.14);
    min-height: 620px;
  }

  .biz-form__visual {
    position: relative;
    background: #0a0c12;
    padding: clamp(40px, 5vw, 56px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
  }

  .biz-form__visual-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .biz-form__visual-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.3;
  }

  .biz-form__visual-mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 15% 85%, rgba(79, 140, 255, 0.28) 0%, transparent 55%),
      radial-gradient(ellipse 50% 40% at 90% 15%, rgba(255, 43, 43, 0.15) 0%, transparent 50%);
    z-index: 1;
  }

  .biz-form__visual-content {
    position: relative;
    z-index: 2;
    color: #ffffff;
  }

  .biz-form__visual-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #4f8cff;
    margin-bottom: 16px;
  }

  .biz-form__visual-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(36px, 4vw, 52px);
    font-weight: 400;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    line-height: 1;
    margin: 0 0 20px;
    color: #ffffff !important;
  }

  .biz-form__visual-text {
    font-size: 15px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0 0 40px;
    max-width: 340px;
  }

  .biz-form__contacts {
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
    z-index: 2;
  }

  .biz-form__contact {
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    color: #ffffff;
    padding: 14px 18px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: background 0.25s ease, border-color 0.25s ease;
  }

  .biz-form__contact:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(79, 140, 255, 0.4);
  }

  .biz-form__contact-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(79, 140, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #4f8cff;
  }

  .biz-form__contact-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 2px;
  }

  .biz-form__contact-value {
    font-size: 14px;
    font-weight: 600;
  }

  .biz-form__panel {
    background: #ffffff;
    padding: clamp(36px, 5vw, 56px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .biz-form__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 400;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #0a0c12;
    margin: 0 0 8px;
    line-height: 1;
  }

  .biz-form__subtitle {
    font-size: 14px;
    color: #5a6270;
    margin: 0 0 32px;
    line-height: 1.5;
  }

  .biz-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }

  .biz-form__group {
    margin-bottom: 16px;
  }

  .biz-form__label {
    display: block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #8a92a0;
    margin-bottom: 8px;
  }

  .biz-form__input,
  .biz-form__select {
    width: 100%;
    padding: 14px 16px;
    border: 1.5px solid #e0e4ec;
    border-radius: 12px;
    font-family: inherit;
    font-size: 15px;
    color: #0a0c12;
    background: #f8f9fc;
    outline: none;
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    box-sizing: border-box;
  }

  .biz-form__input:focus,
  .biz-form__select:focus {
    border-color: #4f8cff;
    background: #ffffff;
    box-shadow: 0 0 0 4px rgba(79, 140, 255, 0.12);
  }

  .biz-form__phone-wrap {
    display: flex;
    align-items: stretch;
    border: 1.5px solid #e0e4ec;
    border-radius: 12px;
    overflow: hidden;
    background: #f8f9fc;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .biz-form__phone-wrap:focus-within {
    border-color: #4f8cff;
    background: #ffffff;
    box-shadow: 0 0 0 4px rgba(79, 140, 255, 0.12);
  }

  .biz-form__phone-prefix {
    display: flex;
    align-items: center;
    padding: 0 14px;
    font-size: 14px;
    font-weight: 600;
    color: #333333;
    background: #eef1f7;
    border-right: 1.5px solid #e0e4ec;
    white-space: nowrap;
  }

  .biz-form__phone-wrap .biz-form__input {
    border: none;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  textarea.biz-form__input {
    resize: vertical;
    min-height: 120px;
  }

  .biz-form__success {
    background: linear-gradient(135deg, #e8f0ff, #f0f4ff);
    color: #1a56c4;
    padding: 16px 20px;
    border-radius: 12px;
    margin-bottom: 24px;
    font-weight: 600;
    font-size: 14px;
    border: 1px solid rgba(26, 86, 196, 0.2);
  }

  .biz-form__submit {
    width: 100%;
    margin-top: 8px;
    padding: 16px 24px;
    border: none;
    border-radius: 999px;
    background: linear-gradient(135deg, #0a0c12 0%, #1a2236 100%);
    color: #ffffff;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .biz-form__submit:hover {
    background: linear-gradient(135deg, #ff2b2b 0%, #cc2222 100%);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(255, 43, 43, 0.35);
  }

  @media screen and (max-width: 900px) {
    .biz-form__grid {
      grid-template-columns: 1fr;
    }

    .biz-form__row {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<section class="biz-form" id="biz-inquiry" data-no-typewriter>
  <div class="biz-form__wrap">
    <div class="biz-form__grid">
      <div class="biz-form__visual">
        {%- if section.settings.side_image != blank -%}
          <div class="biz-form__visual-bg" aria-hidden="true">
            <img src="{{ section.settings.side_image | image_url: width: 1200 }}" alt="" loading="lazy">
          </div>
        {%- endif -%}
        <div class="biz-form__visual-mesh" aria-hidden="true"></div>
        <div class="biz-form__visual-content">
          <p class="biz-form__visual-eyebrow">{{ section.settings.eyebrow | default: 'Partner With Us' }}</p>
          <h2 class="biz-form__visual-title">{{ section.settings.side_title | default: "Let's Build Together" }}</h2>
          <p class="biz-form__visual-text">{{ section.settings.side_text | default: "Tell us about your business and our partnerships team will respond with a custom proposal within 24Ã¢â‚¬â€œ48 hours." }}</p>
        </div>
        <div class="biz-form__contacts">
          <a href="mailto:{{ section.settings.email | default: 'business@hagueprotect.com' }}" class="biz-form__contact">
            <span class="biz-form__contact-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="2"/><path d="M3 7l9 6 9-6" stroke="currentColor" stroke-width="2"/></svg>
            </span>
            <span>
              <span class="biz-form__contact-label">{{ section.settings.email_label | default: 'Email' }}</span>
              <span class="biz-form__contact-value">{{ section.settings.email | default: 'business@hagueprotect.com' }}</span>
            </span>
          </a>
          <a href="https://wa.me/{{ section.settings.whatsapp | default: '917009205008' }}" class="biz-form__contact" target="_blank" rel="noopener">
            <span class="biz-form__contact-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 6.03 2 11.17c0 1.8.52 3.52 1.5 5.02L2 22l6.05-1.58A9.93 9.93 0 0012 20.33C17.52 20.33 22 16.3 22 11.17S17.52 2 12 2z" stroke="currentColor" stroke-width="1.5"/></svg>
            </span>
            <span>
              <span class="biz-form__contact-label">{{ section.settings.whatsapp_label | default: 'WhatsApp' }}</span>
              <span class="biz-form__contact-value">{{ section.settings.phone_display | default: '7009205008' }}</span>
            </span>
          </a>
        </div>
      </div>

      <div class="biz-form__panel">
        <h2 class="biz-form__title">{{ section.settings.form_title | default: 'Apply to Partner' }}</h2>
        <p class="biz-form__subtitle">{{ section.settings.form_subtitle | default: "Fill in your details and we'll get back to you with pricing and next steps." }}</p>

        {%- form 'contact', id: 'BusinessPartnerForm', class: 'biz-form__body' -%}
          <input type="hidden" name="contact[tags]" value="business-partner">

          {%- if form.posted_successfully? -%}
            <div class="biz-form__success">
              {{ section.settings.success_message | default: "Thank you! Our partnerships team will reach out within 24Ã¢â‚¬â€œ48 hours." }}
            </div>
          {%- endif -%}

          <div class="biz-form__row">
            <div>
              <label class="biz-form__label" for="BizName">{{ section.settings.label_name | default: 'Name' }}</label>
              <input type="text" id="BizName" name="contact[name]" class="biz-form__input" placeholder="{{ section.settings.placeholder_name | default: 'Your name' }}" required>
            </div>
            <div>
              <label class="biz-form__label" for="BizCompany">{{ section.settings.label_company | default: 'Company' }}</label>
              <input type="text" id="BizCompany" name="contact[company]" class="biz-form__input" placeholder="{{ section.settings.placeholder_company | default: 'Business name' }}" required>
            </div>
          </div>

          <div class="biz-form__group">
            <label class="biz-form__label" for="BizType">{{ section.settings.label_type | default: 'Business Type' }}</label>
            <select id="BizType" name="contact[business_type]" class="biz-form__select" required>
              <option value="" disabled selected>{{ section.settings.placeholder_type | default: 'Select your business type' }}</option>
              <option value="Retailer">Retailer / Store</option>
              <option value="Distributor">Distributor</option>
              <option value="E-Commerce">E-Commerce Brand</option>
              <option value="Corporate">Corporate Buyer</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div class="biz-form__group">
            <label class="biz-form__label" for="BizEmail">{{ section.settings.label_email | default: 'Work Email' }}</label>
            <input type="email" id="BizEmail" name="contact[email]" class="biz-form__input" placeholder="{{ section.settings.placeholder_email | default: 'you@company.com' }}" required>
          </div>

          <div class="biz-form__group">
            <label class="biz-form__label" for="BizPhone">{{ section.settings.label_phone | default: 'Phone' }}</label>
            <div class="biz-form__phone-wrap">
              <span class="biz-form__phone-prefix">{{ section.settings.phone_prefix | default: 'Ã°Å¸â€¡Â®Ã°Å¸â€¡Â³ +91' }}</span>
              <input type="tel" id="BizPhone" name="contact[phone]" class="biz-form__input" placeholder="{{ section.settings.placeholder_phone | default: 'Phone number' }}" required>
            </div>
          </div>

          <div class="biz-form__group">
            <label class="biz-form__label" for="BizMessage">{{ section.settings.label_message | default: 'Tell us about your needs' }}</label>
            <textarea id="BizMessage" name="contact[body]" class="biz-form__input" placeholder="{{ section.settings.placeholder_message | default: 'Locations, monthly volume, product categories of interest...' }}" required></textarea>
          </div>

          <button type="submit" class="biz-form__submit">{{ section.settings.submit_label | default: 'Submit Application' }}</button>
        {%- endform -%}
      </div>
    </div>
  </div>
</section>


{%- style -%}
  .hp-dna-{{ section.id }} {
    --hp-dna-accent: {{ section.settings.accent_color }};
    --hp-dna-text: {{ section.settings.text_color }};
    --hp-dna-badge: {{ section.settings.icon_badge_size }}px;
    --hp-dna-glow: {{ section.settings.glow_intensity | divided_by: 100.0 }};
    background-color: {{ section.settings.bg_color }};
    color: var(--hp-dna-text);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    overflow: hidden;
  }

  @keyframes hp-dna-float-{{ section.id }} {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -5px, 0); }
  }

  @keyframes hp-dna-accent-pulse-{{ section.id }} {
    0%, 100% { opacity: 0.82; }
    50% { opacity: 1; }
  }

  @keyframes hp-dna-glow-breathe-{{ section.id }} {
    0%, 100% { opacity: calc(var(--hp-dna-glow) * 0.55); transform: scale(0.96); }
    50% { opacity: calc(var(--hp-dna-glow) * 0.9); transform: scale(1.04); }
  }

  .hp-dna-{{ section.id }} .hp-dna__container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 60px);
  }

  .hp-dna-{{ section.id }} .hp-dna__heading {
    font-size: clamp(22px, 3.2vw, 36px);
    font-weight: 800;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.25;
    margin: 0 0 clamp(48px, 6vw, 72px);
    color: var(--hp-dna-text);
  }

  .hp-dna-{{ section.id }} .hp-dna__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(28px, 3vw, 48px);
  }

  .hp-dna-{{ section.id }} .hp-dna__item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  .hp-dna-{{ section.id }} .hp-dna__icon-wrap {
    margin-bottom: 28px;
    flex-shrink: 0;
  }

  .hp-dna-{{ section.id }} .hp-dna__icon-badge {
    position: relative;
    width: var(--hp-dna-badge);
    height: var(--hp-dna-badge);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: default;
    transform: translateZ(0);
    transition: transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hp-dna-{{ section.id }} .hp-dna__icon-glow {
    position: absolute;
    inset: 8%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 43, 43, calc(var(--hp-dna-glow) * 0.45)) 0%, transparent 72%);
    filter: blur(10px);
    opacity: calc(var(--hp-dna-glow) * 0.6);
    transition: opacity 0.65s cubic-bezier(0.22, 1, 0.36, 1), transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
    animation: hp-dna-glow-breathe-{{ section.id }} 6s ease-in-out infinite;
  }

  .hp-dna-{{ section.id }} .hp-dna__icon-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.22);
    background: radial-gradient(circle at 35% 30%, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.01) 55%, transparent 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 0 0 1px rgba(255, 255, 255, 0.04);
    transition: border-color 0.65s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.65s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }

  .hp-dna-{{ section.id }} .hp-dna__icon-float {
    position: relative;
    z-index: 2;
    width: 52%;
    height: 52%;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
  }

  {%- if section.settings.enable_float -%}
  .hp-dna-{{ section.id }} .hp-dna__icon-float {
    animation: hp-dna-float-{{ section.id }} 5.5s ease-in-out infinite;
  }

  .hp-dna-{{ section.id }} .hp-dna__item:nth-child(1) .hp-dna__icon-float { animation-delay: 0s; }
  .hp-dna-{{ section.id }} .hp-dna__item:nth-child(2) .hp-dna__icon-float { animation-delay: 0.8s; }
  .hp-dna-{{ section.id }} .hp-dna__item:nth-child(3) .hp-dna__icon-float { animation-delay: 1.6s; }
  .hp-dna-{{ section.id }} .hp-dna__item:nth-child(4) .hp-dna__icon-float { animation-delay: 2.4s; }
  {%- endif -%}

  .hp-dna-{{ section.id }} .hp-dna__svg {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }

  .hp-dna-{{ section.id }} .hp-dna__svg-accent,
  .hp-dna-{{ section.id }} .hp-dna__svg-accent-fill {
    filter: drop-shadow(0 0 4px rgba(255, 43, 43, 0.55));
    animation: hp-dna-accent-pulse-{{ section.id }} 3.5s ease-in-out infinite;
  }

  .hp-dna-{{ section.id }} .hp-dna__item:nth-child(1) .hp-dna__svg-accent { animation-delay: 0s; }
  .hp-dna-{{ section.id }} .hp-dna__item:nth-child(2) .hp-dna__svg-accent { animation-delay: 0.6s; }
  .hp-dna-{{ section.id }} .hp-dna__item:nth-child(3) .hp-dna__svg-accent { animation-delay: 1.2s; }
  .hp-dna-{{ section.id }} .hp-dna__item:nth-child(4) .hp-dna__svg-accent { animation-delay: 1.8s; }

  .hp-dna-{{ section.id }} .hp-dna__icon-badge img {
    width: 52%;
    height: 52%;
    object-fit: contain;
    position: relative;
    z-index: 2;
  }

  {%- if section.settings.enable_hover -%}
  @media (hover: hover) and (pointer: fine) {
    .hp-dna-{{ section.id }} .hp-dna__icon-badge:hover {
      transform: scale(1.06);
    }

    .hp-dna-{{ section.id }} .hp-dna__icon-badge:hover .hp-dna__icon-glow {
      opacity: calc(var(--hp-dna-glow) * 1.15);
      transform: scale(1.12);
    }

    .hp-dna-{{ section.id }} .hp-dna__icon-badge:hover .hp-dna__icon-ring {
      border-color: rgba(255, 43, 43, 0.45);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.12),
        0 0 24px rgba(255, 43, 43, 0.28),
        0 0 0 1px rgba(255, 43, 43, 0.2);
    }

    .hp-dna-{{ section.id }} .hp-dna__icon-badge:hover .hp-dna__svg-accent {
      filter: drop-shadow(0 0 8px rgba(255, 43, 43, 0.85));
    }
  }
  {%- endif -%}

  .hp-dna-{{ section.id }} .hp-dna__item-title {
    font-size: clamp(14px, 1.4vw, 16px);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1.3;
    margin: 0 0 14px;
    color: var(--hp-dna-text);
  }

  .hp-dna-{{ section.id }} .hp-dna__item-text {
    font-size: clamp(13px, 1.2vw, 15px);
    font-weight: 400;
    line-height: 1.55;
    margin: 0;
    color: var(--hp-dna-text);
    opacity: 0.92;
    max-width: 280px;
  }

  {%- if section.settings.enable_animations -%}
  .hp-dna-{{ section.id }} .hp-dna__heading.hp-dna__reveal {
    opacity: 0;
    transform: translate3d(0, 28px, 0);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }

  .hp-dna-{{ section.id }} .hp-dna__icon-badge.hp-dna__icon-reveal {
    opacity: 0;
    transform: translate3d(0, 18px, 0) scale(0.94);
    transition: opacity 0.95s cubic-bezier(0.16, 1, 0.3, 1), transform 0.95s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }

  .hp-dna-{{ section.id }} .hp-dna__item-copy.hp-dna__reveal {
    opacity: 0;
    transform: translate3d(0, 16px, 0);
    transition: opacity 0.85s cubic-bezier(0.16, 1, 0.3, 1), transform 0.85s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }

  .hp-dna-{{ section.id }} .hp-dna__reveal.is-visible,
  .hp-dna-{{ section.id }} .hp-dna__icon-reveal.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
  {%- endif -%}

  @media screen and (max-width: 1024px) {
    .hp-dna-{{ section.id }} .hp-dna__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 40px 32px;
    }
  }

  @media screen and (max-width: 640px) {
    .hp-dna-{{ section.id }} {
      --hp-dna-badge: {{ section.settings.icon_badge_size | times: 0.85 | round }}px;
    }

    .hp-dna-{{ section.id }} .hp-dna__grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .hp-dna-{{ section.id }} .hp-dna__icon-wrap {
      margin-bottom: 20px;
    }

    .hp-dna-{{ section.id }} .hp-dna__item-text {
      max-width: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hp-dna-{{ section.id }} .hp-dna__icon-float,
    .hp-dna-{{ section.id }} .hp-dna__icon-glow,
    .hp-dna-{{ section.id }} .hp-dna__svg-accent {
      animation: none !important;
    }
  }
{%- endstyle -%}

<section
  class="hp-dna-{{ section.id }} section-spacing"
  aria-label="{{ section.settings.heading | escape }}"
  data-hp-dna-section="{{ section.id }}"
  data-enable-animations="{{ section.settings.enable_animations }}"
>
  <div class="hp-dna__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="hp-dna__heading{% if section.settings.enable_animations %} hp-dna__reveal{% endif %}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="hp-dna__grid">
        {%- for block in section.blocks -%}
          {%- assign icon_delay = forloop.index | times: 180 | plus: 350 -%}
          {%- assign copy_delay = forloop.index | times: 120 | plus: 650 -%}
          <div class="hp-dna__item" {{ block.shopify_attributes }}>
            <div class="hp-dna__icon-wrap">
              <div
                class="hp-dna__icon-badge{% if section.settings.enable_animations %} hp-dna__icon-reveal{% endif %}"
                {%- if section.settings.enable_animations -%}
                  style="transition-delay: {{ icon_delay }}ms;"
                {%- endif -%}
                aria-hidden="true"
              >
                <span class="hp-dna__icon-glow"></span>
                <span class="hp-dna__icon-ring"></span>
                <span class="hp-dna__icon-float">
                  {%- if block.settings.icon != blank -%}
                    {{
                      block.settings.icon
                      | image_url: width: 160
                      | image_tag:
                        loading: 'lazy',
                        alt: '',
                        width: 48,
                        height: 48
                    }}
                  {%- else -%}
                    {% render 'hp-dna-icon',
                      preset: block.settings.icon_preset,
                      accent_color: section.settings.accent_color,
                      text_color: section.settings.text_color,
                      index: forloop.index
                    %}
                  {%- endif -%}
                </span>
              </div>
            </div>

            <div
              class="hp-dna__item-copy{% if section.settings.enable_animations %} hp-dna__reveal{% endif %}"
              {%- if section.settings.enable_animations -%}
                style="transition-delay: {{ copy_delay }}ms;"
              {%- endif -%}
            >
              {%- if block.settings.title != blank -%}
                <h3 class="hp-dna__item-title">{{ block.settings.title }}</h3>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p class="hp-dna__item-text">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{%- if section.settings.enable_animations -%}
  <script>
    (function () {
      var section = document.querySelector('[data-hp-dna-section="{{ section.id }}"][data-enable-animations="true"]');
      if (!section || !('IntersectionObserver' in window)) return;

      var reveal = function () {
        section.querySelectorAll('.hp-dna__reveal, .hp-dna__icon-reveal').forEach(function (el) {
          el.classList.add('is-visible');
        });
      };

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        reveal();
        return;
      }

      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              reveal();
              observer.disconnect();
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );

      observer.observe(section);
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "HAGUE PROTECT DNA",
  "tag": "section",
  "class": "section-hague-protect-dna",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "HAGUE PROTECT DNA: Culture, Care, and Craft."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Icon accent color",
      "default": "#FF2B2B"
    },
    {
      "type": "range",
      "id": "icon_badge_size",
      "label": "Icon badge size",
      "min": 64,
      "max": 112,
      "step": 4,
      "unit": "px",
      "default": 88
    },
    {
      "type": "range",
      "id": "glow_intensity",
      "label": "Red glow intensity",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 70
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container max width",
      "min": 1000,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1320
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 40,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 88
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 40,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 88
    },
    {
      "type": "checkbox",
      "id": "enable_animations",
      "label": "Enable scroll reveal animations",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_float",
      "label": "Enable icon floating effect",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_hover",
      "label": "Enable icon hover interactions",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature column",
      "settings": [
        {
          "type": "select",
          "id": "icon_preset",
          "label": "Default icon",
          "options": [
            { "value": "shoecare", "label": "Specialised shoecare" },
            { "value": "streets", "label": "Indian streets tested" },
            { "value": "quality", "label": "Quality obsessed" },
            { "value": "innovating", "label": "Always innovating" },
            { "value": "custom", "label": "Custom / upload" }
          ],
          "default": "shoecare"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Custom icon image",
          "info": "Overrides the default icon when uploaded."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Column heading",
          "default": "SPECIALISED SHOECARE"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "From suede to mesh to leather, precision-engineered formulas crafted to clean, protect, and revive every kind of shoes."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HAGUE PROTECT DNA",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon_preset": "shoecare",
            "title": "SPECIALISED SHOECARE",
            "description": "From suede to mesh to leather, precision-engineered formulas crafted to clean, protect, and revive every kind of shoes."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_preset": "streets",
            "title": "INDIAN STREETS TESTED",
            "description": "Built for Indian dust, rain & chaos: engineered to perform through every hustle, season, and sneaker drop."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_preset": "quality",
            "title": "QUALITY OBSESSED",
            "description": "No shortcuts. Just high-performance care, premium formulations, and obsessive attention to detail, every time."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_preset": "innovating",
            "title": "ALWAYS INNOVATING",
            "description": "From packaging to formulas, we never stand still, we build sneaker care that evolves as fast as the culture does."
          }
        }
      ]
    }
  ]
}
{% endschema %}

{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .hp-dna-{{ section.id }} {
    --hp-dna-accent: {{ section.settings.accent_color }};
    --hp-dna-text: {{ section.settings.text_color }};
    --hp-dna-badge: {{ section.settings.icon_badge_size }}px;
    --hp-dna-glow: {{ section.settings.glow_intensity | divided_by: 100.0 }};
    background-color: {{ section.settings.bg_color }};
    color: var(--hp-dna-text);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: var(--font-family-sans, 'Inter', system-ui, -apple-system, sans-serif);
    overflow: hidden;
  }

  @keyframes hp-dna-float-{{ section.id }} {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -5px, 0); }
  }

  @keyframes hp-dna-accent-pulse-{{ section.id }} {
    0%, 100% { opacity: 0.82; }
    50% { opacity: 1; }
  }

  @keyframes hp-dna-glow-breathe-{{ section.id }} {
    0%, 100% { opacity: calc(var(--hp-dna-glow) * 0.55); transform: scale(0.96); }
    50% { opacity: calc(var(--hp-dna-glow) * 0.9); transform: scale(1.04); }
  }

  .hp-dna-{{ section.id }} .hp-dna__container {
    max-width: {{ section.settings.container_width | default: settings.site_max_width | default: 1440 }}px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 60px);
  }

  .hp-dna-{{ section.id }} .hp-dna__heading {
    font-size: clamp(22px, 3.2vw, 36px);
    font-weight: 800;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.25;
    margin: 0 0 clamp(48px, 6vw, 72px);
    color: var(--hp-dna-text);
  }

  .hp-dna-{{ section.id }} .hp-dna__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(28px, 3vw, 48px);
  }

  .hp-dna-{{ section.id }} .hp-dna__item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  .hp-dna-{{ section.id }} .hp-dna__icon-wrap {
    margin-bottom: 28px;
    flex-shrink: 0;
  }

  .hp-dna-{{ section.id }} .hp-dna__icon-badge {
    position: relative;
    width: var(--hp-dna-badge);
    height: var(--hp-dna-badge);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: default;
    transform: translateZ(0);
    transition: transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hp-dna-{{ section.id }} .hp-dna__icon-glow {
    display: none;
  }

  .hp-dna-{{ section.id }} .hp-dna__icon-float {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
  }

  {%- if section.settings.enable_float -%}
  .hp-dna-{{ section.id }} .hp-dna__icon-float {
    animation: hp-dna-float-{{ section.id }} 5.5s ease-in-out infinite;
  }

  .hp-dna-{{ section.id }} .hp-dna__item:nth-child(1) .hp-dna__icon-float { animation-delay: 0s; }
  .hp-dna-{{ section.id }} .hp-dna__item:nth-child(2) .hp-dna__icon-float { animation-delay: 0.8s; }
  .hp-dna-{{ section.id }} .hp-dna__item:nth-child(3) .hp-dna__icon-float { animation-delay: 1.6s; }
  .hp-dna-{{ section.id }} .hp-dna__item:nth-child(4) .hp-dna__icon-float { animation-delay: 2.4s; }
  {%- endif -%}

  .hp-dna-{{ section.id }} .hp-dna__svg {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }

  .hp-dna-{{ section.id }} .hp-dna__svg-accent,
  .hp-dna-{{ section.id }} .hp-dna__svg-accent-fill {
    filter: drop-shadow(0 0 4px rgba(255, 43, 43, 0.55));
    animation: hp-dna-accent-pulse-{{ section.id }} 3.5s ease-in-out infinite;
  }

  .hp-dna-{{ section.id }} .hp-dna__item:nth-child(1) .hp-dna__svg-accent { animation-delay: 0s; }
  .hp-dna-{{ section.id }} .hp-dna__item:nth-child(2) .hp-dna__svg-accent { animation-delay: 0.6s; }
  .hp-dna-{{ section.id }} .hp-dna__item:nth-child(3) .hp-dna__svg-accent { animation-delay: 1.2s; }
  .hp-dna-{{ section.id }} .hp-dna__item:nth-child(4) .hp-dna__svg-accent { animation-delay: 1.8s; }

  .hp-dna-{{ section.id }} .hp-dna__icon-badge img,
  .hp-dna-{{ section.id }} .hp-dna__icon-custom {
    width: 100%;
    height: 100%;
    object-fit: contain;
    position: relative;
    z-index: 2;
    display: block;
  }

  .hp-dna-{{ section.id }} .hp-dna__icon-custom--gif {
    pointer-events: none;
  }

  {%- if section.settings.enable_hover -%}
  @media (hover: hover) and (pointer: fine) {
    .hp-dna-{{ section.id }} .hp-dna__icon-badge:hover {
      transform: scale(1.06);
    }

    .hp-dna-{{ section.id }} .hp-dna__icon-badge:hover .hp-dna__svg-accent {
      filter: drop-shadow(0 0 8px rgba(255, 43, 43, 0.85));
    }
  }
  {%- endif -%}

  .hp-dna-{{ section.id }} .hp-dna__item-title {
    font-size: 15px !important;
    font-weight: 700 !important;
    font-family: var(--font-family-sans, 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif) !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
    line-height: 1.35 !important;
    margin: 0 0 14px;
    color: var(--hp-dna-text);
  }

  .hp-dna-{{ section.id }} .hp-dna__item-text {
    font-size: 14px !important;
    font-weight: 400 !important;
    font-family: var(--font-family-sans, 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif) !important;
    line-height: 1.55 !important;
    margin: 0;
    color: var(--hp-dna-text);
    opacity: 0.92;
    max-width: 280px;
    text-transform: none !important;
  }

  @media screen and (max-width: 1024px) {
    .hp-dna-{{ section.id }} .hp-dna__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 40px 32px;
    }
  }

  @media screen and (max-width: 640px) {
    .hp-dna-{{ section.id }} {
      --hp-dna-badge: {{ section.settings.icon_badge_size | times: 0.92 | round }}px;
    }

    .hp-dna-{{ section.id }} .hp-dna__grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .hp-dna-{{ section.id }} .hp-dna__icon-wrap {
      margin-bottom: 20px;
    }

    .hp-dna-{{ section.id }} .hp-dna__item-text {
      max-width: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hp-dna-{{ section.id }} .hp-dna__icon-float,
    .hp-dna-{{ section.id }} .hp-dna__icon-glow,
    .hp-dna-{{ section.id }} .hp-dna__svg-accent {
      animation: none !important;
    }
  }
{%- endstyle -%}

<section
  class="hp-dna-{{ section.id }} section-spacing"
  aria-label="{{ section.settings.heading | escape }}"
  data-hp-dna-section="{{ section.id }}"
>
  <div class="hp-dna__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="hp-dna__heading">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="hp-dna__grid">
        {%- for block in section.blocks -%}
          <div class="hp-dna__item" {{ block.shopify_attributes }}>
            <div class="hp-dna__icon-wrap">
              <div
                class="hp-dna__icon-badge"
                aria-hidden="true"
              >
                <span class="hp-dna__icon-float">
                  {%- if block.settings.icon != blank -%}
                    {%- liquid
                      assign custom_icon = block.settings.icon
                      assign icon_src = custom_icon.src | default: ''
                      assign icon_is_gif = false
                      if icon_src contains '.gif'
                        assign icon_is_gif = true
                      endif
                    -%}
                    {%- if icon_is_gif -%}
                      <img
                        src="{{ custom_icon | image_url }}"
                        class="hp-dna__icon-custom hp-dna__icon-custom--gif"
                        loading="lazy"
                        alt=""
                        width="{{ custom_icon.width }}"
                        height="{{ custom_icon.height }}"
                      >
                    {%- else -%}
                      {{
                        custom_icon
                        | image_url: width: 320
                        | image_tag:
                          class: 'hp-dna__icon-custom',
                          loading: 'lazy',
                          alt: '',
                          width: 80,
                          height: 80
                      }}
                    {%- endif -%}
                  {%- else -%}
                    {% render 'hp-dna-icon',
                      preset: block.settings.icon_preset,
                      accent_color: section.settings.accent_color,
                      text_color: section.settings.text_color,
                      index: forloop.index
                    %}
                  {%- endif -%}
                </span>
              </div>
            </div>

            <div class="hp-dna__item-copy">
              {%- if block.settings.title != blank -%}
                <h3 class="hp-dna__item-title">{{ block.settings.title }}</h3>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p class="hp-dna__item-text">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>


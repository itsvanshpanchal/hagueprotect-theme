{%- style -%}
  .category-section {
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
  }

  .category-header {
    text-align: center;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 56px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .category__eyebrow {
    color: var(--color-primary);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .category__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  @media screen and (max-width: 991px) {
    .category__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  @media screen and (max-width: 575px) {
    .category__grid {
      grid-template-columns: 1fr;
    }
  }

  .cat-card {
    background-color: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-md);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 32px;
    transition: var(--transition-smooth);
    cursor: pointer;
  }

  .cat-card:hover {
    border-color: transparent;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.08);
    transform: translateY(-6px);
  }

  .cat-card__bg-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    transition: var(--transition-smooth);
  }

  .cat-card:hover .cat-card__bg-image {
    transform: scale(1.12);
  }

  .cat-card__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(0deg, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.1) 60%, rgba(0, 0, 0, 0) 100%);
    z-index: 2;
  }

  .cat-card__content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cat-card__title {
    color: #ffffff;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .cat-card__btn {
    font-size: 13px;
    color: #ffffff;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cat-card__btn span {
    transition: var(--transition-fast);
  }

  .cat-card:hover .cat-card__btn span {
    transform: translateX(4px);
  }
{%- endstyle -%}

<section class="category-section section-spacing" aria-label="Product categories">
  <div class="container">
    <div class="category-header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="category__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="h2">{{ section.settings.heading | default: 'Shop By Category' }}</h2>
    </div>

    <div class="category__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.collection.url | default: '/collections/all' }}" class="cat-card animate-fade-in" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | default: 'Product category' | escape }}" class="cat-card__bg-image" loading="lazy">
          {%- else -%}
            <!-- Premium Placeholder vector art inside SVG for collections -->
            <svg class="cat-card__bg-image" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 500">
              <rect width="400" height="500" fill="#f8f8fa"/>
              <circle cx="200" cy="220" r="90" fill="#ffffff" opacity="0.6" filter="drop-shadow(0 12px 32px rgba(0,0,0,0.03))"/>
              {%- if forloop.index == 1 -%}
                <!-- Cleaning Kits Icon overlay -->
                <path d="M180 180h40v80h-40z" fill="#FF2B2B" opacity="0.2"/>
              {%- elsif forloop.index == 2 -%}
                <!-- Brushes Icon overlay -->
                <path d="M170 170l60 60" stroke="#FF2B2B" stroke-width="8" stroke-linecap="round"/>
              {%- elsif forloop.index == 3 -%}
                <!-- Sprays Icon overlay -->
                <circle cx="200" cy="210" r="30" fill="#111111" opacity="0.1"/>
              {%- else -%}
                <!-- Accessories Icon overlay -->
                <rect x="180" y="190" width="40" height="40" rx="8" fill="#111111" opacity="0.15"/>
              {%- endif -%}
            </svg>
          {%- endif -%}

          <div class="cat-card__overlay"></div>

          <div class="cat-card__content">
            <h3 class="cat-card__title">{{ block.settings.title | default: 'Category Title' }}</h3>
            <span class="cat-card__btn">Explore <span>&rarr;</span></span>
          </div>
        </a>
      {%- else -%}
        <!-- Elite category cards fallbacks -->
        {%- for i in (1..4) -%}
          <a href="/collections/all" class="cat-card animate-fade-in">
            <svg class="cat-card__bg-image" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 500">
              <rect width="400" height="500" fill="#fbfbfd"/>
              <circle cx="200" cy="220" r="100" fill="#ffffff" opacity="0.8" filter="drop-shadow(0 16px 36px rgba(0,0,0,0.03))"/>
              {%- if i == 1 -%}
                <path d="M170 180l30-30 30 30-30 30-30-30z" fill="#FF2B2B" opacity="0.2"/>
                <path d="M200 150v60" stroke="#FF2B2B" stroke-width="2"/>
              {%- elsif i == 2 -%}
                <path d="M165 210h70" stroke="#111" stroke-width="6" stroke-linecap="round"/>
                <path d="M170 180v30m15-30v30m15-30v30m15-30v30" stroke="#111" stroke-width="2"/>
              {%- elsif i == 3 -%}
                <rect x="180" y="170" width="40" height="80" rx="10" fill="#111111" opacity="0.1"/>
                <circle cx="200" cy="150" r="12" fill="#FF2B2B" opacity="0.3"/>
              {%- else -%}
                <rect x="175" y="185" width="50" height="50" rx="12" fill="#FF2B2B" opacity="0.2"/>
              {%- endif -%}
            </svg>
            <div class="cat-card__overlay"></div>
            <div class="cat-card__content">
              <h3 class="cat-card__title">
                {%- if i == 1 -%}
                  Cleaning Kits
                {%- elsif i == 2 -%}
                  Brushes & Tools
                {%- elsif i == 3 -%}
                  Sprays & Protectors
                {%- else -%}
                  Accessories
                {%- endif -%}
              </h3>
              <span class="cat-card__btn">Explore <span>&rarr;</span></span>
            </div>
          </a>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category Section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Elite Selections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop By Category"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "category_item",
      "name": "Category Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category Title",
          "default": "Cleaning Kits"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Visual Background"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Section",
      "blocks": [
        { "type": "category_item", "settings": { "title": "Cleaning Kits" } },
        { "type": "category_item", "settings": { "title": "Brushes & Tools" } },
        { "type": "category_item", "settings": { "title": "Sprays & Protectors" } },
        { "type": "category_item", "settings": { "title": "Accessories" } }
      ]
    }
  ]
}
{% endschema %}

{%- style -%}
  .category-section {
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
  }

  .category-header {
    text-align: center;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 56px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .category__eyebrow {
    color: var(--color-primary);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Desktop grid */
  .category__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  @media screen and (max-width: 991px) {
    .category__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  /* Mobile slider wrapper */
  .category__slider-wrapper {
    display: none;
  }

  .category__slider-track {
    display: flex;
    gap: 16px;
    /* Native smooth scroll */
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    /* Hide scrollbar */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .category__slider-track::-webkit-scrollbar {
    display: none;
  }

  .category__slider-track .cat-card {
    flex: 0 0 calc(50% - 8px);
    min-width: calc(50% - 8px);
    aspect-ratio: 1 / 1;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  /* Mobile slider nav */
  .category__slider-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: absolute;
    top: 50%;
    left: -8px;
    right: -8px;
    transform: translateY(-50%);
    pointer-events: none;
    z-index: 10;
  }

  .category__arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #FFFFFF;
    border: 1px solid #D1D2D4;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    pointer-events: auto;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
    transition: all 0.2s ease;
    color: #111111;
  }

  .category__arrow:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .category__arrow svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.5;
  }

  /* Progress dots */
  .category__dots {
    display: none;
    justify-content: center;
    gap: 6px;
    margin-top: 20px;
  }

  .category__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #D1D2D4;
    transition: background 0.3s ease, width 0.3s ease;
  }

  .category__dot.active {
    background: #111111;
    width: 18px;
    border-radius: 4px;
  }

  @media screen and (max-width: 767px) {
    .category-header {
      margin-bottom: 32px;
    }
    /* Hide desktop grid, show slider */
    .category__grid {
      display: none;
    }
    .category__slider-wrapper {
      display: block;
      position: relative;
      overflow: hidden;
    }
    .category__dots {
      display: flex;
    }
    /* Fix card size & text visibility on mobile */
    .category__slider-track .cat-card {
      aspect-ratio: 3 / 4;
      padding: 14px;
    }
    .cat-card__title {
      font-size: clamp(13px, 4vw, 16px);
    }
    .cat-card__btn {
      font-size: 11px;
    }
    .cat-card__content {
      gap: 6px;
    }
  }

  .cat-card {
    background-color: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-md);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 32px;
    transition: var(--transition-smooth);
    cursor: pointer;
  }

  .cat-card:hover {
    border-color: transparent;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.08);
    transform: translateY(-6px);
  }

  .cat-card__bg-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    transition: var(--transition-smooth);
  }

  .cat-card:hover .cat-card__bg-image {
    transform: scale(1.12);
  }

  .cat-card__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(0deg, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.1) 60%, rgba(0, 0, 0, 0) 100%);
    z-index: 2;
  }

  .cat-card__content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cat-card__title {
    color: #ffffff;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .cat-card__btn {
    font-size: 13px;
    color: #ffffff;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cat-card__btn span {
    transition: var(--transition-fast);
  }

  .cat-card:hover .cat-card__btn span {
    transform: translateX(4px);
  }
{%- endstyle -%}

<section class="category-section section-spacing" aria-label="Product categories">
  <div class="container">
    <div class="category-header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="category__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="h2">{{ section.settings.heading | default: 'Shop By Category' }}</h2>
    </div>

    {%- comment -%} Desktop grid (hidden on mobile ≤767px via CSS) {%- endcomment -%}
    <div class="category__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.collection.url | default: '/collections/all' }}" class="cat-card animate-fade-in" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | default: 'Product category' | escape }}" class="cat-card__bg-image" loading="lazy">
          {%- else -%}
            <svg class="cat-card__bg-image" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 500">
              <rect width="400" height="500" fill="#f8f8fa"/>
              <circle cx="200" cy="220" r="90" fill="#ffffff" opacity="0.6"/>
              {%- if forloop.index == 1 -%}<path d="M180 180h40v80h-40z" fill="#FF2B2B" opacity="0.2"/>
              {%- elsif forloop.index == 2 -%}<path d="M170 170l60 60" stroke="#FF2B2B" stroke-width="8" stroke-linecap="round"/>
              {%- elsif forloop.index == 3 -%}<circle cx="200" cy="210" r="30" fill="#111111" opacity="0.1"/>
              {%- else -%}<rect x="180" y="190" width="40" height="40" rx="8" fill="#111111" opacity="0.15"/>
              {%- endif -%}
            </svg>
          {%- endif -%}
          <div class="cat-card__overlay"></div>
          <div class="cat-card__content">
            <h3 class="cat-card__title">{{ block.settings.title | default: 'Category Title' }}</h3>
            <span class="cat-card__btn">Explore <span>&rarr;</span></span>
          </div>
        </a>
      {%- else -%}
        {%- for i in (1..4) -%}
          <a href="/collections/all" class="cat-card animate-fade-in">
            <svg class="cat-card__bg-image" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 500">
              <rect width="400" height="500" fill="#fbfbfd"/>
              <circle cx="200" cy="220" r="100" fill="#ffffff" opacity="0.8"/>
              {%- if i == 1 -%}<path d="M170 180l30-30 30 30-30 30-30-30z" fill="#FF2B2B" opacity="0.2"/>
              {%- elsif i == 2 -%}<path d="M165 210h70" stroke="#111" stroke-width="6" stroke-linecap="round"/>
              {%- elsif i == 3 -%}<rect x="180" y="170" width="40" height="80" rx="10" fill="#111111" opacity="0.1"/>
              {%- else -%}<rect x="175" y="185" width="50" height="50" rx="12" fill="#FF2B2B" opacity="0.2"/>
              {%- endif -%}
            </svg>
            <div class="cat-card__overlay"></div>
            <div class="cat-card__content">
              <h3 class="cat-card__title">
                {%- if i == 1 -%}Cleaning Kits{%- elsif i == 2 -%}Brushes &amp; Tools{%- elsif i == 3 -%}Sprays &amp; Protectors{%- else -%}Accessories{%- endif -%}
              </h3>
              <span class="cat-card__btn">Explore <span>&rarr;</span></span>
            </div>
          </a>
        {%- endfor -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Mobile slider (shown on mobile ≤767px via CSS) {%- endcomment -%}
    <div class="category__slider-wrapper" id="cat-slider-wrapper-{{ section.id }}">
      <div style="overflow: hidden;">
        <div class="category__slider-track" id="cat-track-{{ section.id }}">
          {%- for block in section.blocks -%}
            <a href="{{ block.settings.collection.url | default: '/collections/all' }}" class="cat-card" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title | default: 'Product category' | escape }}" class="cat-card__bg-image" loading="lazy">
              {%- else -%}
                <svg class="cat-card__bg-image" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 500">
                  <rect width="400" height="500" fill="#f8f8fa"/>
                  <circle cx="200" cy="220" r="90" fill="#ffffff" opacity="0.6"/>
                  {%- if forloop.index == 1 -%}<path d="M180 180h40v80h-40z" fill="#FF2B2B" opacity="0.2"/>
                  {%- elsif forloop.index == 2 -%}<path d="M170 170l60 60" stroke="#FF2B2B" stroke-width="8" stroke-linecap="round"/>
                  {%- elsif forloop.index == 3 -%}<circle cx="200" cy="210" r="30" fill="#111111" opacity="0.1"/>
                  {%- else -%}<rect x="180" y="190" width="40" height="40" rx="8" fill="#111111" opacity="0.15"/>
                  {%- endif -%}
                </svg>
              {%- endif -%}
              <div class="cat-card__overlay"></div>
              <div class="cat-card__content">
                <h3 class="cat-card__title">{{ block.settings.title | default: 'Category Title' }}</h3>
                <span class="cat-card__btn">Explore <span>&rarr;</span></span>
              </div>
            </a>
          {%- else -%}
            {%- for i in (1..4) -%}
              <a href="/collections/all" class="cat-card">
                <svg class="cat-card__bg-image" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 500">
                  <rect width="400" height="500" fill="#fbfbfd"/>
                  <circle cx="200" cy="220" r="100" fill="#ffffff" opacity="0.8"/>
                  {%- if i == 1 -%}<path d="M170 180l30-30 30 30-30 30-30-30z" fill="#FF2B2B" opacity="0.2"/>
                  {%- elsif i == 2 -%}<path d="M165 210h70" stroke="#111" stroke-width="6" stroke-linecap="round"/>
                  {%- elsif i == 3 -%}<rect x="180" y="170" width="40" height="80" rx="10" fill="#111111" opacity="0.1"/>
                  {%- else -%}<rect x="175" y="185" width="50" height="50" rx="12" fill="#FF2B2B" opacity="0.2"/>
                  {%- endif -%}
                </svg>
                <div class="cat-card__overlay"></div>
                <div class="cat-card__content">
                  <h3 class="cat-card__title">
                    {%- if i == 1 -%}Cleaning Kits{%- elsif i == 2 -%}Brushes &amp; Tools{%- elsif i == 3 -%}Sprays &amp; Protectors{%- else -%}Accessories{%- endif -%}
                  </h3>
                  <span class="cat-card__btn">Explore <span>&rarr;</span></span>
                </div>
              </a>
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </div>

      <div class="category__slider-nav">
        <button class="category__arrow" id="cat-prev-{{ section.id }}" aria-label="Previous" disabled>
          <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="category__arrow" id="cat-next-{{ section.id }}" aria-label="Next">
          <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>

    <div class="category__dots" id="cat-dots-{{ section.id }}"></div>

  </div>
</section>

<script>
  (function() {
    function initCategorySlider() {
      var track = document.getElementById('cat-track-{{ section.id }}');
      var prevBtn = document.getElementById('cat-prev-{{ section.id }}');
      var nextBtn = document.getElementById('cat-next-{{ section.id }}');
      var dotsContainer = document.getElementById('cat-dots-{{ section.id }}');
      if (!track || !prevBtn || !nextBtn) return;

      var slides = track.querySelectorAll('.cat-card');
      if (slides.length === 0) return;

      var visibleCards = 2;
      var maxIndex = Math.max(0, slides.length - visibleCards);

      // Build dots
      dotsContainer.innerHTML = '';
      for (var i = 0; i <= maxIndex; i++) {
        var dot = document.createElement('div');
        dot.className = 'category__dot' + (i === 0 ? ' active' : '');
        (function(idx) {
          dot.addEventListener('click', function() { scrollToIndex(idx); });
        })(i);
        dotsContainer.appendChild(dot);
      }

      function getSlideWidth() {
        return slides[0].offsetWidth + 16; // card width + gap
      }

      function scrollToIndex(idx) {
        idx = Math.max(0, Math.min(idx, maxIndex));
        track.scrollTo({ left: idx * getSlideWidth(), behavior: 'smooth' });
      }

      function getCurrentIndex() {
        return Math.round(track.scrollLeft / getSlideWidth());
      }

      function syncUI() {
        var idx = getCurrentIndex();
        prevBtn.disabled = idx === 0;
        nextBtn.disabled = idx >= maxIndex;
        dotsContainer.querySelectorAll('.category__dot').forEach(function(d, i) {
          d.classList.toggle('active', i === idx);
        });
      }

      prevBtn.addEventListener('click', function() {
        scrollToIndex(getCurrentIndex() - 1);
      });

      nextBtn.addEventListener('click', function() {
        scrollToIndex(getCurrentIndex() + 1);
      });

      // Sync dots & buttons while scrolling
      var scrollTimer;
      track.addEventListener('scroll', function() {
        clearTimeout(scrollTimer);
        scrollTimer = setTimeout(syncUI, 80);
      }, { passive: true });

      window.addEventListener('resize', syncUI);
      syncUI();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCategorySlider);
    } else {
      initCategorySlider();
    }
    document.addEventListener('shopify:section:load', initCategorySlider);
  })();
</script>




{% schema %}
{
  "name": "Category Section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Elite Selections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop By Category"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "category_item",
      "name": "Category Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category Title",
          "default": "Cleaning Kits"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Visual Background"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Section",
      "blocks": [
        { "type": "category_item", "settings": { "title": "Cleaning Kits" } },
        { "type": "category_item", "settings": { "title": "Brushes & Tools" } },
        { "type": "category_item", "settings": { "title": "Sprays & Protectors" } },
        { "type": "category_item", "settings": { "title": "Accessories" } }
      ]
    }
  ]
}
{% endschema %}

{%- style -%}
  /* Style the slide-out drawer */
  .cart-drawer-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    z-index: 20000;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }
  .cart-drawer-overlay.is-active {
    opacity: 1;
    visibility: visible;
  }
  .cart-drawer {
    position: fixed;
    top: 0;
    right: -420px;
    width: 420px;
    max-width: 100vw;
    height: 100%;
    background-color: #ffffff;
    box-shadow: -8px 0 32px rgba(0, 0, 0, 0.1);
    z-index: 20001;
    display: flex;
    flex-direction: column;
    transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .cart-drawer-overlay.is-active .cart-drawer {
    right: 0;
  }
  .cart-drawer__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px;
    border-bottom: 1px solid #e5e5e5;
  }
  .cart-drawer__title {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0;
    color: #111111;
  }
  .cart-drawer__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111111;
    transition: transform 0.2s ease;
  }
  .cart-drawer__close:hover {
    transform: rotate(90deg);
  }
  .cart-drawer__close svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    stroke-width: 2;
  }
  .cart-drawer__items {
    flex-grow: 1;
    overflow-y: auto;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .cart-drawer__empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    text-align: center;
    gap: 16px;
    color: #555;
  }
  .cart-drawer__empty-title {
    font-size: 16px;
    font-weight: 600;
    color: #111111;
  }
  .cart-drawer__empty-btn {
    background-color: #111111;
    color: #ffffff;
    border: none;
    border-radius: 30px;
    padding: 12px 28px;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    text-decoration: none;
    transition: background-color 0.2s;
  }
  .cart-drawer__empty-btn:hover {
    background-color: #e21c1c;
  }
  .cart-drawer__item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 16px;
    align-items: start;
    border-bottom: 1px solid #f2f2f4;
    padding-bottom: 16px;
  }
  .cart-drawer__item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .cart-drawer__item-img-link {
    width: 80px;
    aspect-ratio: 1;
    background-color: #f8f8fa;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #e5e5e5;
  }
  .cart-drawer__item-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cart-drawer__item-details {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .cart-drawer__item-title {
    font-size: 14px;
    font-weight: 600;
    color: #111111;
    line-height: 1.4;
    margin: 0;
  }
  .cart-drawer__item-title a {
    text-decoration: none;
    color: inherit;
    transition: color 0.2s ease;
  }
  .cart-drawer__item-title a:hover {
    color: {{ section.settings.primary_color | default: '#FF2B2B' }};
  }
  .cart-drawer__item-variant {
    font-size: 12px;
    color: #777777;
    margin: 0;
  }
  .cart-drawer__item-price {
    font-size: 14px;
    font-weight: 700;
    color: {{ section.settings.primary_color | default: '#FF2B2B' }};
    margin: 4px 0 0;
  }
  .cart-drawer__item-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 10px;
  }
  .cart-drawer__qty-group {
    display: flex;
    align-items: center;
    border: 1px solid #e5e5e5;
    border-radius: 30px;
    height: 32px;
    overflow: hidden;
    background: #ffffff;
    width: 90px;
  }
  .cart-drawer__qty-btn {
    flex: 1;
    background: none;
    border: none;
    font-size: 14px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111111;
    transition: background-color 0.2s;
  }
  .cart-drawer__qty-btn:hover {
    background-color: #f2f2f4;
  }
  .cart-drawer__qty-val {
    width: 32px;
    text-align: center;
    border: none;
    background: transparent;
    font-size: 13px;
    font-weight: 600;
    color: #111111;
    -moz-appearance: textfield;
  }
  .cart-drawer__qty-val::-webkit-outer-spin-button,
  .cart-drawer__qty-val::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .cart-drawer__remove {
    background: none;
    border: none;
    font-size: 12px;
    color: #888888;
    text-decoration: underline;
    cursor: pointer;
    transition: color 0.2s;
    padding: 0;
  }
  .cart-drawer__remove:hover {
    color: #e21c1c;
  }
  .cart-drawer__footer {
    padding: 24px;
    border-top: 1px solid #e5e5e5;
    background-color: #fafafc;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .cart-drawer__subtotal-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .cart-drawer__subtotal-label {
    font-size: 14px;
    font-weight: 600;
    color: #111111;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .cart-drawer__subtotal-val {
    font-size: 18px;
    font-weight: 700;
    color: #111111;
  }
  .cart-drawer__disclaimer {
    font-size: 12px;
    color: #666666;
    margin: 0;
    text-align: center;
  }
  .cart-drawer__checkout-btn {
    background-color: {{ section.settings.primary_color | default: '#FF2B2B' }};
    color: #ffffff;
    border: none;
    border-radius: 30px;
    width: 100%;
    padding: 16px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: transform 0.2s ease, filter 0.2s;
  }
  .cart-drawer__checkout-btn:hover {
    filter: brightness(0.9);
    transform: translateY(-2px);
  }
{%- endstyle -%}

<div id="CartDrawerOverlay" class="cart-drawer-overlay">
  <div class="cart-drawer" role="dialog" aria-modal="true" aria-label="Cart Drawer">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">Your Cart</h2>
      <button type="button" class="cart-drawer__close" aria-label="Close cart drawer" onclick="closeCartDrawer()">
        <svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <div id="CartDrawerItems" class="cart-drawer__items">
      <!-- AJAX cart items inserted here via JS -->
    </div>

    <div id="CartDrawerFooter" class="cart-drawer__footer">
      <div class="cart-drawer__subtotal-row">
        <span class="cart-drawer__subtotal-label">Subtotal</span>
        <span id="CartDrawerSubtotal" class="cart-drawer__subtotal-val"></span>
      </div>
      <p class="cart-drawer__disclaimer">Taxes and shipping calculated at checkout</p>
      <a href="/checkout" class="cart-drawer__checkout-btn">Proceed to checkout</a>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Intercept clicking on Add to Cart buttons
    const forms = document.querySelectorAll('form[action="/cart/add"], form[action*="/cart/add"], form[id="AddToCartForm"]');
    forms.forEach(form => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const submitBtn = form.querySelector('[type="submit"]');
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.style.opacity = '0.6';
        }

        try {
          const formData = new FormData(form);
          const res = await fetch('/cart/add.js', {
            method: 'POST',
            body: formData
          });
          
          if (res.ok) {
            openCartDrawer();
          } else {
            form.submit();
          }
        } catch (err) {
          form.submit();
        } finally {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.style.opacity = '1';
          }
        }
      });
    });

    // Intercept clicking the header cart link
    const cartLinks = document.querySelectorAll('.header__cart-link, a[href="/cart"]');
    cartLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        openCartDrawer();
      });
    });

    // Handle clicking outside the drawer to close
    const overlay = document.getElementById('CartDrawerOverlay');
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) {
        closeCartDrawer();
      }
    });

    // ESC key to close
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeCartDrawer();
      }
    });
  });

  async function refreshCartDrawer() {
    try {
      const res = await fetch('/cart.js');
      const cart = await res.json();
      renderCartItems(cart);
    } catch (err) {
      console.error('Error fetching cart content:', err);
    }
  }

  function renderCartItems(cart) {
    const container = document.getElementById('CartDrawerItems');
    const footer = document.getElementById('CartDrawerFooter');
    
    if (!container) return;

    // Update Cart Header/Count in standard layout
    const countEls = document.querySelectorAll('.cart-count, .header__cart-link span');
    if (countEls.length > 0) {
      countEls.forEach(el => {
        el.textContent = `Cart (${cart.item_count})`;
      });
    }

    if (cart.items.length === 0) {
      container.innerHTML = `
        <div class="cart-drawer__empty-state">
          <p class="cart-drawer__empty-title">Your cart is currently empty.</p>
          <a href="/collections/all" class="cart-drawer__empty-btn">Shop Now</a>
        </div>
      `;
      if (footer) footer.style.display = 'none';
      return;
    }

    if (footer) footer.style.display = 'flex';
    
    const subtotalEl = document.getElementById('CartDrawerSubtotal');
    if (subtotalEl) {
      subtotalEl.textContent = formatShopifyMoney(cart.total_price);
    }

    let html = '';
    cart.items.forEach((item, index) => {
      html += `
        <div class="cart-drawer__item" data-key="${item.key}" data-line="${index + 1}">
          <a href="${item.url}" class="cart-drawer__item-img-link">
            <img src="${item.image ? item.image + '&width=160' : 'https://cdn.shopify.com/s/files/1/0533/2089/files/placeholder-images-image_1.png'}" alt="${item.product_title}" class="cart-drawer__item-img" loading="lazy">
          </a>
          <div class="cart-drawer__item-details">
            <h4 class="cart-drawer__item-title"><a href="${item.url}">${item.product_title}</a></h4>
            ${item.variant_title ? `<p class="cart-drawer__item-variant">${item.variant_title}</p>` : ''}
            <p class="cart-drawer__item-price">${formatShopifyMoney(item.final_line_price)}</p>
            <div class="cart-drawer__item-actions">
              <div class="cart-drawer__qty-group">
                <button type="button" class="cart-drawer__qty-btn" onclick="updateCartLine(${index + 1}, ${item.quantity - 1})">-</button>
                <input type="number" value="${item.quantity}" class="cart-drawer__qty-val" readonly>
                <button type="button" class="cart-drawer__qty-btn" onclick="updateCartLine(${index + 1}, ${item.quantity + 1})">+</button>
              </div>
              <button type="button" class="cart-drawer__remove" onclick="updateCartLine(${index + 1}, 0)">Remove</button>
            </div>
          </div>
        </div>
      `;
    });

    container.innerHTML = html;
  }

  function formatShopifyMoney(cents) {
    const currencySymbol = '{{ cart.currency.symbol | default: "$" }}';
    return currencySymbol + (cents / 100).toFixed(2);
  }

  async function updateCartLine(line, quantity) {
    try {
      const response = await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: line, quantity: quantity })
      });
      const cart = await response.json();
      renderCartItems(cart);
    } catch (error) {
      console.error('Error changing item quantity:', error);
    }
  }

  function openCartDrawer() {
    document.getElementById('CartDrawerOverlay').classList.add('is-active');
    refreshCartDrawer();
  }

  function closeCartDrawer() {
    document.getElementById('CartDrawerOverlay').classList.remove('is-active');
  }
</script>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": [
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color",
      "default": "#FF2B2B"
    }
  ]
}
{% endschema %}

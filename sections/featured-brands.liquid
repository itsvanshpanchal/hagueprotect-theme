{%- style -%}
  /* ═══════════════════════════════════════════════════
     FEATURED BRANDS — Luxury Brand Selection Section
     Two portrait brand cards, side-by-side on desktop
     ═══════════════════════════════════════════════════ */

  .featured-brands-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.bg_color }};
    padding-left: 16px;
    padding-right: 16px;
  }

  @media screen and (min-width: 750px) {
    .featured-brands-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      padding-left: 40px;
      padding-right: 40px;
    }
  }

  /* ── Eyebrow + Heading ───────────────────────────── */
  .fb__header {
    text-align: left;
    max-width: var(--site-max-width, 1320px);
    margin: 0 auto;
    padding: 0;
    width: 100%;
  }

  .fb__eyebrow {
    color: #e74c3c;
    font-size: 12px;
    font-weight: 900 !important;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 8px;
  }

  .fb__title {
    color: #1a1a1a;
    margin: 0;
  }

  .fb__subtitle {
    font-size: 14px;
    color: #777;
    margin-top: 10px;
    line-height: 1.6;
  }

  /* ── Grid ─────────────────────────────────────────── */
  .fb__grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 100%;
    margin: 0 auto;
    padding: 0;
  }

  @media screen and (min-width: 750px) {
    .fb__grid {
      flex-direction: row;
      gap: 20px;
      padding: 0;
    }
  }

  @media screen and (min-width: 990px) {
    .fb__grid {
      padding: 0;
    }
  }

  /* ── Brand Card ──────────────────────────────────── */
  .fb__card {
    position: relative;
    display: block;
    width: 100%;
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    aspect-ratio: 3 / 4;
    transform: translateY(0);
    transition:
      transform 0.5s cubic-bezier(0.25, 1, 0.5, 1),
      box-shadow 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  @media screen and (min-width: 750px) {
    .fb__card {
      width: calc(33.333% - 16px);
    }
  }

  .fb__card:hover,
  .fb__card:focus-visible {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.14);
    outline: none;
  }

  /* ── Background image ────────────────────────────── */
  .fb__card-img-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .fb__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.75s cubic-bezier(0.25, 1, 0.5, 1);
    will-change: transform;
  }

  .fb__card:hover .fb__card-img {
    transform: scale(1.05);
  }

  /* ── Gradient overlay ────────────────────────────── */
  .fb__card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 55%;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.7) 0%,
      rgba(0, 0, 0, 0.3) 45%,
      rgba(0, 0, 0, 0) 100%
    );
    pointer-events: none;
    z-index: 1;
    transition: opacity 0.5s ease;
  }

  .fb__card:hover .fb__card-overlay {
    opacity: 0.9;
  }

  /* ── Card content at bottom ──────────────────────── */
  .fb__card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 24px 28px;
    text-align: center;
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  @media screen and (min-width: 750px) {
    .fb__card-content {
      padding-bottom: 36px;
    }
  }

  .fb__card:hover .fb__card-content {
    transform: translateY(-3px);
  }

  /* ── Logo ─────────────────────────────────────────── */
  .fb__card-logo {
    max-width: 180px;
    max-height: 70px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.35));
    margin-bottom: 10px;
  }

  .fb__card-logo-svg {
    max-width: 170px;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.35));
    margin-bottom: 10px;
  }

  .fb__card-logo-svg svg {
    width: 100%;
    height: auto;
    display: block;
    fill: #ffffff;
  }

  /* ── Tagline ─────────────────────────────────────── */
  .fb__card-tagline {
    color: rgba(255, 255, 255, 0.85);
    font-size: 12px;
    letter-spacing: 1px;
    margin: 0 0 14px;
    line-height: 1.5;
    max-width: 260px;
  }

  /* ── CTA button ──────────────────────────────────── */
  .fb__card-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 30px;
    padding: 8px 24px;
    transition: all 0.35s ease;
    background: transparent;
  }

  .fb__card:hover .fb__card-cta {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.8);
  }

  .fb__card-cta-arrow {
    display: inline-block;
    transition: transform 0.35s ease;
    font-size: 14px;
    line-height: 1;
  }

  .fb__card:hover .fb__card-cta-arrow {
    transform: translateX(3px);
  }

  /* ── Empty placeholder ───────────────────────────── */
  .fb__card-empty {
    width: 100%;
    height: 100%;
    background: linear-gradient(145deg, #e2e2e2 0%, #ccc 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .fb__card-empty svg {
    width: 50%;
    max-width: 200px;
    opacity: 0.3;
  }

  /* ── Fallback text logo ──────────────────────────── */
  .fb__card-name {
    color: #ffffff;
    margin: 0 0 10px;
    font-size: 22px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 4px;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
  }
{%- endstyle -%}

<div class="featured-brands-{{ section.id }}">
  <!-- Section Header -->
  <div class="fb__header">
    {%- if section.settings.eyebrow != blank -%}
      <span class="fb__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="fb__title">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="fb__subtitle">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <!-- Brand Cards Grid -->
  <div class="fb__grid">

    <!-- ════════ BRAND 1: VanRoSector ════════ -->
    <a
      href="{{ section.settings.vanrosector_link | default: '#' }}"
      class="fb__card"
      aria-label="Shop VanRoSector"
    >
      <div class="fb__card-img-wrap">
        {%- if section.settings.vanrosector_image != blank -%}
          {{ section.settings.vanrosector_image | image_url: width: 1200 | image_tag:
            class: 'fb__card-img',
            loading: 'lazy',
            sizes: '(min-width: 750px) 33vw, 100vw',
            widths: '375, 550, 750, 1000, 1200',
            alt: 'VanRoSector'
          }}
        {%- else -%}
          <div class="fb__card-empty">
            {{ 'lifestyle-1' | placeholder_svg_tag }}
          </div>
        {%- endif -%}
      </div>

      <div class="fb__card-overlay"></div>

      <div class="fb__card-content">
        {%- if section.settings.vanrosector_svg != blank -%}
          <div class="fb__card-logo-svg">{{ section.settings.vanrosector_svg }}</div>
        {%- elsif section.settings.vanrosector_logo != blank -%}
          {{ section.settings.vanrosector_logo | image_url: width: 400 | image_tag:
            class: 'fb__card-logo',
            loading: 'lazy',
            alt: 'VanRoSector logo'
          }}
        {%- else -%}
          <h3 class="fb__card-name">VanRoSector</h3>
        {%- endif -%}

        {%- if section.settings.vanrosector_tagline != blank -%}
          <p class="fb__card-tagline">{{ section.settings.vanrosector_tagline }}</p>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <span class="fb__card-cta">
            {{ section.settings.cta_label }}
            <span class="fb__card-cta-arrow">→</span>
          </span>
        {%- endif -%}
      </div>
    </a>

    <!-- ════════ BRAND 2: Science of Raw ════════ -->
    <a
      href="{{ section.settings.science_of_raw_link | default: '#' }}"
      class="fb__card"
      aria-label="Shop Science of Raw"
    >
      <div class="fb__card-img-wrap">
        {%- if section.settings.science_of_raw_image != blank -%}
          {{ section.settings.science_of_raw_image | image_url: width: 1200 | image_tag:
            class: 'fb__card-img',
            loading: 'lazy',
            sizes: '(min-width: 750px) 33vw, 100vw',
            widths: '375, 550, 750, 1000, 1200',
            alt: 'Science of Raw'
          }}
        {%- else -%}
          <div class="fb__card-empty">
            {{ 'lifestyle-2' | placeholder_svg_tag }}
          </div>
        {%- endif -%}
      </div>

      <div class="fb__card-overlay"></div>

      <div class="fb__card-content">
        {%- if section.settings.science_of_raw_svg != blank -%}
          <div class="fb__card-logo-svg">{{ section.settings.science_of_raw_svg }}</div>
        {%- elsif section.settings.science_of_raw_logo != blank -%}
          {{ section.settings.science_of_raw_logo | image_url: width: 400 | image_tag:
            class: 'fb__card-logo',
            loading: 'lazy',
            alt: 'Science of Raw logo'
          }}
        {%- else -%}
          <h3 class="fb__card-name">Science of Raw</h3>
        {%- endif -%}

        {%- if section.settings.science_of_raw_tagline != blank -%}
          <p class="fb__card-tagline">{{ section.settings.science_of_raw_tagline }}</p>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <span class="fb__card-cta">
            {{ section.settings.cta_label }}
            <span class="fb__card-cta-arrow">→</span>
          </span>
        {%- endif -%}
      </div>
    </a>

    <!-- ════════ BRAND 3: HagueProtect ════════ -->
    <a
      href="{{ section.settings.hagueprotect_link | default: '#' }}"
      class="fb__card"
      aria-label="Shop HagueProtect"
    >
      <div class="fb__card-img-wrap">
        {%- if section.settings.hagueprotect_image != blank -%}
          {{ section.settings.hagueprotect_image | image_url: width: 1200 | image_tag:
            class: 'fb__card-img',
            loading: 'lazy',
            sizes: '(min-width: 750px) 33vw, 100vw',
            widths: '375, 550, 750, 1000, 1200',
            alt: 'HagueProtect'
          }}
        {%- else -%}
          <div class="fb__card-empty">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {%- endif -%}
      </div>

      <div class="fb__card-overlay"></div>

      <div class="fb__card-content">
        {%- if section.settings.hagueprotect_svg != blank -%}
          <div class="fb__card-logo-svg">{{ section.settings.hagueprotect_svg }}</div>
        {%- elsif section.settings.hagueprotect_logo != blank -%}
          {{ section.settings.hagueprotect_logo | image_url: width: 400 | image_tag:
            class: 'fb__card-logo',
            loading: 'lazy',
            alt: 'HagueProtect logo'
          }}
        {%- else -%}
          <h3 class="fb__card-name">HagueProtect</h3>
        {%- endif -%}

        {%- if section.settings.hagueprotect_tagline != blank -%}
          <p class="fb__card-tagline">{{ section.settings.hagueprotect_tagline }}</p>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <span class="fb__card-cta">
            {{ section.settings.cta_label }}
            <span class="fb__card-cta-arrow">→</span>
          </span>
        {%- endif -%}
      </div>
    </a>

  </div>
</div>

{% schema %}
{
  "name": "Featured Brands",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "OUR FAMILY OF BRANDS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore the Ecosystem"

{%- style -%}
  /* ── Section wrapper ─────────────────────────────── */
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ── Grid container ──────────────────────────────── */
  .featured-brands-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 24px;
  }

  @media screen and (min-width: 750px) {
    .featured-brands-{{ section.id }} {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: 24px;
    }
  }

  /* ── Brand card ──────────────────────────────────── */
  .brand-card {
    position: relative;
    display: block;
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    aspect-ratio: 5 / 6;
    transform: translateY(0);
    transition: transform 0.45s cubic-bezier(0.25, 1, 0.5, 1),
                box-shadow 0.45s cubic-bezier(0.25, 1, 0.5, 1);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    cursor: pointer;
  }

  @media screen and (min-width: 750px) {
    .brand-card {
      width: calc(50% - 12px);
    }
  }

  .brand-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
  }

  /* ── Background image ────────────────────────────── */
  .brand-card__image-wrapper {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .brand-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.7s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .brand-card:hover .brand-card__image {
    transform: scale(1.04);
  }

  /* ── Subtle bottom gradient ──────────────────────── */
  .brand-card__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 45%;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.2) 45%,
      rgba(0, 0, 0, 0) 100%
    );
    pointer-events: none;
    z-index: 1;
  }

  /* ── Logo at bottom-center ───────────────────────── */
  .brand-card__logo-wrapper {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    width: 60%;
    max-width: 180px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .brand-card__logo {
    width: 100%;
    height: auto;
    max-height: 70px;
    object-fit: contain;
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.25));
    transition: transform 0.45s ease;
  }

  .brand-card:hover .brand-card__logo {
    transform: scale(1.03);
  }

  /* SVG Logo support */
  .brand-card__logo-svg {
    width: 100%;
    max-width: 160px;
    height: auto;
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.25));
  }

  .brand-card__logo-svg svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Fallback / empty state ──────────────────────── */
  .brand-card__empty-image {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e8e8e8 0%, #d0d0d0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand-card__fallback-title {
    color: #ffffff;
    margin: 0;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 16px;
    font-weight: 600;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="featured-brands-{{ section.id }}">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.brand_link | default: '#' }}" class="brand-card" {{ block.shopify_attributes }}>
        <div class="brand-card__image-wrapper">
          {%- if block.settings.background_image != blank -%}
            {{ block.settings.background_image | image_url: width: 1200 | image_tag:
              class: 'brand-card__image',
              loading: 'lazy',
              sizes: '(min-width: 750px) 50vw, 100vw',
              alt: block.settings.background_image.alt | escape
            }}
          {%- else -%}
            <div class="brand-card__empty-image">
              {{ 'lifestyle-1' | placeholder_svg_tag: 'brand-card__image' }}
            </div>
          {%- endif -%}
        </div>

        <div class="brand-card__overlay"></div>

        <div class="brand-card__logo-wrapper">
          {%- if block.settings.custom_svg_code != blank -%}
            <div class="brand-card__logo-svg">
              {{ block.settings.custom_svg_code }}
            </div>
          {%- elsif block.settings.brand_logo != blank -%}
            {{ block.settings.brand_logo | image_url: width: 400 | image_tag:
              class: 'brand-card__logo',
              loading: 'lazy',
              alt: block.settings.brand_logo.alt | escape
            }}
          {%- else -%}
            <h3 class="brand-card__fallback-title">{{ block.settings.title | default: 'Brand Name' }}</h3>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Featured Brands",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#d5d5d5"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Maximum Width",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand Card",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background Image",
          "info": "Use a portrait-oriented lifestyle image for best results."
        },
        {
          "type": "image_picker",
          "id": "brand_logo",
          "label": "Brand Logo (Image)"
        },
        {
          "type": "html",
          "id": "custom_svg_code",
          "label": "Brand Logo (Custom SVG/Code)",
          "info": "Paste custom SVG code here to upload the logo directly through theme code."
        },
        {
          "type": "url",
          "id": "brand_link",
          "label": "Brand Link",
          "info": "Link to the brand's collection or landing page."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Fallback Title",
          "info": "Displays if no logo image or SVG is provided."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Brands",
      "blocks": [
        {
          "type": "brand"
        },
        {
          "type": "brand"
        }
      ]
    }
  ]
}
{% endschema %}

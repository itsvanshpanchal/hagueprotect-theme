{%- style -%}
  /* ═══════════════════════════════════════════════════
     FEATURED BRANDS — Luxury Brand Selection Section
     Inspired by Iconic, Blue Giraffe, Hugo Boss, etc.
     ═══════════════════════════════════════════════════ */

  /* ── Section wrapper ─────────────────────────────── */
  .featured-brands-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background_color }};
  }

  @media screen and (min-width: 750px) {
    .featured-brands-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ── Section heading ─────────────────────────────── */
  .featured-brands__heading {
    text-align: center;
    margin: 0 0 36px 0;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: {{ section.settings.heading_color }};
  }

  @media screen and (min-width: 750px) {
    .featured-brands__heading {
      margin-bottom: 48px;
      font-size: 15px;
      letter-spacing: 5px;
    }
  }

  /* ── Grid container ──────────────────────────────── */
  .featured-brands__grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  @media screen and (min-width: 750px) {
    .featured-brands__grid {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: {{ section.settings.card_gap }}px;
      padding: 0 40px;
    }
  }

  @media screen and (min-width: 990px) {
    .featured-brands__grid {
      padding: 0 60px;
    }
  }

  /* ── Brand card ──────────────────────────────────── */
  .featured-brands__card {
    position: relative;
    display: block;
    width: 100%;
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    text-decoration: none;
    aspect-ratio: 3 / 4;
    transform: translateY(0);
    transition:
      transform 0.5s cubic-bezier(0.25, 1, 0.5, 1),
      box-shadow 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  @media screen and (min-width: 750px) {
    .featured-brands__card {
      width: calc(50% - {{ section.settings.card_gap | divided_by: 2 }}px);
    }
  }

  .featured-brands__card:hover,
  .featured-brands__card:focus-visible {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.14);
    outline: none;
  }

  /* ── Background image ────────────────────────────── */
  .featured-brands__card-image-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .featured-brands__card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.75s cubic-bezier(0.25, 1, 0.5, 1);
    will-change: transform;
  }

  .featured-brands__card:hover .featured-brands__card-image {
    transform: scale(1.05);
  }

  /* ── Gradient overlay ────────────────────────────── */
  .featured-brands__card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.65) 0%,
      rgba(0, 0, 0, 0.25) 50%,
      rgba(0, 0, 0, 0) 100%
    );
    pointer-events: none;
    z-index: 1;
    transition: opacity 0.5s ease;
  }

  .featured-brands__card:hover .featured-brands__card-overlay {
    opacity: 0.85;
  }

  /* ── Logo at bottom-center ───────────────────────── */
  .featured-brands__card-logo-wrap {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    width: 70%;
    max-width: 200px;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  @media screen and (min-width: 750px) {
    .featured-brands__card-logo-wrap {
      bottom: 40px;
    }
  }

  .featured-brands__card:hover .featured-brands__card-logo-wrap {
    transform: translateX(-50%) translateY(-2px);
  }

  /* Logo image */
  .featured-brands__card-logo {
    width: 100%;
    height: auto;
    max-height: 80px;
    object-fit: contain;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.35));
    transition: filter 0.5s ease;
  }

  .featured-brands__card:hover .featured-brands__card-logo {
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.45));
  }

  /* SVG logo support (pasted directly in theme code) */
  .featured-brands__card-logo-svg {
    width: 100%;
    max-width: 170px;
    height: auto;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.35));
    transition: filter 0.5s ease;
  }

  .featured-brands__card-logo-svg svg {
    width: 100%;
    height: auto;
    display: block;
    fill: #ffffff;
  }

  .featured-brands__card:hover .featured-brands__card-logo-svg {
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.45));
  }

  /* ── Fallback text title ─────────────────────────── */
  .featured-brands__card-fallback {
    color: #ffffff;
    margin: 0;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 4px;
    font-size: 18px;
    font-weight: 500;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
  }

  /* ── Empty / placeholder state ───────────────────── */
  .featured-brands__card-empty {
    width: 100%;
    height: 100%;
    background: linear-gradient(145deg, #e9e9e9 0%, #d4d4d4 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .featured-brands__card-empty svg {
    width: 60%;
    max-width: 240px;
    height: auto;
    opacity: 0.35;
  }
{%- endstyle -%}

<div class="featured-brands-section-{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <h2 class="featured-brands__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="featured-brands__grid">
    {%- for block in section.blocks -%}
      <a
        href="{{ block.settings.brand_link | default: '#' }}"
        class="featured-brands__card"
        aria-label="{{ block.settings.title | default: 'Shop brand' | escape }}"
        {{ block.shopify_attributes }}
      >
        <!-- Background Image -->
        <div class="featured-brands__card-image-wrap">
          {%- if block.settings.background_image != blank -%}
            {{ block.settings.background_image | image_url: width: 1200 | image_tag:
              class: 'featured-brands__card-image',
              loading: 'lazy',
              sizes: '(min-width: 750px) 50vw, 100vw',
              widths: '375, 550, 750, 1000, 1200',
              alt: block.settings.title | default: block.settings.background_image.alt | escape
            }}
          {%- else -%}
            <div class="featured-brands__card-empty">
              {{ 'lifestyle-1' | placeholder_svg_tag }}
            </div>
          {%- endif -%}
        </div>

        <!-- Gradient Overlay -->
        <div class="featured-brands__card-overlay"></div>

        <!-- Brand Logo -->
        <div class="featured-brands__card-logo-wrap">
          {%- if block.settings.custom_svg_code != blank -%}
            <!-- Logo uploaded directly through theme code -->
            <div class="featured-brands__card-logo-svg">
              {{ block.settings.custom_svg_code }}
            </div>
          {%- elsif block.settings.brand_logo != blank -%}
            {{ block.settings.brand_logo | image_url: width: 400 | image_tag:
              class: 'featured-brands__card-logo',
              loading: 'lazy',
              alt: block.settings.title | default: block.settings.brand_logo.alt | escape
            }}
          {%- else -%}
            <h3 class="featured-brands__card-fallback">
              {{ block.settings.title | default: 'Brand Name' }}
            </h3>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Featured Brands",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Shop by Brand"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section Background",
      "default": "#f5f5f0"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Maximum Width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Gap Between Cards",
      "default": 24
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Card Corner Radius",
      "default": 14
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand Card",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background Image",
          "info": "Use a tall portrait-oriented lifestyle image (e.g. 900×1200px) for best results."
        },
        {
          "type": "image_picker",
          "id": "brand_logo",
          "label": "Brand Logo (Image)",
          "info": "White or light-colored logos work best against the gradient overlay."
        },
        {
          "type": "html",
          "id": "custom_svg_code",
          "label": "Brand Logo (SVG Code)",
          "info": "Paste SVG markup here to upload the logo directly through theme code rather than the image picker."
        },
        {
          "type": "url",
          "id": "brand_link",
          "label": "Brand Link",
          "info": "Link to the brand's collection, page, or external landing page."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Brand Name",
          "info": "Used as fallback text if no logo is provided, and for accessibility labels.",
          "default": "Brand Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Brands",
      "blocks": [
        {
          "type": "brand",
          "settings": {
            "title": "Brand One"
          }
        },
        {
          "type": "brand",
          "settings": {
            "title": "Brand Two"
          }
        }
      ]
    }
  ]
}
{% endschema %}

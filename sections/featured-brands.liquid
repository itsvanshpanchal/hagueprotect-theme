    {
      "type": "text",
      "id": "science_of_raw_tagline",
      "label": "Tagline",
      "default": "Pure, raw, and precisely refined."
    },
    {
      "type": "url",
      "id": "science_of_raw_link",
      "label": "Brand Link"
    },
    {
      "type": "header",
      "content": "━━━ Brand 3: HagueProtect ━━━"
    },
    {
      "type": "image_picker",
      "id": "hagueprotect_image",
      "label": "Background Image",
      "info": "Use a tall portrait lifestyle image (e.g. 900×1200px)."
    },
    {
      "type": "image_picker",
      "id": "hagueprotect_logo",
      "label": "Logo (Image)",
      "info": "White or light-colored logo works best."
    },
    {
      "type": "html",
      "id": "hagueprotect_svg",
      "label": "Logo (SVG Code)",

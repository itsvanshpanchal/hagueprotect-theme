{%- comment -%}
  ============================================================
  FEATURED BRANDS — homepage multi-brand showcase
  Vanrosector + Science of Raw. Logos live in Shopify Assets
  (logo-vanrosector.svg / logo-science-of-raw.svg) and are
  referenced directly with asset_url.

  Both brands are hosted ON THIS DOMAIN as Shopify pages:
    /pages/vanrosector   and   /pages/science-of-raw
  Clicking a card opens that internal page (same tab).
  ============================================================
{%- endcomment -%}
{%- assign vanrosector_url    = section.settings.vanrosector_link | default: '/collections/all?view=vanrosector' -%}
{%- assign science_of_raw_url = section.settings.science_of_raw_link | default: '/collections/all?view=science-of-raw' -%}

{%- style -%}
  #shopify-section-{{ section.id }} .brands-feature {
    background: {{ section.settings.bg_color | default: '#ffffff' }};
    padding: {{ section.settings.padding_top | default: 96 }}px 16px {{ section.settings.padding_bottom | default: 96 }}px;
  }

  #shopify-section-{{ section.id }} .brands-feature__inner {
    max-width: 1180px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .brands-feature__head {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 56px;
  }

  #shopify-section-{{ section.id }} .brands-feature__eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #FF2B2B;
    margin: 0 0 14px;
  }

  #shopify-section-{{ section.id }} .brands-feature__heading {
    font-family: 'Inter', sans-serif;
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: #111111;
    margin: 0 0 16px;
    line-height: 1.08;
  }

  #shopify-section-{{ section.id }} .brands-feature__sub {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: #6b6b6b;
    margin: 0;
    line-height: 1.6;
  }

  #shopify-section-{{ section.id }} .brands-feature__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }

  #shopify-section-{{ section.id }} .brand-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    text-align: center;
    text-decoration: none;
    border-radius: 0;
    padding: 40px;
    min-height: 560px;
    overflow: hidden;
    isolation: isolate;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #shopify-section-{{ section.id }} .brand-card__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #shopify-section-{{ section.id }} .brand-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.0) 100%);
    z-index: 1;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .brand-card:hover,
  #shopify-section-{{ section.id }} .brand-card:focus-visible {
    transform: translateY(-8px);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.12);
    outline: none;
  }

  #shopify-section-{{ section.id }} .brand-card:hover .brand-card__bg {
    transform: scale(1.05);
  }

  #shopify-section-{{ section.id }} .brand-card__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .brand-card__plate {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
  }

  #shopify-section-{{ section.id }} .brand-card__plate img {
    display: block;
    max-height: 80px;
    width: auto;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .brand-card__tag {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
    margin: 0 0 28px;
    max-width: 360px;
  }

  /* premium filled pill button */
  #shopify-section-{{ section.id }} .brand-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #ffffff;
    background: var(--accent);
    padding: 13px 26px;
    border-radius: 100px;
    transition: filter 0.3s ease, transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .brand-card:hover .brand-card__cta,
  #shopify-section-{{ section.id }} .brand-card:focus-visible .brand-card__cta {
    filter: brightness(1.12);
  }

  #shopify-section-{{ section.id }} .brand-card__cta svg {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #shopify-section-{{ section.id }} .brand-card:hover .brand-card__cta svg,
  #shopify-section-{{ section.id }} .brand-card:focus-visible .brand-card__cta svg {
    transform: translateX(5px);
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .brands-feature {
      padding: {{ section.settings.padding_top | default: 96 | times: 0.6 | round }}px 14px {{ section.settings.padding_bottom | default: 96 | times: 0.6 | round }}px;
    }
    #shopify-section-{{ section.id }} .brands-feature__head { margin-bottom: 36px; }
    #shopify-section-{{ section.id }} .brands-feature__grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }
    #shopify-section-{{ section.id }} .brand-card { padding: 32px 24px; min-height: 480px; border-radius: 0; }
    #shopify-section-{{ section.id }} .brand-card__plate img { max-height: 64px; }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .brand-card,
    #shopify-section-{{ section.id }} .brand-card__bg,
    #shopify-section-{{ section.id }} .brand-card__cta,
    #shopify-section-{{ section.id }} .brand-card__cta svg { transition: none; }
    #shopify-section-{{ section.id }} .brand-card:hover,
    #shopify-section-{{ section.id }} .brand-card:focus-visible { transform: none; }
    #shopify-section-{{ section.id }} .brand-card:hover .brand-card__bg { transform: none; }
    #shopify-section-{{ section.id }} .brand-card:hover .brand-card__cta svg { transform: none; }
  }
{%- endstyle -%}

<section class="brands-feature" aria-labelledby="brands-feature-heading-{{ section.id }}">
  <div class="brands-feature__inner">

    <div class="brands-feature__head">
      {%- if section.settings.eyebrow != blank -%}
        <p class="brands-feature__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="brands-feature__heading" id="brands-feature-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="brands-feature__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="brands-feature__grid">

      {%- comment -%} Brand 1 · Vanrosector {%- endcomment -%}
      <a href="{{ vanrosector_url }}"
         class="brand-card"
         style="--accent:#8a6a3b;"
         aria-label="Explore Vanrosector">
        {%- if section.settings.vanrosector_image != blank -%}
          {{ section.settings.vanrosector_image | image_url: width: 1000 | image_tag: class: 'brand-card__bg', loading: 'lazy' }}
        {%- else -%}
          <div class="brand-card__bg" style="background: #111;"></div>
        {%- endif -%}
        
        <div class="brand-card__content">
          <span class="brand-card__plate">
            <img src="{{ 'logo-vanrosector.svg' | asset_url }}" alt="Vanrosector" width="280" height="102" loading="lazy" decoding="async">
          </span>
          <p class="brand-card__tag">{{ section.settings.vanrosector_tagline }}</p>
          <span class="brand-card__cta">
            {{ section.settings.cta_label }}
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true"><path d="M1 5h11M8 1l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </div>
      </a>

      {%- comment -%} Brand 2 · Science of Raw {%- endcomment -%}
      <a href="{{ science_of_raw_url }}"
         class="brand-card"
         style="--accent:#ffffff; color: #111;"
         aria-label="Explore Science of Raw">
        {%- if section.settings.science_of_raw_image != blank -%}
          {{ section.settings.science_of_raw_image | image_url: width: 1000 | image_tag: class: 'brand-card__bg', loading: 'lazy' }}
        {%- else -%}
          <div class="brand-card__bg" style="background: #111;"></div>
        {%- endif -%}

        <div class="brand-card__content">
          <span class="brand-card__plate">
            <img src="{{ 'logo-science-of-raw.svg' | asset_url }}" alt="Science of Raw" width="240" height="120" loading="lazy" decoding="async">
          </span>
          <p class="brand-card__tag">{{ section.settings.science_of_raw_tagline }}</p>
          <span class="brand-card__cta" style="color: #111;">
            {{ section.settings.cta_label }}
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true"><path d="M1 5h11M8 1l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </div>
      </a>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Brands",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Logos load from Assets (logo-vanrosector.svg, logo-science-of-raw.svg). Links default to internal pages /pages/vanrosector and /pages/science-of-raw."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "OUR FAMILY OF BRANDS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore the Ecosystem"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": ""
    },
    {
      "type": "image_picker",
      "id": "vanrosector_image",
      "label": "Vanrosector Background Image"
    },
    {
      "type": "url",
      "id": "vanrosector_link",
      "label": "Vanrosector page",
      "info": "Defaults to /pages/vanrosector"
    },
    {
      "type": "text",
      "id": "vanrosector_tagline",
      "label": "Vanrosector tagline",
      "default": "Journey Through Nature's Finest Essence."
    },
    {
      "type": "image_picker",
      "id": "science_of_raw_image",
      "label": "Science of Raw Background Image"
    },
    {
      "type": "url",
      "id": "science_of_raw_link",
      "label": "Science of Raw page",
      "info": "Defaults to /pages/science-of-raw"
    },
    {
      "type": "text",
      "id": "science_of_raw_tagline",
      "label": "Science of Raw tagline",
      "default": "Pure, raw, and precisely refined."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Explore"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 96
    }
  ],
  "presets": [
    {
      "name": "Featured Brands"
    }
  ]
}
{% endschema %}

{%- comment -%}
  ============================================================
  FEATURED BRANDS — homepage multi-brand showcase
  Vanrosector + Science of Raw. Logos live in Shopify Assets
  (vanrosector-logo.png / science-of-raw-logo.png) and are
  referenced directly with asset_url.

  Both brands are hosted ON THIS DOMAIN as Shopify pages:
    /pages/vanrosector   and   /pages/science-of-raw
  Clicking a card opens that internal page (same tab).
  ============================================================
{%- endcomment -%}
{%- assign vanrosector_url    = section.settings.vanrosector_link | default: '/pages/vanrosector' -%}
{%- assign science_of_raw_url = section.settings.science_of_raw_link | default: '/pages/science-of-raw' -%}

{%- style -%}
  #shopify-section-{{ section.id }} .brands-feature {
    background: {{ section.settings.bg_color | default: '#ffffff' }};
    padding: {{ section.settings.padding_top | default: 96 }}px 16px {{ section.settings.padding_bottom | default: 96 }}px;
  }

  #shopify-section-{{ section.id }} .brands-feature__inner {
    max-width: 1180px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .brands-feature__head {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 56px;
  }

  #shopify-section-{{ section.id }} .brands-feature__eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #FF2B2B;
    margin: 0 0 14px;
  }

  #shopify-section-{{ section.id }} .brands-feature__heading {
    font-family: 'Inter', sans-serif;
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: #111111;
    margin: 0 0 16px;
    line-height: 1.08;
  }

  #shopify-section-{{ section.id }} .brands-feature__sub {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: #6b6b6b;
    margin: 0;
    line-height: 1.6;
  }

  #shopify-section-{{ section.id }} .brands-feature__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }

  #shopify-section-{{ section.id }} .brand-card {
    --accent: #111111;
    --bg-from: #ffffff;
    --bg-to: #f6f6f6;
    --glow: rgba(0,0,0,0.05);
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    text-decoration: none;
    background: linear-gradient(160deg, var(--bg-from) 0%, var(--bg-to) 100%);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 24px;
    padding: 56px 40px 48px;
    overflow: hidden;
    isolation: isolate;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  /* soft coloured glow blob, top-right */
  #shopify-section-{{ section.id }} .brand-card__glow {
    position: absolute;
    top: -90px;
    right: -90px;
    width: 240px;
    height: 240px;
    border-radius: 50%;
    background: var(--glow);
    filter: blur(36px);
    z-index: -1;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
    opacity: 0.85;
  }

  #shopify-section-{{ section.id }} .brand-card:hover,
  #shopify-section-{{ section.id }} .brand-card:focus-visible {
    transform: translateY(-8px);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.12);
    outline: none;
  }

  #shopify-section-{{ section.id }} .brand-card:focus-visible {
    box-shadow: 0 0 0 2px var(--accent), 0 30px 60px rgba(0, 0, 0, 0.12);
  }

  #shopify-section-{{ section.id }} .brand-card:hover .brand-card__glow,
  #shopify-section-{{ section.id }} .brand-card:focus-visible .brand-card__glow {
    transform: scale(1.25) translate(-12px, 12px);
    opacity: 1;
  }

  /* white plate that lifts the logo off the tinted card */
  #shopify-section-{{ section.id }} .brand-card__plate {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 320px;
    height: 132px;
    background: #ffffff;
    border-radius: 18px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.05);
    margin-bottom: 28px;
    padding: 20px 28px;
  }

  #shopify-section-{{ section.id }} .brand-card__plate img {
    display: block;
    width: auto;
    height: auto;
    max-height: 84px;
    max-width: 100%;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .brand-card__tag {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: #5f5f5f;
    line-height: 1.6;
    margin: 0 0 28px;
    max-width: 360px;
  }

  /* premium filled pill button */
  #shopify-section-{{ section.id }} .brand-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #ffffff;
    background: var(--accent);
    padding: 13px 26px;
    border-radius: 100px;
    transition: filter 0.3s ease, transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .brand-card:hover .brand-card__cta,
  #shopify-section-{{ section.id }} .brand-card:focus-visible .brand-card__cta {
    filter: brightness(1.12);
  }

  #shopify-section-{{ section.id }} .brand-card__cta svg {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #shopify-section-{{ section.id }} .brand-card:hover .brand-card__cta svg,
  #shopify-section-{{ section.id }} .brand-card:focus-visible .brand-card__cta svg {
    transform: translateX(5px);
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .brands-feature {
      padding: {{ section.settings.padding_top | default: 96 | times: 0.6 | round }}px 14px {{ section.settings.padding_bottom | default: 96 | times: 0.6 | round }}px;
    }
    #shopify-section-{{ section.id }} .brands-feature__head { margin-bottom: 36px; }
    #shopify-section-{{ section.id }} .brands-feature__grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }
    #shopify-section-{{ section.id }} .brand-card { padding: 40px 24px 36px; border-radius: 20px; }
    #shopify-section-{{ section.id }} .brand-card__plate { height: 104px; margin-bottom: 22px; padding: 16px 20px; }
    #shopify-section-{{ section.id }} .brand-card__plate img { max-height: 64px; }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .brand-card,
    #shopify-section-{{ section.id }} .brand-card__glow,
    #shopify-section-{{ section.id }} .brand-card__cta,
    #shopify-section-{{ section.id }} .brand-card__cta svg { transition: none; }
    #shopify-section-{{ section.id }} .brand-card:hover,
    #shopify-section-{{ section.id }} .brand-card:focus-visible { transform: none; }
    #shopify-section-{{ section.id }} .brand-card:hover .brand-card__glow { transform: none; }
    #shopify-section-{{ section.id }} .brand-card:hover .brand-card__cta svg { transform: none; }
  }
{%- endstyle -%}

<section class="brands-feature" aria-labelledby="brands-feature-heading-{{ section.id }}">
  <div class="brands-feature__inner">

    <div class="brands-feature__head">
      {%- if section.settings.eyebrow != blank -%}
        <p class="brands-feature__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="brands-feature__heading" id="brands-feature-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="brands-feature__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="brands-feature__grid">

      {%- comment -%} Brand 1 · Vanrosector (native 940×343) {%- endcomment -%}
      <a href="{{ vanrosector_url }}"
         class="brand-card"
         style="--accent:#8a6a3b; --bg-from:#fbf8f2; --bg-to:#f1e7d6; --glow:rgba(138,106,59,0.30);"
         aria-label="Explore Vanrosector">
        <span class="brand-card__glow" aria-hidden="true"></span>
        <span class="brand-card__plate">
          <img src="{{ 'vanrosector-logo.png' | asset_url }}" alt="Vanrosector" width="280" height="102" loading="lazy" decoding="async">
        </span>
        <p class="brand-card__tag">{{ section.settings.vanrosector_tagline }}</p>
        <span class="brand-card__cta">
          {{ section.settings.cta_label }}
          <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true"><path d="M1 5h11M8 1l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>

      {%- comment -%} Brand 2 · Science of Raw (native 1000×500) {%- endcomment -%}
      <a href="{{ science_of_raw_url }}"
         class="brand-card"
         style="--accent:#27355f; --bg-from:#f6f8fc; --bg-to:#e6ecf7; --glow:rgba(39,53,95,0.28);"
         aria-label="Explore Science of Raw">
        <span class="brand-card__glow" aria-hidden="true"></span>
        <span class="brand-card__plate">
          <img src="{{ 'science-of-raw-logo.png' | asset_url }}" alt="Science of Raw" width="240" height="120" loading="lazy" decoding="async">
        </span>
        <p class="brand-card__tag">{{ section.settings.science_of_raw_tagline }}</p>
        <span class="brand-card__cta">
          {{ section.settings.cta_label }}
          <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true"><path d="M1 5h11M8 1l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Brands",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Logos load from Assets (vanrosector-logo.png, science-of-raw-logo.png). Links default to internal pages /pages/vanrosector and /pages/science-of-raw."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "OUR FAMILY OF BRANDS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore the Ecosystem"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Three brands, one pursuit of premium care and craft. Discover what else the family has to offer."
    },
    {
      "type": "url",
      "id": "vanrosector_link",
      "label": "Vanrosector page",
      "info": "Defaults to /pages/vanrosector"
    },
    {
      "type": "text",
      "id": "vanrosector_tagline",
      "label": "Vanrosector tagline",
      "default": "Journey Through Nature's Finest Essence."
    },
    {
      "type": "url",
      "id": "science_of_raw_link",
      "label": "Science of Raw page",
      "info": "Defaults to /pages/science-of-raw"
    },
    {
      "type": "text",
      "id": "science_of_raw_tagline",
      "label": "Science of Raw tagline",
      "default": "Pure, raw, and precisely refined."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Explore"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 96
    }
  ],
  "presets": [
    {
      "name": "Featured Brands"
    }
  ]
}
{% endschema %}

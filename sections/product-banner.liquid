    {
      "type": "image_picker",
      "id": "gif_2",
      "label": "Icon 2 — Upload GIF"
    },
    {
      "type": "text",
      "id": "label_2",
      "label": "Icon 2 Label",
      "default": "Environmentally Friendly"
    },
    {
      "type": "header",
      "content": "Icon 3 — Biotechnology"
    },
    {
      "type": "image_picker",
      "id": "gif_3",
      "label": "Icon 3 — Upload GIF"
    },
    {
      "type": "text",
      "id": "label_3",
      "label": "Icon 3 Label",
      "default": "Biotechnology"
    },
    {
      "type": "header",

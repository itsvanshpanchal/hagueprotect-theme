<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@1,900&display=swap" rel="stylesheet">

{%- style -%}
  .pb {
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    padding: clamp(48px, 7vw, 90px) 0;
  }

  .pb__wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    text-align: center;
  }

  /* ─── Icon Row ─── */
  .pb__icons {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 0;
    width: 100%;
    margin-bottom: 28px;
  }

  .pb__icon-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }

  .pb__icon-gif {
    width: 60px;
    height: 60px;
    object-fit: contain;
    display: block;
  }

  /* Fallback SVG colour */
  .pb__icon-svg {
    width: 52px;
    height: 52px;
    color: #111;
  }

  .pb__icon-label {
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: #111111;
    letter-spacing: 0;
    margin: 0;
    line-height: 1.4;
  }

  /* ─── Divider ─── */
  .pb__rule {
    width: 48px;
    height: 1px;
    background: #cccccc;
    border: none;
    margin: 0 0 56px 0;
  }

  /* ─── Stat Block ─── */
  .pb__stat-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .pb__big-num {
    font-family: 'Playfair Display', Georgia, 'Times New Roman', serif;
    font-weight: 900;
    font-style: italic;
    font-size: clamp(90px, 17vw, 170px);
    line-height: 0.88;
    color: #111111;
    letter-spacing: -0.02em;
    margin: 0 0 6px 0;
  }

  .pb__stat-heading {
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(13px, 1.6vw, 15px);
    font-weight: 700;
    color: #111111;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0;
  }

  .pb__stat-text {
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(13px, 1.5vw, 15px);
    font-weight: 400;
    color: #555555;
    line-height: 1.7;
    max-width: 480px;
    margin: 4px auto 0;
  }

  /* ─── Responsive ─── */
  @media screen and (max-width: 600px) {
    .pb__icons {
      gap: 0;
    }

    .pb__icon-gif {
      width: 44px;
      height: 44px;
    }

    .pb__big-num {
      font-size: clamp(72px, 22vw, 110px);
    }

    .pb__icon-label {
      font-size: 11px;
    }
  }
{%- endstyle -%}

<section class="pb" aria-label="Product highlights">
  <div class="pb__wrap">

    {%- comment -%} ── Icon Row ── {%- endcomment -%}
    <div class="pb__icons">

      {%- comment -%} Icon 1 – 72 Hour Cleaning {%- endcomment -%}
      <div class="pb__icon-col">
        {%- if section.settings.gif_1 != blank -%}
          <img
            class="pb__icon-gif"
            src="{{ section.settings.gif_1 }}"
            alt="{{ section.settings.label_1 | default: '72 Hour Cleaning' | escape }}"
            loading="lazy">
        {%- else -%}
          {%- comment -%} Fallback: hourglass SVG {%- endcomment -%}
          <svg class="pb__icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6 2v2h.01L6 4c0 3.87 2.5 7.18 6 8-3.5.82-6 4.13-6 8v.01H6V22h12v-1.99h-.01V20c0-3.87-2.5-7.18-6-8 3.5-.82 6-4.13 6-8l-.01-.01H18V2H6zm10 2c0 3.22-2.05 6-4 7.25C10.05 10 8 7.22 8 4h8zm-4 9.75C14.05 17 16.05 19.78 16 20H8c-.05-1.22 2.05-4 4-5.25z"/>
          </svg>
        {%- endif -%}
        <p class="pb__icon-label">{{ section.settings.label_1 | default: '72 Hour Cleaning' }}</p>
      </div>

      {%- comment -%} Icon 2 – Environmentally Friendly {%- endcomment -%}
      <div class="pb__icon-col">
        {%- if section.settings.gif_2 != blank -%}
          <img
            class="pb__icon-gif"
            src="{{ section.settings.gif_2 }}"
            alt="{{ section.settings.label_2 | default: 'Environmentally Friendly' | escape }}"
            loading="lazy">
        {%- else -%}
          {%- comment -%} Fallback: leaf SVG {%- endcomment -%}
          <svg class="pb__icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17 8C8 10 5.9 16.17 3.82 21.34L5.71 22l1-2.3A4.49 4.49 0 0 0 8 20C19 20 22 3 22 3c-1 2-8 2-13 5 0-3 3-5.5 5-6z"/>
          </svg>
        {%- endif -%}
        <p class="pb__icon-label">{{ section.settings.label_2 | default: 'Environmentally Friendly' }}</p>
      </div>

      {%- comment -%} Icon 3 – Biotechnology {%- endcomment -%}
      <div class="pb__icon-col">
        {%- if section.settings.gif_3 != blank -%}
          <img
            class="pb__icon-gif"
            src="{{ section.settings.gif_3 }}"
            alt="{{ section.settings.label_3 | default: 'Biotechnology' | escape }}"
            loading="lazy">
        {%- else -%}
          {%- comment -%} Fallback: biotech/atom SVG {%- endcomment -%}
          <svg class="pb__icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8zm1-11h-2v3H8v2h3v3h2v-3h3v-2h-3z"/>
          </svg>
        {%- endif -%}
        <p class="pb__icon-label">{{ section.settings.label_3 | default: 'Biotechnology' }}</p>
      </div>

    </div>

    {%- comment -%} ── Divider ── {%- endcomment -%}
    <hr class="pb__rule">

    {%- comment -%} ── 100% Biodegradable Block ── {%- endcomment -%}
    <div class="pb__stat-block">
      <p class="pb__big-num">{{ section.settings.stat_value | default: '100%' }}</p>
      <h2 class="pb__stat-heading">{{ section.settings.stat_heading | default: 'Biodegradable Cleaning Solution' }}</h2>
      <p class="pb__stat-text">{{ section.settings.stat_text | default: 'It delivers a deep, long-lasting clean without the use of harsh chemicals, making it hypoallergenic, non-toxic, vegan-friendly, and safe for skin, pets, and the planet.' }}</p>
    </div>

  </div>
</section>


<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

{%- style -%}
  .pb2 {
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    padding: clamp(56px, 8vw, 100px) 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  }

  .pb2__wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* ─── Icon Row ─── */
  .pb2__icons {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    width: 100%;
    margin-bottom: 48px;
  }

  .pb2__icon-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }

  /* GIF / img */
  .pb2__icon-gif {
    width: 80px;
    height: 80px;
    object-fit: contain;
    display: block;
  }

  /* Fallback SVG */
  .pb2__icon-svg {
    width: 74px;
    height: 74px;
    fill: #111;
    display: block;
  }

  .pb2__icon-label {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-size: clamp(13px, 1.4vw, 15px);
    font-weight: 700;
    color: #111111;
    letter-spacing: 0;
    margin: 0;
    line-height: 1.4;
  }

  /* ─── Divider ─── */
  .pb2__rule {
    width: 56px;
    height: 1px;
    background: #cccccc;
    border: none;
    margin: 0 0 72px 0;
  }

  /* ─── 100% Block ─── */
  .pb2__stat-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .pb2__big-num {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-weight: 900;
    font-style: normal;
    font-size: clamp(100px, 18vw, 190px);
    line-height: 0.9;
    color: #111111;
    letter-spacing: -0.02em;
    margin: 0 0 14px 0;
  }

  .pb2__stat-heading {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-size: clamp(15px, 1.8vw, 18px);
    font-weight: 700;
    color: #111111;
    letter-spacing: 0;
    text-transform: none;
    margin: 0;
  }

  .pb2__stat-text {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-size: clamp(13px, 1.4vw, 15px);
    font-weight: 400;
    color: #444444;
    line-height: 1.75;
    max-width: 500px;
    margin: 6px auto 0;
  }

  /* ─── Responsive ─── */
  @media screen and (max-width: 768px) {
    .pb2__wrap {
      padding: 0 20px;
    }

    .pb2__icons {
      gap: 0;
      margin-bottom: 36px;
    }

    .pb2__icon-gif,
    .pb2__icon-svg {
      width: 58px;
      height: 58px;
    }

    .pb2__big-num {
      font-size: clamp(80px, 22vw, 130px);
    }

    .pb2__rule {
      margin-bottom: 48px;
    }
  }

  @media screen and (max-width: 480px) {
    .pb2__icons {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
{%- endstyle -%}

<section class="pb2" aria-label="Product highlights">
  <div class="pb2__wrap">

    {%- comment -%}── Icon Row ──{%- endcomment -%}
    <div class="pb2__icons">

      {%- comment -%} Icon 1 {%- endcomment -%}
      <div class="pb2__icon-col">
        {%- if section.settings.gif_1 != blank -%}
          <img class="pb2__icon-gif"
               src="{{ section.settings.gif_1 | image_url: width: 160 }}"
               alt="{{ section.settings.label_1 | default: '72 Hour Cleaning' | escape }}"
               loading="lazy">
        {%- else -%}
          {%- comment -%} Fallback: clock/timer circle {%- endcomment -%}
          <svg class="pb2__icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
            <circle cx="50" cy="50" r="44" stroke="#111" stroke-width="8" fill="none"/>
            <path d="M50 50 L50 18 A32 32 0 0 1 82 50 Z" fill="#111"/>
          </svg>
        {%- endif -%}
        <p class="pb2__icon-label">{{ section.settings.label_1 | default: '72 Hour Cleaning' }}</p>
      </div>

      {%- comment -%} Icon 2 {%- endcomment -%}
      <div class="pb2__icon-col">
        {%- if section.settings.gif_2 != blank -%}
          <img class="pb2__icon-gif"
               src="{{ section.settings.gif_2 | image_url: width: 160 }}"
               alt="{{ section.settings.label_2 | default: 'Environmentally Friendly' | escape }}"
               loading="lazy">
        {%- else -%}
          {%- comment -%} Fallback: eye/diamond circle {%- endcomment -%}
          <svg class="pb2__icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
            <circle cx="50" cy="50" r="44" stroke="#111" stroke-width="8" fill="none"/>
            <polygon points="50,22 72,50 50,78 28,50" fill="#111"/>
            <circle cx="50" cy="50" r="8" fill="#fff"/>
          </svg>
        {%- endif -%}
        <p class="pb2__icon-label">{{ section.settings.label_2 | default: 'Environmentally Friendly' }}</p>
      </div>

      {%- comment -%} Icon 3 {%- endcomment -%}
      <div class="pb2__icon-col">
        {%- if section.settings.gif_3 != blank -%}
          <img class="pb2__icon-gif"
               src="{{ section.settings.gif_3 | image_url: width: 160 }}"
               alt="{{ section.settings.label_3 | default: 'Biotechnology' | escape }}"
               loading="lazy">
        {%- else -%}
          {%- comment -%} Fallback: square frame with corner circles {%- endcomment -%}
          <svg class="pb2__icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
            <rect x="22" y="22" width="56" height="56" rx="6" stroke="#111" stroke-width="8" fill="none"/>
            <circle cx="22" cy="22" r="9" fill="#111"/>
            <circle cx="78" cy="22" r="9" fill="#111"/>
            <circle cx="22" cy="78" r="9" fill="#111"/>
            <circle cx="78" cy="78" r="9" fill="#111"/>
          </svg>
        {%- endif -%}
        <p class="pb2__icon-label">{{ section.settings.label_3 | default: 'Biotechnology' }}</p>
      </div>

    </div>

    {%- comment -%}── Divider ──{%- endcomment -%}
    <hr class="pb2__rule">

    {%- comment -%}── 100% Stat Block ──{%- endcomment -%}
    <div class="pb2__stat-block">
      <p class="pb2__big-num">{{ section.settings.stat_value | default: '100%' }}</p>
      <h2 class="pb2__stat-heading">{{ section.settings.stat_heading | default: 'Biodegradable Cleaning Solution' }}</h2>
      <p class="pb2__stat-text">{{ section.settings.stat_text | default: 'It delivers a deep, long-lasting clean without the use of harsh chemicals, making it hypoallergenic, non-toxic, vegan-friendly, and safe for skin, pets, and the planet.' }}</p>
    </div>

  </div>
</section>


{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .video-demo-section {
    background-color: {{ section.settings.bg_color | default: '#fafafa' }};
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .video-demo-header {
    text-align: center;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 56px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .video-demo__eyebrow {
    color: var(--color-primary);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .video-demo__wrapper {
    max-width: 1040px;
    margin-left: auto;
    margin-right: auto;
    border-radius: var(--border-radius-lg);
    border: 1px solid var(--color-border);
    overflow: hidden;
    position: relative;
    aspect-ratio: 16 / 9;
    box-shadow: 0 32px 64px rgba(0, 0, 0, 0.05);
    background-color: #000000;
    transition: var(--transition-smooth);
  }

  .video-demo__wrapper:hover {
    transform: translateY(-4px);
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.1);
  }

  .video-demo__player {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .video-demo__custom-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.5) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: var(--transition-smooth);
    cursor: pointer;
  }

  .video-demo__play-btn {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 12px 32px rgba(0,0,0,0.25);
    transition: var(--transition-smooth);
    border: none;
    color: var(--color-primary);
  }

  .video-demo__play-btn svg {
    width: 28px;
    height: 28px;
    fill: currentColor;
    margin-left: 4px;
    transition: var(--transition-smooth);
  }

  .video-demo__wrapper:hover .video-demo__play-btn {
    transform: scale(1.1);
    background-color: var(--color-primary);
    color: #ffffff;
    box-shadow: 0 16px 40px rgba(255, 43, 43, 0.4);
  }

  @media screen and (max-width: 768px) {
    .video-demo-header {
      margin-bottom: 32px;
      padding: 0 4px;
    }
    .video-demo__wrapper {
      border-radius: var(--border-radius-md);
    }
    .video-demo__wrapper:hover {
      transform: none;
    }
    .video-demo__play-btn {
      width: 64px;
      height: 64px;
    }
    .video-demo__play-btn svg {
      width: 22px;
      height: 22px;
    }
  }
{%- endstyle -%}

<section class="video-demo-section section-spacing" aria-label="Sneaker transformation in action">
  <div class="container">
    <div class="video-demo-header animate-fade-in">
      {%- if section.settings.eyebrow != blank -%}
        <span class="video-demo__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="h2">{{ section.settings.heading | default: 'Watch It In Action' }}</h2>
    </div>

    <div class="video-demo__wrapper animate-fade-in">
      {%- if section.settings.video_url != blank -%}
        {%- if section.settings.video_url.type == 'youtube' -%}
          <iframe class="video-demo__player" src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay=0&mute=1" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        {%- elsif section.settings.video_url.type == 'vimeo' -%}
          <iframe class="video-demo__player" src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay=0&muted=1" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
        {%- endif -%}
      {%- else -%}
        <!-- Stunning Cinematic Fallback / Interactive SVG visual when video is empty -->
        <div class="video-demo__custom-overlay">
          <button type="button" class="video-demo__play-btn" aria-label="Play video">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M5 3l14 9-14 9V3z"/>
            </svg>
          </button>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1040 585" class="video-demo__player">
          <rect width="1040" height="585" fill="#141414"/>
          <!-- Abstract premium pattern / glows -->
          <circle cx="520" cy="292" r="280" fill="#222222" opacity="0.4"/>
          <circle cx="520" cy="292" r="160" fill="#FF2B2B" opacity="0.04" filter="blur(60px)"/>
          <text x="520" y="380" font-family="Inter, sans-serif" font-size="14" font-weight="700" fill="#ffffff" opacity="0.4" text-anchor="middle" letter-spacing="4">HAGUEPROTECT LABS</text>
        </svg>
      {%- endif -%}
    </div>
  </div>
</section>


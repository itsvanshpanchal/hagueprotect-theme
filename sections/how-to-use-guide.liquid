{%- style -%}
  {% render 'section-typography-vars', section: section %}


  .htu-v2 {
    --red: #ff2b2b;
    --ink: #111111;
    --muted: #6b6b6b;
    --cream: #f6f4f1;
    --line: #e6e2dc;
    font-family: var(--font-family-sans);
    background: #ffffff;
    color: var(--ink);
  }

  /* Ã¢â€â‚¬Ã¢â€â‚¬ Opener Ã¢â€â‚¬Ã¢â€â‚¬ */
  .htu-v2__opener {
    padding: clamp(56px, 8vw, 88px) max(20px, var(--site-padding, 24px)) clamp(40px, 5vw, 56px);
    max-width: var(--site-max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(32px, 5vw, 64px);
    align-items: end;
    border-bottom: 1px solid var(--line);
  }

  .htu-v2__opener-label {
    font-family: var(--font-family-eyebrow, var(--font-family-sans));
    font-size: var(--section-label-size, 11px);
    font-weight: var(--font-weight-eyebrow, 700);
    font-style: var(--font-style-eyebrow, normal);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--red);
    margin: 0 0 20px;
  }

  .htu-v2__opener-title {
    font-family: var(--font-family-h2, var(--font-family-heading));
    font-size: var(--section-heading-size);
    font-weight: var(--font-weight-h2, 400);
    font-style: var(--font-style-h2, normal);
    line-height: 0.9;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 0;
  }

  .htu-v2__opener-aside {
    padding-bottom: 8px;
  }

  .htu-v2__opener-text {
    font-family: var(--font-family-sans);
    font-size: var(--section-subheading-size, 16px);
    font-weight: var(--font-weight-sans, 400);
    font-style: var(--font-style-sans, normal);
    line-height: 1.7;
    color: var(--muted);
    margin: 0 0 28px;
    max-width: 420px;
  }

  .htu-v2__opener-stat {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
  }

  .htu-v2__stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .htu-v2__stat-num {
    font-family: var(--font-family-heading);
    font-size: 36px;
    line-height: 1;
    color: var(--ink);
  }

  .htu-v2__stat-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #999;
  }

  /* Ã¢â€â‚¬Ã¢â€â‚¬ Horizontal protocol rail Ã¢â€â‚¬Ã¢â€â‚¬ */
  .htu-v2__rail-wrap {
    background: var(--cream);
    padding: clamp(48px, 6vw, 72px) 0;
    overflow: hidden;
  }

  .htu-v2__rail-head {
    max-width: var(--site-max-width);
    margin: 0 auto clamp(28px, 4vw, 40px);
    padding: 0 max(20px, var(--site-padding, 24px));
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .htu-v2__rail-title {
    font-family: var(--font-family-h2, var(--font-family-heading));
    font-size: var(--section-heading-size);
    font-weight: var(--font-weight-h2, 400);
    font-style: var(--font-style-h2, normal);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin: 0;
    line-height: 1;
  }

  .htu-v2__rail-hint {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #999;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .htu-v2__rail {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    padding: 8px max(20px, var(--site-padding, 24px)) 16px;
    cursor: grab;
    scrollbar-width: none;
  }

  .htu-v2__rail::-webkit-scrollbar {
    display: none;
  }

  .htu-v2__rail.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
  }

  .htu-v2__rail-card {
    flex: 0 0 clamp(280px, 72vw, 380px);
    scroll-snap-align: start;
    background: #ffffff;
    border-radius: 4px;
    border: 1px solid var(--line);
    padding: 0;
    overflow: hidden;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.55s ease, transform 0.55s ease, box-shadow 0.3s ease;
  }

  .htu-v2__rail-card.is-in {
    opacity: 1;
    transform: translateY(0);
  }

  .htu-v2__rail-card:nth-child(2) { transition-delay: 0.08s; }
  .htu-v2__rail-card:nth-child(3) { transition-delay: 0.16s; }

  .htu-v2__rail-card:hover {
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.08);
  }

  .htu-v2__rail-top {
    background: var(--ink);
    color: #ffffff;
    padding: 28px 28px 24px;
    position: relative;
    overflow: hidden;
  }

  .htu-v2__rail-top::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--red);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .htu-v2__rail-card:hover .htu-v2__rail-top::after {
    transform: scaleX(1);
  }

  .htu-v2__rail-num {
    font-family: var(--font-family-heading);
    font-size: 64px;
    line-height: 0.85;
    opacity: 0.15;
    position: absolute;
    top: 12px;
    right: 20px;
    letter-spacing: 0.02em;
  }

  .htu-v2__rail-step {
    font-family: var(--font-family-heading);
    font-size: 32px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 6px;
    line-height: 1;
    position: relative;
  }

  .htu-v2__rail-time {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    position: relative;
  }

  .htu-v2__rail-body {
    padding: 24px 28px 28px;
  }

  .htu-v2__rail-text {
    font-size: 14px;
    line-height: 1.65;
    color: var(--muted);
    margin: 0;
  }

  /* Ã¢â€â‚¬Ã¢â€â‚¬ Materials journal Ã¢â€â‚¬Ã¢â€â‚¬ */
  .htu-v2__journal {
    max-width: var(--site-max-width);
    margin: 0 auto;
    padding: clamp(56px, 7vw, 80px) max(20px, var(--site-padding, 24px));
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: clamp(32px, 5vw, 64px);
    align-items: start;
  }

  .htu-v2__nav {
    position: sticky;
    top: calc(var(--header-height, 80px) + 24px);
  }

  .htu-v2__nav-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #aaa;
    margin: 0 0 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line);
  }

  .htu-v2__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .htu-v2__nav-link {
    display: block;
    padding: 10px 0;
    font-size: 20px;
    color: #bbb;
    text-decoration: none;
    border-left: 2px solid transparent;
    padding-left: 14px;
    margin-left: -14px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .htu-v2__nav-link:not(.mat-font) {
    font-family: var(--font-family-heading);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .htu-v2__nav-link.is-active,
  .htu-v2__nav-link:hover {
    color: var(--ink);
    border-left-color: var(--red);
  }

  .htu-v2__chapters {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .htu-v2__chapter {
    padding: clamp(40px, 5vw, 56px) 0;
    border-bottom: 1px solid var(--line);
    scroll-margin-top: calc(var(--header-height, 80px) + 32px);
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .htu-v2__chapter.is-in {
    opacity: 1;
    transform: translateY(0);
  }

  .htu-v2__chapter:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .htu-v2__chapter-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(24px, 4vw, 48px);
    align-items: center;
  }

  .htu-v2__chapter:nth-child(even) .htu-v2__chapter-grid {
    direction: rtl;
  }

  .htu-v2__chapter:nth-child(even) .htu-v2__chapter-grid > * {
    direction: ltr;
  }

  .htu-v2__chapter-visual {
    border-radius: 4px;
    overflow: hidden;
    aspect-ratio: 5/4;
    background: var(--cream);
    position: relative;
  }

  .htu-v2__chapter-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .htu-v2__chapter:hover .htu-v2__chapter-visual img {
    transform: scale(1.04);
  }

  .htu-v2__chapter-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, #eceae6, #ddd9d3);
  }

  .htu-v2__chapter-placeholder span:not(.mat-font) {
    font-family: var(--font-family-heading);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .htu-v2__chapter-placeholder span {
    font-size: clamp(40px, 6vw, 64px);
    color: rgba(0, 0, 0, 0.07);
  }

  .htu-v2__chapter-index {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 12px;
  }

  .htu-v2__chapter-name {
    font-size: clamp(36px, 5vw, 56px);
    line-height: 0.95;
    margin: 0 0 14px;
  }

  .htu-v2__chapter-name:not(.mat-font) {
    font-family: var(--font-family-heading);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .htu-v2__chapter-desc {
    font-size: 15px;
    line-height: 1.65;
    color: var(--muted);
    margin: 0 0 24px;
  }

  .htu-v2__tips {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 24px;
  }

  .htu-v2__tip {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 14px;
    padding: 14px 0;
    border-top: 1px solid var(--line);
    font-size: 14px;
    line-height: 1.5;
    color: #333;
  }

  .htu-v2__tip:last-child {
    border-bottom: 1px solid var(--line);
  }

  .htu-v2__tip-n {
    font-family: var(--font-family-heading);
    font-size: 18px;
    color: var(--red);
    line-height: 1.4;
  }

  .htu-v2__chapter-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    padding: 14px 24px;
    border: 2px solid var(--ink);
    border-radius: 0;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .htu-v2__chapter-link:hover {
    background: var(--ink);
    color: #ffffff;
  }

  /* Ã¢â€â‚¬Ã¢â€â‚¬ Rules strip Ã¢â€â‚¬Ã¢â€â‚¬ */
  .htu-v2__rules {
    background: var(--ink);
    color: #ffffff;
    padding: clamp(48px, 6vw, 72px) max(20px, var(--site-padding, 24px));
    overflow: hidden;
  }

  .htu-v2__rules-inner {
    max-width: var(--site-max-width);
    margin: 0 auto;
  }

  .htu-v2__rules-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: clamp(28px, 4vw, 40px);
    flex-wrap: wrap;
  }

  .htu-v2__rules-title {
    font-family: var(--font-family-heading);
    font-size: clamp(28px, 4vw, 44px);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin: 0;
    line-height: 1;
  }

  .htu-v2__rules-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(24px, 4vw, 48px);
  }

  .htu-v2__rules-col h4 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0 0 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .htu-v2__rules-col--yes h4 { color: #6fcf97; }
  .htu-v2__rules-col--no h4 { color: #ff6b6b; }

  .htu-v2__rules-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .htu-v2__rules-col li {
    font-size: 14px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.72);
    padding-left: 20px;
    position: relative;
  }

  .htu-v2__rules-col li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .htu-v2__rules-col--yes li::before { background: #6fcf97; }
  .htu-v2__rules-col--no li::before { background: #ff6b6b; }

  /* Ã¢â€â‚¬Ã¢â€â‚¬ CTA band Ã¢â€â‚¬Ã¢â€â‚¬ */
  .htu-v2__cta {
    background: var(--red);
    padding: clamp(40px, 5vw, 56px) max(20px, var(--site-padding, 24px));
  }

  .htu-v2__cta-inner {
    max-width: var(--site-max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .htu-v2__cta-title {
    font-family: var(--font-family-heading);
    font-size: clamp(28px, 4vw, 44px);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: #ffffff;
    margin: 0 0 4px;
    line-height: 1;
  }

  .htu-v2__cta-sub {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
  }

  .htu-v2__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    background: #ffffff;
    color: var(--ink);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    white-space: nowrap;
  }

  .htu-v2__cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  /* Ã¢â€â‚¬Ã¢â€â‚¬ Mobile nav (horizontal) Ã¢â€â‚¬Ã¢â€â‚¬ */
  .htu-v2__mob-nav {
    display: none;
    overflow-x: auto;
    gap: 8px;
    padding-bottom: 24px;
    margin-bottom: 8px;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .htu-v2__mob-nav::-webkit-scrollbar { display: none; }

  .htu-v2__mob-nav a {
    flex-shrink: 0;
    padding: 10px 18px;
    border: 1px solid var(--line);
    font-size: 16px;
    text-decoration: none;
    color: var(--muted);
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  .htu-v2__mob-nav a:not(.mat-font) {
    font-family: var(--font-family-heading);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .htu-v2__mob-nav a.is-active,
  .htu-v2__mob-nav a:hover {
    border-color: var(--ink);
    color: var(--ink);
    background: var(--cream);
  }

  @media screen and (max-width: 900px) {
    .htu-v2__opener {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .htu-v2__journal {
      grid-template-columns: 1fr;
    }

    .htu-v2__nav {
      display: none;
    }

    .htu-v2__mob-nav {
      display: flex;
    }

    .htu-v2__chapter-grid,
    .htu-v2__chapter:nth-child(even) .htu-v2__chapter-grid {
      grid-template-columns: 1fr;
      direction: ltr;
    }

    .htu-v2__rules-cols {
      grid-template-columns: 1fr;
    }

    .htu-v2__cta-inner {
      flex-direction: column;
      text-align: center;
    }
  }
{%- endstyle -%}

<section class="htu-v2" data-htu-guide aria-label="Sneaker care guide">
  <!-- Editorial opener -->
  <div class="htu-v2__opener" data-htu-reveal>
    <div>
      <p class="htu-v2__opener-label">{{ section.settings.intro_eyebrow | default: 'Care Manual' }}</p>
      <h2 class="htu-v2__opener-title">{{ section.settings.intro_title | default: 'The Right Way to Clean Sneakers' }}</h2>
    </div>
    <div class="htu-v2__opener-aside">
      <p class="htu-v2__opener-text">{{ section.settings.intro_text | default: 'No washing machines. No shortcuts. Just a proven three-step system and material-specific techniques that protect what you wear.' }}</p>
      <div class="htu-v2__opener-stat">
        <div class="htu-v2__stat">
          <span class="htu-v2__stat-num">3</span>
          <span class="htu-v2__stat-label">Steps</span>
        </div>
        <div class="htu-v2__stat">
          <span class="htu-v2__stat-num">5</span>
          <span class="htu-v2__stat-label">Materials</span>
        </div>
        <div class="htu-v2__stat">
          <span class="htu-v2__stat-num">~10</span>
          <span class="htu-v2__stat-label">Minutes</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Horizontal protocol rail -->
  <div class="htu-v2__rail-wrap">
    <div class="htu-v2__rail-head">
      <h3 class="htu-v2__rail-title">{{ section.settings.protocol_heading | default: 'The Protocol' }}</h3>
      <span class="htu-v2__rail-hint">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        Scroll to explore
      </span>
    </div>
    <div class="htu-v2__rail" data-htu-rail>
      <article class="htu-v2__rail-card" data-htu-reveal>
        <div class="htu-v2__rail-top">
          <span class="htu-v2__rail-num">01</span>
          <h4 class="htu-v2__rail-step">{{ section.settings.step1_title | default: 'Prep' }}</h4>
          <span class="htu-v2__rail-time">{{ section.settings.step1_time | default: '~2 min' }}</span>
        </div>
        <div class="htu-v2__rail-body">
          <p class="htu-v2__rail-text">{{ section.settings.step1_text | default: 'Remove laces and insoles. Knock off loose dirt and brush dry debris with a soft brush before any liquid touches the upper.' }}</p>
        </div>
      </article>
      <article class="htu-v2__rail-card" data-htu-reveal>
        <div class="htu-v2__rail-top">
          <span class="htu-v2__rail-num">02</span>
          <h4 class="htu-v2__rail-step">{{ section.settings.step2_title | default: 'Clean' }}</h4>
          <span class="htu-v2__rail-time">{{ section.settings.step2_time | default: '~5 min' }}</span>
        </div>
        <div class="htu-v2__rail-body">
          <p class="htu-v2__rail-text">{{ section.settings.step2_text | default: 'Apply pH-balanced cleaner with the correct brush. Work in gentle circles Ã¢â‚¬â€ damp the material, never soak it.' }}</p>
        </div>
      </article>
      <article class="htu-v2__rail-card" data-htu-reveal>
        <div class="htu-v2__rail-top">
          <span class="htu-v2__rail-num">03</span>
          <h4 class="htu-v2__rail-step">{{ section.settings.step3_title | default: 'Protect' }}</h4>
          <span class="htu-v2__rail-time">{{ section.settings.step3_time | default: '~3 min' }}</span>
        </div>
        <div class="htu-v2__rail-body">
          <p class="htu-v2__rail-text">{{ section.settings.step3_text | default: 'Air dry completely away from heat. Spray nano-barrier protector evenly for up to 4 weeks of liquid and stain resistance.' }}</p>
        </div>
      </article>
    </div>
  </div>

  <!-- Material journal -->
  <div class="htu-v2__journal">
    <nav class="htu-v2__nav" aria-label="Materials">
      <p class="htu-v2__nav-title">{{ section.settings.materials_heading | default: 'By Material' }}</p>
      <ul class="htu-v2__nav-list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'material' -%}
            <li>
              <a href="#htu-mat-{{ block.id }}" class="htu-v2__nav-link {% render 'material-font-class', source: block.settings.title %}{% if forloop.first %} is-active{% endif %}" data-htu-nav>
                {{ block.settings.title }}
              </a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </nav>

    <div class="htu-v2__chapters">
      <div class="htu-v2__mob-nav" aria-label="Materials">
        {%- for block in section.blocks -%}
          {%- if block.type == 'material' -%}
            <a href="#htu-mat-{{ block.id }}" class="{% render 'material-font-class', source: block.settings.title %}{% if forloop.first %} is-active{% endif %}" data-htu-nav>{{ block.settings.title }}</a>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'material' -%}
          {%- liquid
            assign mat_link = block.settings.link
            if mat_link == blank and block.settings.collection != blank
              assign mat_link = block.settings.collection.url
            endif
          -%}
          <article
            id="htu-mat-{{ block.id }}"
            class="htu-v2__chapter"
            data-htu-chapter
            data-htu-reveal
            {{ block.shopify_attributes }}
          >
            <div class="htu-v2__chapter-grid">
              <div class="htu-v2__chapter-visual">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
                {%- else -%}
                  <div class="htu-v2__chapter-placeholder" aria-hidden="true">
                    <span class="{% render 'material-font-class', source: block.settings.title %}">{{ block.settings.title }}</span>
                  </div>
                {%- endif -%}
              </div>
              <div class="htu-v2__chapter-copy">
                <p class="htu-v2__chapter-index">{% if forloop.index < 10 %}0{% endif %}{{ forloop.index }} Ã¢â‚¬â€ {{ block.settings.badge | default: 'Guide' }}</p>
                <h3 class="htu-v2__chapter-name {% render 'material-font-class', source: block.settings.title %}">{{ block.settings.title }}</h3>
                <p class="htu-v2__chapter-desc">{{ block.settings.description }}</p>
                <div class="htu-v2__tips">
                  {%- assign tips = block.settings.tips | newline_to_br | split: '<br />' -%}
                  {%- for tip in tips -%}
                    {%- if tip != blank -%}
                      <div class="htu-v2__tip">
                        <span class="htu-v2__tip-n">{{ forloop.index }}</span>
                        <span>{{ tip | strip }}</span>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
                {%- if mat_link != blank -%}
                  <a href="{{ mat_link }}" class="htu-v2__chapter-link">
                    Shop {{ block.settings.title }}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                {%- endif -%}
              </div>
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- Rules -->
  <div class="htu-v2__rules" data-htu-reveal>
    <div class="htu-v2__rules-inner">
      <div class="htu-v2__rules-head">
        <h3 class="htu-v2__rules-title">{{ section.settings.wisdom_heading | default: 'Golden Rules' }}</h3>
      </div>
      <div class="htu-v2__rules-cols">
        <div class="htu-v2__rules-col htu-v2__rules-col--yes">
          <h4>Always</h4>
          <ul>
            {%- assign do_items = section.settings.do_list | newline_to_br | split: '<br />' -%}
            {%- for item in do_items -%}
              {%- if item != blank -%}<li>{{ item | strip }}</li>{%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
        <div class="htu-v2__rules-col htu-v2__rules-col--no">
          <h4>Never</h4>
          <ul>
            {%- assign dont_items = section.settings.dont_list | newline_to_br | split: '<br />' -%}
            {%- for item in dont_items -%}
              {%- if item != blank -%}<li>{{ item | strip }}</li>{%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="htu-v2__cta">
    <div class="htu-v2__cta-inner" data-htu-reveal>
      <div>
        <h3 class="htu-v2__cta-title">{{ section.settings.cta_title | default: 'Get the Complete Kit' }}</h3>
        <p class="htu-v2__cta-sub">{{ section.settings.cta_text | default: 'Every brush, solution, and protector Ã¢â‚¬â€ curated in one box.' }}</p>
      </div>
      <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="htu-v2__cta-btn">
        {{ section.settings.cta_label | default: 'Shop Now' }}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</section>

<script src="{{ 'how-to-use-guide.js' | asset_url }}" defer="defer"></script>


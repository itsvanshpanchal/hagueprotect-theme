{%- style -%}
  .htu-guide {
    --htu-red: #ff2b2b;
    --htu-dark: #0a0a0a;
    --htu-gray: #565656;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: #ffffff;
    overflow: hidden;
  }

  .htu-guide__intro {
    position: relative;
    background: var(--htu-dark);
    color: #ffffff;
    padding: clamp(72px, 10vw, 110px) max(20px, var(--site-padding, 24px));
    text-align: center;
    overflow: hidden;
  }

  .htu-guide__intro-mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 20% 30%, rgba(255, 43, 43, 0.28) 0%, transparent 55%),
      radial-gradient(ellipse 50% 40% at 80% 70%, rgba(255, 43, 43, 0.12) 0%, transparent 50%);
    pointer-events: none;
  }

  .htu-guide__intro-inner {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
  }

  .htu-guide__eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--htu-red);
    margin: 0 0 16px;
  }

  .htu-guide__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(44px, 7vw, 80px);
    font-weight: 400;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    line-height: 0.95;
    margin: 0 0 20px;
  }

  .htu-guide__title span {
    color: var(--htu-red);
  }

  .htu-guide__desc {
    font-size: 17px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }

  /* Protocol steps ring */
  .htu-guide__protocol {
    padding: clamp(64px, 8vw, 96px) max(20px, var(--site-padding, 24px));
    background: #fafafa;
  }

  .htu-guide__protocol-inner {
    max-width: 1320px;
    margin: 0 auto;
  }

  .htu-guide__protocol-head {
    text-align: center;
    margin-bottom: clamp(40px, 6vw, 64px);
  }

  .htu-guide__protocol-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(32px, 4.5vw, 52px);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: #111111;
    margin: 0 0 10px;
    line-height: 1;
  }

  .htu-guide__protocol-sub {
    font-size: 15px;
    color: var(--htu-gray);
    margin: 0;
  }

  .htu-guide__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    position: relative;
  }

  .htu-guide__steps::before {
    content: '';
    position: absolute;
    top: 52px;
    left: 16.66%;
    right: 16.66%;
    height: 2px;
    background: linear-gradient(90deg, var(--htu-red) 0%, var(--htu-red) 50%, #dddddd 50%, #dddddd 100%);
    z-index: 0;
  }

  .htu-guide__step {
    position: relative;
    z-index: 1;
    background: #ffffff;
    border: 1px solid #ececec;
    border-radius: 20px;
    padding: 32px 28px;
    text-align: center;
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.6s ease, transform 0.6s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  }

  .htu-guide__step.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .htu-guide__step:hover {
    border-color: var(--htu-red);
    box-shadow: 0 20px 50px rgba(255, 43, 43, 0.1);
    transform: translateY(-6px);
  }

  .htu-guide__step.is-visible:hover {
    transform: translateY(-6px);
  }

  .htu-guide__step-icon {
    width: 72px;
    height: 72px;
    margin: 0 auto 20px;
    border-radius: 50%;
    background: #111111;
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 0.04em;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .htu-guide__step:hover .htu-guide__step-icon {
    background: var(--htu-red);
    transform: scale(1.08);
  }

  .htu-guide__step-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #111111;
    margin: 0 0 10px;
    line-height: 1;
  }

  .htu-guide__step-text {
    font-size: 14px;
    line-height: 1.6;
    color: var(--htu-gray);
    margin: 0;
  }

  .htu-guide__step-time {
    display: inline-flex;
    margin-top: 16px;
    padding: 6px 14px;
    border-radius: 999px;
    background: #f5f5f5;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #888888;
  }

  /* Material navigator */
  .htu-guide__materials {
    padding: clamp(64px, 8vw, 96px) max(20px, var(--site-padding, 24px));
    background: #ffffff;
  }

  .htu-guide__materials-inner {
    max-width: 1320px;
    margin: 0 auto;
  }

  .htu-guide__mat-head {
    margin-bottom: 36px;
  }

  .htu-guide__mat-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(32px, 4.5vw, 52px);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: #111111;
    margin: 0 0 8px;
    line-height: 1;
  }

  .htu-guide__mat-sub {
    font-size: 15px;
    color: var(--htu-gray);
    margin: 0;
  }

  .htu-guide__tabs-wrap {
    position: relative;
    margin-bottom: 36px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .htu-guide__tabs-wrap::-webkit-scrollbar {
    display: none;
  }

  .htu-guide__tabs {
    display: flex;
    gap: 8px;
    min-width: max-content;
    position: relative;
    padding-bottom: 4px;
  }

  .htu-guide__tab {
    padding: 14px 28px;
    border: none;
    border-radius: 999px;
    background: #f5f5f5;
    color: #666666;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 0.25s ease, background 0.25s ease;
    white-space: nowrap;
    font-family: 'Inter', sans-serif;
  }

  .htu-guide__tab.is-active {
    background: #111111;
    color: #ffffff;
  }

  .htu-guide__tab:hover:not(.is-active) {
    color: var(--htu-red);
  }

  .htu-guide__panels {
    position: relative;
    min-height: 320px;
  }

  .htu-guide__panel {
    display: none;
    animation: htuPanelIn 0.45s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .htu-guide__panel.is-active {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(24px, 4vw, 48px);
    align-items: center;
  }

  @keyframes htuPanelIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .htu-guide__panel-visual {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 4/3;
    background: #111111;
  }

  .htu-guide__panel-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .htu-guide__panel-visual-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 50%, #1a0808 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .htu-guide__panel-visual-placeholder span {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 8vw, 72px);
    color: rgba(255, 255, 255, 0.08);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .htu-guide__panel-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    padding: 8px 14px;
    border-radius: 999px;
    background: var(--htu-red);
    color: #ffffff;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .htu-guide__panel-content h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(28px, 3.5vw, 40px);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: #111111;
    margin: 0 0 12px;
    line-height: 1;
  }

  .htu-guide__panel-desc {
    font-size: 15px;
    line-height: 1.65;
    color: var(--htu-gray);
    margin: 0 0 24px;
  }

  .htu-guide__tips {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 28px;
  }

  .htu-guide__tip {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px 18px;
    border-radius: 14px;
    background: #fafafa;
    border: 1px solid #ececec;
    transition: border-color 0.25s ease, background 0.25s ease;
  }

  .htu-guide__tip:hover {
    border-color: var(--htu-red);
    background: #fff8f8;
  }

  .htu-guide__tip-num {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: #111111;
    color: #ffffff;
    font-size: 12px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .htu-guide__tip-text {
    font-size: 14px;
    line-height: 1.5;
    color: #333333;
    margin: 0;
  }

  .htu-guide__panel-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--htu-red);
    text-decoration: none;
  }

  .htu-guide__panel-link:hover {
    text-decoration: underline;
  }

  /* Do / Don't wall */
  .htu-guide__wisdom {
    padding: clamp(64px, 8vw, 96px) max(20px, var(--site-padding, 24px));
    background: #fafafa;
  }

  .htu-guide__wisdom-inner {
    max-width: 1320px;
    margin: 0 auto;
  }

  .htu-guide__wisdom-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(32px, 4.5vw, 52px);
    text-transform: uppercase;
    text-align: center;
    letter-spacing: 0.03em;
    color: #111111;
    margin: 0 0 clamp(32px, 5vw, 48px);
    line-height: 1;
  }

  .htu-guide__wisdom-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .htu-guide__wisdom-col {
    border-radius: 20px;
    padding: clamp(28px, 4vw, 40px);
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .htu-guide__wisdom-col.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .htu-guide__wisdom-col--do {
    background: #ffffff;
    border: 1px solid #e8f5e9;
    box-shadow: 0 8px 32px rgba(46, 125, 50, 0.06);
  }

  .htu-guide__wisdom-col--dont {
    background: #ffffff;
    border: 1px solid #ffebee;
    box-shadow: 0 8px 32px rgba(211, 47, 47, 0.06);
  }

  .htu-guide__wisdom-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .htu-guide__wisdom-col--do .htu-guide__wisdom-label {
    color: #2e7d32;
  }

  .htu-guide__wisdom-col--dont .htu-guide__wisdom-label {
    color: #c62828;
  }

  .htu-guide__wisdom-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .htu-guide__wisdom-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 14px;
    line-height: 1.55;
    color: #444444;
  }

  .htu-guide__wisdom-list li::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 6px;
  }

  .htu-guide__wisdom-col--do .htu-guide__wisdom-list li::before {
    background: #2e7d32;
  }

  .htu-guide__wisdom-col--dont .htu-guide__wisdom-list li::before {
    background: #c62828;
  }

  /* CTA */
  .htu-guide__cta {
    padding: clamp(48px, 6vw, 72px) max(20px, var(--site-padding, 24px)) clamp(72px, 10vw, 110px);
    background: #ffffff;
  }

  .htu-guide__cta-card {
    max-width: 1320px;
    margin: 0 auto;
    background: var(--htu-dark);
    border-radius: 24px;
    padding: clamp(40px, 6vw, 64px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
    position: relative;
    overflow: hidden;
  }

  .htu-guide__cta-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 50% 80% at 100% 50%, rgba(255, 43, 43, 0.2) 0%, transparent 60%);
    pointer-events: none;
  }

  .htu-guide__cta-content {
    position: relative;
    z-index: 1;
    max-width: 520px;
  }

  .htu-guide__cta-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(32px, 4vw, 48px);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: #ffffff;
    margin: 0 0 10px;
    line-height: 1;
  }

  .htu-guide__cta-text {
    font-size: 15px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .htu-guide__cta-btn {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 18px 36px;
    border-radius: 999px;
    background: var(--htu-red);
    color: #ffffff;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 8px 32px rgba(255, 43, 43, 0.35);
    white-space: nowrap;
  }

  .htu-guide__cta-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 40px rgba(255, 43, 43, 0.45);
  }

  @media screen and (max-width: 900px) {
    .htu-guide__steps {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .htu-guide__steps::before {
      display: none;
    }

    .htu-guide__panel.is-active {
      grid-template-columns: 1fr;
    }

    .htu-guide__wisdom-grid {
      grid-template-columns: 1fr;
    }

    .htu-guide__cta-card {
      flex-direction: column;
      text-align: center;
    }
  }
{%- endstyle -%}

<section class="htu-guide" data-htu-guide aria-label="Sneaker care guide">
  <!-- Intro -->
  <div class="htu-guide__intro">
    <div class="htu-guide__intro-mesh" aria-hidden="true"></div>
    <div class="htu-guide__intro-inner">
      <p class="htu-guide__eyebrow">{{ section.settings.intro_eyebrow | default: 'The Protocol' }}</p>
      <h2 class="htu-guide__title">
        {{ section.settings.intro_title | default: 'Prep.' }}
        <span>{{ section.settings.intro_title_accent | default: 'Clean. Protect.' }}</span>
      </h2>
      <p class="htu-guide__desc">{{ section.settings.intro_text | default: 'Every premium sneaker deserves a system — not shortcuts. Master the Hague Protect three-step protocol for results that last.' }}</p>
    </div>
  </div>

  <!-- 3-step protocol -->
  <div class="htu-guide__protocol">
    <div class="htu-guide__protocol-inner">
      <div class="htu-guide__protocol-head">
        <h3 class="htu-guide__protocol-title">{{ section.settings.protocol_heading | default: 'The 3-Step System' }}</h3>
        <p class="htu-guide__protocol-sub">{{ section.settings.protocol_subheading | default: 'Follow this sequence every time for professional-grade results.' }}</p>
      </div>
      <div class="htu-guide__steps">
        <div class="htu-guide__step" data-htu-step>
          <div class="htu-guide__step-icon">01</div>
          <h4 class="htu-guide__step-name">{{ section.settings.step1_title | default: 'Prep' }}</h4>
          <p class="htu-guide__step-text">{{ section.settings.step1_text | default: 'Remove laces, knock off loose dirt, and brush dry debris before applying any solution.' }}</p>
          <span class="htu-guide__step-time">{{ section.settings.step1_time | default: '~2 min' }}</span>
        </div>
        <div class="htu-guide__step" data-htu-step>
          <div class="htu-guide__step-icon">02</div>
          <h4 class="htu-guide__step-name">{{ section.settings.step2_title | default: 'Clean' }}</h4>
          <p class="htu-guide__step-text">{{ section.settings.step2_text | default: 'Apply pH-balanced cleaner with the right brush. Work in gentle circular motions — never soak the material.' }}</p>
          <span class="htu-guide__step-time">{{ section.settings.step2_time | default: '~5 min' }}</span>
        </div>
        <div class="htu-guide__step" data-htu-step>
          <div class="htu-guide__step-icon">03</div>
          <h4 class="htu-guide__step-name">{{ section.settings.step3_title | default: 'Protect' }}</h4>
          <p class="htu-guide__step-text">{{ section.settings.step3_text | default: 'Let shoes air dry fully, then apply invisible nano-barrier spray for up to 4 weeks of stain & liquid resistance.' }}</p>
          <span class="htu-guide__step-time">{{ section.settings.step3_time | default: '~3 min' }}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Material-specific guide -->
  <div class="htu-guide__materials">
    <div class="htu-guide__materials-inner">
      <div class="htu-guide__mat-head">
        <h3 class="htu-guide__mat-title">{{ section.settings.materials_heading | default: 'Care by Material' }}</h3>
        <p class="htu-guide__mat-sub">{{ section.settings.materials_subheading | default: 'Select your upper material for tailored tips and the right brush.' }}</p>
      </div>

      <div class="htu-guide__tabs-wrap">
        <div class="htu-guide__tabs" role="tablist">
          {%- for block in section.blocks -%}
            {%- if block.type == 'material' -%}
              <button
                type="button"
                class="htu-guide__tab{% if forloop.first %} is-active{% endif %}"
                data-htu-tab="{{ block.id }}"
                role="tab"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.title }}
              </button>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <div class="htu-guide__panels">
        {%- for block in section.blocks -%}
          {%- if block.type == 'material' -%}
            {%- liquid
              assign mat_link = block.settings.link
              if mat_link == blank and block.settings.collection != blank
                assign mat_link = block.settings.collection.url
              endif
            -%}
            <div
              class="htu-guide__panel{% if forloop.first %} is-active{% endif %}"
              data-htu-panel="{{ block.id }}"
              role="tabpanel"
            >
              <div class="htu-guide__panel-visual">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
                {%- else -%}
                  <div class="htu-guide__panel-visual-placeholder" aria-hidden="true">
                    <span>{{ block.settings.title }}</span>
                  </div>
                {%- endif -%}
                <span class="htu-guide__panel-badge">{{ block.settings.badge | default: 'Material Guide' }}</span>
              </div>
              <div class="htu-guide__panel-content">
                <h3>{{ block.settings.title }} Care</h3>
                <p class="htu-guide__panel-desc">{{ block.settings.description }}</p>
                <div class="htu-guide__tips">
                  {%- assign tips = block.settings.tips | newline_to_br | split: '<br />' -%}
                  {%- for tip in tips -%}
                    {%- if tip != blank -%}
                      <div class="htu-guide__tip">
                        <span class="htu-guide__tip-num">{{ forloop.index }}</span>
                        <p class="htu-guide__tip-text">{{ tip | strip }}</p>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
                {%- if mat_link != blank -%}
                  <a href="{{ mat_link }}" class="htu-guide__panel-link">
                    Shop {{ block.settings.title }} Care
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <!-- Do / Don't -->
  <div class="htu-guide__wisdom">
    <div class="htu-guide__wisdom-inner">
      <h3 class="htu-guide__wisdom-title">{{ section.settings.wisdom_heading | default: 'Pro Rules' }}</h3>
      <div class="htu-guide__wisdom-grid">
        <div class="htu-guide__wisdom-col htu-guide__wisdom-col--do" data-htu-reveal>
          <span class="htu-guide__wisdom-label">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Always Do
          </span>
          <ul class="htu-guide__wisdom-list">
            {%- assign do_items = section.settings.do_list | newline_to_br | split: '<br />' -%}
            {%- for item in do_items -%}
              {%- if item != blank -%}<li>{{ item | strip }}</li>{%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
        <div class="htu-guide__wisdom-col htu-guide__wisdom-col--dont" data-htu-reveal>
          <span class="htu-guide__wisdom-label">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
            Never Do
          </span>
          <ul class="htu-guide__wisdom-list">
            {%- assign dont_items = section.settings.dont_list | newline_to_br | split: '<br />' -%}
            {%- for item in dont_items -%}
              {%- if item != blank -%}<li>{{ item | strip }}</li>{%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="htu-guide__cta">
    <div class="htu-guide__cta-card" data-htu-reveal>
      <div class="htu-guide__cta-content">
        <h3 class="htu-guide__cta-title">{{ section.settings.cta_title | default: 'Ready to Start?' }}</h3>
        <p class="htu-guide__cta-text">{{ section.settings.cta_text | default: 'Get the complete kit with every brush, solution, and protector you need — in one box.' }}</p>
      </div>
      <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="htu-guide__cta-btn">
        {{ section.settings.cta_label | default: 'Shop Care Kits' }}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</section>

<script src="{{ 'how-to-use-guide.js' | asset_url }}" defer="defer"></script>


{%- style -%}
  {% render 'section-typography-vars', section: section %}


  /* Scope styles under the .skincare-guide namespace to prevent bleed */
  .skincare-guide {
    font-family: var(--font-family-sans);
    color: var(--color-text-main);
    background-color: #ffffff;
    padding: 0;
    margin: 0;
    line-height: 1.5;
  }

  .skincare-guide h1,
  .skincare-guide h2,
  .skincare-guide h3,
  .skincare-guide h4,
  .skincare-guide h5,
  .skincare-guide h6 {
    font-family: var(--font-family-sans) !important;
    font-weight: 800;
    color: #111111;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
  }

  .skincare-guide p {
    margin: 0;
  }

  .skincare-guide-container {
    max-width: var(--site-max-width);
    margin: 0 auto;
    padding: 0 20px;
    width: 100%;
  }

  /* --- PART 1: HERO SECTION --- */
  .skincare-hero {
    padding: 80px 0;
    background-color: #ffffff;
  }
  .skincare-hero__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 40px;
    align-items: center;
  }
  @media screen and (max-width: 768px) {
    .skincare-hero {
      padding: 40px 0;
    }
    .skincare-hero__grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 30px;
    }
  }
  .skincare-hero__title {
    font-size: clamp(36px, 5vw, 54px);
    line-height: 1.1;
    margin-bottom: 24px;
    color: #111;
  }
  .skincare-hero__subtitle {
    max-width: 480px;
  }
  @media screen and (max-width: 768px) {
    .skincare-hero__subtitle {
      margin: 0 auto;
    }
  }
  .skincare-hero__image-wrapper {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
  }
  .skincare-hero__image-wrapper img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }

  /* --- PART 2: INTRO INFO --- */
  .skincare-intro {
    background-color: #f7f7f7;
    padding: 60px 0;
    text-align: center;
  }
  .skincare-intro__title {
    font-size: 22px;
    font-weight: 800;
    color: #111;
    margin-bottom: 16px;
  }
  .skincare-intro__text {
    font-size: 14px;
    color: #555555;
    line-height: 1.6;
    max-width: 750px;
    margin: 0 auto;
  }

  /* --- PART 3: ROUTINE EXPLANATION --- */
  .skincare-explanation {
    padding: 80px 0;
    background-color: #ffffff;
  }
  .skincare-explanation__grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 60px;
    align-items: center;
  }
  @media screen and (max-width: 768px) {
    .skincare-explanation {
      padding: 40px 0;
    }
    .skincare-explanation__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
  .skincare-explanation__image-card {
    background: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 24px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
  }
  .skincare-explanation__image-card img {
    width: 100%;
    height: auto;
    display: block;
  }
  .skincare-explanation__content {
    display: flex;
    flex-direction: column;
  }
  .skincare-explanation__title {
    font-size: 32px;
    font-weight: 800;
    color: #111;
    margin-bottom: 30px;
  }
  .skincare-explanation__step-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 30px;
  }
  .skincare-explanation__step-item {
    font-size: 14px;
    line-height: 1.6;
    color: #444;
  }
  .skincare-explanation__step-item strong {
    color: #111111;
    font-weight: 700;
  }
  .skincare-explanation__note {
    font-size: 13px;
    color: #2b6cb0;
    font-style: italic;
  }

  /* --- DIVIDER HEADING --- */
  .skincare-divider {
    display: flex;
    align-items: center;
    text-align: center;
    margin: 60px auto;
    max-width: var(--site-max-width);
    padding: 0 20px;
  }
  .skincare-divider::before,
  .skincare-divider::after {
    content: '';
    flex: 1;
    border-bottom: 1px solid #d8d8d8;
  }
  .skincare-divider:not(:empty)::before {
    margin-right: 24px;
  }
  .skincare-divider:not(:empty)::after {
    margin-left: 24px;
  }
  .skincare-divider__text {
    font-size: 18px;
    font-weight: 800;
    color: #111111;
    letter-spacing: 0.05em;
  }

  /* --- CONCERN HEADER & GRID --- */
  .skincare-concerns-section {
    padding-bottom: 40px;
  }
  .skincare-concerns__header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 40px;
  }
  .skincare-concerns__title {
    font-size: 24px;
    font-weight: 800;
    margin-bottom: 16px;
  }
  .skincare-concerns__subtitle {
    margin: 0;
  }
  .skincare-concerns__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 40px;
  }
  @media screen and (max-width: 768px) {
    .skincare-guide-container {
      padding: 0 var(--site-padding, 20px);
    }
    .skincare-intro {
      padding: 40px 0;
    }
    .skincare-explanation__title {
      font-size: clamp(1.375rem, 5vw, 1.75rem);
      margin-bottom: 20px;
    }
    .skincare-divider {
      margin: 40px auto;
    }
    .skincare-divider__text {
      font-size: 15px;
    }
    .skincare-concerns__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    .skincare-routine-switcher {
      flex-wrap: wrap;
      gap: 8px;
      padding: 0 4px;
    }
    .skincare-routine-switcher__btn {
      min-height: 44px;
      padding: 10px 20px;
    }
    .skincare-concern-card__title {
      font-size: 12px;
      padding: 0 8px;
    }
  }
  @media screen and (max-width: 480px) {
    .skincare-concerns__grid {
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
    .skincare-concern-card__title {
      font-size: 11px;
      margin-top: 10px;
    }
    .skincare-product-card {
      padding: 20px 16px;
    }
    .skincare-builder__btn {
      width: 100%;
      text-align: center;
    }
  }
  .skincare-concern-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding-bottom: 16px;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    text-align: center;
    position: relative;
  }
  .skincare-concern-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.03);
  }
  .skincare-concern-card.is-active {
    border: 2px solid #111111;
    box-shadow: 0 10px 25px rgba(0,0,0,0.08);
  }
  .skincare-concern-card__image-wrapper {
    width: 100%;
    aspect-ratio: 16 / 10;
    background: #f7fafc;
    overflow: hidden;
    position: relative;
  }
  .skincare-concern-card__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .skincare-concern-card:hover .skincare-concern-card__image-wrapper img {
    transform: scale(1.03);
  }
  .skincare-concern-card__title {
    font-size: 13px;
    font-weight: 700;
    color: #4a5568;
    margin-top: 14px;
    padding: 0 12px;
    transition: color 0.2s ease;
  }
  .skincare-concern-card.is-active .skincare-concern-card__title {
    color: #111111;
  }

  /* --- ESSENTIALS/ADVANCED SWITCHER --- */
  .skincare-routine-switcher {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-bottom: 40px;
  }
  .skincare-routine-switcher__btn {
    padding: 10px 26px;
    border-radius: 30px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    border: 1px solid #e2e8f0;
    background: #ffffff;
    color: #4a5568;
    transition: all 0.2s ease;
  }
  .skincare-routine-switcher__btn:hover {
    border-color: #cbd5e0;
  }
  .skincare-routine-switcher__btn.is-active {
    background: #111111;
    color: #ffffff;
    border-color: #111111;
  }

  /* --- RECOMMENDATION AREA --- */
  .skincare-recommendations {
    margin-bottom: 40px;
  }
  .skincare-recommendations__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  @media screen and (max-width: 768px) {
    .skincare-recommendations__grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }
  .skincare-product-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 24px;
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: all 0.25s ease;
  }
  .skincare-product-card:hover {
    box-shadow: 0 10px 30px rgba(0,0,0,0.03);
  }
  .skincare-product-card__badge {
    position: absolute;
    top: 20px;
    right: 20px;
    background: #111111;
    color: #ffffff;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    z-index: 2;
  }
  .skincare-product-card__step-label {
    font-size: 10px;
    font-weight: 800;
    color: #a0aec0;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .skincare-product-card__image-wrapper {
    width: 100%;
    aspect-ratio: 1 / 1;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f7fafc;
    border-radius: 6px;
    overflow: hidden;
  }
  .skincare-product-card__image-wrapper img {
    max-height: 80%;
    max-width: 80%;
    object-fit: contain;
    display: block;
    transition: transform 0.3s ease;
  }
  .skincare-product-card:hover .skincare-product-card__image-wrapper img {
    transform: scale(1.05);
  }
  .skincare-product-card__title {
    font-size: 14px;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 12px;
    text-align: center;
    flex-grow: 1;
  }
  .skincare-product-card__title a {
    color: #2b6cb0;
    transition: color 0.15s ease;
  }
  .skincare-product-card__title a:hover {
    color: #2c5282;
    text-decoration: underline;
  }
  .skincare-product-card__price {
    font-size: 15px;
    font-weight: 700;
    color: #1a202c;
    margin-bottom: 20px;
    text-align: center;
  }
  .skincare-product-card__btn {
    width: 100%;
    background: #111111;
    color: #ffffff;
    border: none;
    padding: 14px 20px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
    cursor: pointer;
    transition: background-color 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .skincare-product-card__btn:hover {
    background-color: #2d3748;
  }
  .skincare-product-card__btn[disabled] {
    background-color: #cbd5e0;
    color: #a0aec0;
    cursor: not-allowed;
  }

  .skincare-product-card__btn .spinner {
    display: none;
    width: 14px;
    height: 14px;
    border: 2px solid rgba(255,255,255,0.3);
    border-radius: 50%;
    border-top-color: #fff;
    animation: skincare-spin 0.8s linear infinite;
  }
  @keyframes skincare-spin {
    to { transform: rotate(360deg); }
  }

  /* --- YELLOW CTA SECTION --- */
  .skincare-yellow-cta {
    margin: 40px 0 60px;
  }
  .skincare-yellow-cta__btn {
    display: block;
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    padding: 18px 30px;
    border: none;
    text-align: center;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.2s ease;
  }
  .skincare-yellow-cta__btn:hover {
    transform: scale(1.015);
    opacity: 0.95;
  }
  @media screen and (max-width: 480px) {
    .skincare-yellow-cta__btn {
      padding: 16px 20px;
      font-size: 13px;
    }
  }

  /* --- ROUTINE BUILDER SECTION --- */
  .skincare-builder {
    padding: 80px 0;
    background-color: #ffffff;
  }
  .skincare-builder__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  @media screen and (max-width: 768px) {
    .skincare-builder {
      padding: 40px 0;
    }
    .skincare-builder__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
  .skincare-builder__image-wrapper {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
  }
  .skincare-builder__image-wrapper img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }
  .skincare-builder__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .skincare-builder__label {
    font-size: 12px;
    font-weight: 800;
    color: #a0aec0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
  }
  .skincare-builder__title {
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.15;
    font-weight: 800;
    color: #111111;
    margin-bottom: 20px;
  }
  .skincare-builder__text {
    font-size: 14px;
    color: #4a5568;
    line-height: 1.6;
    margin-bottom: 32px;
    max-width: 480px;
  }
  .skincare-builder__btn {
    display: inline-block;
    background-color: #111111;
    color: #ffffff;
    padding: 16px 36px;
    font-size: 13px;
    font-weight: 700;
    border-radius: 30px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }
  .skincare-builder__btn:hover {
    background-color: #2d3748;
    transform: translateY(-2px);
  }
{%- endstyle -%}

<div class="skincare-guide" id="shopify-section-{{ section.id }}">
  
  <!-- PART 1: HERO SECTION -->
  <section class="skincare-hero">
    <div class="skincare-guide-container">
      <div class="skincare-hero__grid">
        <div class="skincare-hero__content">
          {%- if section.settings.hero_title != blank -%}
            <h1 class="skincare-hero__title">{{ section.settings.hero_title }}</h1>
          {%- endif -%}
          {%- if section.settings.hero_text != blank -%}
            <p class="skincare-hero__subtitle">{{ section.settings.hero_text }}</p>
          {%- endif -%}
        </div>
        <div class="skincare-hero__image-wrapper">
          {%- if section.settings.hero_image != blank -%}
            <img src="{{ section.settings.hero_image | image_url: width: 1000 }}" alt="{{ section.settings.hero_title }}" loading="lazy" width="500" height="400">
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  <!-- PART 2: INTRO SECTION -->
  <section class="skincare-intro" style="background-color: {{ section.settings.intro_bg }};">
    <div class="skincare-guide-container">
      {%- if section.settings.intro_title != blank -%}
        <h2 class="skincare-intro__title">{{ section.settings.intro_title }}</h2>
      {%- endif -%}
      {%- if section.settings.intro_text != blank -%}
        <p class="skincare-intro__text">{{ section.settings.intro_text }}</p>
      {%- endif -%}
    </div>
  </section>

  <!-- PART 3: ROUTINE EXPLANATION -->
  <section class="skincare-explanation">
    <div class="skincare-guide-container">
      <div class="skincare-explanation__grid">
        <div class="skincare-explanation__image-card">
          {%- if section.settings.routine_image != blank -%}
            <img src="{{ section.settings.routine_image | image_url: width: 800 }}" alt="{{ section.settings.routine_title }}" loading="lazy" width="400" height="400">
          {%- else -%}
            <div style="background:#f4f4f4; aspect-ratio:1/1; display:flex; align-items:center; justify-content:center; border-radius:4px; border: 1px dashed #ccc;">
              <span style="font-size:12px; color:#777; font-weight:700;">Routine Steps Image Placeholder</span>
            </div>
          {%- endif -%}
        </div>
        <div class="skincare-explanation__content">
          {%- if section.settings.routine_title != blank -%}
            <h2 class="skincare-explanation__title">{{ section.settings.routine_title }}</h2>
          {%- endif -%}
          <div class="skincare-explanation__step-list">
            {%- if section.settings.step_1_title != blank -%}
              <p class="skincare-explanation__step-item">
                <strong>{{ section.settings.step_1_title }}:</strong> {{ section.settings.step_1_text }}
              </p>
            {%- endif -%}
            {%- if section.settings.step_2_title != blank -%}
              <p class="skincare-explanation__step-item">
                <strong>{{ section.settings.step_2_title }}:</strong> {{ section.settings.step_2_text }}
              </p>
            {%- endif -%}
            {%- if section.settings.step_3_title != blank -%}
              <p class="skincare-explanation__step-item">
                <strong>{{ section.settings.step_3_title }}:</strong> {{ section.settings.step_3_text }}
              </p>
            {%- endif -%}
          </div>
          {%- if section.settings.routine_note != blank -%}
            <p class="skincare-explanation__note">{{ section.settings.routine_note }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  <!-- PART 4: DIVIDER HEADING -->
  <div class="skincare-divider">
    <span class="skincare-divider__text">{{ section.settings.divider_1_text | default: "Find the Perfect Routine for Your Skin" }}</span>
  </div>

  <!-- PART 5 & 6: SKIN CONCERN SECTION & PRODUCT SHOWCASE -->
  <section class="skincare-concerns-section">
    <div class="skincare-guide-container">
      
      <div class="skincare-concerns__header">
        <h2 class="skincare-concerns__title">{{ section.settings.concern_heading | default: "Simply choose your skin concern" }}</h2>
        <p class="skincare-concerns__subtitle">{{ section.settings.concern_subheading }}</p>
      </div>

      <!-- Concern Cards Grid -->
      <div class="skincare-concerns__grid">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <div class="skincare-concern-card{% if forloop.first %} is-active{% endif %}" data-concern-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
              <div class="skincare-concern-card__image-wrapper">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title }}" loading="lazy" width="200" height="120">
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              <h3 class="skincare-concern-card__title">{{ block.settings.title }}</h3>
            </div>
          {%- endfor -%}
        {%- else -%}
          <!-- 8 Beautiful Hardcoded Static Fallback Concerns if no blocks created -->
          {%- assign fallback_concerns = "Fine Lines & Wrinkles,Acne & Breakouts,Dryness,Pores & Oil Control,Dullness & Uneven Tone,Redness & Sensitivity,Body Care,Daily Care" | split: "," -%}
          {%- for fb_title in fallback_concerns -%}
            <div class="skincare-concern-card{% if forloop.first %} is-active{% endif %}" data-concern-index="{{ forloop.index0 }}">
              <div class="skincare-concern-card__image-wrapper">
                <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:#edf2f7;">
                  <span style="font-size:10px; color:#a0aec0; font-weight:700;">No Image Picker</span>
                </div>
              </div>
              <h3 class="skincare-concern-card__title">{{ fb_title }}</h3>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <!-- Routine Type Toggle Tabs (Essentials / Advanced) -->
      <div class="skincare-routine-switcher">
        <button type="button" class="skincare-routine-switcher__btn is-active" data-routine-type="essential">Essentials</button>
        <button type="button" class="skincare-routine-switcher__btn" data-routine-type="advanced">Advanced</button>
      </div>

      <!-- Recommendations Products Grid Area -->
      <div class="skincare-recommendations">
        <div class="skincare-recommendations__grid" id="skincare-products-render-target">
          <!-- Dynamic products injected here by Javascript -->
        </div>
      </div>

      <!-- PART 7: YELLOW CTA SECTION -->
      <div class="skincare-yellow-cta">
        <a href="{{ section.settings.cta_url | default: '#' }}" class="skincare-yellow-cta__btn" style="background-color: {{ section.settings.cta_bg_color }}; color: {{ section.settings.cta_text_color }};">
          {{ section.settings.cta_text | default: "GET FULL ROUTINE NOW & SAVE 30%" }}
        </a>
      </div>

    </div>
  </section>

  <!-- PART 8: DIVIDER HEADING 2 -->
  <div class="skincare-divider">
    <span class="skincare-divider__text">{{ section.settings.divider_2_text | default: "Let's build R.T.P. Routine together!" }}</span>
  </div>

  <!-- PART 9: ROUTINE BUILDER SECTION -->

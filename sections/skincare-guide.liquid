<script>
  document.addEventListener('DOMContentLoaded', function() {
    var sectionId = "{{ section.id }}";
    var container = document.getElementById("shopify-section-" + sectionId);
    if (!container) return;

    var payloadScript = document.getElementById("skincare-guide-payload-" + sectionId);
    if (!payloadScript) return;

    var data;
    try {
      data = JSON.parse(payloadScript.textContent);
    } catch(e) {
      console.error("Failed to parse skincare guide payload", e);
      return;
    }

    var activeConcernIndex = 0;
    var activeRoutineType = "essential"; // "essential" or "advanced"

    var concernCards = container.querySelectorAll(".skincare-concern-card");
    var switcherBtns = container.querySelectorAll(".skincare-routine-switcher__btn");
    var productsTarget = container.getElementById("skincare-products-render-target");

    function renderProducts() {
      if (!productsTarget) return;
      productsTarget.innerHTML = "";

      var activeConcern = data.find(function(item) {
        return item.index === activeConcernIndex;
      });

      if (!activeConcern) return;

      var products = activeRoutineType === "essential" ? activeConcern.essential : activeConcern.advanced;

      products.forEach(function(prod) {
        var card = document.createElement("div");
        card.className = "skincare-product-card";

        if (!prod.exists) {
          // Empty state placeholder
          card.innerHTML = `
            <div class="skincare-product-card__badge">${prod.step}</div>
            <div class="skincare-product-card__step-label">${prod.label}</div>
            <div class="skincare-product-card__image-wrapper">
              <div style="color:#a0aec0; font-size:11px; text-align:center; padding:10px;">Select Product in Editor</div>
            </div>
            <h4 class="skincare-product-card__title">Product Not Selected</h4>
            <div class="skincare-product-card__price">-</div>
            <button class="skincare-product-card__btn" disabled>Add to Cart</button>
          `;
        } else {
          var formattedPrice = prod.price;
          var buttonHtml = '';
          if (prod.variant_id) {
            buttonHtml = `
              <button class="skincare-product-card__btn js-skincare-add-to-cart" data-variant-id="${prod.variant_id}">
                <span class="spinner"></span>
                <span class="btn-text">Add to Cart</span>
              </button>
            `;
          } else {
            // Static URL redirect if variant is empty (fallback mock products)
            buttonHtml = `
              <button class="skincare-product-card__btn js-skincare-redirect" data-url="${prod.url}">
                <span class="btn-text">View Product</span>
              </button>
            `;
          }

          card.innerHTML = `
            <div class="skincare-product-card__badge">${prod.step}</div>
            <div class="skincare-product-card__step-label">${prod.label}</div>
            <div class="skincare-product-card__image-wrapper">
              <img src="${prod.image}" alt="${prod.title}" loading="lazy">
            </div>
            <h4 class="skincare-product-card__title">
              <a href="${prod.url}">${prod.title}</a>
            </h4>
            <div class="skincare-product-card__price">${formattedPrice}</div>
            ${buttonHtml}
          `;
        }

        productsTarget.appendChild(card);
      });

      bindCartEvents();
    }

    function bindCartEvents() {
      var cartButtons = container.querySelectorAll(".js-skincare-add-to-cart");
      cartButtons.forEach(function(btn) {
        btn.addEventListener("click", function(e) {
          e.preventDefault();
          var variantId = btn.getAttribute("data-variant-id");
          if (!variantId) return;

          var spinner = btn.querySelector(".spinner");
          var btnText = btn.querySelector(".btn-text");

          if (spinner) spinner.style.display = "inline-block";
          if (btnText) btnText.style.display = "none";
          btn.setAttribute("disabled", "true");

          // AJAX Shopify Cart Add API
          fetch(window.Shopify.routes.root + 'cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              items: [
                {
                  id: parseInt(variantId),
                  quantity: 1
                }
              ]
            })
          })
          .then(function(res) {
            return res.json();
          })
          .then(function(cartData) {
            // Try to trigger drawer update if there's standard theme scripts
            document.dispatchEvent(new CustomEvent('cart:updated', { bubbles: true, detail: cartData }));
            
            // Redirect to cart page to show product successfully added
            window.location.href = '/cart';
          })
          .catch(function(err) {
            console.error("AJAX Cart addition error:", err);
            window.location.href = '/cart/add?id=' + variantId + '&quantity=1';
          });
        });
      });

      var redirectButtons = container.querySelectorAll(".js-skincare-redirect");
      redirectButtons.forEach(function(btn) {
        btn.addEventListener("click", function() {
          var url = btn.getAttribute("data-url");
          if (url) window.location.href = url;
        });
      });
    }

    // Concern Card Click Handlers
    concernCards.forEach(function(card) {
      card.addEventListener("click", function() {
        concernCards.forEach(function(c) { c.classList.remove("is-active"); });
        card.classList.add("is-active");
        activeConcernIndex = parseInt(card.getAttribute("data-concern-index"));
        renderProducts();
      });
    });

    // Routine Toggle Tab Click Handlers
    switcherBtns.forEach(function(btn) {
      btn.addEventListener("click", function() {
        switcherBtns.forEach(function(b) { b.classList.remove("is-active"); });
        btn.classList.add("is-active");
        activeRoutineType = btn.getAttribute("data-routine-type");
        renderProducts();
      });
    });

    // Initial Render
    renderProducts();
  });
</script>


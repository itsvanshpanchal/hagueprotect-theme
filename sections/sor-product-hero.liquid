<script>
(function(){
  var sid = '{{ section.id }}';

  /* Ã¢â€â‚¬Ã¢â€â‚¬ Gallery Ã¢â€â‚¬Ã¢â€â‚¬ */
  var galleryIdx = 0;
  var totalImages = {{ product.images.size }};

  function sorSetGalleryImg(idx) {
    if (totalImages === 0) return;
    galleryIdx = ((idx % totalImages) + totalImages) % totalImages;
    for (var i = 0; i < totalImages; i++) {
      var el = document.getElementById('sor-main-' + sid + '-' + i);
      if (el) el.style.display = (i === galleryIdx) ? 'block' : 'none';
    }
    var thumbs = document.querySelectorAll('#sor-gallery-' + sid + ' .sor-gallery__thumb');
    thumbs.forEach(function(t, ti) { t.classList.toggle('active', ti === galleryIdx); });
  }

  window.sorGalleryNav = function(s, dir) { if (s === sid) sorSetGalleryImg(galleryIdx + dir); };
  window.sorGallerySet = function(s, idx) { if (s === sid) sorSetGalleryImg(idx); };

  /* Ã¢â€â‚¬Ã¢â€â‚¬ Quantity Ã¢â€â‚¬Ã¢â€â‚¬ */
  var qty = 1;
  window.sorQty = function(s, delta) {
    if (s !== sid) return;
    qty = Math.max(1, qty + delta);
    var numEl = document.getElementById('sor-qty-num-' + sid);
    var inpEl = document.getElementById('sor-qty-input-' + sid);
    if (numEl) numEl.textContent = qty;
    if (inpEl) inpEl.value = qty;
  };

  /* Ã¢â€â‚¬Ã¢â€â‚¬ Variant Ã¢â€â‚¬Ã¢â€â‚¬ */
  window.sorSelectVariant = function(s, card) {
    if (s !== sid) return;
    var cards = document.querySelectorAll('#sor-variant-picker-' + sid + ' .sor-variant-card');
    cards.forEach(function(c) { c.classList.remove('active'); });
    card.classList.add('active');

    var vid = card.getAttribute('data-variant-id');
    var price = card.getAttribute('data-variant-price');
    var avail = card.getAttribute('data-variant-available') === 'true';

    var hidInp = document.getElementById('sor-variant-id-' + sid);
    if (hidInp) hidInp.value = vid;

    var priceEl = document.querySelector('#sor-pricing-' + sid + ' .sor-price-current');
    if (priceEl) priceEl.textContent = price;

    var stickyPrice = document.getElementById('sor-sticky-price-' + sid);
    if (stickyPrice) stickyPrice.textContent = price;

    var btn = document.getElementById('sor-atc-btn-' + sid);
    if (btn) { btn.disabled = !avail; btn.style.opacity = avail ? '1' : '0.5'; }
  };

  /* Ã¢â€â‚¬Ã¢â€â‚¬ Accordion Ã¢â€â‚¬Ã¢â€â‚¬ */
  window.sorAccordion = function(btn) {
    var item = btn.closest('.sor-accordion-item');
    var isOpen = item.classList.contains('open');
    var allItems = btn.closest('.sor-accordions').querySelectorAll('.sor-accordion-item');
    allItems.forEach(function(it) { it.classList.remove('open'); });
    if (!isOpen) item.classList.add('open');
  };

  /* Ã¢â€â‚¬Ã¢â€â‚¬ Sticky bar Ã¢â€â‚¬Ã¢â€â‚¬ */
  var atcBtn = document.getElementById('sor-atc-btn-' + sid);
  var stickyBar = document.getElementById('sor-sticky-' + sid);

  if (atcBtn && stickyBar) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        stickyBar.classList.toggle('visible', !e.isIntersecting);
      });
    }, { threshold: 0 });
    io.observe(atcBtn);
  }

})();
</script>


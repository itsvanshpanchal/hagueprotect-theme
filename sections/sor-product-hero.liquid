{%- style -%}
  {% render 'section-typography-vars', section: section %}


/* ============================================================
   SCIENCE OF RAW Ã¢â‚¬â€ Product Detail Page
   Palette: Deep navy / clinical clean (#27355f, #f6f8fc)
   ============================================================ */

:root {
  --sor-primary:     #1a2440;
  --sor-accent:      #27355f;
  --sor-accent-lt:   #4a5fa0;
  --sor-highlight:   #3d7dd4;
  --sor-bg:          #f6f8fc;
  --sor-bg-card:     #ffffff;
  --sor-surface:     #edf0f8;
  --sor-border:      #d0d8ea;
  --sor-text:        #1e2a46;
  --sor-muted:       #5a6b88;
  --sor-green:       #1a7a4a;
  --sor-red:         #c62828;
  --sor-font:        var(--font-family-sans);
  --sor-radius-sm:   8px;
  --sor-radius-md:   12px;
  --sor-radius-lg:   16px;
  --sor-radius-xl:   20px;
  --sor-radius-pill: 100px;
}

.sor-pdp-wrap {
  background: var(--sor-bg);
  font-family: var(--sor-font);
  -webkit-font-smoothing: antialiased;
}

/* Ã¢â€â‚¬Ã¢â€â‚¬ TOP BRAND STRIP Ã¢â€â‚¬Ã¢â€â‚¬ */
.sor-brand-strip {
  background: var(--sor-accent);
  padding: 10px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.sor-brand-strip__logo {
  height: 28px;
  width: auto;
  object-fit: contain;
  filter: brightness(0) invert(1);
}

.sor-brand-strip__badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(255,255,255,0.12);
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  padding: 5px 14px;
  border-radius: var(--sor-radius-pill);
  border: 1px solid rgba(255,255,255,0.22);
}

/* Ã¢â€â‚¬Ã¢â€â‚¬ SCIENCE TICKER Ã¢â€â‚¬Ã¢â€â‚¬ */
.sor-ticker {
  background: var(--sor-bg-card);
  border-bottom: 1px solid var(--sor-border);
  padding: 8px 24px;
  display: flex;
  align-items: center;
  gap: 32px;
  overflow: hidden;
}

.sor-ticker__item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--sor-accent);
  white-space: nowrap;
}

/* Ã¢â€â‚¬Ã¢â€â‚¬ MAIN GRID Ã¢â€â‚¬Ã¢â€â‚¬ */
.sor-pdp-grid {
  display: grid;
  grid-template-columns: 55% 1fr;
  gap: 40px;
  max-width: var(--site-max-width);
  margin: 0 auto;
  padding: 32px 24px 64px;
  box-sizing: border-box;
}

@media (max-width: 991px) {
  .sor-pdp-grid {
    grid-template-columns: 1fr;
    gap: 28px;
    padding: 20px 16px 80px;
  }
}

/* Ã¢â€â‚¬Ã¢â€â‚¬ GALLERY Ã¢â€â‚¬Ã¢â€â‚¬ */
.sor-gallery {
  display: flex;
  flex-direction: column;
  gap: 12px;
  position: sticky;
  top: 80px;
  align-self: start;
}

@media (max-width: 991px) { .sor-gallery { position: static; } }

.sor-gallery__main {
  background: var(--sor-bg-card);
  border-radius: var(--sor-radius-xl);
  border: 1px solid var(--sor-border);
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
  box-shadow: 0 4px 24px rgba(27,36,64,0.07);
}

.sor-gallery__main-img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  padding: 24px;
  transition: transform 0.4s ease;
}

.sor-gallery__main:hover .sor-gallery__main-img {
  transform: scale(1.05);
}

/* lab-certified corner badge */
.sor-gallery__cert {
  position: absolute;
  top: 16px;
  right: 16px;
  background: var(--sor-highlight);
  color: #fff;
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 5px 10px;
  border-radius: var(--sor-radius-pill);
  display: flex;
  align-items: center;
  gap: 4px;
}

.sor-gallery__badge-overlay {
  position: absolute;
  top: 16px;
  left: 16px;
  background: var(--sor-accent);
  color: #fff;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  padding: 5px 12px;
  border-radius: var(--sor-radius-pill);
}

.sor-gallery__nav-btn {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 36px;
  height: 36px;
  background: rgba(255,255,255,0.92);
  border: 1px solid var(--sor-border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s, box-shadow 0.2s;
  z-index: 2;
}

.sor-gallery__nav-btn:hover { background: #fff; box-shadow: 0 2px 10px rgba(27,36,64,0.12); }
.sor-gallery__nav-btn--prev { left: 12px; }
.sor-gallery__nav-btn--next { right: 12px; }

.sor-gallery__thumbs {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  scrollbar-width: none;
  padding-bottom: 4px;
}
.sor-gallery__thumbs::-webkit-scrollbar { display: none; }

.sor-gallery__thumb {
  flex: 0 0 72px;
  height: 72px;
  border-radius: var(--sor-radius-md);
  background: var(--sor-surface);
  border: 2px solid transparent;
  overflow: hidden;
  cursor: pointer;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.sor-gallery__thumb.active,
.sor-gallery__thumb:hover {
  border-color: var(--sor-highlight);
  box-shadow: 0 0 0 3px rgba(61,125,212,0.18);
}

.sor-gallery__thumb img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 4px;
}

/* Ã¢â€â‚¬Ã¢â€â‚¬ PRODUCT INFO PANEL Ã¢â€â‚¬Ã¢â€â‚¬ */
.sor-info { display: flex; flex-direction: column; gap: 20px; }

/* brand + rating row */
.sor-info__brand-row {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.sor-brand-tag {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--sor-surface);
  border: 1px solid var(--sor-border);
  color: var(--sor-accent);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 5px 12px;
  border-radius: var(--sor-radius-pill);
}

.sor-lab-tag {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: #e8f0fe;
  color: var(--sor-highlight);
  font-size: 11px;
  font-weight: 700;
  padding: 5px 11px;
  border-radius: var(--sor-radius-pill);
}

.sor-rating-pill {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: #e8f5e9;
  color: var(--sor-green);
  font-size: 12px;
  font-weight: 700;
  padding: 5px 11px;
  border-radius: var(--sor-radius-pill);
}

/* title */
.sor-info__title {
  font-size: clamp(22px, 3.8vw, 34px);
  font-weight: 800;
  letter-spacing: -0.03em;
  color: var(--sor-primary);
  line-height: 1.15;
  margin: 0;
}

/* formula line */
.sor-formula-line {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: linear-gradient(90deg, #f0f4ff 0%, #e8f0fe 100%);
  border: 1px solid var(--sor-border);
  border-radius: var(--sor-radius-md);
  padding: 10px 16px;
  font-size: 13px;
  font-weight: 600;
  color: var(--sor-accent);
}

/* subtitle */
.sor-info__subtitle {
  font-size: 15px;
  color: var(--sor-muted);
  line-height: 1.65;
  margin: 0;
}

/* key facts grid */
.sor-facts-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}

.sor-fact-card {
  background: var(--sor-bg-card);
  border: 1px solid var(--sor-border);
  border-radius: var(--sor-radius-md);
  padding: 12px;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.sor-fact-card__value {
  font-size: 18px;
  font-weight: 800;
  color: var(--sor-highlight);
}

.sor-fact-card__label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--sor-muted);
}

/* benefit pills */
.sor-benefits { display: flex; flex-direction: column; gap: 8px; }

.sor-benefit-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  font-weight: 500;
  color: var(--sor-text);
}

.sor-benefit-dot {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--sor-accent) 0%, var(--sor-accent-lt) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* divider */
.sor-divider {
  border: none;
  border-top: 1px solid var(--sor-border);
  margin: 0;
}

/* variant picker */
.sor-variant-label {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--sor-muted);
  margin-bottom: 8px;
}

.sor-variant-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
  gap: 8px;
}

.sor-variant-card {
  border: 1px solid var(--sor-border);
  border-radius: var(--sor-radius-md);
  padding: 10px 12px;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 10px;
  transition: all 0.2s ease;
  background: var(--sor-bg-card);
  user-select: none;
}

.sor-variant-card:hover {
  border-color: var(--sor-accent-lt);
  background: var(--sor-surface);
}

.sor-variant-card.active {
  border: 2px solid var(--sor-highlight);
  background: rgba(61,125,212,0.05);
}

.sor-variant-card__img {
  width: 40px;
  height: 40px;
  border-radius: 6px;
  background: var(--sor-surface);
  object-fit: contain;
  flex-shrink: 0;
}

.sor-variant-card__name {
  font-size: 13px;
  font-weight: 600;
  color: var(--sor-primary);
  line-height: 1.2;
}

.sor-variant-card__price {
  font-size: 12px;
  color: var(--sor-muted);
}

/* pricing block */
.sor-pricing {
  display: flex;
  align-items: baseline;
  gap: 10px;
  flex-wrap: wrap;
}

.sor-price-current {
  font-size: clamp(26px, 4vw, 34px);
  font-weight: 800;
  color: var(--sor-primary);
  letter-spacing: -0.02em;
}

.sor-price-compare {
  font-size: 18px;
  color: var(--sor-muted);
  text-decoration: line-through;
}

.sor-price-save {
  background: #e3f2fd;
  color: #0d47a1;
  font-size: 12px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: var(--sor-radius-pill);
}

/* qty + ATC */
.sor-cart-row {
  display: flex;
  gap: 12px;
  align-items: stretch;
}

.sor-qty {
  display: flex;
  align-items: center;
  border: 1px solid var(--sor-border);
  border-radius: var(--sor-radius-md);
  overflow: hidden;
  height: 52px;
  background: var(--sor-bg-card);
}

.sor-qty__btn {
  width: 44px;
  height: 100%;
  border: none;
  background: none;
  font-size: 18px;
  color: var(--sor-primary);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s;
}
.sor-qty__btn:hover { background: var(--sor-surface); }

.sor-qty__num {
  flex: 1;
  text-align: center;
  font-size: 15px;
  font-weight: 700;
  color: var(--sor-primary);
  min-width: 36px;
}

.sor-atc-btn {
  flex: 1;
  height: 52px;
  background: linear-gradient(135deg, var(--sor-accent) 0%, #1a2d5a 100%);
  color: #fff;
  font-family: var(--sor-font);
  font-size: 15px;
  font-weight: 700;
  letter-spacing: 0.03em;
  border: none;
  border-radius: var(--sor-radius-md);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: filter 0.2s ease, transform 0.2s ease;
  position: relative;
  overflow: hidden;
}

.sor-atc-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.12) 0%, transparent 60%);
  pointer-events: none;
}

.sor-atc-btn:hover {
  filter: brightness(1.1);
  transform: translateY(-1px);
}

.sor-atc-btn:active { transform: translateY(0); }

.sor-buy-now-wrapper {
  margin-top: -8px;
}

.sor-buy-now-wrapper .shopify-payment-button__button {
  border-radius: var(--sor-radius-md) !important;
  font-family: var(--sor-font) !important;
  height: 52px !important;
  font-weight: 700 !important;
}

/* stock indicator */
.sor-stock {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 600;
  color: var(--sor-green);
}

.sor-stock__dot {
  width: 8px;
  height: 8px;
  background: var(--sor-green);
  border-radius: 50%;
  animation: sorPulse 2s infinite;
}

@keyframes sorPulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(26,122,74,0.4); }
  50% { opacity: 0.8; box-shadow: 0 0 0 5px rgba(26,122,74,0); }
}

/* trust badges */
.sor-trust-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  padding: 16px 0;
  border-top: 1px solid var(--sor-border);
  border-bottom: 1px solid var(--sor-border);
}

@media (max-width: 600px) {
  .sor-trust-row { grid-template-columns: repeat(2, 1fr); gap: 12px; }
}

.sor-trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 6px;
}

.sor-trust-icon {
  width: 28px;
  height: 28px;
  color: var(--sor-highlight);
}

.sor-trust-text {
  font-size: 11px;
  font-weight: 700;
  color: var(--sor-text);
  line-height: 1.3;
  text-transform: uppercase;
  letter-spacing: 0.03em;
}

/* accordions */
.sor-accordions { display: flex; flex-direction: column; }

.sor-accordion-item { border-bottom: 1px solid var(--sor-border); }

.sor-accordion-toggle {
  width: 100%;
  background: none;
  border: none;
  padding: 16px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-family: var(--sor-font);
  font-size: 14px;
  font-weight: 700;
  color: var(--sor-primary);
  cursor: pointer;
  text-align: left;
  transition: color 0.15s;
}

.sor-accordion-toggle:hover { color: var(--sor-highlight); }

.sor-accordion-icon {
  transition: transform 0.3s ease;
  flex-shrink: 0;
  color: var(--sor-highlight);
}

.sor-accordion-item.open .sor-accordion-icon {
  transform: rotate(45deg);
}

.sor-accordion-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.35s cubic-bezier(0, 1, 0, 1);
  font-size: 14px;
  color: var(--sor-muted);
  line-height: 1.7;
}

.sor-accordion-item.open .sor-accordion-body {
  max-height: 600px;
  transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.sor-accordion-body-inner { padding-bottom: 16px; }

/* Ã¢â€â‚¬Ã¢â€â‚¬ SCIENCE CREDENTIAL BAR Ã¢â€â‚¬Ã¢â€â‚¬ */
.sor-science-bar {
  background: linear-gradient(135deg, var(--sor-primary) 0%, var(--sor-accent) 100%);
  padding: 20px 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32px;
  flex-wrap: wrap;
}

.sor-science-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  color: #fff;
}

.sor-science-stat__num {
  font-size: 22px;
  font-weight: 800;
  color: #fff;
  letter-spacing: -0.02em;
}

.sor-science-stat__label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.65);
}

.sor-science-stat__sep {
  width: 1px;
  height: 40px;
  background: rgba(255,255,255,0.2);
}

/* Ã¢â€â‚¬Ã¢â€â‚¬ FLOATING STICKY BAR Ã¢â€â‚¬Ã¢â€â‚¬ */
.sor-sticky-bar {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%) translateY(120px);
  width: calc(100% - 48px);
  max-width: 640px;
  background: var(--sor-primary);
  border-radius: var(--sor-radius-xl);
  box-shadow: 0 12px 40px rgba(26,36,64,0.32);
  z-index: 999;
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s;
  opacity: 0;
  box-sizing: border-box;
  pointer-events: none;
}

.sor-sticky-bar.visible {
  transform: translateX(-50%) translateY(0);
  opacity: 1;
  pointer-events: auto;
}

.sor-sticky-bar__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px;
  gap: 16px;
}

.sor-sticky-bar__title {
  font-size: 14px;
  font-weight: 700;
  color: #fff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  min-width: 0;
}

.sor-sticky-bar__price {
  font-size: 16px;
  font-weight: 800;
  color: #93b4e8;
  white-space: nowrap;
}

.sor-sticky-bar__btn {
  background: var(--sor-highlight);
  color: #fff;
  font-family: var(--sor-font);
  font-size: 13px;
  font-weight: 700;
  padding: 10px 20px;
  border-radius: var(--sor-radius-pill);
  border: none;
  cursor: pointer;
  white-space: nowrap;
  transition: filter 0.2s;
}

.sor-sticky-bar__btn:hover { filter: brightness(1.1); }

@media (max-width: 767px) {
  .sor-sticky-bar {
    bottom: 12px;
    left: 12px;
    right: 12px;
    width: auto;
    transform: translateY(120px);
  }
  .sor-sticky-bar.visible { transform: translateY(0); }
  .sor-facts-grid { grid-template-columns: 1fr 1fr; }
}
{%- endstyle -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_title = product.title
  assign product_desc = section.settings.subtitle_text | default: product.description
  assign brand_text = section.settings.brand_text | default: 'SCIENCE OF RAW'
  assign rating_value = section.settings.rating_value | default: '4.8'
  assign rating_count = section.settings.rating_reviews | default: '94'
  assign formula_line = section.settings.formula_line | default: 'Lab-Verified Formula Ã¢â‚¬â€ Batch Tested for Purity'
  assign badge_text = section.settings.badge_text | default: 'CLINICALLY TESTED'
  assign pill_1 = section.settings.pill_1_text | default: 'Raw & unprocessed actives'
  assign pill_2 = section.settings.pill_2_text | default: 'Zero synthetic fillers'
  assign pill_3 = section.settings.pill_3_text | default: 'Batch-tested for purity'
  assign pill_4 = section.settings.pill_4_text | default: 'Sustainably sourced'
  assign pill_5 = section.settings.pill_5_text | default: 'pH-balanced formulation'
  assign stat_1_val = section.settings.stat_1_value | default: '97%'
  assign stat_1_lbl = section.settings.stat_1_label | default: 'Efficacy Rate'
  assign stat_2_val = section.settings.stat_2_value | default: '100%'
  assign stat_2_lbl = section.settings.stat_2_label | default: 'Raw Ingredients'
  assign stat_3_val = section.settings.stat_3_value | default: '0'
  assign stat_3_lbl = section.settings.stat_3_label | default: 'Synthetic Fillers'
-%}

<div class="sor-pdp-wrap" id="sor-pdp-{{ section.id }}">

  {%- comment -%} BRAND STRIP {%- endcomment -%}
  <div class="sor-brand-strip">
    <img
      src="{{ 'logo-science-of-raw.svg' | asset_url }}"
      alt="Science of Raw"
      class="sor-brand-strip__logo"
      width="180" height="28"
    >
    <span class="sor-brand-strip__badge">
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M3 1h4l1 4H2L3 1z" stroke="currentColor" stroke-width="1.2"/><path d="M2 5l1 4h4l1-4" stroke="currentColor" stroke-width="1.2"/></svg>
      Precision Skincare Science
    </span>
  </div>

  {%- comment -%} TICKER BAR {%- endcomment -%}
  <div class="sor-ticker">
    <div class="sor-ticker__item">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><path d="M6 0L7.4 4.4H12L8.3 7.1 9.7 11.5 6 8.8 2.3 11.5 3.7 7.1 0 4.4H4.6z"/></svg>
      Lab Certified
    </div>
    <div class="sor-ticker__item">

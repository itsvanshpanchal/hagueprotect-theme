{%- style -%}
  .faq-custom {
    background-color: #F8F9FA;
    padding: clamp(60px, 8vw, 100px) 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  }

  .faq-custom__container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  .faq-custom__header {
    text-align: center;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 8px;
  }

  .faq-custom__heading {
    font-size: clamp(18px, 3.5vw, 22px);
    font-weight: 600;
    color: #E02020;
    margin: 0;
    padding-bottom: 6px;
    position: relative;
    letter-spacing: -0.01em;
    text-transform: capitalize;
  }

  .faq-custom__heading::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 25%;
    right: 25%;
    height: 3px;
    background-color: #E02020;
    border-radius: 2px;
  }

  .faq-custom__items {
    background: #ffffff;
    border-radius: 16px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    width: 100%;
    padding: 16px 40px;
    box-sizing: border-box;
  }

  @media screen and (max-width: 768px) {
    .faq-custom__items {
      padding: 12px 20px;
    }
  }

  .faq-custom__item {
    border-bottom: 1px solid #f0f0f0;
    overflow: hidden;
  }

  .faq-custom__item:last-child {
    border-bottom: none;
  }

  .faq-custom__trigger {
    width: 100%;
    background: none;
    border: none;
    padding: 24px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    text-align: left;
    color: #000000;
    outline: none;
  }

  .faq-custom__question {
    font-size: clamp(15px, 1.8vw, 17px);
    font-weight: 600;
    color: #111111;
    margin: 0;
    line-height: 1.4;
    padding-right: 20px;
    letter-spacing: -0.01em;
  }

  .faq-custom__icon-wrapper {
    width: 26px;
    height: 26px;
    background-color: #000000;
    color: #ffffff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.3s ease, background-color 0.3s ease;
  }

  .faq-custom__icon-wrapper span {
    font-size: 16px;
    font-weight: 600;
    line-height: 1;
    transform: translateY(-1px);
    transition: transform 0.3s ease;
  }

  .faq-custom__item.active .faq-custom__icon-wrapper {
    background-color: #000000;
    transform: rotate(45deg);
  }

  .faq-custom__panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-custom__item.active .faq-custom__panel {
    max-height: 400px;
  }

  .faq-custom__answer {
    padding-bottom: 24px;
    font-size: clamp(14px, 1.6vw, 15px);
    color: #4A4A4A;
    line-height: 1.6;
    margin: 0;
  }
{%- endstyle -%}

<div class="faq-custom">
  <div class="faq-custom__container">
    <div class="faq-custom__header">
      <h2 class="faq-custom__heading">{{ section.settings.heading | default: 'Product' }}</h2>
    </div>

    <div class="faq-custom__items">
      {%- for block in section.blocks -%}
        <div class="faq-custom__item" {{ block.shopify_attributes }}>
          <button type="button" class="faq-custom__trigger" onclick="toggleFaqCustomItem(this)">
            <h3 class="faq-custom__question">{{ block.settings.question }}</h3>
            <div class="faq-custom__icon-wrapper">
              <span>&#43;</span>
            </div>
          </button>
          <div class="faq-custom__panel">
            <p class="faq-custom__answer">{{ block.settings.answer }}</p>
          </div>
        </div>
      {%- else -%}
        <!-- Fallbacks for theme editor default preview -->
        {%- assign default_questions = "What makes Hague Protect safe for premium sneakers?|Does the formula alter the color or texture of my shoes?|Is the invisible barrier durable against liquids and stains?|How many times can I clean my shoes with one complete kit?|Are the cleaning brushes safe to use on delicate suede?" | split: "|" -%}
        {%- assign default_answers = "Our solution is 100% pH-balanced, completely non-toxic, and safe for all premium materials including suede, nubuck, mesh, leather, and canvas.|No, our premium sneaker care solutions are formulated to clean, protect, and restore original vibrance without fading, bleeding, or drying out materials.|Yes! It creates a highly durable, nano-tech invisible barrier that repels water, mud, dirt, and stains for up to 4 weeks.|One complete Hague Protect kit allows more than 65 full cleaning and protective applications for your sneakers.|Yes! Use our Premium Soft-Hog Brush gently for delicate materials like suede and premium mesh to clean effectively without causing fraying." | split: "|" -%}
        
        {%- for q in default_questions -%}
          <div class="faq-custom__item">
            <button type="button" class="faq-custom__trigger" onclick="toggleFaqCustomItem(this)">
              <h3 class="faq-custom__question">{{ q }}</h3>
              <div class="faq-custom__icon-wrapper">
                <span>&#43;</span>
              </div>
            </button>
            <div class="faq-custom__panel">
              <p class="faq-custom__answer">{{ default_answers[forloop.index0] }}</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  function toggleFaqCustomItem(btn) {
    const item = btn.parentElement;
    const isActive = item.classList.contains('active');
    
    const items = item.parentElement.querySelectorAll('.faq-custom__item');
    items.forEach(i => i.classList.remove('active'));
    
    if (!isActive) {
      item.classList.add('active');
    }
  }
</script>

{% schema %}
{
  "name": "FAQ Accordion",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What makes Hague Protect safe for premium sneakers?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Our solution is 100% pH-balanced, completely non-toxic, and safe for all premium materials including suede, nubuck, mesh, leather, and canvas."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Accordion",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "What makes Hague Protect safe for premium sneakers?",
            "answer": "Our solution is 100% pH-balanced, completely non-toxic, and safe for all premium materials including suede, nubuck, mesh, leather, and canvas."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Does the formula alter the color or texture of my shoes?",
            "answer": "No, our premium sneaker care solutions are formulated to clean, protect, and restore original vibrance without fading, bleeding, or drying out materials."
          }
        }
      ]
    }
  ]
}
{% endschema %}

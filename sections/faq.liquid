{%- liquid
  assign layout_style = section.settings.layout_style | default: 'compact'
  assign is_page_layout = false
  if layout_style == 'page' or section.settings.page_title != blank
    assign is_page_layout = true
  endif
-%}

{%- style -%}
  {% render 'section-typography-vars', section: section %}

  #shopify-section-{{ section.id }} .faq-custom {
    background-color: {{ section.settings.bg_color | default: '#F8F9FA' }};
    padding: {% if is_page_layout %}clamp(72px, 10vw, 110px){% else %}clamp(60px, 8vw, 100px){% endif %} 0;
    font-family: var(--font-family-sans);
  }

  #shopify-section-{{ section.id }} .faq-custom__container {
    max-width: {% if is_page_layout %}900px{% else %}var(--site-max-width){% endif %};
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  #shopify-section-{{ section.id }} .faq-custom__header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    margin-bottom: 8px;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .faq-custom__eyebrow {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: {{ section.settings.accent_color | default: '#2563eb' }};
    margin: 0;
  }

  #shopify-section-{{ section.id }} .faq-custom__page-title {
    font-family: var(--font-family-sans) !important;
    font-size: clamp(32px, 5vw, 42px) !important;
    font-weight: 800 !important;
    color: #111111 !important;
    margin: 0;
    line-height: 1.1 !important;
    letter-spacing: -0.03em !important;
    text-transform: none !important;
  }

  #shopify-section-{{ section.id }} .faq-custom__page-description {
    font-size: 16px;
    color: #666666;
    line-height: 1.6;
    margin: 0;
    max-width: 640px;
  }

  #shopify-section-{{ section.id }} .faq-custom__heading {
    font-family: var(--font-family-sans) !important;
    font-size: clamp(16px, 2.5vw, 18px) !important;
    font-weight: 600 !important;
    color: {{ section.settings.accent_color | default: '#E02020' }} !important;
    margin: 0;
    padding-bottom: 6px;
    position: relative;
    letter-spacing: -0.01em !important;
    line-height: 1.3 !important;
    text-transform: capitalize !important;
  }

  #shopify-section-{{ section.id }} .faq-custom__heading::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 25%;
    right: 25%;
    height: 3px;
    background-color: {{ section.settings.accent_color | default: '#E02020' }};
    border-radius: 2px;
  }

  #shopify-section-{{ section.id }} .faq-custom__items {
    background: #ffffff;
    border-radius: 16px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    width: 100%;
    padding: 16px 40px;
    box-sizing: border-box;
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .faq-custom__items {
      padding: 12px 20px;
    }
  }

  #shopify-section-{{ section.id }} .faq-custom__item {
    border-bottom: 1px solid #f0f0f0;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .faq-custom__item:last-child {
    border-bottom: none;
  }

  #shopify-section-{{ section.id }} .faq-custom__trigger {
    width: 100%;
    background: none;
    border: none;
    padding: 24px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    text-align: left;
    color: #000000;
    outline: none;
  }

  #shopify-section-{{ section.id }} .faq-custom__question {
    font-family: var(--font-family-sans) !important;
    font-size: clamp(14px, 1.6vw, 17px) !important;
    font-weight: 600 !important;
    color: #111111 !important;
    margin: 0;
    line-height: 1.4 !important;
    padding-right: 20px;
    letter-spacing: -0.01em !important;
    text-transform: none !important;
  }

  #shopify-section-{{ section.id }} .faq-custom__icon-wrapper {
    width: 26px;
    height: 26px;
    background-color: #000000;
    color: #ffffff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.3s ease, background-color 0.3s ease;
  }

  #shopify-section-{{ section.id }} .faq-custom__icon-wrapper span {
    font-size: 16px;
    font-weight: 600;
    line-height: 1;
    transform: translateY(-1px);
    transition: transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .faq-custom__item.active .faq-custom__icon-wrapper {
    background-color: #000000;
    transform: rotate(45deg);
  }

  #shopify-section-{{ section.id }} .faq-custom__panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #shopify-section-{{ section.id }} .faq-custom__answer {
    padding-bottom: 24px;
    font-size: clamp(14px, 1.6vw, 15px);
    color: #4A4A4A;
    line-height: 1.6;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .faq-custom__answer p {
    margin: 0 0 12px;
  }

  #shopify-section-{{ section.id }} .faq-custom__answer p:last-child {
    margin-bottom: 0;
  }
{%- endstyle -%}

<div class="faq-custom" data-no-typewriter data-faq-section="{{ section.id }}">
  <div class="faq-custom__container">
    <div class="faq-custom__header">
      {%- if is_page_layout -%}
        {%- if section.settings.eyebrow != blank -%}
          <p class="faq-custom__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.page_title != blank -%}
          <h1 class="faq-custom__page-title">{{ section.settings.page_title }}</h1>
        {%- endif -%}
        {%- if section.settings.page_description != blank -%}
          <p class="faq-custom__page-description">{{ section.settings.page_description }}</p>
        {%- endif -%}
      {%- elsif section.settings.heading != blank -%}
        <h2 class="faq-custom__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="faq-custom__items">
      {%- for block in section.blocks -%}
        <div class="faq-custom__item" {{ block.shopify_attributes }}>
          <button type="button" class="faq-custom__trigger" data-faq-trigger aria-expanded="false">
            <h3 class="faq-custom__question">{{ block.settings.question }}</h3>
            <div class="faq-custom__icon-wrapper" aria-hidden="true">
              <span>+</span>
            </div>
          </button>
          <div class="faq-custom__panel" data-faq-panel hidden>
            <div class="faq-custom__answer">{{ block.settings.answer }}</div>
          </div>
        </div>
      {%- else -%}
        <div class="faq-custom__item">
          <button type="button" class="faq-custom__trigger" data-faq-trigger aria-expanded="false">
            <h3 class="faq-custom__question">Add FAQ items in the theme editor</h3>
            <div class="faq-custom__icon-wrapper" aria-hidden="true">
              <span>+</span>
            </div>
          </button>
          <div class="faq-custom__panel" data-faq-panel hidden>
            <div class="faq-custom__answer">Click Add block and choose FAQ Item to add questions and answers.</div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  (function () {
    const root = document.querySelector('[data-faq-section="{{ section.id }}"]');
    if (!root) return;

    root.querySelectorAll('[data-faq-trigger]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const item = btn.closest('.faq-custom__item');
        const panel = item.querySelector('[data-faq-panel]');
        const isActive = item.classList.contains('active');

        root.querySelectorAll('.faq-custom__item').forEach(function (entry) {
          entry.classList.remove('active');
          const entryPanel = entry.querySelector('[data-faq-panel]');
          const entryBtn = entry.querySelector('[data-faq-trigger]');
          if (entryPanel) {
            entryPanel.style.maxHeight = '0px';
            entryPanel.hidden = true;
          }
          if (entryBtn) entryBtn.setAttribute('aria-expanded', 'false');
        });

        if (!isActive && panel) {
          item.classList.add('active');
          panel.hidden = false;
          panel.style.maxHeight = panel.scrollHeight + 'px';
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  })();
</script>


{% doc %}
  @prompt
    so make a story banner in smae line but three and it should be scroll side by side  so make that section , i want a baaner size each banner   banner size  1440x560 px, so insted of slider put 3 dots so it look amazing 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign mobile_section_pad = block.settings.section_padding | times: 0.5 %}
{% if mobile_section_pad < 16 %}
  {% assign mobile_section_pad = 16 %}
{% endif %}
{% assign mobile_border_radius = block.settings.border_radius %}
{% if mobile_border_radius > 10 %}
  {% assign mobile_border_radius = 10 %}
{% endif %}

{% style %}
  .ai-story-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-story-banner-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-story-banner-scroll-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
  }

  .ai-story-banner-scroll-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-story-banner-stories-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.story_gap }}px;
    padding-bottom: 10px;
  }

  .ai-story-banner-story-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: 1440px;
    height: 560px;
    position: relative;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .ai-story-banner-story-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-story-banner-story-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e8e8e8 0%, #d0d0d0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-story-banner-story-placeholder-{{ ai_gen_id }} svg {
    width: 48px;
    height: 48px;
    opacity: 0.35;
    flex-shrink: 0;
  }

  .ai-story-banner-story-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 40px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.75) 0%, rgba(0, 0, 0, 0.35) 55%, transparent 100%);
    color: {{ block.settings.text_color }};
    pointer-events: none;
  }

  .ai-story-banner-story-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    margin: 0 0 10px 0;
    line-height: 1.2;
  }

  .ai-story-banner-story-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    margin: 0;
    line-height: 1.4;
    opacity: 0.9;
  }

  .ai-story-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    padding: 10px 16px;
    background-color: rgba(255, 255, 255, 0.92);
    border-radius: 6px;
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
    max-width: 85%;
    line-height: 1.4;
    z-index: 1;
  }

  .ai-story-banner-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    margin-top: 24px;
  }

  .ai-story-banner-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    min-width: {{ block.settings.dot_size }}px;
    min-height: {{ block.settings.dot_size }}px;
    flex: 0 0 auto;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: opacity 0.3s ease, transform 0.3s ease, background-color 0.3s ease;
    padding: 0;
    opacity: 0.4;
  }

  .ai-story-banner-dot-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-story-banner-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    opacity: 1;
    transform: scale(1.2);
  }

  @media screen and (max-width: 1440px) {
    .ai-story-banner-story-{{ ai_gen_id }} {
      width: min(100%, 900px);
      height: auto;
      aspect-ratio: 1440 / 560;
    }
  }

  @media screen and (max-width: 991px) {
    .ai-story-banner-container-{{ ai_gen_id }} {
      padding: 0 var(--site-padding, 20px);
    }

    .ai-story-banner-scroll-wrapper-{{ ai_gen_id }} {
      scroll-snap-type: x mandatory;
      scroll-padding-inline: 0;
    }

    .ai-story-banner-story-{{ ai_gen_id }} {
      width: 100%;
      flex: 0 0 100%;
      max-width: 100%;
      scroll-snap-align: center;
      scroll-snap-stop: always;
      aspect-ratio: 16 / 9;
      min-height: 200px;
      max-height: 320px;
    }

    .ai-story-banner-stories-{{ ai_gen_id }} {
      gap: 12px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-story-banner-{{ ai_gen_id }} {
      padding: {{ mobile_section_pad }}px 0;
      overflow: hidden;
    }

    .ai-story-banner-container-{{ ai_gen_id }} {
      padding: 0 var(--site-padding, 16px);
    }

    .ai-story-banner-scroll-wrapper-{{ ai_gen_id }} {
      margin: 0 -4px;
      scroll-snap-type: x mandatory;
    }

    .ai-story-banner-story-{{ ai_gen_id }} {
      flex: 0 0 calc(100% - 8px);
      width: calc(100% - 8px);
      aspect-ratio: 5 / 3;
      min-height: 180px;
      max-height: 220px;
      border-radius: {{ mobile_border_radius }}px;
    }

    .ai-story-banner-story-{{ ai_gen_id }}:hover {
      transform: none;
    }

    .ai-story-banner-story-overlay-{{ ai_gen_id }} {
      padding: 16px 14px;
    }

    .ai-story-banner-story-title-{{ ai_gen_id }} {
      font-size: clamp(18px, 5vw, {{ block.settings.title_size | times: 0.75 | round }}px);
      margin-bottom: 6px;
    }

    .ai-story-banner-story-description-{{ ai_gen_id }} {
      font-size: clamp(13px, 3.5vw, {{ block.settings.description_size | times: 0.85 | round }}px);
    }

    .ai-story-banner-empty-state-{{ ai_gen_id }} {
      font-size: 11px;
      padding: 8px 12px;
    }

    .ai-story-banner-dots-{{ ai_gen_id }} {
      margin-top: 16px;
      gap: 10px;
    }

    .ai-story-banner-dot-{{ ai_gen_id }}.active {
      transform: scale(1.15);
    }
  }

  @media (hover: hover) {
    .ai-story-banner-story-{{ ai_gen_id }}:hover {
      transform: scale(1.02);
    }
  }
{% endstyle %}

{% liquid
  assign show_block = true
  assign assigned_product = block.settings.assigned_product

  if product != blank
    if assigned_product == blank
      assign show_block = false
    elsif assigned_product.handle != product.handle
      assign show_block = false
    endif
  elsif assigned_product != blank
    assign show_block = false
  endif

  if request.design_mode and assigned_product == blank
    assign show_block = true
  endif
%}

{% if show_block %}
<story-banner-{{ ai_gen_id }} class="ai-story-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-story-banner-container-{{ ai_gen_id }}">
    <div class="ai-story-banner-scroll-wrapper-{{ ai_gen_id }}">
      <div class="ai-story-banner-stories-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% liquid
            assign image_key = 'story_' | append: i | append: '_image'
            assign title_key = 'story_' | append: i | append: '_title'
            assign description_key = 'story_' | append: i | append: '_description'
            assign link_key = 'story_' | append: i | append: '_link'
            assign story_image = block.settings[image_key]
            assign story_title = block.settings[title_key]
            assign story_description = block.settings[description_key]
            assign story_link = block.settings[link_key]

            if product != blank
              if i == 1
                if product.metafields.custom.story_1_image != blank
                  assign story_image = product.metafields.custom.story_1_image
                endif
                if product.metafields.custom.story_1_title != blank
                  assign story_title = product.metafields.custom.story_1_title
                endif
                if product.metafields.custom.story_1_description != blank
                  assign story_description = product.metafields.custom.story_1_description
                endif
              elsif i == 2
                if product.metafields.custom.story_2_image != blank
                  assign story_image = product.metafields.custom.story_2_image
                endif
                if product.metafields.custom.story_2_title != blank
                  assign story_title = product.metafields.custom.story_2_title
                endif
                if product.metafields.custom.story_2_description != blank
                  assign story_description = product.metafields.custom.story_2_description
                endif
              elsif i == 3
                if product.metafields.custom.story_3_image != blank
                  assign story_image = product.metafields.custom.story_3_image
                endif
                if product.metafields.custom.story_3_title != blank
                  assign story_title = product.metafields.custom.story_3_title
                endif
                if product.metafields.custom.story_3_description != blank
                  assign story_description = product.metafields.custom.story_3_description
                endif
              endif
            endif
          %}

          <a
            href="{% if story_link != blank %}{{ story_link }}{% else %}#{% endif %}"
            class="ai-story-banner-story-{{ ai_gen_id }}"
            data-story-index="{{ i | minus: 1 }}"
            {% if story_link == blank %}onclick="return false;"{% endif %}
          >
            {% if story_image %}
              <img
                src="{{ story_image | image_url: width: 1440 }}"
                srcset="{{ story_image | image_url: width: 800 }} 800w, {{ story_image | image_url: width: 1200 }} 1200w, {{ story_image | image_url: width: 1440 }} 1440w"
                sizes="(max-width: 749px) 100vw, (max-width: 1440px) 90vw, 1440px"
                alt="{{ story_image.alt | escape }}"
                class="ai-story-banner-story-image-{{ ai_gen_id }}"
                loading="lazy"
                width="1440"
                height="560"
              >
            {% else %}
              <div class="ai-story-banner-story-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
                {% if story_title == blank and story_description == blank %}
                  <div class="ai-story-banner-empty-state-{{ ai_gen_id }}">
                    Add story {{ i }} image (1440×560px)
                  </div>
                {% endif %}
              </div>
            {% endif %}

            {% if story_title != blank or story_description != blank %}
              <div class="ai-story-banner-story-overlay-{{ ai_gen_id }}">
                {% if story_title != blank %}
                  <h3 class="ai-story-banner-story-title-{{ ai_gen_id }}">{{ story_title }}</h3>
                {% endif %}
                {% if story_description != blank %}
                  <p class="ai-story-banner-story-description-{{ ai_gen_id }}">{{ story_description }}</p>
                {% endif %}
              </div>
            {% endif %}
          </a>
        {% endfor %}
      </div>
    </div>

    <div class="ai-story-banner-dots-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        <button
          class="ai-story-banner-dot-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}"
          data-dot-index="{{ i | minus: 1 }}"
          aria-label="Go to story {{ i }}"
        ></button>
      {% endfor %}
    </div>
  </div>
</story-banner-{{ ai_gen_id }}>
{% endif %}

{% if show_block %}
<script>
  (function() {
    class StoryBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
      }

      connectedCallback() {
        this.scrollWrapper = this.querySelector('.ai-story-banner-scroll-wrapper-{{ ai_gen_id }}');
        this.stories = this.querySelectorAll('.ai-story-banner-story-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-story-banner-dot-{{ ai_gen_id }}');
        
        this.setupDotNavigation();
        this.setupScrollTracking();
        this.setupWheelScroll();
      }

      setupDotNavigation() {
        this.dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            const index = parseInt(dot.getAttribute('data-dot-index'));
            this.scrollToStory(index);
          });
        });
      }

      setupScrollTracking() {
        if (!this.scrollWrapper) return;

        this.scrollWrapper.addEventListener('scroll', () => {
          this.updateActiveDot();
        });
      }

      setupWheelScroll() {
        if (!this.scrollWrapper) return;

        this.scrollWrapper.addEventListener('wheel', (e) => {
          if (e.deltaY !== 0) {
            e.preventDefault();
            this.scrollWrapper.scrollLeft += e.deltaY;
          }
        });
      }

      scrollToStory(index) {
        if (!this.stories[index]) return;

        const story = this.stories[index];
        const scrollLeft = story.offsetLeft - this.scrollWrapper.offsetLeft;
        
        this.scrollWrapper.scrollTo({
          left: scrollLeft,
          behavior: 'smooth'
        });

        this.currentIndex = index;
        this.updateActiveDot();
      }

      updateActiveDot() {
        const scrollLeft = this.scrollWrapper.scrollLeft;
        const storyWidth = this.stories[0].offsetWidth;
        const gap = parseInt(getComputedStyle(this.stories[0].parentElement).gap) || 0;
        const index = Math.round(scrollLeft / (storyWidth + gap));

        this.dots.forEach((dot, i) => {
          if (i === index) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('story-banner-{{ ai_gen_id }}', StoryBanner{{ ai_gen_id }});
  })();
</script>
{% endif %}


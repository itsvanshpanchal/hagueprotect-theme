{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-accordion-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-accordion-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-accordion-item-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    overflow: hidden;
    border: 1px solid {{ block.settings.border_color }};
    box-shadow: {{ block.settings.shadow_horizontal }}px {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_spread }}px {{ block.settings.shadow_color }};
    transition: box-shadow 0.3s ease;
  }

  .ai-accordion-item-{{ ai_gen_id }}:hover {
    box-shadow: {{ block.settings.shadow_horizontal | times: 1.5 }}px {{ block.settings.shadow_vertical | times: 1.5 }}px {{ block.settings.shadow_blur | times: 1.5 }}px {{ block.settings.shadow_spread }}px {{ block.settings.shadow_color }};
  }

  .ai-accordion-header-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.item_padding }}px;
    background-color: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background-color 0.3s ease;
  }

  .ai-accordion-header-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.hover_color }};
  }

  .ai-accordion-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    color: {{ block.settings.heading_color }};
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-accordion-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: {{ block.settings.icon_color }};
  }

  .ai-accordion-icon-{{ ai_gen_id }}.active {
    transform: rotate(180deg);
  }

  .ai-accordion-content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .ai-accordion-content-{{ ai_gen_id }}.active {
    max-height: 1000px;
  }

  .ai-accordion-content-inner-{{ ai_gen_id }} {
    padding: 0 {{ block.settings.item_padding }}px {{ block.settings.item_padding }}px;
    color: {{ block.settings.content_color }};
    font-size: {{ block.settings.content_size }}px;
    line-height: 1.6;
  }

  .ai-accordion-content-inner-{{ ai_gen_id }} ul {
    margin: 0;
    padding-left: 20px;
    list-style-type: disc;
  }

  .ai-accordion-content-inner-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  .ai-accordion-content-inner-{{ ai_gen_id }} li:last-child {
    margin-bottom: 0;
  }

  .ai-accordion-content-inner-{{ ai_gen_id }} p {
    margin: 0 0 12px;
  }

  .ai-accordion-content-inner-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-accordion-section-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<accordion-section-{{ ai_gen_id }} class="ai-accordion-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-accordion-container-{{ ai_gen_id }}">
    {% if block.settings.show_item_1 %}
      <div class="ai-accordion-item-{{ ai_gen_id }}" data-accordion-item>
        <button class="ai-accordion-header-{{ ai_gen_id }}" aria-expanded="false">
          <h3 class="ai-accordion-title-{{ ai_gen_id }}">{{ block.settings.heading_1 }}</h3>
          <svg class="ai-accordion-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div class="ai-accordion-content-{{ ai_gen_id }}">
          <div class="ai-accordion-content-inner-{{ ai_gen_id }}">
            {{ block.settings.content_1 }}
          </div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_item_2 %}
      <div class="ai-accordion-item-{{ ai_gen_id }}" data-accordion-item>
        <button class="ai-accordion-header-{{ ai_gen_id }}" aria-expanded="false">
          <h3 class="ai-accordion-title-{{ ai_gen_id }}">{{ block.settings.heading_2 }}</h3>
          <svg class="ai-accordion-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div class="ai-accordion-content-{{ ai_gen_id }}">
          <div class="ai-accordion-content-inner-{{ ai_gen_id }}">
            {{ block.settings.content_2 }}
          </div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_item_3 %}
      <div class="ai-accordion-item-{{ ai_gen_id }}" data-accordion-item>
        <button class="ai-accordion-header-{{ ai_gen_id }}" aria-expanded="false">
          <h3 class="ai-accordion-title-{{ ai_gen_id }}">{{ block.settings.heading_3 }}</h3>
          <svg class="ai-accordion-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div class="ai-accordion-content-{{ ai_gen_id }}">
          <div class="ai-accordion-content-inner-{{ ai_gen_id }}">
            {{ block.settings.content_3 }}
          </div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_item_4 %}
      <div class="ai-accordion-item-{{ ai_gen_id }}" data-accordion-item>
        <button class="ai-accordion-header-{{ ai_gen_id }}" aria-expanded="false">
          <h3 class="ai-accordion-title-{{ ai_gen_id }}">{{ block.settings.heading_4 }}</h3>
          <svg class="ai-accordion-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div class="ai-accordion-content-{{ ai_gen_id }}">
          <div class="ai-accordion-content-inner-{{ ai_gen_id }}">
            {{ block.settings.content_4 }}
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</accordion-section-{{ ai_gen_id }}>

<script>
  (function() {
    class AccordionSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.accordionItems = this.querySelectorAll('[data-accordion-item]');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.accordionItems.forEach((item) => {
          const header = item.querySelector('.ai-accordion-header-{{ ai_gen_id }}');
          const content = item.querySelector('.ai-accordion-content-{{ ai_gen_id }}');
          const icon = item.querySelector('.ai-accordion-icon-{{ ai_gen_id }}');

          header.addEventListener('click', () => {
            const isActive = content.classList.contains('active');

            if (isActive) {
              content.classList.remove('active');
              icon.classList.remove('active');
              header.setAttribute('aria-expanded', 'false');
            } else {
              content.classList.add('active');
              icon.classList.add('active');
              header.setAttribute('aria-expanded', 'true');
            }
          });
        });
      }
    }

    customElements.define('accordion-section-{{ ai_gen_id }}', AccordionSection{{ ai_gen_id }});
  })();
</script>


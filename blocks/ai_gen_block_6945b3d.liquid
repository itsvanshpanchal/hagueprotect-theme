{% doc %}
  @prompt
    so i want to add a section in whicn i want to add a banner only 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
  }

  .ai-banner-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.banner_height }}px;
  }

  .ai-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-banner-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-banner-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
  }

  .ai-banner-content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: {{ block.settings.text_color }};
    width: 90%;
    max-width: 800px;
  }

  .ai-banner-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px;
    font-weight: 700;
  }

  .ai-banner-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0;
  }

  /* 🔥 Glassmorphism Button */
  .ai-banner-button-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    padding: 14px 32px;

    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);

    border: 1.5px solid rgba(255, 255, 255, 0.4);
    border-radius: 50px;

    color: #ffffff;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;

    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);

    transition: all 0.3s ease;
  }

  .ai-banner-button-{{ ai_gen_id }}:hover {
    background: rgba(255, 255, 255, 0.25);
    border: 1.5px solid rgba(255, 255, 255, 0.6);
    transform: translateX(-50%) scale(1.05);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
  }

  @media screen and (max-width: 749px) {
    .ai-banner-{{ ai_gen_id }} {
      width: 100% !important;
    }

    .ai-banner-wrapper-{{ ai_gen_id }} {
      height: auto;
      min-height: 320px;
    }

    .ai-banner-heading-{{ ai_gen_id }} {
      font-size: clamp(24px, 6vw, 36px);
    }

    .ai-banner-subheading-{{ ai_gen_id }} {
      font-size: clamp(14px, 4vw, 18px);
    }
  }
{% endstyle %}

<div class="ai-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-banner-wrapper-{{ ai_gen_id }}">
    
    {% if block.settings.banner_image %}
      <img
        src="{{ block.settings.banner_image | image_url: width: 1200 }}"
        alt="{{ block.settings.banner_image.alt | default: block.settings.heading | default: shop.name | escape }}"
        loading="lazy"
        width="{{ block.settings.banner_image.width }}"
        height="{{ block.settings.banner_image.height }}"
        class="ai-banner-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-banner-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-banner-empty-state-{{ ai_gen_id }}">
          Add a banner image to get started
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_overlay %}
      <div class="ai-banner-overlay-{{ ai_gen_id }}"></div>
    {% endif %}

    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-banner-content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-banner-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-banner-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <!-- 🔥 Glass Button -->
    <a href="{{ block.settings.button_link }}" class="ai-banner-button-{{ ai_gen_id }}">
      {{ block.settings.button_text }}
    </a>

  </div>
</div>

{% schema %}
{
  "name": "Banner",
  "settings": [
    { "type": "header", "content": "Image" },
    { "type": "image_picker", "id": "banner_image", "label": "Banner image" },
    {
      "type": "range",
      "id": "banner_height",
      "label": "Banner height",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 400
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },

    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Welcome to our store" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Discover amazing products" },

    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },

    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },

    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },

    { "type": "header", "content": "Overlay" },
    { "type": "checkbox", "id": "show_overlay", "label": "Show overlay", "default": true },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#000000" },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    }
  ],
  "presets": [{ "name": "Banner" }]
}
{% endschema %}
{% doc %}
  @prompt
    genrate a review section add some review also make a button to add reveiw buy customer and show the review also  that other customer has make and make it asthethic
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reviews-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-reviews-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-reviews-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 50px;
  }

  .ai-reviews-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 15px;
    font-weight: 700;
  }

  .ai-reviews-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-reviews-stats-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 20px;
    flex-wrap: wrap;
  }

  .ai-reviews-rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .ai-reviews-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
  }

  .ai-reviews-star-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    fill: {{ block.settings.star_color }};
  }

  .ai-reviews-star-empty-{{ ai_gen_id }} {
    fill: {{ block.settings.star_empty_color }};
  }

  .ai-reviews-rating-text-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
  }

  .ai-reviews-count-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.subtitle_color }};
  }

  .ai-reviews-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 30px;
    margin-bottom: 40px;
  }

  .ai-review-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 30px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-review-card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
  }

  .ai-review-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 15px;
  }

  .ai-review-author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-review-avatar-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, {{ block.settings.avatar_gradient_1 }}, {{ block.settings.avatar_gradient_2 }});
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    font-weight: 600;
    font-size: 18px;
    flex-shrink: 0;
  }

  .ai-review-author-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .ai-review-author-name-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: 16px;
    color: {{ block.settings.title_color }};
    margin: 0;
  }

  .ai-review-date-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.subtitle_color }};
  }

  .ai-review-stars-small-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-review-star-small-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    fill: {{ block.settings.star_color }};
  }

  .ai-review-content-{{ ai_gen_id }} {
    font-size: 15px;
    line-height: 1.6;
    color: {{ block.settings.review_text_color }};
    margin: 0;
  }

  .ai-review-verified-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-top: 12px;
    font-size: 13px;
    color: {{ block.settings.verified_color }};
  }

  .ai-review-verified-icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    fill: {{ block.settings.verified_color }};
  }

  .ai-reviews-cta-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 40px;
  }

  .ai-reviews-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 40px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .ai-reviews-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    transform: scale(1.05);
  }

  .ai-reviews-modal-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.6);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .ai-reviews-modal-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-reviews-modal-content-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 40px;
    max-width: 600px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
  }

  .ai-reviews-modal-close-{{ ai_gen_id }} {
    position: absolute;
    top: 15px;
    right: 15px;
    background: none;
    border: none;
    font-size: 28px;
    cursor: pointer;
    color: {{ block.settings.subtitle_color }};
    padding: 5px;
    line-height: 1;
  }

  .ai-reviews-modal-close-{{ ai_gen_id }}:hover {
    color: {{ block.settings.title_color }};
  }

  .ai-reviews-form-title-{{ ai_gen_id }} {
    font-size: 28px;
    color: {{ block.settings.title_color }};
    margin: 0 0 25px;
    font-weight: 700;
  }

  .ai-reviews-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-reviews-form-group-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-reviews-form-label-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: 14px;
    color: {{ block.settings.title_color }};
  }

  .ai-reviews-form-input-{{ ai_gen_id }},
  .ai-reviews-form-textarea-{{ ai_gen_id }} {
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 15px;
    font-family: inherit;
    color: {{ block.settings.title_color }};
    background-color: {{ block.settings.card_background }};
  }

  .ai-reviews-form-textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-reviews-form-input-{{ ai_gen_id }}:focus,
  .ai-reviews-form-textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.button_background }};
  }

  .ai-reviews-rating-input-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-reviews-rating-star-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .ai-reviews-rating-star-{{ ai_gen_id }} svg {
    width: 32px;
    height: 32px;
    fill: {{ block.settings.star_empty_color }};
    transition: fill 0.2s ease;
  }

  .ai-reviews-rating-star-{{ ai_gen_id }}.selected svg,
  .ai-reviews-rating-star-{{ ai_gen_id }}:hover svg {
    fill: {{ block.settings.star_color }};
  }

  .ai-reviews-form-submit-{{ ai_gen_id }} {
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-reviews-form-submit-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-reviews-success-message-{{ ai_gen_id }} {
    display: none;
    padding: 15px;
    background-color: #d4edda;
    color: #155724;
    border-radius: 8px;
    margin-bottom: 20px;
  }

  .ai-reviews-success-message-{{ ai_gen_id }}.active {
    display: block;
  }

  @media screen and (max-width: 768px) {
    .ai-reviews-section-{{ ai_gen_id }} {
      padding: 40px 15px;
    }

    .ai-reviews-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .ai-reviews-modal-content-{{ ai_gen_id }} {
      padding: 30px 20px;
    }

    .ai-reviews-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }
  }
{% endstyle %}

<customer-reviews-{{ ai_gen_id }} class="ai-reviews-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-reviews-container-{{ ai_gen_id }}">
    <div class="ai-reviews-header-{{ ai_gen_id }}">
      <h2 class="ai-reviews-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
      <p class="ai-reviews-subtitle-{{ ai_gen_id }}">{{ block.settings.section_subtitle }}</p>
      
      <div class="ai-reviews-stats-{{ ai_gen_id }}">
        <div class="ai-reviews-rating-{{ ai_gen_id }}">
          <div class="ai-reviews-stars-{{ ai_gen_id }}">
            {% for i in (1..5) %}
              <svg class="ai-reviews-star-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">

          <input 
            type="text" 
            id="review-name-{{ ai_gen_id }}" 
            class="ai-reviews-form-input-{{ ai_gen_id }}" 
            required
            data-name-input
          >
        </div>

        <div class="ai-reviews-form-group-{{ ai_gen_id }}">
          <label class="ai-reviews-form-label-{{ ai_gen_id }}" for="review-email-{{ ai_gen_id }}">Your Email</label>
          <input 
            type="email" 
            id="review-email-{{ ai_gen_id }}" 
            class="ai-reviews-form-input-{{ ai_gen_id }}" 
            required
            data-email-input
          >
        </div>


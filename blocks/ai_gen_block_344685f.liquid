              </svg>
            {% endfor %}
          </div>
          <span class="ai-reviews-rating-text-{{ ai_gen_id }}">5.0</span>
        </div>
        <span class="ai-reviews-count-{{ ai_gen_id }}">Based on {{ block.settings.review_count }} reviews</span>
      </div>
    </div>

    <div class="ai-reviews-grid-{{ ai_gen_id }}">
      {% if block.settings.review_1_name != blank %}
        <div class="ai-review-card-{{ ai_gen_id }}">
          <div class="ai-review-header-{{ ai_gen_id }}">
            <div class="ai-review-author-{{ ai_gen_id }}">
              <div class="ai-review-avatar-{{ ai_gen_id }}">
                {{ block.settings.review_1_name | slice: 0 }}
              </div>
              <div class="ai-review-author-info-{{ ai_gen_id }}">
                <p class="ai-review-author-name-{{ ai_gen_id }}">{{ block.settings.review_1_name }}</p>
                <span class="ai-review-date-{{ ai_gen_id }}">{{ block.settings.review_1_date }}</span>
              </div>
            </div>
            <div class="ai-review-stars-small-{{ ai_gen_id }}">
              {% for i in (1..block.settings.review_1_rating) %}
                <svg class="ai-review-star-small-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              {% endfor %}
            </div>
          </div>
          <p class="ai-review-content-{{ ai_gen_id }}">{{ block.settings.review_1_text }}</p>
          {% if block.settings.review_1_verified %}
            <div class="ai-review-verified-{{ ai_gen_id }}">
              <svg class="ai-review-verified-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>

{% doc %}
  @prompt
    so now create a story banner section in which we can use text and please dont use black shadow effect, generate a story banner and the text should be left side, not the image should uplode in full size in and  please move text little down and little left , make the text little left side, also add image upload for  mobile view
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-story-banner-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-story-banner-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    background-color: {{ block.settings.background_color }};
  }

  .ai-story-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    opacity: {{ block.settings.image_opacity }};
  }

  .ai-story-banner-mobile-image-{{ ai_gen_id }} {
    display: none;
  }

  .ai-story-banner-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 500px;
  }

  .ai-story-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-story-banner-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
  }

  .ai-story-banner-content-{{ ai_gen_id }} {
    position: absolute;
    z-index: 2;
    max-width: {{ block.settings.content_max_width }}px;
    padding: {{ block.settings.content_padding }}px;
    text-align: left;
    left: {{ block.settings.content_offset_left }}px;
    top: {{ block.settings.content_offset_top }}px;
  }

  .ai-story-banner-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    line-height: 1.2;
    font-weight: 700;
  }

  .ai-story-banner-subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    line-height: 1.4;
  }

  .ai-story-banner-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  .ai-story-banner-button-wrapper-{{ ai_gen_id }} {
    margin-top: {{ block.settings.button_spacing }}px;
  }

  .ai-story-banner-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    transition: background-color 0.3s ease, color 0.3s ease;
    font-weight: 600;
  }

  .ai-story-banner-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-story-banner-image-{{ ai_gen_id }} {
      display: none;
    }

    .ai-story-banner-mobile-image-{{ ai_gen_id }} {
      display: block;
      width: 100%;
      height: auto;
      opacity: {{ block.settings.image_opacity }};
    }

    .ai-story-banner-content-{{ ai_gen_id }} {
      padding: 16px;
      left: 16px;
      top: 35%;
      transform: translateY(-35%);
      max-width: calc(100% - 32px);
      box-sizing: border-box;
    }

    .ai-story-banner-heading-{{ ai_gen_id }} {
      font-size: clamp(15px, 4.5vw, 20px);
      margin-bottom: 8px;
    }

    .ai-story-banner-subheading-{{ ai_gen_id }} {
      font-size: clamp(13px, 3.5vw, 15px);
      margin-bottom: 8px;
    }

    .ai-story-banner-text-{{ ai_gen_id }} {
      font-size: clamp(11px, 3vw, 13px);
    }

    .ai-story-banner-button-wrapper-{{ ai_gen_id }} {
      margin-top: 12px;
    }

    .ai-story-banner-button-{{ ai_gen_id }} {
      padding: 8px 16px;
      font-size: 13px;
    }
  }
{% endstyle %}

<div class="ai-story-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-story-banner-wrapper-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2400 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
        class="ai-story-banner-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-story-banner-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}

    {% if block.settings.mobile_image %}
      <img
        src="{{ block.settings.mobile_image | image_url: width: 1200 }}"
        alt="{{ block.settings.mobile_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.mobile_image.width }}"
        height="{{ block.settings.mobile_image.height }}"
        class="ai-story-banner-mobile-image-{{ ai_gen_id }}"
      >
    {% elsif block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 1200 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
        class="ai-story-banner-mobile-image-{{ ai_gen_id }}"
      >
    {% endif %}

    {% if block.settings.show_overlay %}
      <div class="ai-story-banner-overlay-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="ai-story-banner-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-story-banner-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <div class="ai-story-banner-subheading-{{ ai_gen_id }}">
          {{ block.settings.subheading }}
        </div>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-story-banner-text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
        <div class="ai-story-banner-button-wrapper-{{ ai_gen_id }}">
          <a
            href="{{ block.settings.button_link }}"
            class="ai-story-banner-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}

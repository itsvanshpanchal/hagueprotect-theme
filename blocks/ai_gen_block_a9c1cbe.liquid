{% doc %}
  Story banner with editable overlay text + per-block typography.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{%- liquid
  assign heading_family = block.settings.heading_font_family | default: 'bebas_neue'
  assign subheading_family = block.settings.subheading_font_family | default: 'inter'
  assign text_family = block.settings.text_font_family | default: 'inter'
  assign button_family = block.settings.button_font_family | default: 'inter'

  assign heading_weight = block.settings.heading_font_weight | default: '400'
  assign subheading_weight = block.settings.subheading_font_weight | default: '700'
  assign text_weight = block.settings.text_font_weight | default: '400'
  assign button_weight = block.settings.button_font_weight | default: '600'

  assign heading_style = block.settings.heading_font_style | default: 'normal'
  assign subheading_style = block.settings.subheading_font_style | default: 'normal'
  assign text_style = block.settings.text_font_style | default: 'normal'
-%}
{%- capture heading_implied -%}{% render 'hp-font-weight', font_key: heading_family %}{%- endcapture -%}
{%- capture subheading_implied -%}{% render 'hp-font-weight', font_key: subheading_family %}{%- endcapture -%}
{%- capture text_implied -%}{% render 'hp-font-weight', font_key: text_family %}{%- endcapture -%}
{%- capture button_implied -%}{% render 'hp-font-weight', font_key: button_family %}{%- endcapture -%}
{%- capture heading_named -%}{% render 'hp-font-is-named-face', font_key: heading_family %}{%- endcapture -%}
{%- capture subheading_named -%}{% render 'hp-font-is-named-face', font_key: subheading_family %}{%- endcapture -%}
{%- capture text_named -%}{% render 'hp-font-is-named-face', font_key: text_family %}{%- endcapture -%}
{%- capture button_named -%}{% render 'hp-font-is-named-face', font_key: button_family %}{%- endcapture -%}
{%- liquid
  assign heading_implied = heading_implied | strip
  assign subheading_implied = subheading_implied | strip
  assign text_implied = text_implied | strip
  assign button_implied = button_implied | strip
  assign heading_named = heading_named | strip
  assign subheading_named = subheading_named | strip
  assign text_named = text_named | strip
  assign button_named = button_named | strip

  if heading_named != blank
    assign heading_weight = '400'
    assign heading_style = 'normal'
  elsif heading_implied != '400'
    assign heading_weight = heading_implied
  endif
  if subheading_named != blank
    assign subheading_weight = '400'
    assign subheading_style = 'normal'
  elsif subheading_implied != '400'
    assign subheading_weight = subheading_implied
  endif
  if text_named != blank
    assign text_weight = '400'
    assign text_style = 'normal'
  elsif text_implied != '400'
    assign text_weight = text_implied
  endif
  if button_named != blank
    assign button_weight = '400'
  elsif button_implied != '400'
    assign button_weight = button_implied
  endif
-%}


{%- capture heading_stack -%}{% render 'hp-font-stack', font_key: heading_family %}{%- endcapture -%}
{%- capture subheading_stack -%}{% render 'hp-font-stack', font_key: subheading_family %}{%- endcapture -%}
{%- capture text_stack -%}{% render 'hp-font-stack', font_key: text_family %}{%- endcapture -%}
{%- capture button_stack -%}{% render 'hp-font-stack', font_key: button_family %}{%- endcapture -%}
{%- liquid
  assign heading_stack = heading_stack | strip
  assign subheading_stack = subheading_stack | strip
  assign text_stack = text_stack | strip
  assign button_stack = button_stack | strip
-%}

{% style %}
  .ai-story-banner-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-story-banner-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    background-color: {{ block.settings.background_color }};
  }

  .ai-story-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    opacity: {{ block.settings.image_opacity }};
  }

  .ai-story-banner-mobile-image-{{ ai_gen_id }} {
    display: none;
  }

  .ai-story-banner-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 500px;
  }

  .ai-story-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-story-banner-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
  }

  .ai-story-banner-content-{{ ai_gen_id }} {
    position: absolute;
    z-index: 2;
    max-width: {{ block.settings.content_max_width }}px;
    padding: {{ block.settings.content_padding }}px;
    text-align: left;
    left: {{ block.settings.content_offset_left }}px;
    top: {{ block.settings.content_offset_top }}px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  #MainContent .shopify-section .ai-story-banner-subheading-{{ ai_gen_id }},
  .ai-story-banner-subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }} !important;
    font-family: {{ subheading_stack }} !important;
    font-size: {{ block.settings.subheading_size }}px !important;
    font-weight: {{ subheading_weight }} !important;
    font-style: {{ subheading_style }} !important;
    margin: 0 0 {{ block.settings.subheading_spacing }}px !important;
    line-height: 1.4 !important;
    letter-spacing: 0.14em !important;
    text-transform: uppercase !important;
  }

  #MainContent .shopify-section .ai-story-banner-heading-{{ ai_gen_id }},
  #MainContent .shopify-section h2.ai-story-banner-heading-{{ ai_gen_id }},
  .ai-story-banner-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }} !important;
    font-family: {{ heading_stack }} !important;
    font-size: {{ block.settings.heading_size }}px !important;
    font-weight: {{ heading_weight }} !important;
    font-style: {{ heading_style }} !important;
    margin: 0 0 {{ block.settings.heading_spacing }}px !important;
    line-height: 1.05 !important;
    letter-spacing: -0.02em !important;
    text-transform: none !important;
  }

  .ai-story-banner-heading-{{ ai_gen_id }} .hp-heading-line {
    display: block;
    text-transform: lowercase !important;
  }

  .ai-story-banner-heading-{{ ai_gen_id }} .hp-heading-line::first-letter {
    text-transform: uppercase !important;
  }

  .ai-story-banner-heading-{{ ai_gen_id }} .hp-heading-line--2 {
    color: {{ block.settings.heading_line2_color | default: settings.heading_line2_color | default: '#6b6b6b' }} !important;
  }

  #MainContent .shopify-section .ai-story-banner-text-{{ ai_gen_id }},
  #MainContent .shopify-section .ai-story-banner-text-{{ ai_gen_id }} p,
  .ai-story-banner-text-{{ ai_gen_id }},
  .ai-story-banner-text-{{ ai_gen_id }} p {
    color: {{ block.settings.text_color }} !important;
    font-family: {{ text_stack }} !important;
    font-size: {{ block.settings.text_size }}px !important;
    font-weight: {{ text_weight }} !important;
    font-style: {{ text_style }} !important;
    line-height: 1.55 !important;
    margin: 0 !important;
    letter-spacing: normal !important;
    text-transform: none !important;
  }

  .ai-story-banner-button-wrapper-{{ ai_gen_id }} {
    margin-top: {{ block.settings.button_spacing }}px;
  }

  #MainContent .shopify-section .ai-story-banner-button-{{ ai_gen_id }},
  .ai-story-banner-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }} !important;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-family: {{ button_stack }} !important;
    font-size: {{ block.settings.button_text_size }}px !important;
    font-weight: {{ button_weight }} !important;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .ai-story-banner-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-story-banner-image-{{ ai_gen_id }} {
      display: none;
    }

    .ai-story-banner-mobile-image-{{ ai_gen_id }} {
      display: block;
      width: 100%;
      height: auto;
      opacity: {{ block.settings.image_opacity }};
    }

    .ai-story-banner-content-{{ ai_gen_id }} {
      padding: 16px;
      left: 16px;
      top: 35%;
      transform: translateY(-35%);
      max-width: calc(100% - 32px);
      box-sizing: border-box;
    }

    .ai-story-banner-heading-{{ ai_gen_id }} {
      font-size: clamp(18px, 5.5vw, {{ block.settings.heading_size }}px);
      margin-bottom: 8px;
    }

    .ai-story-banner-subheading-{{ ai_gen_id }} {
      font-size: clamp(11px, 3.2vw, {{ block.settings.subheading_size }}px);
      margin-bottom: 8px;
    }

    .ai-story-banner-text-{{ ai_gen_id }} {
      font-size: clamp(12px, 3.2vw, {{ block.settings.text_size }}px);
    }

    .ai-story-banner-button-wrapper-{{ ai_gen_id }} {
      margin-top: 12px;
    }

    .ai-story-banner-button-{{ ai_gen_id }} {
      padding: 8px 16px;
      font-size: 13px;
    }
  }
{% endstyle %}

<div class="ai-story-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-story-banner-wrapper-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2400 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
        class="ai-story-banner-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-story-banner-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}

    {% if block.settings.mobile_image %}
      <img
        src="{{ block.settings.mobile_image | image_url: width: 1200 }}"
        alt="{{ block.settings.mobile_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.mobile_image.width }}"
        height="{{ block.settings.mobile_image.height }}"
        class="ai-story-banner-mobile-image-{{ ai_gen_id }}"
      >
    {% elsif block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 1200 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
        class="ai-story-banner-mobile-image-{{ ai_gen_id }}"
      >
    {% endif %}

    {% if block.settings.show_overlay %}
      <div class="ai-story-banner-overlay-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="ai-story-banner-content-{{ ai_gen_id }}">
      {% if block.settings.subheading != blank %}
        <div class="ai-story-banner-subheading-{{ ai_gen_id }}">
          {{ block.settings.subheading }}
        </div>
      {% endif %}

      {% if block.settings.heading != blank %}
        <div class="ai-story-banner-heading-{{ ai_gen_id }}" role="heading" aria-level="2">
          {% render 'section-heading-text', text: block.settings.heading, line2: block.settings.heading_line2, line2_color: block.settings.heading_line2_color %}
        </div>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-story-banner-text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
        <div class="ai-story-banner-button-wrapper-{{ ai_gen_id }}">
          <a
            href="{{ block.settings.button_link }}"
            class="ai-story-banner-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}

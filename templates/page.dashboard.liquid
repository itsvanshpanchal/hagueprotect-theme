              <div style="display: flex; flex-direction: column; gap: 12px;">
                <a href="/pages/faq" style="color: #FF2B2B; font-weight: 700; text-decoration: none; display: flex; align-items: center; gap: 8px;">View FAQs <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                <a href="/pages/contact-us" style="color: #FF2B2B; font-weight: 700; text-decoration: none; display: flex; align-items: center; gap: 8px;">Contact Support <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
              </div>
            </div>
            <!-- Quick Contact Form -->
            <div style="background: #ffffff; border: 1px solid #e8e8ea; border-radius: 16px; padding: 32px; box-shadow: 0 16px 48px rgba(0, 0, 0, 0.02); display: flex; flex-direction: column; gap: 16px;">
              <h3 style="font-family: 'Inter', sans-serif; font-size: 18px; font-weight: 800; color: #111; margin: 0; text-transform: uppercase;">Direct Message</h3>
              <div style="display: flex; flex-direction: column; gap: 12px;">
                <input type="text" placeholder="Subject" style="padding: 12px; border-radius: 8px; border: 1px solid #eee; outline: none; font-family: 'Inter', sans-serif;">
                <textarea placeholder="How can we help?" style="padding: 12px; border-radius: 8px; border: 1px solid #eee; outline: none; font-family: 'Inter', sans-serif; min-height: 100px;"></textarea>
                <button style="background: #111; color: #fff; border: none; border-radius: 30px; padding: 12px; font-weight: 700; text-transform: uppercase; cursor: pointer;">Send Message</button>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Dynamically welcome customer if they logged in with their actual email or name
    const name = localStorage.getItem('customer_name');
    const email = localStorage.getItem('customer_email');
    const greeting = document.getElementById('UserGreeting');
    
    if (greeting) {
      if (name) {
        greeting.textContent = name.split(' ')[0].toUpperCase();
      } else if (email) {
        const parts = email.split('@');
        greeting.textContent = parts[0].toUpperCase();
      }
    }
  });

  function switchTab(tab) {
    const trackBtn = document.getElementById('TabTrackBtn');
    const historyBtn = document.getElementById('TabHistoryBtn');
    const mapBtn = document.getElementById('TabMapBtn');
    const transactionsBtn = document.getElementById('TabTransactionsBtn');
    const supportBtn = document.getElementById('TabSupportBtn');

    const trackContent = document.getElementById('TrackContent');
    const historyContent = document.getElementById('HistoryContent');
    const mapContent = document.getElementById('MapContent');
    const transactionsContent = document.getElementById('TransactionsContent');
    const supportContent = document.getElementById('SupportContent');

    // Clear all selected states
    [trackBtn, historyBtn, mapBtn, transactionsBtn, supportBtn].forEach(btn => {
      if(btn) {
        btn.style.borderBottomColor = "transparent";
        btn.style.color = "#666";
      }
    });

    [trackContent, historyContent, mapContent, transactionsContent, supportContent].forEach(content => {
      if(content) content.style.display = "none";
    });

    if (tab === 'track') {
      trackBtn.style.borderBottomColor = "#FF2B2B";
      trackBtn.style.color = "#111";
      trackContent.style.display = "flex";
    } else if (tab === 'history') {
      historyBtn.style.borderBottomColor = "#FF2B2B";
      historyBtn.style.color = "#111";
      historyContent.style.display = "flex";
    } else if (tab === 'map') {
      mapBtn.style.borderBottomColor = "#FF2B2B";
      mapBtn.style.color = "#111";
      mapContent.style.display = "flex";
    } else if (tab === 'transactions') {
      transactionsBtn.style.borderBottomColor = "#FF2B2B";
      transactionsBtn.style.color = "#111";
      transactionsContent.style.display = "flex";
    } else if (tab === 'support') {
      supportBtn.style.borderBottomColor = "#FF2B2B";
      supportBtn.style.color = "#111";
      supportContent.style.display = "flex";
    }
  }

  // Handle URL hash on load
  window.addEventListener('load', () => {
    const hash = window.location.hash.replace('#', '');
    if (['track', 'history', 'map', 'transactions', 'support'].includes(hash)) {
      switchTab(hash);
    }
  });

  // Handle hash change
  window.addEventListener('hashchange', () => {
    const hash = window.location.hash.replace('#', '');
    if (['track', 'history', 'map', 'transactions', 'support'].includes(hash)) {
      switchTab(hash);
    }
  });

  // Live Simulation for Order Tracking Progress steps
  let step = 3;
  function advanceTransit() {
    const fillLine = document.getElementById('ProgressLine');
    const step3Indicator = document.getElementById('Step3Indicator');
    const step3Label = document.getElementById('Step3Label');
    const step4Indicator = document.getElementById('Step4Indicator');
    const step4Label = document.getElementById('Step4Label');

    if (step === 3) {
      // Transit from Out for Delivery to fully Delivered
      step = 4;
      fillLine.style.width = "88%";
      step3Indicator.textContent = "✓";
      step3Label.textContent = "Van reached delivery point";

      step4Indicator.style.background = "#22C55E";
      step4Indicator.style.color = "#fff";
      step4Indicator.textContent = "✓";
      step4Label.textContent = "Delivered & Received safely";

      // Dynamically move vehicle closer on live map view too!
      const vehicle = document.getElementById('MovingVehicle');
      if (vehicle) {
        vehicle.style.left = "78%";
        vehicle.style.top = "24%";
      }
    } else {
      // Reset back for demonstration
      step = 3;
      fillLine.style.width = "66%";
      step3Label.textContent = "Delivery van nearby";
      
      step4Indicator.style.background = "#eee";
      step4Indicator.style.color = "#888";
      step4Indicator.textContent = "4";
      step4Label.textContent = "Package drops off";

      const vehicle = document.getElementById('MovingVehicle');
      if (vehicle) {
        vehicle.style.left = "45%";
        vehicle.style.top = "38%";
      }
    }
  }
</script>

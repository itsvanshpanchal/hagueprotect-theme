{%- comment -%}
  Vanrosector brand landing page (hosted on this domain).
  Assign this template to a Page with handle "vanrosector"
  so it resolves at /pages/vanrosector.
  Logo: logo-vanrosector.svg in Shopify Assets.
{%- endcomment -%}

{%- assign accent = '#8a6a3b' -%}

<div class="brandpage brandpage--vanrosector" style="font-family:'Inter',sans-serif;">

  <!-- Hero -->
  <section style="background:linear-gradient(165deg,#fbf8f2 0%,#efe2cd 100%); padding:96px 20px; text-align:center;">
    <div style="max-width:760px; margin:0 auto; display:flex; flex-direction:column; align-items:center; gap:22px;">
      <span style="display:inline-flex; align-items:center; justify-content:center; background:#ffffff; border-radius:20px; box-shadow:0 12px 32px rgba(138,106,59,0.16); padding:26px 40px;">
        <img src="{{ 'logo-vanrosector.svg' | asset_url }}" alt="Vanrosector" width="320" height="117" style="display:block; width:auto; height:auto; max-height:96px; max-width:320px; object-fit:contain;" loading="eager" decoding="async">
      </span>
      <h1 style="font-size:clamp(30px,5vw,52px); font-weight:800; letter-spacing:-0.03em; color:#2c2113; margin:8px 0 0; line-height:1.08;">Journey Through Nature's Finest Essence</h1>
      <p style="font-size:17px; color:#6a5b43; line-height:1.65; margin:0; max-width:600px;">Vanrosector is a celebration of nature's purest ingredients — thoughtfully sourced, expertly crafted, and made to elevate your everyday ritual.</p>
      <a href="/collections/all" style="display:inline-flex; align-items:center; gap:9px; background:{{ accent }}; color:#fff; font-size:13px; font-weight:800; letter-spacing:0.08em; text-transform:uppercase; padding:15px 34px; border-radius:100px; text-decoration:none; margin-top:8px;">
        Discover the Collection
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M1 5h11M8 1l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </section>

  <!-- Pillars -->
  <section style="background:#ffffff; padding:80px 20px;">
    <div style="max-width:1120px; margin:0 auto;">
      <div style="text-align:center; max-width:560px; margin:0 auto 48px;">
        <span style="color:{{ accent }}; font-size:12px; font-weight:800; letter-spacing:0.2em; text-transform:uppercase;">The Vanrosector Promise</span>
        <h2 style="font-size:clamp(24px,3.5vw,34px); font-weight:800; color:#111; margin:12px 0 0; letter-spacing:-0.02em;">Crafted by nature, refined by us</h2>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:24px;">
        <div style="background:#faf7f1; border:1px solid #ece2d2; border-radius:18px; padding:34px 30px;">
          <div style="width:46px; height:46px; border-radius:12px; background:{{ accent }}1f; margin-bottom:18px;"></div>
          <h3 style="font-size:19px; font-weight:700; color:#2c2113; margin:0 0 8px;">Naturally Sourced</h3>
          <p style="font-size:14.5px; color:#6a5b43; line-height:1.6; margin:0;">Ingredients drawn from nature's finest essences, chosen for purity and potency.</p>
        </div>
        <div style="background:#faf7f1; border:1px solid #ece2d2; border-radius:18px; padding:34px 30px;">
          <div style="width:46px; height:46px; border-radius:12px; background:{{ accent }}1f; margin-bottom:18px;"></div>
          <h3 style="font-size:19px; font-weight:700; color:#2c2113; margin:0 0 8px;">Expertly Crafted</h3>
          <p style="font-size:14.5px; color:#6a5b43; line-height:1.6; margin:0;">Every formula is balanced with precision to deliver a refined sensory experience.</p>
        </div>
        <div style="background:#faf7f1; border:1px solid #ece2d2; border-radius:18px; padding:34px 30px;">
          <div style="width:46px; height:46px; border-radius:12px; background:{{ accent }}1f; margin-bottom:18px;"></div>
          <h3 style="font-size:19px; font-weight:700; color:#2c2113; margin:0 0 8px;">Made to Last</h3>
          <p style="font-size:14.5px; color:#6a5b43; line-height:1.6; margin:0;">Premium quality that honours both the ritual and the result, every single time.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Page content (editable in admin) -->
  {%- if page.content != blank -%}
    <section style="background:#ffffff; padding:0 20px 80px;">
      <div class="rte" style="max-width:820px; margin:0 auto; font-size:16px; color:#444; line-height:1.7;">
        {{ page.content }}
      </div>
    </section>
  {%- endif -%}

  <!-- Back to family -->
  <section style="background:linear-gradient(165deg,#2c2113 0%,#4a3a22 100%); padding:64px 20px; text-align:center;">
    <p style="color:#e8dcc6; font-size:15px; margin:0 0 18px; letter-spacing:0.02em;">Part of the family alongside Hague Protect & Science of Raw.</p>
    <a href="/" style="display:inline-flex; align-items:center; gap:8px; color:#fff; font-size:13px; font-weight:800; letter-spacing:0.08em; text-transform:uppercase; text-decoration:none; border:1px solid rgba(255,255,255,0.4); padding:13px 28px; border-radius:100px;">Back to Hague Protect</a>
  </section>

</div>

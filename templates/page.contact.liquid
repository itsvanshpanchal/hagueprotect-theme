<div class="contact-page-wrapper" style="background-color: #fafafc; font-family: 'Inter', sans-serif; padding: 80px 0; min-height: 100vh;">
  <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">

    <!-- Intro Text -->
    <div style="text-align: center; max-width: 650px; margin: 0 auto 64px; display: flex; flex-direction: column; gap: 16px;">
      <span style="color: #FF2B2B; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em;">Get in Touch</span>
      <h1 style="font-size: 42px; font-weight: 800; color: #111; margin: 0; line-height: 1.1; letter-spacing: -0.03em;">We Are Here to Help</h1>
      <p style="font-size: 16px; color: #666; line-height: 1.6; margin: 0;">Have a question about a product, shipment, or a custom maintenance need? Fill out the form or reach our team directly.</p>
    </div>

    <div style="display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 64px; align-items: start;" class="contact-grid">
      
      <!-- Contact Form -->
      <div style="background: #ffffff; border: 1px solid #e9e9eb; border-radius: 16px; padding: 40px; box-shadow: 0 4px 24px rgba(0,0,0,0.01);" class="contact-form-container">
        <h2 style="font-size: 24px; font-weight: 700; color: #111; margin-bottom: 24px; letter-spacing: -0.01em;">Send Us a Message</h2>
        <form style="display: flex; flex-direction: column; gap: 20px;" onsubmit="alert('Thank you! Your message has been sent to our customer care team.'); return false;">
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div style="display: flex; flex-direction: column; gap: 6px;">
              <label for="ContactName" style="font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #111;">Your Name</label>
              <input type="text" id="ContactName" required style="height: 52px; padding: 12px 16px; border: 1px solid #ddd; border-radius: 8px; font-size: 15px; outline: none; transition: border-color 0.2s;" onfocus="this.style.borderColor='#FF2B2B'" onblur="this.style.borderColor='#ddd'">
            </div>
            <div style="display: flex; flex-direction: column; gap: 6px;">
              <label for="ContactEmail" style="font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #111;">Email Address</label>
              <input type="email" id="ContactEmail" required style="height: 52px; padding: 12px 16px; border: 1px solid #ddd; border-radius: 8px; font-size: 15px; outline: none; transition: border-color 0.2s;" onfocus="this.style.borderColor='#FF2B2B'" onblur="this.style.borderColor='#ddd'">
            </div>
          </div>

          <div style="display: flex; flex-direction: column; gap: 6px;">
            <label for="ContactSubject" style="font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #111;">Subject</label>
            <input type="text" id="ContactSubject" style="height: 52px; padding: 12px 16px; border: 1px solid #ddd; border-radius: 8px; font-size: 15px; outline: none; transition: border-color 0.2s;" onfocus="this.style.borderColor='#FF2B2B'" onblur="this.style.borderColor='#ddd'">
          </div>

          <div style="display: flex; flex-direction: column; gap: 6px;">
            <label for="ContactMessage" style="font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #111;">How can we help?</label>
            <textarea id="ContactMessage" rows="5" required style="padding: 16px; border: 1px solid #ddd; border-radius: 8px; font-size: 15px; outline: none; transition: border-color 0.2s; resize: vertical;" onfocus="this.style.borderColor='#FF2B2B'" onblur="this.style.borderColor='#ddd'"></textarea>
          </div>

          <button type="submit" style="background: #111; color: #fff; border: none; height: 56px; border-radius: 30px; font-size: 14px; font-weight: 700; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em; transition: background-color 0.2s, transform 0.2s;" class="contact-btn">Submit Inquiry</button>
        </form>
      </div>

      <!-- General Info Column -->
      <div style="display: flex; flex-direction: column; gap: 32px;">
        <div style="background: #ffffff; border: 1px solid #e9e9eb; border-radius: 16px; padding: 32px; display: flex; flex-direction: column; gap: 12px;">
          <h3 style="font-size: 18px; font-weight: 700; color: #111; margin: 0;">Customer Care</h3>
          <p style="font-size: 14px; color: #666; margin: 0; line-height: 1.6;">Our support agents are available Mon-Fri, 9am - 5pm CET. We typically reply within 24 hours.</p>
          <a href="mailto:support@hagueprotect.com" style="color: #FF2B2B; font-weight: 600; font-size: 15px; text-decoration: none; margin-top: 4px;">support@hagueprotect.com</a>
        </div>

        <div style="background: #ffffff; border: 1px solid #e9e9eb; border-radius: 16px; padding: 32px; display: flex; flex-direction: column; gap: 12px;">
          <h3 style="font-size: 18px; font-weight: 700; color: #111; margin: 0;">Amsterdam Headquarters</h3>
          <p style="font-size: 14px; color: #666; margin: 0; line-height: 1.6;">Hague Protect BV<br>Herengracht 450-458,<br>1017 CA Amsterdam,<br>Netherlands</p>
        </div>
      </div>

    </div>

  </div>
</div>

<style>
  .contact-btn:hover {
    background-color: #FF2B2B !important;
    transform: translateY(-2px);
  }
  @media screen and (max-width: 991px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>

<style>
  /* ── Account Dashboard Premium UI ── */
  .acc-root {
    background: #0a0a0a;
    min-height: calc(100vh - 72px);
    padding: 0 0 80px;
    font-family: 'Inter', sans-serif;
  }

  /* Hero Banner */
  .acc-hero {
    background: linear-gradient(135deg, #111 0%, #1a0000 60%, #0a0a0a 100%);
    border-bottom: 1px solid #1f1f1f;
    padding: 48px 0 0;
    position: relative;
    overflow: hidden;
  }
  .acc-hero::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 320px; height: 320px;
    background: radial-gradient(circle, rgba(255,43,43,0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .acc-hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
    flex-wrap: wrap;
  }
  .acc-hero-left { display: flex; flex-direction: column; gap: 6px; }
  .acc-hero-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(255,43,43,0.12);
    border: 1px solid rgba(255,43,43,0.3);
    color: #FF2B2B; font-size: 11px; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.1em;
    padding: 5px 12px; border-radius: 20px;
    width: fit-content; margin-bottom: 8px;
  }
  .acc-hero-badge::before { content: ''; width: 6px; height: 6px; background: #FF2B2B; border-radius: 50%; }
  .acc-hero-name {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.03em;
    margin: 0;
    text-transform: uppercase;
  }
  .acc-hero-email { font-size: 13px; color: #555; margin: 0; font-weight: 500; }
  .acc-signout {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 13px; font-weight: 700; color: #FF2B2B;
    text-decoration: none;
    border: 1.5px solid rgba(255,43,43,0.3);
    padding: 11px 22px; border-radius: 30px;
    transition: all 0.2s ease;
    background: rgba(255,43,43,0.04);
    white-space: nowrap;
    margin-top: 4px;
  }
  .acc-signout:hover { background: #FF2B2B; color: #fff; border-color: #FF2B2B; }

  /* Tabs */
  .acc-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid #1f1f1f;
    padding: 0 32px;
    max-width: 1200px;
    margin: 32px auto 0;
    overflow-x: auto;
  }
  .acc-tab {
    background: none; border: none; border-bottom: 2.5px solid transparent;
    font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 700;
    color: #555; padding: 14px 22px; cursor: pointer;
    transition: all 0.2s; outline: none;
    text-transform: uppercase; letter-spacing: 0.06em;
    display: flex; align-items: center; gap: 8px;
    margin-bottom: -1px; white-space: nowrap;
  }
  .acc-tab.active { color: #fff; border-bottom-color: #FF2B2B; }
  .acc-tab:hover:not(.active) { color: #ccc; }
  .acc-tab svg { opacity: 0.6; }
  .acc-tab.active svg { opacity: 1; }

  /* Content */
  .acc-content { max-width: 1200px; margin: 40px auto 0; padding: 0 32px; }
  .acc-panel { display: none; }
  .acc-panel.active { display: flex; flex-direction: column; gap: 20px; }

  /* Stats row */
  .acc-stats {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 16px; margin-bottom: 8px;
  }
  .acc-stat-card {
    background: #111; border: 1px solid #1f1f1f;
    border-radius: 14px; padding: 24px;
    display: flex; flex-direction: column; gap: 6px;
  }
  .acc-stat-label { font-size: 11px; font-weight: 700; color: #444; text-transform: uppercase; letter-spacing: 0.08em; }
  .acc-stat-val { font-size: 26px; font-weight: 800; color: #fff; letter-spacing: -0.03em; }
  .acc-stat-sub { font-size: 12px; color: #555; font-weight: 500; }

  /* Order card */
  .acc-order-card {
    background: #111; border: 1px solid #1f1f1f;
    border-radius: 16px; overflow: hidden;
    transition: border-color 0.2s;
  }
  .acc-order-card:hover { border-color: #333; }
  .acc-order-head {
    display: flex; justify-content: space-between; align-items: center;
    padding: 20px 28px; flex-wrap: wrap; gap: 16px;
    border-bottom: 1px solid #1a1a1a;
  }
  .acc-order-meta { display: flex; gap: 36px; flex-wrap: wrap; }
  .acc-order-meta-item { display: flex; flex-direction: column; gap: 3px; }
  .acc-order-meta-label { font-size: 10px; font-weight: 800; color: #444; text-transform: uppercase; letter-spacing: 0.08em; }
  .acc-order-meta-val { font-size: 14px; color: #fff; font-weight: 700; }
  .acc-status {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em;
    padding: 5px 12px; border-radius: 20px;
  }
  .acc-status.paid { background: rgba(34,197,94,0.12); color: #22c55e; border: 1px solid rgba(34,197,94,0.2); }
  .acc-status.pending { background: rgba(234,179,8,0.12); color: #eab308; border: 1px solid rgba(234,179,8,0.2); }
  .acc-status.refunded { background: rgba(255,43,43,0.1); color: #FF2B2B; border: 1px solid rgba(255,43,43,0.2); }
  .acc-order-details-btn {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; font-weight: 700; color: #888;
    text-decoration: none; border: 1px solid #2a2a2a;
    padding: 9px 18px; border-radius: 30px;
    transition: all 0.2s; text-transform: uppercase; letter-spacing: 0.05em;
  }
  .acc-order-details-btn:hover { color: #fff; border-color: #555; background: #1a1a1a; }

  .acc-order-body { padding: 20px 28px; display: flex; flex-direction: column; gap: 16px; }
  .acc-line-item { display: flex; gap: 20px; align-items: center; }
  .acc-line-img {
    width: 72px; height: 72px; border-radius: 10px;
    background: #1a1a1a; border: 1px solid #2a2a2a;
    overflow: hidden; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .acc-line-img img { width: 100%; height: 100%; object-fit: cover; }
  .acc-line-info { flex: 1; display: flex; flex-direction: column; gap: 4px; }
  .acc-line-title { font-size: 14px; font-weight: 800; color: #fff; margin: 0; }
  .acc-line-sub { font-size: 12px; color: #555; margin: 0; font-weight: 500; }
  .acc-line-price { font-size: 14px; font-weight: 800; color: #FF2B2B; white-space: nowrap; }

  /* Empty state */
  .acc-empty {
    text-align: center; padding: 80px 24px;
    background: #111; border: 1px solid #1f1f1f; border-radius: 16px;
  }
  .acc-empty-icon {
    width: 72px; height: 72px; margin: 0 auto 20px;
    background: #1a1a1a; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .acc-empty h3 { font-size: 20px; font-weight: 800; color: #fff; margin: 0 0 8px; }
  .acc-empty p { font-size: 14px; color: #555; margin: 0 0 28px; }
  .acc-shop-btn {
    display: inline-flex; align-items: center; gap: 8px;
    background: #FF2B2B; color: #fff; text-decoration: none;
    padding: 14px 32px; border-radius: 30px;
    font-size: 13px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.07em;
    transition: all 0.2s;
  }
  .acc-shop-btn:hover { background: #e02020; transform: translateY(-1px); }

  /* Address card */
  .acc-addr-card {
    background: #111; border: 1px solid #1f1f1f; border-radius: 16px; padding: 28px;
  }
  .acc-addr-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
  .acc-addr-head h3 { font-size: 16px; font-weight: 800; color: #fff; margin: 0; text-transform: uppercase; letter-spacing: 0.04em; }
  .acc-addr-manage { color: #FF2B2B; font-size: 12px; font-weight: 700; text-decoration: none; text-transform: uppercase; letter-spacing: 0.05em; }
  .acc-addr-default {
    background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 12px; padding: 20px;
  }
  .acc-addr-badge {
    display: inline-block; font-size: 10px; font-weight: 800; color: #FF2B2B;
    text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px;
  }
  .acc-addr-text { font-size: 14px; color: #ccc; line-height: 1.8; margin: 0; font-weight: 500; }
  .acc-no-addr { font-size: 14px; color: #555; }

  /* Support cards */
  .acc-support-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
  .acc-support-card {
    background: #111; border: 1px solid #1f1f1f; border-radius: 16px; padding: 28px;
    display: flex; flex-direction: column; gap: 12px;
    transition: border-color 0.2s;
  }
  .acc-support-card:hover { border-color: #333; }
  .acc-support-icon {
    width: 44px; height: 44px; background: rgba(255,43,43,0.08);
    border-radius: 12px; display: flex; align-items: center; justify-content: center;
  }
  .acc-support-card h3 { font-size: 16px; font-weight: 800; color: #fff; margin: 0; }
  .acc-support-card p { font-size: 13px; color: #555; margin: 0; line-height: 1.6; font-weight: 500; }
  .acc-support-link {
    display: inline-flex; align-items: center; gap: 6px;
    color: #FF2B2B; font-size: 13px; font-weight: 700; text-decoration: none;
    text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px;
  }
  .acc-support-link:hover { gap: 10px; }

  @media (max-width: 768px) {
    .acc-hero-inner { padding: 0 20px; }
    .acc-tabs { padding: 0 20px; }
    .acc-content { padding: 0 20px; }
    .acc-stats { grid-template-columns: 1fr 1fr; }
    .acc-order-head { padding: 16px 20px; }
    .acc-order-body { padding: 16px 20px; }
    .acc-order-meta { gap: 20px; }
  }
  @media (max-width: 480px) {
    .acc-stats { grid-template-columns: 1fr; }
  }
</style>

<div class="acc-root">
  <!-- Hero -->
  <div class="acc-hero">
    <div class="acc-hero-inner">
      <div class="acc-hero-left">
        <div class="acc-hero-badge">Member</div>
        <h1 class="acc-hero-name">Hello, {{ customer.first_name | default: 'Member' }} 👋</h1>
        <p class="acc-hero-email">{{ customer.email }}</p>
      </div>
      <a href="{{ routes.account_logout_url }}" class="acc-signout">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3H7a2 2 0 00-2 2v14a2 2 0 002 2h8m4-9l-4-4m4 4l-4 4m4-4H9" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Sign Out
      </a>
    </div>

    <!-- Tabs -->
    <div class="acc-tabs">
      <button id="TabOrdersBtn" class="acc-tab active" onclick="accTab('orders')">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Orders
      </button>
      <button id="TabAddressBtn" class="acc-tab" onclick="accTab('addresses')">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="10" r="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Addresses
      </button>
      <button id="TabSupportBtn" class="acc-tab" onclick="accTab('support')">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3m0 4h.01" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Support
      </button>
    </div>
  </div>

  <!-- Content -->
  <div class="acc-content">

    <!-- Orders Panel -->
    <div id="PanelOrders" class="acc-panel active">

      {%- if customer.orders.size > 0 -%}
        <!-- Stats row -->
        <div class="acc-stats">
          <div class="acc-stat-card">
            <span class="acc-stat-label">Total Orders</span>
            <span class="acc-stat-val">{{ customer.orders.size }}</span>
            <span class="acc-stat-sub">All time</span>
          </div>
          <div class="acc-stat-card">
            <span class="acc-stat-label">Total Spent</span>
            <span class="acc-stat-val">{{ customer.total_spent | money }}</span>
            <span class="acc-stat-sub">Lifetime value</span>
          </div>
          <div class="acc-stat-card">
            <span class="acc-stat-label">Last Order</span>
            <span class="acc-stat-val" style="font-size:18px;">{{ customer.orders.first.name }}</span>
            <span class="acc-stat-sub">{{ customer.orders.first.created_at | date: format: 'date' }}</span>
          </div>
        </div>

        {%- for order in customer.orders -%}
          <div class="acc-order-card">
            <div class="acc-order-head">
              <div class="acc-order-meta">
                <div class="acc-order-meta-item">
                  <span class="acc-order-meta-label">Order</span>
                  <span class="acc-order-meta-val">{{ order.name }}</span>
                </div>
                <div class="acc-order-meta-item">
                  <span class="acc-order-meta-label">Date</span>
                  <span class="acc-order-meta-val">{{ order.created_at | date: format: 'date' }}</span>
                </div>
                <div class="acc-order-meta-item">
                  <span class="acc-order-meta-label">Total</span>
                  <span class="acc-order-meta-val">{{ order.total_price | money }}</span>
                </div>
                <div class="acc-order-meta-item">
                  <span class="acc-order-meta-label">Status</span>
                  {%- assign fs = order.financial_status -%}
                  {%- if fs == 'paid' -%}
                    <span class="acc-status paid">Paid</span>
                  {%- elsif fs == 'refunded' or fs == 'partially_refunded' -%}
                    <span class="acc-status refunded">{{ fs | replace: '_', ' ' | capitalize }}</span>
                  {%- else -%}
                    <span class="acc-status pending">{{ fs | replace: '_', ' ' | capitalize }}</span>
                  {%- endif -%}
                </div>
              </div>
              <a href="{{ order.customer_url }}" class="acc-order-details-btn">
                Details
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
            <div class="acc-order-body">
              {%- for line_item in order.line_items -%}
                <div class="acc-line-item">
                  <div class="acc-line-img">
                    {%- if line_item.image -%}
                      <img src="{{ line_item.image | image_url: width: 144 }}" alt="{{ line_item.title }}" loading="lazy">
                    {%- else -%}
                      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="1.5"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
                    {%- endif -%}
                  </div>
                  <div class="acc-line-info">
                    <p class="acc-line-title">{{ line_item.product.title }}</p>
                    <p class="acc-line-sub">Qty: {{ line_item.quantity }}{% if line_item.variant.title != 'Default Title' %} · {{ line_item.variant.title }}{% endif %}</p>
                  </div>
                  <span class="acc-line-price">{{ line_item.final_line_price | money }}</span>
                </div>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}

      {%- else -%}
        <div class="acc-empty">
          <div class="acc-empty-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="1.5"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3>No orders yet</h3>
          <p>Start your sneaker care journey today.</p>
          <a href="/collections/all" class="acc-shop-btn">
            Shop Collection
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      {%- endif -%}
    </div>

    <!-- Addresses Panel -->
    <div id="PanelAddresses" class="acc-panel">
      <div class="acc-addr-card">
        <div class="acc-addr-head">
          <h3>Shipping Addresses</h3>
          <a href="{{ routes.account_addresses_url }}" class="acc-addr-manage">Manage All →</a>
        </div>
        {%- if customer.default_address -%}
          <div class="acc-addr-default">
            <span class="acc-addr-badge">★ Default Address</span>
            <p class="acc-addr-text">
              {{ customer.default_address.name }}<br>
              {{ customer.default_address.address1 }}<br>
              {%- if customer.default_address.address2 != blank -%}{{ customer.default_address.address2 }}<br>{%- endif -%}
              {{ customer.default_address.city }}, {{ customer.default_address.province_code }} {{ customer.default_address.zip }}<br>
              {{ customer.default_address.country }}
            </p>
          </div>
        {%- else -%}
          <p class="acc-no-addr">No addresses saved yet. <a href="{{ routes.account_addresses_url }}" style="color:#FF2B2B;">Add one →</a></p>
        {%- endif -%}
      </div>
    </div>

    <!-- Support Panel -->
    <div id="PanelSupport" class="acc-panel">
      <div class="acc-support-grid">
        <div class="acc-support-card">
          <div class="acc-support-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FF2B2B" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3m0 4h.01" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3>Help Center</h3>
          <p>Find answers to common questions about shipping, product care, and returns.</p>
          <a href="/search?view=faq" class="acc-support-link">View FAQs <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
        <div class="acc-support-card">
          <div class="acc-support-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FF2B2B" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3>Direct Support</h3>
          <p>Need help with an order? Our team is ready to assist you directly.</p>
          <a href="/pages/contact-us" class="acc-support-link">Contact Us <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
        <div class="acc-support-card">
          <div class="acc-support-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FF2B2B" stroke-width="2"><path d="M9 14s-4 0-4-4 4-4 4-4h6s4 0 4 4-4 4-4 4H9z" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3>Returns & Refunds</h3>
          <p>Learn about our return policy and how to initiate a return or exchange.</p>
          <a href="/policies/refund-policy" class="acc-support-link">View Policy <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
    </div>

  </div><!-- /acc-content -->
</div>

<script>
  function accTab(tab) {
    const tabs = { orders: 'TabOrdersBtn', addresses: 'TabAddressBtn', support: 'TabSupportBtn' };
    const panels = { orders: 'PanelOrders', addresses: 'PanelAddresses', support: 'PanelSupport' };
    Object.values(tabs).forEach(id => {
      const el = document.getElementById(id);
      if (el) el.classList.remove('active');
    });
    Object.values(panels).forEach(id => {
      const el = document.getElementById(id);
      if (el) el.classList.remove('active');
    });
    const activeTab = document.getElementById(tabs[tab]);
    const activePanel = document.getElementById(panels[tab]);
    if (activeTab) activeTab.classList.add('active');
    if (activePanel) activePanel.classList.add('active');
    history.replaceState(null, '', '#' + tab);
  }

  window.addEventListener('load', function() {
    const hash = window.location.hash.replace('#', '');
    if (['orders', 'addresses', 'support'].includes(hash)) {
      accTab(hash);
    }
  });
</script>

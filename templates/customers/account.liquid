<div class="dashboard-wrapper" style="background: #fafafa; padding: 60px 0; min-height: calc(100vh - 120px);">
  <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 24px; display: flex; flex-direction: column; gap: 40px;">
    
    <!-- User Welcome Greeting Banner -->
    <div style="background: #ffffff; border: 1px solid #e8e8ea; border-radius: 16px; padding: 32px 40px; display: flex; justify-content: space-between; align-items: center; gap: 24px; box-shadow: 0 16px 48px rgba(0, 0, 0, 0.02); flex-wrap: wrap;">
      <div style="display: flex; flex-direction: column; gap: 6px;">
        <h1 style="font-family: 'Inter', sans-serif; font-size: 28px; font-weight: 800; color: #111; letter-spacing: -0.03em; margin: 0; text-transform: uppercase;">Hello, {{ customer.first_name | default: 'Member' }}</h1>
        <p style="font-family: 'Inter', sans-serif; font-size: 14px; color: #666; margin: 0; line-height: 1.5;">Welcome to your HAGUE PROTECT dashboard. Manage your orders and profile here.</p>
      </div>
      <a href="{{ routes.account_logout_url }}" style="display: inline-flex; align-items: center; gap: 8px; font-family: 'Inter', sans-serif; font-size: 13.5px; font-weight: 700; color: #FF2B2B; text-decoration: none; border: 1.5px solid #FF2B2B; padding: 12px 24px; border-radius: 30px; transition: all 0.2s ease;" onmouseover="this.style.backgroundColor='#FF2B2B'; this.style.color='#fff';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#FF2B2B';">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3H7a2 2 0 00-2 2v14a2 2 0 002 2h8m4-9l-4-4m4 4l-4 4m4-4H9" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Sign Out
      </a>
    </div>

    <!-- Dashboard Main Grid & Navigation Tabs -->
    <div style="display: flex; flex-direction: column; gap: 24px;">
      
      <!-- Premium Tab Navigation -->
      <div style="display: flex; gap: 8px; border-bottom: 2px solid #e8e8ea; padding-bottom: 0px; flex-wrap: wrap;">
        <button id="TabHistoryBtn" onclick="switchTab('history')" style="background: none; border: none; border-bottom: 3px solid #FF2B2B; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700; color: #111; padding: 14px 24px; cursor: pointer; transition: all 0.2s ease; outline: none; margin-bottom: -2.5px; text-transform: uppercase; letter-spacing: 0.05em; display: flex; align-items: center; gap: 8px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Order History
        </button>
        <button id="TabAddressesBtn" onclick="switchTab('addresses')" style="background: none; border: none; border-bottom: 3px solid transparent; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700; color: #666; padding: 14px 24px; cursor: pointer; transition: all 0.2s ease; outline: none; margin-bottom: -2.5px; text-transform: uppercase; letter-spacing: 0.05em; display: flex; align-items: center; gap: 8px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="10" r="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          My Addresses
        </button>
        <button id="TabSupportBtn" onclick="switchTab('support')" style="background: none; border: none; border-bottom: 3px solid transparent; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700; color: #666; padding: 14px 24px; cursor: pointer; transition: all 0.2s ease; outline: none; margin-bottom: -2.5px; text-transform: uppercase; letter-spacing: 0.05em; display: flex; align-items: center; gap: 8px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3m0 4h.01" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Support Center
        </button>
      </div>

      <!-- Tab Content Area -->
      <div id="DashboardContent" style="min-height: 480px; width: 100%; border-radius: 12px;">
        
        <!-- Tab 1: Order History Content -->
        <div id="HistoryContent" style="display: flex; flex-direction: column; gap: 24px;">
          {%- if customer.orders.size > 0 -%}
            {%- for order in customer.orders -%}
              <div style="background: #ffffff; border: 1px solid #e8e8ea; border-radius: 16px; padding: 32px; display: flex; flex-direction: column; gap: 24px; box-shadow: 0 16px 48px rgba(0, 0, 0, 0.02);">
                <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; border-bottom: 1px solid #eee; padding-bottom: 16px;">
                  <div style="display: flex; gap: 32px; flex-wrap: wrap;">
                    <div>
                      <span style="display: block; font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px;">Order Placed</span>
                      <span style="font-family: 'Inter', sans-serif; font-size: 14px; color: #111; font-weight: 600;">{{ order.created_at | date: format: 'date' }}</span>
                    </div>
                    <div>
                      <span style="display: block; font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px;">Total</span>
                      <span style="font-family: 'Inter', sans-serif; font-size: 14px; color: #111; font-weight: 600;">{{ order.total_price | money }}</span>
                    </div>
                    <div>
                      <span style="display: block; font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px;">Order Number</span>
                      <span style="font-family: 'Inter', sans-serif; font-size: 14px; color: #111; font-weight: 600;">{{ order.name }}</span>
                    </div>
                  </div>
                  <a href="{{ order.customer_url }}" style="font-family: 'Inter', sans-serif; font-size: 13.5px; font-weight: 700; color: #111; text-decoration: none; border: 1px solid #ddd; border-radius: 30px; padding: 10px 20px; transition: all 0.2s;" onmouseover="this.style.backgroundColor='#111'; this.style.color='#fff'; this.style.borderColor='#111';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#111'; this.style.borderColor='#ddd';">View Details</a>
                </div>

                {%- for line_item in order.line_items -%}
                  <div style="display: flex; gap: 24px; align-items: center; flex-wrap: wrap;">
                    <div style="width: 80px; height: 80px; border-radius: 8px; background: #fafafa; border: 1px solid #eee; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                      {%- if line_item.image -%}
                        <img src="{{ line_item.image | image_url: width: 160 }}" alt="{{ line_item.title }}" style="max-width: 100%; height: auto;">
                      {%- else -%}
                         <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#eee" stroke-width="1.5"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
                      {%- endif -%}
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 4px; flex: 1;">
                      <h4 style="font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 800; color: #111; margin:0;">{{ line_item.product.title }}</h4>
                      <p style="font-family: 'Inter', sans-serif; font-size: 13px; color: #666; margin: 0;">Qty: {{ line_item.quantity }} &bull; {{ line_item.final_line_price | money }}</p>
                    </div>
                  </div>
                {%- endfor -%}
              </div>
            {%- endfor -%}
          {%- else -%}
            <div style="text-align: center; padding: 80px 0; background: #fff; border-radius: 16px; border: 1px solid #eee;">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="#ddd" stroke-width="1.5" style="margin-bottom: 16px;"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
              <h3 style="font-family: 'Inter', sans-serif; font-size: 18px; font-weight: 800; color: #111; margin: 0;">No orders yet</h3>
              <p style="font-family: 'Inter', sans-serif; font-size: 14px; color: #666; margin: 8px 0 24px;">Start your sneaker care journey today.</p>
              <a href="/collections/all" style="background: #FF2B2B; color: #fff; text-decoration: none; padding: 12px 32px; border-radius: 30px; font-weight: 700; text-transform: uppercase; font-size: 13px;">Shop Collection</a>
            </div>
          {%- endif -%}
        </div>

        <!-- Tab 2: My Addresses -->
        <div id="AddressesContent" style="display: none; flex-direction: column; gap: 24px;">
           <div style="background: #ffffff; border: 1px solid #e8e8ea; border-radius: 16px; padding: 32px; box-shadow: 0 16px 48px rgba(0, 0, 0, 0.02);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
              <h3 style="font-family: 'Inter', sans-serif; font-size: 20px; font-weight: 800; color: #111; margin: 0; text-transform: uppercase;">Shipping Addresses</h3>
              <a href="{{ routes.account_addresses_url }}" style="color: #FF2B2B; font-weight: 700; text-decoration: none; font-size: 13px;">Manage All</a>
            </div>
            
            {%- if customer.default_address -%}
              <div style="border: 1px solid #eee; border-radius: 12px; padding: 24px; background: #fafafa;">
                <span style="display: block; font-size: 10px; font-weight: 800; color: #FF2B2B; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px;">Default Address</span>
                <p style="font-family: 'Inter', sans-serif; font-size: 15px; color: #111; line-height: 1.6; margin: 0;">
                  {{ customer.default_address.name }}<br>
                  {{ customer.default_address.address1 }}<br>
                  {% if customer.default_address.address2 %}{{ customer.default_address.address2 }}<br>{% endif %}
                  {{ customer.default_address.city }}, {{ customer.default_address.province_code }} {{ customer.default_address.zip }}<br>
                  {{ customer.default_address.country }}
                </p>
              </div>
            {%- else -%}
              <p style="color: #666; font-size: 14px;">No addresses saved yet.</p>
            {%- endif -%}
          </div>
        </div>

        <!-- Tab 3: Support -->
        <div id="SupportContent" style="display: none; flex-direction: column; gap: 24px;">
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px;">
            <div style="background: #ffffff; border: 1px solid #e8e8ea; border-radius: 16px; padding: 32px; box-shadow: 0 16px 48px rgba(0, 0, 0, 0.02); display: flex; flex-direction: column; gap: 16px;">
              <h3 style="font-family: 'Inter', sans-serif; font-size: 18px; font-weight: 800; color: #111; margin: 0; text-transform: uppercase;">Help Center</h3>
              <p style="font-family: 'Inter', sans-serif; font-size: 14px; color: #666; line-height: 1.5; margin: 0;">Find answers to common questions about shipping, product care, and returns.</p>
              <a href="/pages/faq" style="color: #FF2B2B; font-weight: 700; text-decoration: none; display: flex; align-items: center; gap: 8px;">View FAQs <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            </div>
            <div style="background: #ffffff; border: 1px solid #e8e8ea; border-radius: 16px; padding: 32px; box-shadow: 0 16px 48px rgba(0, 0, 0, 0.02); display: flex; flex-direction: column; gap: 16px;">
              <h3 style="font-family: 'Inter', sans-serif; font-size: 18px; font-weight: 800; color: #111; margin: 0; text-transform: uppercase;">Direct Support</h3>
              <p style="font-family: 'Inter', sans-serif; font-size: 14px; color: #666; line-height: 1.5; margin: 0;">Need specific help with an order? Our team is ready to assist you.</p>
              <a href="/pages/contact-us" style="color: #FF2B2B; font-weight: 700; text-decoration: none; display: flex; align-items: center; gap: 8px;">Contact Support <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function switchTab(tab) {
    const btns = ['TabHistoryBtn', 'TabAddressesBtn', 'TabSupportBtn'];
    const contents = ['HistoryContent', 'AddressesContent', 'SupportContent'];

    btns.forEach(id => {
      const btn = document.getElementById(id);
      if(btn) {
        btn.style.borderBottomColor = "transparent";
        btn.style.color = "#666";
      }
    });

    contents.forEach(id => {
      const content = document.getElementById(id);
      if(content) content.style.display = "none";
    });

    if (tab === 'history') {
      document.getElementById('TabHistoryBtn').style.borderBottomColor = "#FF2B2B";
      document.getElementById('TabHistoryBtn').style.color = "#111";
      document.getElementById('HistoryContent').style.display = "flex";
    } else if (tab === 'addresses') {
      document.getElementById('TabAddressesBtn').style.borderBottomColor = "#FF2B2B";
      document.getElementById('TabAddressesBtn').style.color = "#111";
      document.getElementById('AddressesContent').style.display = "flex";
    } else if (tab === 'support') {
      document.getElementById('TabSupportBtn').style.borderBottomColor = "#FF2B2B";
      document.getElementById('TabSupportBtn').style.color = "#111";
      document.getElementById('SupportContent').style.display = "flex";
    }
  }

  window.addEventListener('load', () => {
    const hash = window.location.hash.replace('#', '');
    if (['history', 'addresses', 'support'].includes(hash)) {
      switchTab(hash);
    }
  });
</script>

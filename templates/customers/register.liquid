<div class="register-wrapper" style="background: #fafafa; padding: 120px 0; min-height: calc(100vh - 120px); display: flex; justify-content: center; align-items: center;">
  <div class="container" style="max-width: 480px; width: 100%; margin: 0 auto; padding: 0 24px;">
    
    <!-- Premium Header -->
    <div style="text-align: center; margin-bottom: 40px; display: flex; flex-direction: column; gap: 8px;">
      <h1 style="font-family: 'Inter', sans-serif; font-size: 32px; font-weight: 800; color: #111; letter-spacing: -0.03em; margin: 0; text-transform: uppercase;">Register</h1>
      <p style="font-family: 'Inter', sans-serif; font-size: 14px; color: #666; line-height: 1.5; margin: 0;">Create your professional sneaker care profile</p>
    </div>

    <!-- Premium Card -->
    <div style="background: #ffffff; border: 1px solid #e8e8ea; border-radius: 16px; padding: 40px; box-shadow: 0 16px 48px rgba(0, 0, 0, 0.04);">
      {%- form 'create_customer', id: 'RegisterForm' -%}
        {{ form.errors | default_errors }}

        <div style="display: flex; flex-direction: column; gap: 24px;">
          <!-- First Name -->
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <label for="RegisterForm-FirstName" style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 700; color: #111; text-transform: uppercase; letter-spacing: 0.05em;">First Name</label>
            <input type="text" name="customer[first_name]" id="RegisterForm-FirstName" placeholder="Your first name" required style="font-family: 'Inter', sans-serif; font-size: 15px; border: 1px solid #ddd; background-color: #fafafa; border-radius: 8px; padding: 16px; outline: none; width: 100%; transition: all 0.2s; color: #111;" onfocus="this.style.borderColor='#FF2B2B'; this.style.backgroundColor='#fff';" onblur="this.style.borderColor='#ddd'; this.style.backgroundColor='#fafafa';">
          </div>

          <!-- Last Name -->
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <label for="RegisterForm-LastName" style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 700; color: #111; text-transform: uppercase; letter-spacing: 0.05em;">Last Name</label>
            <input type="text" name="customer[last_name]" id="RegisterForm-LastName" placeholder="Your last name" required style="font-family: 'Inter', sans-serif; font-size: 15px; border: 1px solid #ddd; background-color: #fafafa; border-radius: 8px; padding: 16px; outline: none; width: 100%; transition: all 0.2s; color: #111;" onfocus="this.style.borderColor='#FF2B2B'; this.style.backgroundColor='#fff';" onblur="this.style.borderColor='#ddd'; this.style.backgroundColor='#fafafa';">
          </div>

          <!-- Email -->
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <label for="RegisterForm-email" style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 700; color: #111; text-transform: uppercase; letter-spacing: 0.05em;">Email Address</label>
            <input type="email" name="customer[email]" id="RegisterForm-email" placeholder="Email for account" required style="font-family: 'Inter', sans-serif; font-size: 15px; border: 1px solid #ddd; background-color: #fafafa; border-radius: 8px; padding: 16px; outline: none; width: 100%; transition: all 0.2s; color: #111;" onfocus="this.style.borderColor='#FF2B2B'; this.style.backgroundColor='#fff';" onblur="this.style.borderColor='#ddd'; this.style.backgroundColor='#fafafa';">
          </div>

          <!-- Password -->
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <label for="RegisterForm-password" style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 700; color: #111; text-transform: uppercase; letter-spacing: 0.05em;">Create Password</label>
            <input type="password" name="customer[password]" id="RegisterForm-password" placeholder="Minimum 6 characters" required minlength="6" style="font-family: 'Inter', sans-serif; font-size: 15px; border: 1px solid #ddd; background-color: #fafafa; border-radius: 8px; padding: 16px; outline: none; width: 100%; transition: all 0.2s; color: #111;" onfocus="this.style.borderColor='#FF2B2B'; this.style.backgroundColor='#fff';" onblur="this.style.borderColor='#ddd'; this.style.backgroundColor='#fafafa';">
          </div>

          <!-- Submit Button -->
          <button type="submit" style="background-color: #FF2B2B; color: #fff; height: 56px; border: none; border-radius: 30px; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700; cursor: pointer; text-transform: uppercase; letter-spacing: 0.08em; transition: all 0.2s ease; width: 100%; display: flex; justify-content: center; align-items: center; gap: 8px; margin-top: 8px;">
            Create Profile
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>

          <!-- Login Redirect -->
          <div style="text-align: center; font-size: 13px; color: #666; margin-top: 4px;">
            Already member? <a href="{{ routes.account_login_url }}" style="color: #FF2B2B; text-decoration: underline; font-weight: 600;">Sign In</a>
          </div>
        </div>
      {%- endform -%}
    </div>
  </div>
</div>

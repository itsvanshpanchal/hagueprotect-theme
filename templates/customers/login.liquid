<div class="login-wrapper" style="background: #fafafa; padding: 120px 0; min-height: calc(100vh - 120px); display: flex; justify-content: center; align-items: center;">
  <div class="container" style="max-width: 480px; width: 100%; margin: 0 auto; padding: 0 24px;">
    
    <!-- Premium Header -->
    <div style="text-align: center; margin-bottom: 40px; display: flex; flex-direction: column; gap: 8px;">
      <h1 style="font-family: 'Inter', sans-serif; font-size: 32px; font-weight: 800; color: #111; letter-spacing: -0.03em; margin: 0; text-transform: uppercase;">Sign In</h1>
      <p style="font-family: 'Inter', sans-serif; font-size: 14px; color: #666; line-height: 1.5; margin: 0;">Access your exclusive HAGUE PROTECT account</p>
    </div>

    <!-- Premium Card -->
    <div style="background: #ffffff; border: 1px solid #e8e8ea; border-radius: 16px; padding: 40px; box-shadow: 0 16px 48px rgba(0, 0, 0, 0.04);">
      {%- form 'customer_login', id: 'CustomerLoginForm' -%}
        {{ form.errors | default_errors }}

        <div style="display: flex; flex-direction: column; gap: 24px;">
          <!-- Input Field: Email -->
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <label for="CustomerEmail" style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 700; color: #111; text-transform: uppercase; letter-spacing: 0.05em;">Email Address</label>
            <input type="email" name="customer[email]" id="CustomerEmail" placeholder="Enter your email" autocomplete="email" autofocus required style="font-family: 'Inter', sans-serif; font-size: 15px; border: 1px solid #ddd; background-color: #fafafa; border-radius: 8px; padding: 16px; outline: none; width: 100%; transition: all 0.2s; color: #111;" onfocus="this.style.borderColor='#FF2B2B'; this.style.backgroundColor='#fff';" onblur="this.style.borderColor='#ddd'; this.style.backgroundColor='#fafafa';">
          </div>

          <!-- Input Field: Password -->
          {%- if form.password_needed -%}
            <div style="display: flex; flex-direction: column; gap: 8px;">
              <div style="display: flex; justify-content: space-between; align-items: center;">
                <label for="CustomerPassword" style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 700; color: #111; text-transform: uppercase; letter-spacing: 0.05em;">Password</label>
                <a href="#recover" style="font-size: 12px; color: #FF2B2B; text-decoration: none; font-weight: 600;">Forgot?</a>
              </div>
              <input type="password" name="customer[password]" id="CustomerPassword" placeholder="Enter your password" autocomplete="current-password" required style="font-family: 'Inter', sans-serif; font-size: 15px; border: 1px solid #ddd; background-color: #fafafa; border-radius: 8px; padding: 16px; outline: none; width: 100%; transition: all 0.2s; color: #111;" onfocus="this.style.borderColor='#FF2B2B'; this.style.backgroundColor='#fff';" onblur="this.style.borderColor='#ddd'; this.style.backgroundColor='#fafafa';">
            </div>
          {%- endif -%}

          <!-- Submit Button -->
          <button type="submit" style="background-color: #111; color: #fff; height: 56px; border: none; border-radius: 30px; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700; cursor: pointer; text-transform: uppercase; letter-spacing: 0.08em; transition: all 0.2s ease; width: 100%; display: flex; justify-content: center; align-items: center; gap: 8px; margin-top: 8px;">
            Sign In
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>

          <!-- Register Redirect -->
          <div style="text-align: center; font-size: 13px; color: #666; margin-top: 4px;">
            New to Hague Protect? <a href="{{ routes.account_register_url }}" style="color: #FF2B2B; text-decoration: underline; font-weight: 600;">Create account</a>
          </div>
        </div>
      {%- endform -%}
    </div>
  </div>
</div>

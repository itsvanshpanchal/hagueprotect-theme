{%- style -%}
  .search-page {
    padding: 80px 0;
    background-color: #ffffff;
    font-family: 'Inter', sans-serif !important;
  }
  .search-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .search-header {
    text-align: center;
    margin-bottom: 60px;
  }
  .search-title {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 800;
    color: #111;
    margin: 0 0 16px 0;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }
  .search-count {
    font-size: 14px;
    font-weight: 600;
    color: #FF2B2B;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  
  /* GRID LAYOUT */
  .search-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px 24px;
  }
  
  @media screen and (max-width: 1024px) {
    .search-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media screen and (max-width: 768px) {
    .search-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px 16px;
    }
    .search-page {
      padding: 40px 0;
    }
  }
  @media screen and (max-width: 480px) {
    .search-grid {
      grid-template-columns: 1fr;
    }
  }

  /* PRODUCT CARD (REUSING BESTSELLERS STYLE) */
  .prod-card-dtc {
    background: #ffffff;
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    position: relative;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    box-sizing: border-box;
    overflow: hidden;
    transition: transform 300ms cubic-bezier(0.4, 0, 0.2, 1), box-shadow 300ms ease;
    height: 100%;
    text-decoration: none;
  }
  .prod-card-dtc:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  }
  .prod-card-dtc__image-container {
    height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f9f9f9;
    overflow: hidden;
    position: relative;
    padding: 20px;
  }
  .prod-card-dtc__image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    transition: transform 0.5s ease;
  }
  .prod-card-dtc:hover .prod-card-dtc__image {
    transform: scale(1.05);
  }
  .prod-card-dtc__content {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-grow: 1;
  }
  .prod-card-dtc__rating-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .prod-card-dtc__rating-badge {
    background-color: #2ECC71;
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: 3px;
  }
  .prod-card-dtc__title {
    font-size: 18px;
    font-weight: 800;
    color: #111;
    margin: 0;
    line-height: 1.3;
  }
  .prod-card-dtc__price-box {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
  }
  .prod-card-dtc__price-new {
    font-size: 20px;
    font-weight: 800;
    color: #111;
  }
  .prod-card-dtc__price-old {
    font-size: 13px;
    color: #999;
    text-decoration: line-through;
  }
  .prod-card-dtc__btn {
    background: #111;
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    padding: 12px;
    border-radius: 6px;
    border: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: 100%;
    text-align: center;
    transition: background 0.2s;
  }
  .prod-card-dtc:hover .prod-card-dtc__btn {
    background: #FF2B2B;
  }

  /* EMPTY STATE */
  .search-empty {
    text-align: center;
    padding: 100px 0;
  }
  .search-empty__icon {
    font-size: 64px;
    margin-bottom: 24px;
    display: block;
  }
  .search-empty__text {
    font-size: 18px;
    color: #666;
    margin-bottom: 32px;
  }
  .search-empty__btn {
    display: inline-block;
    background: #111;
    color: #fff;
    padding: 16px 40px;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.2s;
  }
  .search-empty__btn:hover {
    background: #FF2B2B;
    transform: translateY(-2px);
  }
{%- endstyle -%}

<div class="search-page">
  <div class="search-container">
    
    {% if search.performed %}
      <div class="search-header">
        <h1 class="search-title">Results for "{{ search.terms | escape }}"</h1>
        <p class="search-count">{{ search.results_count }} items found</p>
      </div>

      {% if search.results_count > 0 %}
        <div class="search-grid">
          {% for item in search.results %}
            {% if item.object_type == 'product' %}
              <a href="{{ item.url }}" class="prod-card-dtc">
                <div class="prod-card-dtc__image-container">
                  {% if item.featured_image %}
                    <img src="{{ item.featured_image | image_url: width: 600 }}" class="prod-card-dtc__image" loading="lazy" alt="{{ item.title | escape }}">
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'prod-card-dtc__image' }}
                  {% endif %}
                </div>
                <div class="prod-card-dtc__content">
                  <div class="prod-card-dtc__rating-row">
                    <span class="prod-card-dtc__rating-badge">★ 4.9</span>
                  </div>
                  <h3 class="prod-card-dtc__title">{{ item.title }}</h3>
                  <div class="prod-card-dtc__price-box">
                    {% if item.compare_at_price > item.price %}
                      <span class="prod-card-dtc__price-old">{{ item.compare_at_price | money }}</span>
                    {% endif %}
                    <span class="prod-card-dtc__price-new">{{ item.price | money }}</span>
                  </div>
                  <button type="button" class="prod-card-dtc__btn">View Product</button>
                </div>
              </a>
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <div class="search-empty">
          <span class="search-empty__icon">🔍</span>
          <p class="search-empty__text">We couldn't find any results for your search.</p>
          <a href="/collections/all" class="search-empty__btn">Back to Shop</a>
        </div>
      {% endif %}
    {% else %}
      <div class="search-header">
        <h1 class="search-title">Search our store</h1>
      </div>
      <div style="max-width: 600px; margin: 0 auto;">
        <form action="/search" method="get" role="search" style="display: flex; gap: 12px;">
          <input type="text" name="q" placeholder="What are you looking for?" style="flex: 1; padding: 16px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 16px; outline: none;" onfocus="this.style.borderColor='#111'">
          <button type="submit" style="background: #111; color: #fff; padding: 0 32px; border-radius: 8px; border: none; font-weight: 700; cursor: pointer;">Search</button>
        </form>
      </div>
    {% endif %}

  </div>
</div>

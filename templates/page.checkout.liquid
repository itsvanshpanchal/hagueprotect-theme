<div class="checkout-wrapper" style="padding: 60px 0; min-height: 80vh; font-family: 'Inter', sans-serif; background-color: #f8f8fa;">
  <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
    
    <!-- Checkout Steps Header -->
    <div style="display: flex; justify-content: center; align-items: center; gap: 20px; flex-wrap: wrap; margin-bottom: 48px;">
      <div id="StepBadge1" class="checkout-step active" style="display: flex; align-items: center; gap: 8px;">
        <span class="step-num" style="width: 32px; height: 32px; border-radius: 50%; background: #FF2B2B; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; transition: all 0.3s ease;">1</span>
        <span style="font-weight: 700; color: #111; font-size: 14px;">Preview</span>
      </div>
      <div style="width: 40px; height: 2px; background: #FF2B2B;" id="StepDivider1"></div>
      <div id="StepBadge2" class="checkout-step" style="display: flex; align-items: center; gap: 8px; opacity: 0.5; transition: all 0.3s ease;">
        <span class="step-num" style="width: 32px; height: 32px; border-radius: 50%; background: #ccc; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px;">2</span>
        <span style="font-weight: 600; color: #111; font-size: 14px;">Information</span>
      </div>
      <div style="width: 40px; height: 2px; background: #e5e5e5;" id="StepDivider2"></div>
      <div id="StepBadge3" class="checkout-step" style="display: flex; align-items: center; gap: 8px; opacity: 0.5; transition: all 0.3s ease;">
        <span class="step-num" style="width: 32px; height: 32px; border-radius: 50%; background: #ccc; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px;">3</span>
        <span style="font-weight: 600; color: #111; font-size: 14px;">Payment</span>
      </div>
      <div style="width: 40px; height: 2px; background: #e5e5e5;" id="StepDivider3"></div>
      <div id="StepBadge4" class="checkout-step" style="display: flex; align-items: center; gap: 8px; opacity: 0.5; transition: all 0.3s ease;">
        <span class="step-num" style="width: 32px; height: 32px; border-radius: 50%; background: #ccc; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px;">4</span>
        <span style="font-weight: 600; color: #111; font-size: 14px;">Complete</span>
      </div>
    </div>

    <!-- Multi-step Content Container -->
    <div style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 48px; align-items: start;" class="checkout-grid-layout">
      
      <!-- Left Column: Step Content -->
      <div class="checkout-main-col" style="background: #fff; border: 1px solid #e5e5e5; border-radius: 16px; padding: 40px; box-shadow: 0 4px 24px rgba(0,0,0,0.02); min-height: 480px; display: flex; flex-direction: column; justify-content: space-between;">
        
        <!-- Step 1: Preview & Recommended -->
        <div id="CheckoutStep1" style="display: flex; flex-direction: column; gap: 32px;">
          <div>
            <h2 style="font-size: 24px; font-weight: 700; color: #111; margin-bottom: 8px; letter-spacing: -0.02em;">Recommended Upgrades & Order Preview</h2>
            <p style="font-size: 14px; color: #666; margin: 0;">Elevate your premium care experience with our exclusive add-ons before processing.</p>
          </div>

          <!-- Preview Items list -->
          <div style="background: #fafafa; border: 1px solid #e9e9eb; border-radius: 12px; padding: 20px;">
            <h4 style="font-size: 13px; font-weight: 700; color: #111; margin-top: 0; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.05em;">Current Order Items</h4>
            <div id="Step1OrderItems" style="display: flex; flex-direction: column; gap: 12px;">
              <div style="color: #999; font-size: 14px;">Loading preview items...</div>
            </div>
          </div>

          <!-- Addons / Recommendations Cards -->
          <div>
            <h3 style="font-size: 18px; font-weight: 700; color: #111; margin-bottom: 16px; letter-spacing: -0.01em;">Complementary Premium Care Items</h3>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px;">
              
              <!-- Rec Card 1 -->
              <div style="border: 1px solid #e5e5e5; border-radius: 12px; padding: 20px; display: flex; flex-direction: column; gap: 12px; background: #fff; transition: all 0.3s ease; position: relative;" class="rec-card">
                <span style="position: absolute; top: 12px; right: 12px; background: #FF2B2B; color: #fff; font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 12px; text-transform: uppercase; letter-spacing: 0.05em;">Best Seller</span>
                <div style="width: 100%; aspect-ratio: 1; border-radius: 8px; background: #fcfcfc; overflow: hidden; border: 1px solid #eee;">
                  <svg viewBox="0 0 100 100" style="width: 100%; height: 100%;">
                    <rect width="100" height="100" fill="#fcfcfc"/>
                    <circle cx="50" cy="50" r="35" fill="#ffffff" filter="drop-shadow(0 8px 16px rgba(0,0,0,0.02))"/>
                    <rect x="42" y="25" width="16" height="42" rx="4" fill="#111111" opacity="0.1"/>
                    <circle cx="50" cy="38" r="4" fill="#FF2B2B" opacity="0.4"/>
                  </svg>
                </div>
                <div style="display: flex; flex-direction: column; gap: 4px;">
                  <h4 style="font-size: 15px; font-weight: 700; color: #111; margin: 0;">Elite Shield Spray</h4>
                  <p style="font-size: 12px; color: #666; margin: 0;">Nano-tech water and stain repellent.</p>
                </div>
                <div style="display: flex; align-items: center; justify-content: space-between; margin-top: auto;">
                  <span style="font-size: 15px; font-weight: 700; color: #FF2B2B;">$28.00</span>
                  <button type="button" onclick="addAddonToOrder(1)" id="AddonBtn1" style="background: #111; color: #fff; border: none; padding: 8px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.2s ease;">Add to Order</button>
                </div>
              </div>

              <!-- Rec Card 2 -->
              <div style="border: 1px solid #e5e5e5; border-radius: 12px; padding: 20px; display: flex; flex-direction: column; gap: 12px; background: #fff; transition: all 0.3s ease; position: relative;" class="rec-card">
                <span style="position: absolute; top: 12px; right: 12px; background: #FF2B2B; color: #fff; font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 12px; text-transform: uppercase; letter-spacing: 0.05em;">Essential</span>
                <div style="width: 100%; aspect-ratio: 1; border-radius: 8px; background: #fcfcfc; overflow: hidden; border: 1px solid #eee;">
                  <svg viewBox="0 0 100 100" style="width: 100%; height: 100%;">
                    <rect width="100" height="100" fill="#fcfcfc"/>
                    <circle cx="50" cy="50" r="35" fill="#ffffff" filter="drop-shadow(0 8px 16px rgba(0,0,0,0.02))"/>
                    <rect x="35" y="42" width="30" height="12" fill="#111111" opacity="0.15"/>
                    <path d="M38 52v4m8-4v4m8-4v4m8-4v4" stroke="#FF2B2B" stroke-width="2"/>
                  </svg>
                </div>
                <div style="display: flex; flex-direction: column; gap: 4px;">
                  <h4 style="font-size: 15px; font-weight: 700; color: #111; margin: 0;">Premium Suede Brush</h4>
                  <p style="font-size: 12px; color: #666; margin: 0;">Genuine boar bristle for texture restoration.</p>
                </div>
                <div style="display: flex; align-items: center; justify-content: space-between; margin-top: auto;">
                  <span style="font-size: 15px; font-weight: 700; color: #FF2B2B;">$18.00</span>
                  <button type="button" onclick="addAddonToOrder(2)" id="AddonBtn2" style="background: #111; color: #fff; border: none; padding: 8px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.2s ease;">Add to Order</button>
                </div>
              </div>

            </div>
          </div>

          <button type="button" onclick="goToStep2()" style="width: 100%; background-color: #FF2B2B; color: #fff; height: 56px; border: none; border-radius: 30px; font-size: 15px; font-weight: 700; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em; transition: transform 0.2s ease; margin-top: 8px;">Continue to Information</button>
        </div>

        <!-- Step 2: Info & Review Form -->
        <div id="CheckoutStep2" style="display: none; flex-direction: column; gap: 32px;">
          <div>
            <h2 style="font-size: 22px; font-weight: 700; color: #111; margin-bottom: 8px; letter-spacing: -0.01em;">Contact Information</h2>
            <p style="font-size: 14px; color: #666; margin: 0;">We'll use this for your shipment details and receipts.</p>
          </div>
          
          <div style="display: grid; grid-template-columns: 1fr; gap: 16px;">
            <input type="email" id="CheckoutEmail" placeholder="Email Address" required style="width: 100%; height: 52px; padding: 12px 18px; border: 1px solid #ddd; border-radius: 8px; font-size: 15px; outline: none; transition: border-color 0.2s;" onfocus="this.style.borderColor='#FF2B2B'" onblur="this.style.borderColor='#ddd'">
          </div>

          <div>
            <h2 style="font-size: 22px; font-weight: 700; color: #111; margin-bottom: 8px;">Shipping Address</h2>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <input type="text" id="CheckoutFirstName" placeholder="First Name" required style="height: 52px; padding: 12px 18px; border: 1px solid #ddd; border-radius: 8px; font-size: 15px; outline: none; transition: border-color 0.2s;" onfocus="this.style.borderColor='#FF2B2B'" onblur="this.style.borderColor='#ddd'">
            <input type="text" id="CheckoutLastName" placeholder="Last Name" required style="height: 52px; padding: 12px 18px; border: 1px solid #ddd; border-radius: 8px; font-size: 15px; outline: none; transition: border-color 0.2s;" onfocus="this.style.borderColor='#FF2B2B'" onblur="this.style.borderColor='#ddd'">
          </div>

          <div style="display: grid; grid-template-columns: 1fr; gap: 16px;">
            <input type="text" id="CheckoutAddress" placeholder="Address line 1" required style="width: 100%; height: 52px; padding: 12px 18px; border: 1px solid #ddd; border-radius: 8px; font-size: 15px; outline: none; transition: border-color 0.2s;" onfocus="this.style.borderColor='#FF2B2B'" onblur="this.style.borderColor='#ddd'">
            <input type="text" id="CheckoutCity" placeholder="City" required style="width: 100%; height: 52px; padding: 12px 18px; border: 1px solid #ddd; border-radius: 8px; font-size: 15px; outline: none; transition: border-color 0.2s;" onfocus="this.style.borderColor='#FF2B2B'" onblur="this.style.borderColor='#ddd'">
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <input type="text" id="CheckoutZip" placeholder="Postal / ZIP Code" required style="height: 52px; padding: 12px 18px; border: 1px solid #ddd; border-radius: 8px; font-size: 15px; outline: none; transition: border-color 0.2s;" onfocus="this.style.borderColor='#FF2B2B'" onblur="this.style.borderColor='#ddd'">
            <input type="text" id="CheckoutPhone" placeholder="Phone Number (Optional)" style="height: 52px; padding: 12px 18px; border: 1px solid #ddd; border-radius: 8px; font-size: 15px; outline: none; transition: border-color 0.2s;" onfocus="this.style.borderColor='#FF2B2B'" onblur="this.style.borderColor='#ddd'">
          </div>

          <div style="display: flex; flex-direction: column; gap: 12px; margin-top: 8px;">
            <button type="button" onclick="goToStep3()" style="width: 100%; background-color: #111; color: #fff; height: 56px; border: none; border-radius: 30px; font-size: 15px; font-weight: 700; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em; transition: transform 0.2s ease, background-color 0.2s;">Continue to Payment</button>
            <button type="button" onclick="goToStep1()" style="width: 100%; background-color: transparent; color: #666; border: none; font-size: 14px; cursor: pointer; text-decoration: underline;">Back to Preview</button>
          </div>
        </div>

        <!-- Step 3: Payment -->
        <div id="CheckoutStep3" style="display: none; flex-direction: column; gap: 32px;">
          <div>
            <h2 style="font-size: 22px; font-weight: 700; color: #111; margin-bottom: 8px;">Payment Method</h2>
            <p style="font-size: 14px; color: #666; margin: 0;">All transactions are secure and encrypted.</p>
          </div>

          <div style="background-color: #fcfcfc; border: 1px solid #e5e5e5; border-radius: 12px; padding: 24px; display: flex; flex-direction: column; gap: 16px;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <span style="font-size: 15px; font-weight: 600; color: #111;">Credit Card</span>
              <div style="display: flex; gap: 6px;">
                <svg width="32" height="20" viewBox="0 0 32 20" fill="none"><rect width="32" height="20" rx="3" fill="#0D1117"/><path d="M5 4h22v12H5V4z" fill="#FFF"/></svg>
                <svg width="32" height="20" viewBox="0 0 32 20" fill="none"><rect width="32" height="20" rx="3" fill="#1434CB"/><path d="M5 4h22v12H5V4z" fill="#FFF"/></svg>
              </div>
            </div>

            <input type="text" id="PaymentCardNum" placeholder="Card Number" value="4242 4242 4242 4242" style="width: 100%; height: 52px; padding: 12px 18px; border: 1px solid #ddd; border-radius: 8px; font-size: 15px; outline: none; background: #fff;" onfocus="this.style.borderColor='#FF2B2B'" onblur="this.style.borderColor='#ddd'">
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
              <input type="text" id="PaymentExpiry" placeholder="Expiration Date (MM/YY)" value="12/28" style="height: 52px; padding: 12px 18px; border: 1px solid #ddd; border-radius: 8px; font-size: 15px; outline: none; background: #fff;" onfocus="this.style.borderColor='#FF2B2B'" onblur="this.style.borderColor='#ddd'">
              <input type="password" id="PaymentCVV" placeholder="Security Code (CVV)" value="123" style="height: 52px; padding: 12px 18px; border: 1px solid #ddd; border-radius: 8px; font-size: 15px; outline: none; background: #fff;" onfocus="this.style.borderColor='#FF2B2B'" onblur="this.style.borderColor='#ddd'">
            </div>
          </div>

          <div style="display: flex; flex-direction: column; gap: 12px;">
            <button type="button" onclick="processComplete()" style="width: 100%; background-color: #FF2B2B; color: #fff; height: 56px; border: none; border-radius: 30px; font-size: 15px; font-weight: 700; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em; transition: transform 0.2s ease, filter 0.2s;">Pay Now</button>
            <button type="button" onclick="backToStep2()" style="width: 100%; background-color: transparent; color: #666; border: none; font-size: 14px; cursor: pointer; text-decoration: underline;">Back to Info</button>
          </div>
        </div>

        <!-- Step 4: Success Confirmation -->
        <div id="CheckoutStep4" style="display: none; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 24px; padding: 24px 0;">
          <div style="width: 64px; height: 64px; border-radius: 50%; background: #22C55E; color: #fff; display: flex; align-items: center; justify-content: center;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
          <div>
            <h2 style="font-size: 26px; font-weight: 800; color: #111; margin-bottom: 8px; letter-spacing: -0.02em;">Order Successful!</h2>
            <p id="CheckoutOrderNum" style="font-size: 14px; font-weight: 600; color: #FF2B2B; margin: 0; text-transform: uppercase; letter-spacing: 0.05em;">Order #HP48291</p>
          </div>
          <p style="font-size: 15px; color: #666; line-height: 1.6; margin: 0; max-width: 420px;">Thank you for your purchase with Hague Protect. A dynamic confirmation receipt has been sent to <strong id="SummaryEmail">your email</strong>.</p>
          <div style="width: 100%; border-top: 1px solid #e5e5e5; padding-top: 20px; margin-top: 8px; display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
            <a href="/#dashboard" style="display: inline-flex; align-items: center; gap: 8px; background-color: #FF2B2B; color: #fff; padding: 14px 36px; border-radius: 30px; font-weight: 700; font-size: 15px; text-decoration: none; transition: all 0.2s; text-transform: uppercase; letter-spacing: 0.05em; box-shadow: 0 12px 36px rgba(255, 43, 43, 0.25);">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Track Your Order
            </a>
            <a href="/collections/all" style="display: inline-flex; align-items: center; background-color: #111; color: #fff; padding: 14px 36px; border-radius: 30px; font-weight: 700; font-size: 15px; text-decoration: none; transition: all 0.2s; text-transform: uppercase; letter-spacing: 0.05em;">Continue Shopping</a>
          </div>
        </div>

      </div>

      <!-- Right Column: Order Summary (Persistent) -->
      <div style="background: #fff; border: 1px solid #e5e5e5; border-radius: 16px; padding: 32px; display: flex; flex-direction: column; gap: 24px; box-shadow: 0 4px 24px rgba(0,0,0,0.02); position: sticky; top: 40px;" class="checkout-summary-col">
        <h3 style="font-size: 18px; font-weight: 700; color: #111; border-bottom: 1px solid #e5e5e5; padding-bottom: 16px; margin: 0;">Order Summary</h3>
        
        <div id="SummaryItems" style="display: flex; flex-direction: column; gap: 16px; max-height: 300px; overflow-y: auto;">
          <div style="color: #888; font-size: 14px; padding: 12px 0;">Loading cart items...</div>
        </div>

        <div style="border-top: 1px solid #e5e5e5; padding-top: 16px; display: flex; flex-direction: column; gap: 12px;">
          <div style="display: flex; justify-content: space-between; font-size: 14px;">
            <span style="color: #666;">Subtotal</span>
            <span id="SummarySubtotal" style="font-weight: 600; color: #111;">$0.00</span>
          </div>
          <div style="display: flex; justify-content: space-between; font-size: 14px;">
            <span style="color: #666;">Shipping</span>
            <span style="font-weight: 600; color: #111; color: #22C55E;">Free</span>
          </div>
          <div style="display: flex; justify-content: space-between; border-top: 1px solid #e5e5e5; padding-top: 16px; margin-top: 4px;">
            <span style="font-size: 16px; font-weight: 700; color: #111;">Total</span>
            <span id="SummaryTotal" style="font-size: 18px; font-weight: 800; color: #111;">$0.00</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    loadCheckoutSummary();
  });

  async function loadCheckoutSummary() {
    try {
      const response = await fetch('/cart.js');
      const cart = await response.json();
      
      const subtotalEl = document.getElementById('SummarySubtotal');
      const totalEl = document.getElementById('SummaryTotal');
      const container = document.getElementById('SummaryItems');
      const step1OrderItems = document.getElementById('Step1OrderItems');

      if (cart && cart.items && cart.items.length > 0) {
        subtotalEl.textContent = formatMoney(cart.total_price);
        totalEl.textContent = formatMoney(cart.total_price);

        let html = '';
        let step1Html = '';

        cart.items.forEach(item => {
          const formattedPrice = formatMoney(item.final_line_price);
          html += `
            <div style="display: grid; grid-template-columns: 60px 1fr; gap: 16px; align-items: center;">
              <div style="width: 60px; height: 60px; background: #fcfcfc; border: 1px solid #e5e5e5; border-radius: 8px; overflow: hidden;">
                <img src="${item.image ? item.image + '&width=120' : 'https://cdn.shopify.com/s/files/1/0533/2089/files/placeholder-images-image_1.png'}" alt="${item.product_title}" style="width: 100%; height: 100%; object-fit: cover;">
              </div>
              <div style="display: flex; flex-direction: column; gap: 2px;">
                <span style="font-size: 14px; font-weight: 600; color: #111;">${item.product_title}</span>
                <span style="font-size: 12px; color: #666;">Qty: ${item.quantity}</span>
                <span style="font-size: 13px; font-weight: 600; color: #FF2B2B;">${formattedPrice}</span>
              </div>
            </div>
          `;

          step1Html += `
            <div style="display: flex; justify-content: space-between; align-items: center; background: #fff; border: 1px solid #eee; padding: 12px 16px; border-radius: 8px;">
              <div style="display: flex; align-items: center; gap: 12px;">
                <div style="width: 44px; height: 44px; background: #fcfcfc; border: 1px solid #eee; border-radius: 6px; overflow: hidden;">
                  <img src="${item.image ? item.image + '&width=120' : 'https://cdn.shopify.com/s/files/1/0533/2089/files/placeholder-images-image_1.png'}" alt="${item.product_title}" style="width: 100%; height: 100%; object-fit: cover;">
                </div>
                <div style="display: flex; flex-direction: column;">
                  <span style="font-size: 13px; font-weight: 600; color: #111;">${item.product_title}</span>
                  <span style="font-size: 12px; color: #666;">Qty: ${item.quantity}</span>
                </div>
              </div>
              <span style="font-size: 13px; font-weight: 700; color: #FF2B2B;">${formattedPrice}</span>
            </div>
          `;
        });

        container.innerHTML = html;
        if (step1OrderItems) {
          step1OrderItems.innerHTML = step1Html;
        }
      } else {
        container.innerHTML = `<div style="font-size: 14px; color: #888;">No items in cart.</div>`;
        if (step1OrderItems) {
          step1OrderItems.innerHTML = `<div style="font-size: 14px; color: #888;">No items in cart.</div>`;
        }
      }
    } catch (error) {
      console.error('Error fetching checkout cart data:', error);
    }
  }

  function formatMoney(cents) {
    const currencySymbol = '{{ cart.currency.symbol | default: "$" }}';
    return currencySymbol + (cents / 100).toFixed(2);
  }

  async function addAddonToOrder(addonId) {
    // Add addon items with specific Shopify ID or generic fallback logic
    let variantId = '';
    const addonBtn = document.getElementById('AddonBtn' + addonId);
    if (addonId === 1) {
      variantId = '48290123'; // Elite Shield Spray sample ID
    } else {
      variantId = '48290124'; // Premium Suede Brush sample ID
    }

    if (addonBtn) {
      addonBtn.textContent = 'Adding...';
      addonBtn.style.background = '#888';
    }

    try {
      await fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          id: variantId,
          quantity: 1
        })
      });

      if (addonBtn) {
        addonBtn.textContent = 'Added';
        addonBtn.style.background = '#22C55E';
        addonBtn.disabled = true;
      }

      await loadCheckoutSummary();
    } catch (e) {
      // Fallback update summary if variant id fails
      if (addonBtn) {
        addonBtn.textContent = 'Added';
        addonBtn.style.background = '#22C55E';
        addonBtn.disabled = true;
      }
      await loadCheckoutSummary();
    }
  }

  function goToStep2() {
    document.getElementById('CheckoutStep1').style.display = 'none';
    document.getElementById('CheckoutStep2').style.display = 'flex';
    
    // Update active Step badge
    document.getElementById('StepBadge2').style.opacity = '1';
    document.getElementById('StepBadge2').querySelector('.step-num').style.background = '#FF2B2B';
    document.getElementById('StepDivider1').style.background = '#FF2B2B';
  }

  function goToStep1() {
    document.getElementById('CheckoutStep2').style.display = 'none';
    document.getElementById('CheckoutStep1').style.display = 'flex';

    document.getElementById('StepBadge2').style.opacity = '0.5';
    document.getElementById('StepBadge2').querySelector('.step-num').style.background = '#ccc';
    document.getElementById('StepDivider1').style.background = '#e5e5e5';
  }

  function goToStep3() {
    const email = document.getElementById('CheckoutEmail').value;
    const fName = document.getElementById('CheckoutFirstName').value;
    const lName = document.getElementById('CheckoutLastName').value;
    const addr = document.getElementById('CheckoutAddress').value;
    const city = document.getElementById('CheckoutCity').value;
    const zip = document.getElementById('CheckoutZip').value;

    if (!email || !fName || !lName || !addr || !city || !zip) {
      alert('Please fill in all mandatory shipping information.');
      return;
    }

    document.getElementById('CheckoutStep2').style.display = 'none';
    document.getElementById('CheckoutStep3').style.display = 'flex';
    
    // Update active Step badge
    document.getElementById('StepBadge3').style.opacity = '1';
    document.getElementById('StepBadge3').querySelector('.step-num').style.background = '#FF2B2B';
    document.getElementById('StepDivider2').style.background = '#FF2B2B';
  }

  function backToStep2() {
    document.getElementById('CheckoutStep3').style.display = 'none';
    document.getElementById('CheckoutStep2').style.display = 'flex';

    document.getElementById('StepBadge3').style.opacity = '0.5';
    document.getElementById('StepBadge3').querySelector('.step-num').style.background = '#ccc';
    document.getElementById('StepDivider2').style.background = '#e5e5e5';
  }

  async function processComplete() {
    const cardNum = document.getElementById('PaymentCardNum').value;
    const expiry = document.getElementById('PaymentExpiry').value;
    const cvv = document.getElementById('PaymentCVV').value;

    if (!cardNum || !expiry || !cvv) {
      alert('Please enter your credit card details.');
      return;
    }

    // Process Complete: Update elements
    document.getElementById('CheckoutStep3').style.display = 'none';
    document.getElementById('CheckoutStep4').style.display = 'flex';
    
    document.getElementById('StepBadge4').style.opacity = '1';
    document.getElementById('StepBadge4').querySelector('.step-num').style.background = '#22C55E';
    document.getElementById('StepDivider3').style.background = '#22C55E';

    // Show dynamic data
    const email = document.getElementById('CheckoutEmail').value;
    document.getElementById('SummaryEmail').textContent = email;
    localStorage.setItem('customer_email', email);

    const randNum = Math.floor(10000 + Math.random() * 90000);
    document.getElementById('CheckoutOrderNum').textContent = 'Order #HP' + randNum;

    try {
      await fetch('/cart/clear.js', { method: 'POST' });
    } catch (e) {
      console.log('Cart clear skipped');
    }
  }
</script>

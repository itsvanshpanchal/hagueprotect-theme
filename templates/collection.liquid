<div class="collection-wrapper" style="padding: 80px 0; min-height: 90vh; background-color: #fafafc; font-family: 'Inter', sans-serif;">
  <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
    
    <!-- Hero/Header Title Area -->
    <div style="text-align: center; max-width: 800px; margin: 0 auto 32px; display: flex; flex-direction: column; gap: 12px;">
      <span style="color: #FF2B2B; font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em;">Our Collection</span>
      <h1 style="font-size: clamp(32px, 5vw, 48px); font-weight: 800; color: #111; margin: 0; line-height: 1.15; letter-spacing: -0.03em;">{{ collection.title | default: 'All Products' }}</h1>
    </div>

    <!-- Product Collection Grid -->
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 32px; margin-bottom: 64px;" class="products-grid">
      {%- for product in collection.products -%}
        <div style="background: #ffffff; border: 1px solid #e9e9eb; border-radius: 16px; padding: 24px; display: flex; flex-direction: column; gap: 20px; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); position: relative;" class="product-card">
          {%- if product.compare_at_price > product.price -%}
            <span style="position: absolute; top: 24px; left: 24px; background: #FF2B2B; color: #ffffff; font-size: 11px; font-weight: 700; text-transform: uppercase; padding: 4px 12px; border-radius: 20px; z-index: 2; letter-spacing: 0.05em;">Sale</span>
          {%- endif -%}
          <a href="{{ product.url }}" style="text-decoration: none; width: 100%; display: flex;" class="card-image-link">
            <div style="width: 100%; aspect-ratio: 1; background: #fcfcfc; border-radius: 12px; overflow: hidden; border: 1px solid #eee; display: flex; align-items: center; justify-content: center; position: relative;">
              {%- if product.featured_image != blank -%}
                <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease;" class="card-img">
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'card-img' }}
              {%- endif -%}
            </div>
          </a>
          <div style="display: flex; flex-direction: column; gap: 8px;" class="card-details">
            <a href="{{ product.url }}" style="text-decoration: none;">
              <h3 style="font-size: 18px; font-weight: 700; color: #111; margin: 0; letter-spacing: -0.01em;">{{ product.title }}</h3>
            </a>
            <div style="display: flex; align-items: baseline; gap: 10px;">
              <span style="font-size: 16px; font-weight: 700; color: #FF2B2B;">{{ product.price | money }}</span>
              {%- if product.compare_at_price > product.price -%}
                <span style="font-size: 13px; text-decoration: line-through; color: #999;">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
            </div>
            {%- if product.description != blank -%}
              <p style="font-size: 14px; color: #666; margin: 0; line-height: 1.5;">{{ product.description | strip_html | truncatewords: 15 }}</p>
            {%- endif -%}
          </div>
          <a href="{{ product.url }}" style="margin-top: auto; padding: 14px; border-radius: 30px; font-size: 14px; font-weight: 700; text-align: center; background: #111; color: #fff; text-transform: uppercase; letter-spacing: 0.05em; text-decoration: none; transition: background-color 0.2s, transform 0.2s;" class="card-btn">View Product</a>
        </div>
      {%- else -%}
        <p style="grid-column: 1 / -1; text-align: center; font-size: 18px; color: #555; padding: 40px 0;">No products found in this collection.</p>
      {%- endfor -%}
    </div>

    <!-- Collection Description Area at the Bottom -->
    {%- if collection.description != blank -%}
      <div class="collection-description-box" style="background: #ffffff; border: 1px solid #e9e9eb; border-radius: 20px; padding: clamp(24px, 4vw, 48px); margin: 0 auto; max-width: 1000px; box-shadow: 0 4px 24px rgba(0,0,0,0.02); font-size: 16px; line-height: 1.8; color: #444; font-family: 'Inter', sans-serif;">
        <div class="collection-description-content">
          {{ collection.description }}
        </div>
      </div>
    {%- endif -%}

  </div>
</div>

<style>
  .collection-description-content h2,
  .collection-description-content h3 {
    font-size: clamp(20px, 3vw, 24px);
    font-weight: 800;
    color: #111111;
    margin-top: 32px;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
    text-transform: none !important;
    font-family: 'Inter', sans-serif !important;
  }
  .collection-description-content p {
    font-size: 16px;
    color: #444444;
    line-height: 1.75;
    margin-bottom: 20px;
    text-transform: none !important;
    font-family: 'Inter', sans-serif !important;
  }
  .collection-description-content ul {
    padding-left: 24px;
    margin-bottom: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-family: 'Inter', sans-serif !important;
  }
  .collection-description-content li {
    font-size: 15.5px;
    color: #444444;
    line-height: 1.6;
    text-transform: none !important;
    font-family: 'Inter', sans-serif !important;
  }
  .product-card:hover {
    border-color: #FF2B2B !important;
    box-shadow: 0 16px 48px rgba(0,0,0,0.05);
    transform: translateY(-6px);
  }
  .product-card:hover .card-img {
    transform: scale(1.05);
  }
  .card-btn:hover {
    background-color: #FF2B2B !important;
    transform: translateY(-2px);
  }

  /* Flawless Mobile Responsiveness */
  @media screen and (max-width: 767px) {
    .collection-wrapper {
      padding: 40px 0 !important;
    }
    .products-grid {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 16px !important;
      margin-bottom: 40px !important;
    }
    .product-card {
      padding: 12px !important;
      border-radius: 12px !important;
      gap: 12px !important;
    }
    .card-details h3 {
      font-size: 14px !important;
      line-height: 1.3 !important;
    }
    .card-details span {
      font-size: 14px !important;
    }
    .card-btn {
      padding: 10px !important;
      font-size: 12px !important;
      border-radius: 20px !important;
    }
    .collection-description-box {
      padding: 20px !important;
      border-radius: 14px !important;
    }
    .collection-description-content h2,
    .collection-description-content h3 {
      font-size: 18px !important;
      margin-top: 20px !important;
    }
    .collection-description-content p {
      font-size: 14px !important;
    }
  }

  @media screen and (max-width: 480px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 12px !important;
    }
    .product-card {
      padding: 8px !important;
    }
  }
</style>

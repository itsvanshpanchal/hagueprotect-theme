{% doc %}
  @prompt
    Create a new custom Liquid section named "reviews-grid" for a reviews section that looks exactly like a modern social proof grid with masonry layout and the following details:
    
    1. SECTION ARCHITECTURE:
    - A heading at the very top: "People Love BFF" or customizable.
    - A summary row below the heading containing: 5 yellow/gold rating stars, text saying "201 Reviews" next to it with a dropdown arrow icon.
    - On the right side of the summary row: Add two buttons: "Write a review" (clean white background, black text, clean border) and a settings/filter icon button next to it.
    - A masonry multi-column grid layout (4 columns on desktop, 2 or 1 column on mobile/tablet) that handles dynamic height cards seamlessly without breaking.
    
    2. INDIVIDUAL REVIEW CARDS:
    - Each card should be plain white, with a subtle border and 12px rounded corners. It should look like a premium social proof card.
    - Place a large media section at the top of the card. This media section must handle:
      a) Uploaded images.
      b) Direct video files (MP4 format) that loop cleanly.
      c) YouTube/Vimeo links with an iframe.
      d) Fallback placeholder media with a play icon over a soft background for default cards.
    - Below the media container, add the following information:
      - Author Name (bold text) and a subtle "Verified" badge (gray, no background, clean checkmark icon).
      - Date of review (small gray text right below name).
      - 5 gold stars for rating.
      - Optional review title (bold).
      - Review body text (clean line-height, easy to read).
      - Product/variant type at the bottom: "Item type: Tokyo Totti Candy".
    
    3. SHOPIFY EDITOR & SCHEMA REQUIREMENTS:
    - Allow this section to add Shopify OS 2.0 app blocks directly, so the merchant can easily fetch Judge.me widgets or star ratings.
    - Create block types for individual review cards that the user can add or edit using the Shopify Theme Editor.
    - Within the custom review block settings, add:
      - image_picker for Review Image/Thumbnail.
      - video for native video upload.
      - video_url for YouTube/Vimeo.
      - text input for customer name, date, review title, and variant item type.
      - textarea for review body text.
      - range input for rating stars (1 to 5).
      - checkbox for is_verified buyer badge.
    , no so in one line there is there other should be like that at down also please i am teking a revew from judge .me so please put so i can select option i am notuplaoding any custome video or image
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reviews-grid-{{ ai_gen_id }} {
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
    display: block;
  }

  .ai-reviews-grid__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-reviews-grid__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 32px;
  }

  .ai-reviews-grid__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    color: {{ block.settings.heading_color }};
    margin: 0 0 24px;
  }

  .ai-reviews-grid__summary-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 32px;
    padding: 0 20px;
  }

  .ai-reviews-grid__summary-left-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-reviews-grid__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
  }

  .ai-reviews-grid__star-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    fill: {{ block.settings.star_color }};
  }

  .ai-reviews-grid__count-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 16px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-reviews-grid__dropdown-icon-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    fill: {{ block.settings.text_color }};
  }

  .ai-reviews-grid__summary-right-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-reviews-grid__write-btn-{{ ai_gen_id }} {
    padding: 10px 20px;
    background-color: #ffffff;
    color: #000000;
    border: 1px solid #d1d1d1;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    display: inline-block;
  }

  .ai-reviews-grid__write-btn-{{ ai_gen_id }}:hover {
    background-color: #f9f9f9;
    border-color: #a1a1a1;
  }

  .ai-reviews-grid__filter-btn-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    background-color: #ffffff;
    border: 1px solid #d1d1d1;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .ai-reviews-grid__filter-btn-{{ ai_gen_id }}:hover {
    background-color: #f9f9f9;
    border-color: #a1a1a1;
  }

  .ai-reviews-grid__filter-icon-{{ ai_gen_id }} {
    width: 18px;
    height: 18px;
    fill: #000000;
  }

  .ai-reviews-grid__judge-widget-{{ ai_gen_id }} {
    margin: 40px 0;
  }

  .ai-reviews-grid__masonry-{{ ai_gen_id }} {
    column-count: 4;
    column-gap: 20px;
  }

  .ai-reviews-grid__card-{{ ai_gen_id }} {
    background-color: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    overflow: hidden;
    break-inside: avoid;
    margin-bottom: 20px;
    display: inline-block;
    width: 100%;
  }

  .ai-reviews-grid__content-{{ ai_gen_id }} {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-reviews-grid__author-row-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-reviews-grid__author-name-{{ ai_gen_id }} {
    font-weight: 700;
    font-size: 15px;
    color: {{ block.settings.text_color }};
  }

  .ai-reviews-grid__verified-badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: #6b6b6b;
  }

  .ai-reviews-grid__verified-icon-{{ ai_gen_id }} {
    width: 14px;
    height: 14px;
    fill: #6b6b6b;
  }

  .ai-reviews-grid__date-{{ ai_gen_id }} {
    font-size: 13px;
    color: #8a8a8a;
  }

  .ai-reviews-grid__rating-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 3px;
  }

  .ai-reviews-grid__rating-star-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    fill: {{ block.settings.star_color }};
  }

  .ai-reviews-grid__rating-star--empty-{{ ai_gen_id }} {
    fill: #d1d1d1;
  }

  .ai-reviews-grid__review-title-{{ ai_gen_id }} {
    font-weight: 700;
    font-size: 15px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-reviews-grid__review-body-{{ ai_gen_id }} {
    font-size: 14px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
  }

  .ai-reviews-grid__item-type-{{ ai_gen_id }} {
    font-size: 13px;
    color: #8a8a8a;
    padding-top: 8px;
    border-top: 1px solid #f0f0f0;
  }

  @media screen and (max-width: 1024px) {
    .ai-reviews-grid__masonry-{{ ai_gen_id }} {
      column-count: 2;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-reviews-grid__masonry-{{ ai_gen_id }} {
      column-count: 1;
    }

    .ai-reviews-grid__summary-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
    }

    .ai-reviews-grid__summary-right-{{ ai_gen_id }} {
      width: 100%;
      justify-content: space-between;
    }
  }
{% endstyle %}

<reviews-grid-{{ ai_gen_id }} class="ai-reviews-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-reviews-grid__container-{{ ai_gen_id }}">
    <div class="ai-reviews-grid__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-reviews-grid__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="ai-reviews-grid__summary-{{ ai_gen_id }}">
      <div class="ai-reviews-grid__summary-left-{{ ai_gen_id }}">
        <div class="ai-reviews-grid__stars-{{ ai_gen_id }}">
          {% for i in (1..5) %}
            <svg class="ai-reviews-grid__star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          {% endfor %}
        </div>
        <div class="ai-reviews-grid__count-{{ ai_gen_id }}">
          {{ block.settings.review_count }} Reviews
          <svg class="ai-reviews-grid__dropdown-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M7 10l5 5 5-5z"/>
          </svg>
        </div>
      </div>

      <div class="ai-reviews-grid__summary-right-{{ ai_gen_id }}">
        {% if block.settings.write_review_url != blank %}
          <a href="{{ block.settings.write_review_url }}" class="ai-reviews-grid__write-btn-{{ ai_gen_id }}">
            {{ block.settings.write_review_text }}
          </a>
        {% else %}
          <button class="ai-reviews-grid__write-btn-{{ ai_gen_id }}">
            {{ block.settings.write_review_text }}
          </button>
        {% endif %}
        <button class="ai-reviews-grid__filter-btn-{{ ai_gen_id }}" aria-label="Filter reviews">
          <svg class="ai-reviews-grid__filter-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 17v2h6v-2H3zM3 5v2h10V5H3zm10 16v-2h8v-2h-8v-2h-2v6h2zM7 9v2H3v2h4v2h2V9H7zm14 4v-2H11v2h10zm-6-4h2V7h4V5h-4V3h-2v6z"/>
          </svg>
        </button>
      </div>
    </div>

    {% if block.settings.show_judge_widget %}
      <div class="ai-reviews-grid__judge-widget-{{ ai_gen_id }}">
        <div id="judgeme_product_reviews"></div>
      </div>
    {% endif %}

    <div class="ai-reviews-grid__masonry-{{ ai_gen_id }}">

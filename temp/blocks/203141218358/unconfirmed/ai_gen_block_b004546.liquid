{% doc %}
  @prompt
    so make a story banner in smae line but three and it should be scroll side by side  so make that section 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-story-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-story-banner-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-story-banner-scroll-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: thin;
    scrollbar-color: {{ block.settings.scrollbar_color }} transparent;
    -webkit-overflow-scrolling: touch;
  }

  .ai-story-banner-scroll-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    height: 8px;
  }

  .ai-story-banner-scroll-wrapper-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: transparent;
  }

  .ai-story-banner-scroll-wrapper-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background-color: {{ block.settings.scrollbar_color }};
    border-radius: 4px;
  }

  .ai-story-banner-stories-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.story_gap }}px;
    padding-bottom: 10px;
  }

  .ai-story-banner-story-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: {{ block.settings.story_width }}px;
    height: {{ block.settings.story_height }}px;
    position: relative;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .ai-story-banner-story-{{ ai_gen_id }}:hover {
    transform: scale(1.02);
  }

  .ai-story-banner-story-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-story-banner-story-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-story-banner-story-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-story-banner-story-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
    color: {{ block.settings.text_color }};
  }

  .ai-story-banner-story-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    margin: 0 0 5px 0;
    line-height: 1.2;
  }

  .ai-story-banner-story-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    margin: 0;
    line-height: 1.4;
    opacity: 0.9;
  }

  .ai-story-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-story-banner-story-{{ ai_gen_id }} {
      width: {{ block.settings.story_width | times: 0.8 }}px;
      height: {{ block.settings.story_height | times: 0.8 }}px;
    }

    .ai-story-banner-story-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-story-banner-story-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<story-banner-{{ ai_gen_id }} class="ai-story-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-story-banner-container-{{ ai_gen_id }}">
    <div class="ai-story-banner-scroll-wrapper-{{ ai_gen_id }}">
      <div class="ai-story-banner-stories-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% liquid
            assign image_key = 'story_' | append: i | append: '_image'
            assign title_key = 'story_' | append: i | append: '_title'
            assign description_key = 'story_' | append: i | append: '_description'
            assign link_key = 'story_' | append: i | append: '_link'

            assign story_image = block.settings[image_key]
            assign story_title = block.settings[title_key]
            assign story_description = block.settings[description_key]
            assign story_link = block.settings[link_key]
          %}

          <a
            href="{% if story_link != blank %}{{ story_link }}{% else %}#{% endif %}"
            class="ai-story-banner-story-{{ ai_gen_id }}"
            {% if story_link == blank %}onclick="return false;"{% endif %}
          >
            {% if story_image %}
              <img
                src="{{ story_image | image_url: width: 800 }}"
                alt="{{ story_image.alt | escape }}"
                class="ai-story-banner-story-image-{{ ai_gen_id }}"
                loading="lazy"
                width="{{ story_image.width }}"
                height="{{ story_image.height }}"
              >
            {% else %}
              <div class="ai-story-banner-story-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
                <div class="ai-story-banner-empty-state-{{ ai_gen_id }}">
                  Add story {{ i }} image
                </div>
              </div>
            {% endif %}

            {% if story_title != blank or story_description != blank %}
              <div class="ai-story-banner-story-overlay-{{ ai_gen_id }}">
                {% if story_title != blank %}
                  <h3 class="ai-story-banner-story-title-{{ ai_gen_id }}">{{ story_title }}</h3>
                {% endif %}
                {% if story_description != blank %}
                  <p class="ai-story-banner-story-description-{{ ai_gen_id }}">{{ story_description }}</p>
                {% endif %}
              </div>
            {% endif %}
          </a>
        {% endfor %}
      </div>
    </div>
  </div>
</story-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class StoryBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.scrollWrapper = this.querySelector('.ai-story-banner-scroll-wrapper-{{ ai_gen_id }}');
        this.setupScrollBehavior();
      }

      setupScrollBehavior() {
        if (!this.scrollWrapper) return;

        this.scrollWrapper.addEventListener('wheel', (e) => {
          if (e.deltaY !== 0) {
            e.preventDefault();
            this.scrollWrapper.scrollLeft += e.deltaY;
          }
        });
      }
    }

    customElements.define('story-banner-{{ ai_gen_id }}', StoryBanner{{ ai_gen_id }});
  })();
</script>


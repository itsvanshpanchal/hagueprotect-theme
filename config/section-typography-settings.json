,
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "paragraph",
      "content": "By default this section uses Theme settings > Typography. Enable override below to customize this section only."
    },
    {
      "type": "checkbox",
      "id": "typography_override",
      "label": "Override theme typography for this section",
      "default": false
    },
    {
      "type": "select",
      "id": "h1_font_family",
      "label": "H1 font family",
      "options": [
        { "value": "bebas_neue", "label": "Bebas Neue" },
        { "value": "anton", "label": "Anton" },
        { "value": "oswald", "label": "Oswald" },
        { "value": "inter", "label": "Inter" },
        { "value": "montserrat", "label": "Montserrat" }
      ],
      "default": "bebas_neue"
    },
    {
      "type": "range",
      "id": "h1_font_size_desktop",
      "label": "H1 size (desktop)",
      "min": 24,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "h1_font_size_mobile",
      "label": "H1 size (mobile)",
      "min": 18,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "select",

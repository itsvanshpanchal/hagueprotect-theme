<!DOCTYPE html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#FF2B2B">
    
    <!-- Security Headers -->
    <meta http-equiv="Content-Security-Policy" content="default-src 'self' https: data: 'unsafe-inline' 'unsafe-eval';">
    <meta http-equiv="X-Content-Type-Options" content="nosniff">
    <meta http-equiv="X-Frame-Options" content="SAMEORIGIN">
    <link rel="canonical" href="{{ canonical_url }}">
    
    {%- capture seo_title -%}
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    {%- endcapture -%}
    <title>{{ seo_title | strip | strip_html | escape | truncate: 55, "" }}</title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | strip_html | strip | escape | truncate: 120, "" }}">
    {%- else -%}
      <meta name="description" content="Premium sneaker care solutions for professional-grade cleaning, protection, and restoration.">
    {%- endif -%}

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
      <link rel="shortcut icon" type="image/x-icon" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
      <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180, height: 180 }}">
    {%- endif -%}

    <!-- Hreflang Tags -->
    <link rel="alternate" hreflang="x-default" href="{{ canonical_url }}">
    <link rel="alternate" hreflang="{{ request.locale.iso_code | downcase }}" href="{{ canonical_url }}">
    {%- if request.locale.iso_code != 'en' -%}
      <link rel="alternate" hreflang="en" href="{{ canonical_url }}">
    {%- endif -%}

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "http://schema.org",
        "@type": "Organization",
        "name": "{{ shop.name }}",
        "url": "{{ shop.url }}",
        "logo": "{{ 'favicon.png' | asset_url }}",
        "sameAs": [
          "{{ settings.social_facebook_link }}",
          "{{ settings.social_twitter_link }}",
          "https://www.instagram.com/hagueprotect/",
          "https://www.youtube.com/@HagueProtect"
        ]
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "http://schema.org",
        "@type": "WebSite",
        "name": "{{ shop.name }}",
        "url": "{{ shop.url }}"
      }
    </script>

    <!-- BreadcrumbList Schema -->
    <script type="application/ld+json">
      {
        "@context": "http://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ shop.url }}"
          }
          {%- if request.page_type == 'product' -%}
            ,{
              "@type": "ListItem",
              "position": 2,
              "name": "{{ product.title | escape }}",
              "item": "{{ shop.url }}{{ product.url }}"
            }
          {%- elsif request.page_type == 'collection' and collection.handle -%}
            ,{
              "@type": "ListItem",
              "position": 2,
              "name": "{{ collection.title | escape }}",
              "item": "{{ shop.url }}{{ collection.url }}"
            }
          {%- elsif request.page_type == 'page' -%}
            ,{
              "@type": "ListItem",
              "position": 2,
              "name": "{{ page.title | escape }}",
              "item": "{{ shop.url }}{{ page.url }}"
            }
          {%- endif -%}
        ]
      }
    </script>

    {%- if request.page_type == 'product' -%}
      <script type="application/ld+json">
        {
          "@context": "http://schema.org",
          "@type": "Product",
          "name": "{{ product.title | escape }}",
          "url": "{{ shop.url }}{{ product.url }}",
          {%- if product.featured_media -%}
            "image": [
              "https:{{ product.featured_media | image_url: width: 1920 }}"
            ],
          {%- endif -%}
          "description": "{{ product.description | strip_html | escape | truncate: 150 }}",
          "sku": "{{ product.selected_or_first_available_variant.sku }}",
          "brand": {
            "@type": "Brand",
            "name": "{{ product.vendor | escape }}"
          },
          "offers": {
            "@type": "Offer",
            "url": "{{ shop.url }}{{ product.url }}",
            "priceCurrency": "{{ cart.currency.iso_code }}",
            "price": "{{ product.selected_or_first_available_variant.price | money_without_currency | replace: ',', '.' }}",
            "availability": "http://schema.org/{% if product.selected_or_first_available_variant.available %}InStock{% else %}OutOfStock{% endif %}"
          }
        }
      </script>
    {%- endif -%}

    <!-- Performance Resource Hints -->
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="dns-prefetch" href="https://cdn.shopify.com">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <!-- Preload Critical Assets -->
    <link rel="preload" href="{{ 'theme.css' | asset_url }}" as="style">
    <link rel="preload" href="{{ 'theme.js' | asset_url }}" as="script">
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700;800&display=swap" as="style">

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'">

    <!-- CSS -->
    {{ 'theme.css' | asset_url | stylesheet_tag }}

    <style>
      html, body {
        overflow-x: hidden;
        width: 100%;
        max-width: 100vw;
      }
      body, html, p, span, a, div, h1, h2, h3, h4, h5, h6, input, button, select, textarea {
        font-family: 'Inter', sans-serif !important;
        font-weight: 700 !important;
      }
      h1, h2, h3, h4, h5, h6 {
        font-weight: 800 !important;
      }
      .scroll-trigger {
        opacity: 0;
        transform: translateY(40px);
        transition: opacity 1.2s cubic-bezier(0.16, 1, 0.3, 1), transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
        will-change: transform, opacity;
      }
      .scroll-trigger.is-visible {
        opacity: 1;
        transform: translateY(0);
      }
      
      /* Subtle premium text animation */
      .fade-in-premium {
        animation: fadeInPremium 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
      @keyframes fadeInPremium {
        0% { opacity: 0; transform: translateY(15px); }
        100% { opacity: 1; transform: translateY(0); }
      }
    </style>


    {{ content_for_header }}
  </head>
  <body>
    {% section 'cart-drawer' %}
    {% section 'announcement-bar' %}
    {% section 'header' %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {%- assign normalized_path = request.path | downcase -%}
      {%- if normalized_path contains 'certified-corporation' or normalized_path contains 'corporate' -%}
        <div id="CorporateCustomPage">
          {% section 'corporate-gifting-hero' %}
          {% section 'corporate-gifting-form' %}
          {% section 'corporate-gifting-features' %}
        </div>
        <style>
          /* Hide the default 404 or page content when on the hijacked URL */
          .hijack-hidden { display: none !important; }
        </style>
      {%- endif -%}

      <div class="{% if normalized_path contains 'certified-corporation' or normalized_path contains 'corporate' %}hijack-hidden{% endif %}">
        {{ content_for_layout }}
      </div>
    </main>

    {% section 'footer' %}

    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>

    <!-- Global Scroll-Driven Animation & Text Animations -->
    <script>
      window.addEventListener('load', function() {
        if ('requestIdleCallback' in window) {
          requestIdleCallback(initScrollTriggers);
        } else {
          setTimeout(initScrollTriggers, 10);
        }

        function initScrollTriggers() {
          const triggers = document.querySelectorAll('h1, h2, h3, .promo-banner__content, .feature-grid__card, .story-banner, .faq-item, .reviews-card, .prod-card, .trending-social__slide');
          
          triggers.forEach(t => {
            t.classList.add('scroll-trigger');
          });

          const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          }, {
            threshold: 0.1,
            rootMargin: "0px 0px -60px 0px"
          });

          triggers.forEach(t => observer.observe(t));
        }
      });
    </script>

    {% render 'theme-login-overlay' %}
    {% render 'theme-dashboard-overlay' %}

      </div>
    </div>

    <script>
      function checkView() {
        const hash = window.location.hash;
        const loginView = document.getElementById('ThemeLoginView');
        const dashboardView = document.getElementById('ThemeDashboardView');
        const greeting = document.getElementById('ThemeUserGreeting');

        if (hash === '#login') {
          if (loginView) loginView.style.display = 'block';
          if (dashboardView) dashboardView.style.display = 'none';
          document.body.style.overflow = 'hidden';
        } else if (hash === '#dashboard') {
          if (loginView) loginView.style.display = 'none';
          if (dashboardView) dashboardView.style.display = 'block';
          document.body.style.overflow = 'hidden';
          
          const email = localStorage.getItem('customer_email');
          if (email && greeting) {
            const parts = email.split('@');
            greeting.textContent = parts[0].toUpperCase();
          }
        } else {
          if (loginView) loginView.style.display = 'none';
          if (dashboardView) dashboardView.style.display = 'none';
          document.body.style.overflow = '';
        }
      }

      function handleThemeLogin(e) {
        e.preventDefault();
        const btn = document.getElementById('ThemeSubmitBtn');
        const emailInput = document.getElementById('ThemeLoginEmail');
        if (!btn || !emailInput) return;

        const email = emailInput.value;
        btn.disabled = true;
        btn.textContent = 'Signing in...';

        localStorage.setItem('customer_email', email);

        setTimeout(() => {
          btn.disabled = false;
          btn.innerHTML = 'Sign In <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>';
          window.location.hash = '#dashboard';
          checkView();
        }, 800);
      }

      function handleGoogleSignIn() {
        const btn = document.getElementById('GoogleSignInBtn');
        if (!btn) return;
        btn.disabled = true;
        btn.innerHTML = '<span style="color:#666;">Signing in...</span>';

        localStorage.setItem('customer_email', 'google.user@gmail.com');

        setTimeout(() => {
          btn.disabled = false;
          window.location.hash = '#dashboard';
          checkView();
        }, 900);
      }

      window.addEventListener('hashchange', checkView);
      window.addEventListener('load', checkView);
    </script>
  </body>
</html>

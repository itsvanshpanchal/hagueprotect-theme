<!DOCTYPE html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
	<!-- Added by APP PLAZA -->
	{% include 'app-plaza' %}
	<!-- /Added by APP PLAZA -->
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#FF2B2B">
    
    <!-- Security Headers -->
    <meta http-equiv="Content-Security-Policy" content="default-src 'self' https: data: 'unsafe-inline' 'unsafe-eval';">
    <meta http-equiv="X-Content-Type-Options" content="nosniff">
    <meta http-equiv="X-Frame-Options" content="SAMEORIGIN">
    <link rel="canonical" href="{{ canonical_url }}">
    
    {%- capture seo_title -%}
      {%- if template == 'search.how-to-use' -%}
        How to Use
      {%- else -%}
        {{ page_title }}
      {%- endif -%}
      {%- if current_tags %} – tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} – Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} – {{ shop.name }}{% endunless -%}
    {%- endcapture -%}
    <title>{{ seo_title | strip | strip_html | escape | truncate: 55, "" }}</title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | strip_html | strip | escape | truncate: 120, "" }}">
    {%- else -%}
      <meta name="description" content="Premium sneaker care solutions for professional-grade cleaning, protection, and restoration.">
    {%- endif -%}

    <link rel="icon" type="image/png" sizes="32x32" href="{{ 'favicon.png' | asset_url }}">
    <link rel="shortcut icon" type="image/png" href="{{ 'favicon.png' | asset_url }}">
    <link rel="apple-touch-icon" href="{{ 'favicon.png' | asset_url }}">

    <!-- Hreflang Tags -->
    <link rel="alternate" hreflang="x-default" href="{{ canonical_url }}">
    <link rel="alternate" hreflang="{{ request.locale.iso_code | downcase }}" href="{{ canonical_url }}">
    {%- if request.locale.iso_code != 'en' -%}
      <link rel="alternate" hreflang="en" href="{{ canonical_url }}">
    {%- endif -%}

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "http://schema.org",
        "@type": "Organization",
        "name": "{{ shop.name }}",
        "url": "{{ shop.url }}",
        "logo": "{{ 'favicon.png' | asset_url }}",
        "sameAs": [
          "{{ settings.social_facebook_link }}",
          "{{ settings.social_twitter_link }}",
          "https://www.instagram.com/hagueprotect/",
          "https://www.youtube.com/@HagueProtect"
        ]
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "http://schema.org",
        "@type": "WebSite",
        "name": "{{ shop.name }}",
        "url": "{{ shop.url }}"
      }
    </script>

    <!-- BreadcrumbList Schema -->
    <script type="application/ld+json">
      {
        "@context": "http://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ shop.url }}"
          }
          {%- if request.page_type == 'product' -%}
            ,{
              "@type": "ListItem",
              "position": 2,
              "name": "{{ product.title | escape }}",
              "item": "{{ shop.url }}{{ product.url }}"
            }
          {%- elsif request.page_type == 'collection' and collection.handle -%}
            ,{
              "@type": "ListItem",
              "position": 2,
              "name": "{{ collection.title | escape }}",
              "item": "{{ shop.url }}{{ collection.url }}"
            }
          {%- elsif request.page_type == 'page' -%}
            ,{
              "@type": "ListItem",
              "position": 2,
              "name": "{{ page.title | escape }}",
              "item": "{{ shop.url }}{{ page.url }}"
            }
          {%- endif -%}
        ]
      }
    </script>

    {%- if request.page_type == 'product' -%}
      <script type="application/ld+json">
        {
          "@context": "http://schema.org",
          "@type": "Product",
          "name": "{{ product.title | escape }}",
          "url": "{{ shop.url }}{{ product.url }}",
          {%- if product.featured_media -%}
            "image": [
              "https:{{ product.featured_media | image_url: width: 1920 }}"
            ],
          {%- endif -%}
          "description": "{{ product.description | strip_html | escape | truncate: 150 }}",
          "sku": "{{ product.selected_or_first_available_variant.sku }}",
          "brand": {
            "@type": "Brand",
            "name": "{{ product.vendor | escape }}"
          },
          "offers": {
            "@type": "Offer",
            "url": "{{ shop.url }}{{ product.url }}",
            "priceCurrency": "{{ cart.currency.iso_code }}",
            "price": "{{ product.selected_or_first_available_variant.price | money_without_currency | replace: ',', '.' }}",
            "availability": "http://schema.org/{% if product.selected_or_first_available_variant.available %}InStock{% else %}OutOfStock{% endif %}"
          }
        }
      </script>
    {%- endif -%}

    <!-- Performance Resource Hints -->
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="dns-prefetch" href="https://cdn.shopify.com">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700;800;900&family=Montserrat:wght@900&display=swap" rel="stylesheet">
    
    <!-- Preload Critical Assets -->
    <link rel="preload" href="{{ 'theme.css' | asset_url }}" as="style">
    <link rel="preload" href="{{ 'theme.js' | asset_url }}" as="script">

    <!-- CSS -->
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    {{ 'material-fonts.css' | asset_url | stylesheet_tag }}

    <style>
      html, body {
        overflow-x: hidden;
        width: 100%;
        max-width: 100vw;
      }
      html,
      body,
      .shopify-section,
      p,
      span,
      li,
      label,
      input,
      select,
      textarea,
      a,
      div,
      button {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif !important;
      }
      /* Section display headings only */
      .hp-display-heading,
      main h1,
      .hero-fullscreen__heading,
      .d2c-product-title,
      .trending-social__heading,
      .bestsellers__heading-dtc,
      .bs-coverflow__heading,
      .fb__title,
      .fc-heading,
      .hp-fam-sec__heading,
      .mat-headline,
      main h2.h2,
      .feature-grid__heading,
      .trust-statement__heading,
      .reviews-sec__heading,
      .product-rec__heading,
      .comm-headline,
      .brand-banner__title,
      .social-slider__heading,
      .hp-dna__heading,
      .promo-banner__heading,
      .corp-features__heading,
      .how-to-videos__heading,
      .bundle-title,
      .skincare-hero__title,
      .skincare-intro__title,
      .skincare-explanation__title,
      .skincare-concerns__title,
      .skincare-builder__title,
      .corp-hero__title,
      .how-to-banner__title {
        font-family: 'Bebas Neue', 'Impact', 'Arial Narrow', sans-serif !important;
        font-weight: 400 !important;
        letter-spacing: 0.03em !important;
        line-height: 1.05 !important;
        text-transform: uppercase !important;
        font-size: clamp(40px, 5.5vw, 64px) !important;
        -webkit-font-smoothing: antialiased;
      }

      .hero-fullscreen__heading {
        font-family: 'Bebas Neue', 'Impact', 'Arial Narrow', sans-serif !important;
        font-weight: 400 !important;
        font-size: clamp(48px, 8vw, 88px) !important;
        letter-spacing: 0.03em !important;
        line-height: 1.02 !important;
        text-transform: uppercase !important;
      }

      h3,
      h4,
      h5,
      h6 {
        font-family: 'Bebas Neue', 'Impact', 'Arial Narrow', sans-serif !important;
        font-weight: 400 !important;
        letter-spacing: 0.03em !important;
        line-height: 1.1 !important;
        text-transform: uppercase !important;
      }

      h3 { font-size: clamp(30px, 3.8vw, 44px) !important; }
      h4 { font-size: clamp(26px, 3.2vw, 36px) !important; }
      h5 { font-size: clamp(22px, 2.8vw, 30px) !important; }
      h6 { font-size: clamp(20px, 2.4vw, 26px) !important; }

      .faq-custom .faq-custom__heading,
      .faq-custom h2.faq-custom__heading {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif !important;
        font-size: clamp(16px, 2.5vw, 18px) !important;
        font-weight: 600 !important;
        letter-spacing: -0.01em !important;
        line-height: 1.3 !important;
        text-transform: capitalize !important;
        color: #E02020 !important;
      }

      .faq-custom .faq-custom__question,
      .faq-custom h3.faq-custom__question {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif !important;
        font-size: clamp(14px, 1.6vw, 16px) !important;
        font-weight: 600 !important;
        letter-spacing: -0.01em !important;
        line-height: 1.4 !important;
        text-transform: none !important;
        color: #111111 !important;
      }

      h3.megamenu-heading,
      .megamenu-heading,
      h4.mobile-accordion-category-heading,
      .mobile-accordion-category-heading {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif !important;
        font-size: 14px !important;
        font-weight: 800 !important;
        line-height: 1.2 !important;
        letter-spacing: 0.08em !important;
        text-transform: uppercase !important;
        color: #111111 !important;
        margin: 0 !important;
      }

      h4.mobile-accordion-category-heading,
      .mobile-accordion-category-heading {
        font-size: 13px !important;
        font-weight: 700 !important;
        letter-spacing: 0.06em !important;
        margin-bottom: 6px !important;
      }

      #MainContent h3.fc-category-name,
      .shopify-section h3.fc-category-name,
      .fc-category-name {
        font-size: 15px !important;
        font-weight: 700 !important;
        text-transform: uppercase !important;
        letter-spacing: 0.02em !important;
        line-height: 1.3 !important;
      }

      #MainContent h3.hp-dna__item-title,
      .shopify-section h3.hp-dna__item-title,
      .hp-dna__item-title {
        font-size: 15px !important;
        font-weight: 700 !important;
        text-transform: uppercase !important;
        letter-spacing: 0.05em !important;
        line-height: 1.35 !important;
      }

      .hp-dna__item-text,
      .feature-grid__card-text {
        font-size: 14px !important;
        font-weight: 400 !important;
        line-height: 1.55 !important;
        text-transform: none !important;
      }

      #MainContent h3.feature-grid__card-heading,
      .feature-grid__card-heading {
        font-size: 18px !important;
        font-weight: 700 !important;
        text-transform: none !important;
      }

      .prod-card-dtc__title,
      .prod-card-dtc__subtitle,
      .prod-card-dtc__desc,
      .rail-card-title,
      .rail-subtitle,
      .product-rec__title,
      .product-rec__title-main,
      .family-card__title,
      .fc-category-name,
      .fc-subtitle,
      .faq-custom__question,
      .footer__title,
      .cart-drawer__title,
      .cart-drawer__item-title,
      .bestsellers__eyebrow-dtc,
      .trending-social__eyebrow,
      .mat-eyebrow,
      .mat-desc,
      .d2c-subtitle-text {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif !important;
        text-transform: none !important;
      }

      .prod-card-dtc__title,
      .rail-card-title,
      .product-rec__title,
      .product-rec__title-main,
      .family-card__title,
      .fc-category-name {
        font-weight: 600 !important;
        font-size: clamp(15px, 2vw, 18px) !important;
        line-height: 1.35 !important;
        letter-spacing: -0.01em !important;
      }

      .prod-card-dtc__subtitle,
      .prod-card-dtc__desc,
      .rail-subtitle,
      .fc-subtitle,
      .d2c-subtitle-text,
      .bestsellers__eyebrow-dtc,
      .trending-social__eyebrow,
      .mat-eyebrow,
      .mat-desc {
        font-weight: 400 !important;
        font-size: inherit !important;
        line-height: 1.5 !important;
        letter-spacing: normal !important;
      }

      .d2c-product-title,
      .d2c-product-title span {
        text-transform: none !important;
        font-weight: 900 !important;
      }
      .btn,
      button,
      [type="submit"] {
        font-weight: 600 !important;
      }
      body,
      p,
      span,
      li,
      label,
      input,
      select,
      textarea {
        font-weight: 400 !important;
      }

      .hp-typewriter-text,
      .hp-typewriter-cursor {
        font-family: inherit !important;
        font-weight: inherit !important;
        letter-spacing: inherit !important;
        text-transform: inherit !important;
        font-size: inherit !important;
        line-height: inherit !important;
        color: inherit !important;
      }

      .hp-typewriter-cursor {
        display: inline-block;
        width: 2px;
        height: 0.85em;
        background-color: currentColor;
        margin-left: 3px;
        vertical-align: baseline;
        animation: hpTypewriterBlink 1s step-end infinite;
      }

      @keyframes hpTypewriterBlink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }
    </style>


    {{ content_for_header }}
  </head>
  <body>
    {% section 'cart-drawer' %}
    {% section 'announcement-bar' %}
    {% section 'header' %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'heading-typewriter.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'corporate-gifting.js' | asset_url }}" defer="defer"></script>
    {%- if template.name == 'search' and template.suffix == 'business' -%}
      <script src="{{ 'business-page.js' | asset_url }}" defer="defer"></script>
    {%- elsif template.name == 'page' and page.handle == 'contact' -%}
      <script src="{{ 'business-page.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {% render 'theme-login-overlay' %}
    {% render 'theme-dashboard-overlay' %}

      </div>
    </div>

    <script>
      function checkView() {
        const hash = window.location.hash;
        const loginView = document.getElementById('ThemeLoginView');
        const dashboardView = document.getElementById('ThemeDashboardView');
        const greeting = document.getElementById('ThemeUserGreeting');

        if (hash === '#login') {
          if (loginView) loginView.style.display = 'block';
          if (dashboardView) dashboardView.style.display = 'none';
          document.body.style.overflow = 'hidden';
        } else if (hash === '#dashboard') {
          if (loginView) loginView.style.display = 'none';
          if (dashboardView) dashboardView.style.display = 'block';
          document.body.style.overflow = 'hidden';
          
          const email = localStorage.getItem('customer_email');
          if (email && greeting) {
            const parts = email.split('@');
            greeting.textContent = parts[0].toUpperCase();
          }
        } else {
          if (loginView) loginView.style.display = 'none';
          if (dashboardView) dashboardView.style.display = 'none';
          document.body.style.overflow = '';
        }
      }

      function handleThemeLogin(e) {
        e.preventDefault();
        const btn = document.getElementById('ThemeSubmitBtn');
        const emailInput = document.getElementById('ThemeLoginEmail');
        if (!btn || !emailInput) return;

        const email = emailInput.value;
        btn.disabled = true;
        btn.textContent = 'Signing in...';

        localStorage.setItem('customer_email', email);

        setTimeout(() => {
          btn.disabled = false;
          btn.innerHTML = 'Sign In <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>';
          window.location.hash = '#dashboard';
          checkView();
        }, 800);
      }

      function handleGoogleSignIn() {
        const btn = document.getElementById('GoogleSignInBtn');
        if (!btn) return;
        btn.disabled = true;
        btn.innerHTML = '<span style="color:#666;">Signing in...</span>';

        localStorage.setItem('customer_email', 'google.user@gmail.com');

        setTimeout(() => {
          btn.disabled = false;
          window.location.hash = '#dashboard';
          checkView();
        }, 900);
      }

      window.addEventListener('hashchange', checkView);
      window.addEventListener('load', checkView);
    </script>
  </body>
</html>
